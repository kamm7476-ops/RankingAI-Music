<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>RankingAI | Creator Hub</title>
    <style>
        body { background: #050505; color: white; font-family: sans-serif; margin: 0; text-align: center; }
        nav { width: 100%; height: 70px; background: rgba(0,0,0,0.9); display: flex; justify-content: space-between; align-items: center; padding: 0 50px; position: fixed; top: 0; box-sizing: border-box; border-bottom: 1px solid #222; z-index: 1000; }
        .btn-yellow { background: #ffd700; color: black; border: none; padding: 8px 15px; border-radius: 5px; font-weight: bold; cursor: pointer; }
        main { margin-top: 100px; padding: 20px; }
        .card-container { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; }
        .artist-card { background: #111; border-radius: 10px; overflow: hidden; border: 1px solid #222; text-align: left; position: relative; }
        .owner-menu { background: #1a1a1a; padding: 10px; display: flex; gap: 10px; border-top: 1px solid #333; align-items: center; }
        .btn-edit { background: #333; color: white; border: none; padding: 5px 10px; border-radius: 3px; cursor: pointer; font-size: 0.8rem; }
        .btn-delete { background: #cc0000; color: white; border: none; padding: 5px 10px; border-radius: 3px; cursor: pointer; font-size: 0.8rem; }
        audio { width: 100%; filter: invert(1); margin-top: 10px; }
        .modal { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.9); display: none; justify-content: center; align-items: center; z-index: 2000; }
        .modal-form { background: #111; padding: 30px; border-radius: 10px; border: 1px solid #ffd700; width: 320px; }
        input, select { width: 100%; padding: 10px; margin: 10px 0; background: #222; border: 1px solid #444; color: white; box-sizing: border-box; }
    </style>
</head>
<body>
    <% const melonGenres = ["발라드", "댄스", "랩/힙합", "R&B/Soul", "트로트", "POP", "록/메탈", "인디음악", "OST", "재즈"]; %>

    <nav>
        <a href="/" style="color: #ffd700; font-weight: bold; text-decoration: none; font-size: 1.5rem;">RANKING AI</a>
        <div>
            <% if (user) { %>
                <button class="btn-yellow" onclick="document.getElementById('upload-modal').style.display='flex'">+ 업로드</button>
                <a href="/logout" style="color: white; margin-left: 15px; text-decoration: none; font-size: 0.9rem;">로그아웃</a>
            <% } else { %>
                <button onclick="document.getElementById('login-modal').style.display='flex'" style="color:white; background:none; border:none; cursor:pointer;">로그인</button>
                <button class="btn-yellow" onclick="document.getElementById('signup-modal').style.display='flex'" style="margin-left: 10px;">회원가입</button>
            <% } %>
        </div>
    </nav>

    <main>
        <div class="card-container">
            <% artists.forEach(function(song) { %>
                <div class="artist-card">
                    <div style="height:180px; background:url('<%= song.image %>') center/cover;"></div>
                    <div style="padding:15px;">
                        <span style="color:#ffd700; font-size:0.8rem;"><%= song.genre %></span>
                        <h3 style="margin:5px 0;"><%= song.name %></h3>
                        <p style="color:gray; margin:0; font-size:0.9rem;">🎤 <%= song.artist %></p>
                        
                        <audio controls controlsList="nodownload" oncontextmenu="return false;">
                            <source src="<%= song.url %>" type="audio/mpeg">
                        </audio>
                    </div>

                    <% if (user && (song.owner === user.username || isAdmin)) { %>
                        <div class="owner-menu">
                            <button class="btn-edit" onclick="openEditModal('<%= song._id %>', '<%= song.name %>', '<%= song.artist %>', '<%= song.genre %>')">수정</button>
                            <form action="/delete/<%= song._id %>" method="POST" onsubmit="return confirm('삭제하시겠습니까?')">
                                <button type="submit" class="btn-delete">삭제</button>
                            </form>
                            <% if (isAdmin && song.owner !== user.username) { %>
                                <span style="color:#ffd700; font-size:0.7rem; margin-left:auto;">[ADMIN]</span>
                            <% } %>
                        </div>
                    <% } %>
                </div>
            <% }); %>
        </div>
    </main>

    <div id="upload-modal" class="modal">
        <form class="modal-form" action="/upload" method="POST" enctype="multipart/form-data">
            <h2 style="color:#ffd700">곡 업로드</h2>
            <input type="text" name="title" placeholder="곡 제목" required>
            <input type="text" name="artist" placeholder="아티스트" required>
            <select name="type"><option value="music">MUSIC</option><option value="mv">MV</option></select>
            <select name="genre"><% melonGenres.forEach(g => { %><option value="<%= g %>"><%= g %></option><% }) %></select>
            <input type="file" name="mediaFile" required>
            <button type="submit" class="btn-yellow" style="width:100%">업로드 완료</button>
            <button type="button" onclick="this.parentElement.parentElement.style.display='none'" style="background:none; border:none; color:gray; margin-top:10px; cursor:pointer;">취소</button>
        </form>
    </div>

    <div id="edit-modal" class="modal">
        <form id="edit-form" class="modal-form" method="POST">
            <h2 style="color:#ffd700">정보 수정</h2>
            <input type="text" id="edit-title" name="title" required>
            <input type="text" id="edit-artist" name="artist" required>
            <select id="edit-genre" name="genre"><% melonGenres.forEach(g => { %><option value="<%= g %>"><%= g %></option><% }) %></select>
            <button type="submit" class="btn-yellow" style="width:100%">수정 저장</button>
            <button type="button" onclick="document.getElementById('edit-modal').style.display='none'" style="background:none; border:none; color:gray; margin-top:10px; cursor:pointer;">취소</button>
        </form>
    </div>

    <div id="login-modal" class="modal">
        <form class="modal-form" action="/login" method="POST">
            <h2>로그인</h2>
            <input type="text" name="username" placeholder="아이디" required>
            <input type="password" name="password" placeholder="비밀번호" required>
            <button type="submit" class="btn-yellow" style="width:100%">로그인</button>
            <button type="button" onclick="this.parentElement.parentElement.style.display='none'" style="background:none; border:none; color:gray; margin-top:10px; cursor:pointer;">취소</button>
        </form>
    </div>

    <div id="signup-modal" class="modal">
        <form class="modal-form" action="/signup" method="POST">
            <h2>회원가입</h2>
            <input type="text" name="username" placeholder="아이디" required>
            <input type="password" name="password" placeholder="비밀번호" required>
            <button type="submit" class="btn-yellow" style="width:100%">가입하기</button>
            <button type="button" onclick="this.parentElement.parentElement.style.display='none'" style="background:none; border:none; color:gray; margin-top:10px; cursor:pointer;">취소</button>
        </form>
    </div>

    <script>
        function openEditModal(id, title, artist, genre) {
            document.getElementById('edit-form').action = '/edit/' + id;
            document.getElementById('edit-title').value = title;
            document.getElementById('edit-artist').value = artist;
            document.getElementById('edit-genre').value = genre;
            document.getElementById('edit-modal').style.display = 'flex';
        }
    </script>
</body>
</html>