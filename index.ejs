<!DOCTYPE html>
<html lang="ko">
<head>
    <title>Ranking AI</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/dist/css/all.min.css">
    <style>
        body { 
            background: #0a0b10; color: white; font-family: 'Pretendard', sans-serif; 
            margin: 0; padding-bottom: 100px; 
        }
        .nav { display: flex; justify-content: space-between; padding: 15px 20px; border-bottom: 1px solid #222; background-color: #1a1a1a; align-items: center; }
        .logo { font-size: 1.5rem; color: #ff5722; font-weight: bold; text-decoration: none; }
        
        .rank-card { 
            background: rgba(255,255,255,0.05); margin: 10px 0; padding: 15px 20px; 
            border-radius: 12px; display: flex; align-items: center; position: relative; 
            transition: 0.3s; border: 1px solid transparent; cursor: pointer;
        }
        .rank-card:hover { background: rgba(255,255,255,0.1); }
        .album-art { width: 55px; height: 55px; border-radius: 8px; margin: 0 15px; object-fit: cover; }
        .delete-btn-wrap { margin-left: auto; }
        
        .rank-card.playing { background: rgba(255, 87, 34, 0.1); border: 1px solid #ff5722; }
        .playing-icon { color: #ff5722; font-size: 1.2rem; margin-right: 10px; display: none; }
        .rank-card.playing .playing-icon { display: block; }
        .rank-card.playing .rank-number { display: none; }

        #bottom-player {
            position: fixed; bottom: 0; left: 0; width: 100%; 
            background: rgba(20, 21, 24, 0.95); backdrop-filter: blur(10px);
            border-top: 1px solid #333; padding: 12px 20px; 
            display: flex; align-items: center; justify-content: space-between;
            box-sizing: border-box; z-index: 1000; transform: translateY(100%);
            transition: transform 0.3s ease-in-out;
        }
        #bottom-player.active { transform: translateY(0); } 
        
        .bp-info { display: flex; align-items: center; gap: 12px; flex: 1; overflow: hidden; }
        .bp-img { width: 45px; height: 45px; border-radius: 6px; object-fit: cover; }
        .bp-text { display: flex; flex-direction: column; white-space: nowrap; overflow: hidden; }
        .bp-title { font-size: 15px; font-weight: bold; text-overflow: ellipsis; overflow: hidden; color: #fff; }
        .bp-artist { font-size: 12px; color: #aaa; text-overflow: ellipsis; overflow: hidden; }
        
        .bp-controls { display: flex; align-items: center; gap: 20px; margin-left: 10px; }
        .bp-btn { background: none; border: none; color: #fff; font-size: 20px; cursor: pointer; padding: 0; }
        .bp-btn.play-btn { font-size: 28px; color: #ff5722; }
    </style>
</head>
<body>

    <div id="inapp-blocker" style="position:fixed; top:0; left:0; width:100%; height:100%; background:#ff5722; color:white; z-index:9999999; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; padding:20px; box-sizing:border-box; font-family:sans-serif;">
        <i class="fas fa-triangle-exclamation" style="font-size:60px; margin-bottom:20px;"></i>
        <h2 style="margin:0 0 15px 0; font-size:24px;">🚨 접속 오류 안내</h2>
        <p style="font-size:16px; line-height:1.6; margin-bottom:25px;">
            현재 접속하신 앱(카톡/네이버 등)에서는<br>
            <strong>음악 연속 재생과 구글 로그인이 차단</strong>됩니다.
        </p>
        <div style="background:rgba(0,0,0,0.2); padding:20px; border-radius:12px; font-size:16px; line-height:1.6;">
            화면 우측 하단(또는 상단)의 메뉴 <strong>[ ⋮ ]</strong> 를 눌러<br>
            <strong style="color:#ffeb3b; font-size:18px;">[다른 브라우저로 열기(Safari/Chrome)]</strong>를<br>
            반드시 선택해 주세요!
        </div>
    </div>

    <script>
        (function() {
            var ua = navigator.userAgent.toLowerCase();
            var targetUrl = location.href;
            var isKakao = ua.indexOf('kakaotalk') > -1;
            var isInApp = ua.match(/naver|instagram|facebook|inapp|line/i);

            // 1. 튕겨내기 시도 (안드로이드/카톡 우선)
            if (isKakao) {
                location.href = 'kakaotalk://web/openExternal?url=' + encodeURIComponent(targetUrl);
            } else if (isInApp && ua.indexOf('android') > -1) {
                location.href = 'intent://' + targetUrl.replace(/https?:\/\//i, '') + '#Intent;scheme=https;package=com.android.chrome;end';
            }

            // 2. 핵심 로직: 카톡이나 인앱 브라우저가 "아니면(정상 브라우저면)" 주황색 창을 없앤다!
            if (!isKakao && !isInApp) {
                document.getElementById('inapp-blocker').style.display = 'none';
            }
        })();
    </script>

    <nav class="nav">
        <a href="/" class="logo">RANKING AI</a>
        <div style="display: flex; align-items: center; gap: 20px;">
            <% if (user) { %>
                <div style="display: flex; align-items: center; gap: 15px;">
                    <span style="font-weight: bold; color: #fff; font-size: 0.9rem;">
                        <%= user.role === 'admin' ? '👑 관리자' : '👤' %> <span style="color: #ff5722;"><%= user.name || user.id %></span>님
                    </span>
                    <a href="/logout" style="padding: 5px 10px; background-color: #333; color: #fff; text-decoration: none; border-radius: 4px; font-size: 0.8rem;">로그아웃</a>
                </div>
            <% } else { %>
                <div style="display: flex; align-items: center; gap: 10px;">
                    <a href="/login" style="color: #fff; text-decoration: none; font-size: 0.9rem;">로그인</a>
                    <a href="/signup" style="padding: 5px 10px; background-color: #ff5722; color: #000; font-weight: bold; text-decoration: none; border-radius: 4px; font-size: 0.9rem;">회원가입</a>
                </div>
            <% } %>
        </div>
    </nav>

    <div style="padding: 20px; max-width: 800px; margin: 0 auto;">
        <h2 style="margin-bottom: 20px;">🔥 AI TOP CHART</h2>
        
        <% artists.forEach((song, i) => { %>
            <div class="rank-card" data-index="<%= i %>">
                <i class="fas fa-chart-simple playing-icon"></i>
                <div class="rank-number" style="width: 20px; text-align: center; font-weight: bold; color: #aaa;"><%= i+1 %></div>
                
                <img src="<%= song.image %>" class="album-art">
                <div style="flex: 1; overflow: hidden;">
                    <strong style="display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= song.name %></strong>
                    <small style="color: #aaa;"><%= song.artist %></small>
                </div>
                
                <% if (user && user.role === 'admin') { %>
                <div class="delete-btn-wrap">
                    <form action="/delete-music/<%= song._id %>" method="POST" onsubmit="return confirm('관리자 권한으로 삭제하시겠습니까?');" style="margin:0;">
                        <button type="submit" class="admin-delete-btn" style="color: #ff4d4d; border: 1px solid #ff4d4d; background: none; cursor: pointer; padding: 5px 10px; border-radius: 4px; font-size: 0.8rem;">삭제</button>
                    </form>
                </div>
                <% } %>
            </div>
        <% }) %>
    </div>

    <div id="bottom-player">
        <div class="bp-info">
            <img src="" id="bp-img" class="bp-img" alt="album">
            <div class="bp-text">
                <span id="bp-title" class="bp-title">노래 제목</span>
                <span id="bp-artist" class="bp-artist">가수</span>
            </div>
        </div>
        <div class="bp-controls">
            <button class="bp-btn" onclick="playPrev()"><i class="fas fa-backward-step"></i></button>
            <button class="bp-btn play-btn" onclick="togglePlay()"><i class="fas fa-circle-play" id="bp-play-icon"></i></button>
            <button class="bp-btn" onclick="playNext()"><i class="fas fa-forward-step"></i></button>
        </div>
    </div>

<audio id="mainAudio" preload="auto" playsinline webkit-playsinline></audio>

<script>
    const audio = document.getElementById('mainAudio');
    const playlist = <%- JSON.stringify(artists) %>;
    let currentIdx = 0;
    let isUnlocked = false; 

    const bottomPlayer = document.getElementById('bottom-player');
    const bpImg = document.getElementById('bp-img');
    const bpTitle = document.getElementById('bp-title');
    const bpArtist = document.getElementById('bp-artist');
    const bpPlayIcon = document.getElementById('bp-play-icon');
    const cards = document.querySelectorAll('.rank-card');

    document.body.addEventListener('touchstart', unlockAudio, { once: true });
    document.body.addEventListener('click', unlockAudio, { once: true });

    function unlockAudio() {
        if (isUnlocked) return;
        audio.play().then(() => { audio.pause(); }).catch(() => {});
        isUnlocked = true;
    }

    if ('mediaSession' in navigator) {
        navigator.mediaSession.setActionHandler('previoustrack', () => playPrev());
        navigator.mediaSession.setActionHandler('nexttrack', () => playNext());
        navigator.mediaSession.setActionHandler('play', () => audio.play());
        navigator.mediaSession.setActionHandler('pause', () => audio.pause());
    }

    function updateUI(track, index) {
        bottomPlayer.classList.add('active');
        bpImg.src = track.image || 'https://via.placeholder.com/512';
        bpTitle.textContent = track.name || '알 수 없는 곡';
        bpArtist.textContent = track.artist || 'RANKING AI';

        cards.forEach(c => c.classList.remove('playing'));
        if(cards[index]) cards[index].classList.add('playing');

        if ('mediaSession' in navigator) {
            navigator.mediaSession.metadata = new MediaMetadata({
                title: track.name || '제목 없음',
                artist: track.artist || 'RANKING AI',
                album: 'RANKING AI TOP CHART',
                artwork: [{ src: track.image || 'https://via.placeholder.com/512', sizes: '512x512', type: 'image/png' }]
            });
        }
    }

    function playTrack(index) {
        if (!playlist || playlist.length === 0) return;

        if (index < 0) index = playlist.length - 1;
        if (index >= playlist.length) index = 0;
        
        currentIdx = index;
        const track = playlist[currentIdx];
        const trackSrc = track.audioUrl || track.audio || track.url; 
        
        if (!trackSrc) {
            playNext(); 
            return;
        }

        audio.src = trackSrc;
        audio.load();
        
        const playPromise = audio.play();
        if (playPromise !== undefined) {
            playPromise.then(() => {
                updateUI(track, currentIdx);
            }).catch(err => {
                console.log("자동재생 방어됨");
            });
        }
    }

    function playNext() { playTrack(currentIdx + 1); }
    function playPrev() { playTrack(currentIdx - 1); }

    function togglePlay() {
        if (audio.paused) audio.play();
        else audio.pause();
    }

    audio.addEventListener('play', () => {
        bpPlayIcon.classList.remove('fa-circle-play');
        bpPlayIcon.classList.add('fa-circle-pause');
    });
    audio.addEventListener('pause', () => {
        bpPlayIcon.classList.remove('fa-circle-pause');
        bpPlayIcon.classList.add('fa-circle-play');
    });

    audio.addEventListener('ended', playNext);

    cards.forEach(card => {
        card.addEventListener('click', (e) => {
            if(e.target.closest('.admin-delete-btn')) return; 
            const index = parseInt(card.getAttribute('data-index'));
            playTrack(index);
        });
    });
</script>
</body>
</html>
