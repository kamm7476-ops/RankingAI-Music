<!DOCTYPE html>
<html>
<head>
    <title>Ranking AI</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/dist/css/all.min.css">
    <style>
        body { background: #0a0b10; color: white; font-family: sans-serif; }
        .nav { display: flex; justify-content: space-between; padding: 20px; border-bottom: 1px solid #222; }
        .logo { font-size: 1.5rem; color: #00d4ff; font-weight: bold; text-decoration: none; }
        .rank-card { background: rgba(255,255,255,0.05); margin: 10px 0; padding: 20px; border-radius: 15px; display: flex; align-items: center; }
        .album-art { width: 60px; height: 60px; border-radius: 10px; margin: 0 20px; }
    </style>
</head>
<body>
   <nav class="nav" style="display: flex; justify-content: space-between; align-items: center; padding: 15px 20px; background-color: #1a1a1a; border-bottom: 1px solid #333;">
    <a href="/" class="logo" style="font-size: 1.5rem; font-weight: bold; color: #ff5722; text-decoration: none;"><%= t.logo %></a>

    <div style="display: flex; align-items: center; gap: 20px;">
        <div style="font-size: 0.9rem;">
            <a href="/change-lang/ko" style="color: #bbb; text-decoration: none;">KO</a> 
            <span style="color: #444;">|</span> 
            <a href="/change-lang/en" style="color: #bbb; text-decoration: none;">EN</a>
        </div>

        <% if (user) { %>
            <div style="display: flex; align-items: center; gap: 15px;">
                <span style="font-weight: bold; color: #fff;">
                    <%= user.role === 'admin' ? '👑 관리자' : '👤 회원' %> 
                    <span style="color: #ff5722;"><%= user.name %></span>님 환영합니다!
                </span>
                <a href="/logout" style="padding: 5px 10px; background-color: #333; color: #fff; text-decoration: none; border-radius: 4px; font-size: 0.9rem;">로그아웃</a>
            </div>
        <% } else { %>
            <div style="display: flex; align-items: center; gap: 10px;">
                <a href="/login" style="color: #fff; text-decoration: none; font-size: 0.9rem;">로그인</a>
                <a href="/signup" style="padding: 5px 10px; background-color: #ff5722; color: #fff; text-decoration: none; border-radius: 4px; font-size: 0.9rem;">회원가입</a>
            </div>
        <% } %>
    </div>
</nav>
    <div style="padding: 20px;">
        <h2><%= t.chartTitle %></h2>
        <% artists.forEach((song, i) => { %>
            <div class="rank-card">
                <div><%= i+1 %></div>
                <img src="<%= song.image %>" class="album-art">
                <div>
                    <strong><%= song.name %></strong><br>
                    <small><%= song.artist %></small>
                </div>
            </div>
        <% }) %>
        <% if (user && user.role === 'admin') { %>
    <form action="/delete-music/<%= song._id %> method="POST" onsubmit="return confirm('관리자 권한으로 삭제하시겠습니까?');" style="margin-top:10px;">
        <button type="submit" style="color: #ff4d4d; border: 1px solid #ff4d4d; background: none; cursor: pointer; padding: 3px 8px; border-radius: 4px; font-size: 0.8rem;">강제 삭제</button>
    </form>
        <% } %>
    </div>

<audio id="mainAudio" preload="auto"></audio>

<script>
    <script>
    const audio = document.getElementById('mainAudio');
    const playlist = <%- JSON.stringify(artists) %>;
    let currentIdx = 0;

    function playTrack(index) {
        if (index < 0) index = playlist.length - 1;
        if (index >= playlist.length) index = 0;
        
        currentIdx = index;
        const track = playlist[currentIdx];
        const trackSrc = track.audioUrl || track.audio; // 필드명 확인용
        
        if (!trackSrc) return;

        audio.src = trackSrc;
        
        // 📱 모바일/블루투스 핵심 로직
        audio.play().then(() => {
            if ('mediaSession' in navigator) {
                navigator.mediaSession.metadata = new MediaMetadata({
                    title: track.name,
                    artist: track.artist,
                    album: 'RANKING AI CHART',
                    artwork: [{ src: track.image, sizes: '512x512', type: 'image/png' }]
                });

                // 블루투스/핸들 리모컨 버튼 연결
                navigator.mediaSession.setActionHandler('previoustrack', () => playTrack(currentIdx - 1));
                navigator.mediaSession.setActionHandler('nexttrack', () => playTrack(currentIdx + 1));
                navigator.mediaSession.setActionHandler('play', () => audio.play());
                navigator.mediaSession.setActionHandler('pause', () => audio.pause());
            }
        }).catch(err => console.log("재생 차단됨 (첫 클릭 필요)"));
    }

    // 🌟 모바일 연속 재생의 핵심 (ended 이벤트)
    audio.addEventListener('ended', () => {
        console.log("곡 종료, 다음 곡으로!");
        setTimeout(() => {
            playTrack(currentIdx + 1);
        }, 200); // 아주 짧은 딜레이가 모바일 안정성을 높여줍니다.
    });

    document.addEventListener('DOMContentLoaded', () => {
        const cards = document.querySelectorAll('.rank-card');
        cards.forEach((card, index) => {
            card.style.cursor = 'pointer';
            card.addEventListener('click', () => playTrack(index));
        });
    });
</script>

</body>
</html>