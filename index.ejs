<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RankingAI 플랫폼</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Pretendard:wght@400;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Pretendard', sans-serif; background-color: #f8f9fa; }
        .hero-section { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 60px 0; text-align: center; margin-bottom: 40px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
        .card { border: none; border-radius: 15px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); transition: transform 0.2s; }
        .card:hover { transform: translateY(-5px); }
        .card-img-top { height: 250px; object-fit: cover; border-top-left-radius: 15px; border-top-right-radius: 15px; }
        .pulse-badge { background-color: #ff4757; color: white; font-weight: bold; font-size: 1.1em; padding: 8px 15px; border-radius: 20px; }
        .rank-number { font-size: 1.5em; font-weight: bold; color: #764ba2; margin-right: 10px; }
    </style>
</head>
<body>

    <% 
      const melonGenres = {
        "국내 대중음악": ["발라드", "댄스", "랩/힙합", "R&B/Soul", "인디음악", "록/메탈", "트로트", "포크/블루스"],
        "해외 대중음악": ["POP", "EDM/일렉트로니카", "해외 랩/힙합", "해외 R&B/Soul", "해외 록/메탈"],
        "그 외 장르": ["OST", "재즈", "클래식", "뉴에이지", "J-POP", "월드뮤직", "CCM/종교음악", "키즈/애니메이션", "국악"]
      };
    %>

    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm py-3">
        <div class="container">
            <a class="navbar-brand fw-bold fs-4" href="/">🏆 RankingAI Music</a>
            <div class="d-flex align-items-center gap-2">
                <% if (user) { %>
                    <span class="me-3">반갑습니다, <b><%= user.username %></b>님!</span>
                    <a href="/logout" class="btn btn-outline-danger btn-sm">로그아웃</a>
                <% } else { %>
                    <button class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#loginModal">로그인</button>
                    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#signupModal">회원가입</button>
                <% } %>
            </div>
        </div>
    </nav>

    <div class="hero-section">
        <div class="container">
            <h1 class="display-5 fw-bold mb-3">🔥 실시간 AI 음악 랭킹</h1>
            <p class="lead mb-0">누구나 접속해서 감상하고, 당신의 작품을 자랑할 수 있는 오픈 플랫폼</p>
        </div>
    </div>

    <div class="container pb-5">
        <% if (user) { %>
            <div class="card mb-5 p-4" style="background-color: #f1f5f9;">
                <h4 class="fw-bold mb-4 text-primary">🎵 새로운 AI 곡 등록하기</h4>
                <form action="/upload" method="POST" enctype="multipart/form-data" class="row g-3">
                    <div class="col-md-6"><input type="text" name="title" class="form-control" placeholder="음악 제목" required></div>
                    <div class="col-md-6"><input type="text" name="artist" class="form-control" placeholder="아티스트 (가수 이름)" required></div>
                    
                    <div class="col-md-3 mt-3">
                        <select name="genre" class="form-select" required>
                            <option value="" selected disabled>장르를 선택하세요</option>
                            <% for (let group in melonGenres) { %>
                                <optgroup label="=== <%= group %> ===">
                                    <% melonGenres[group].forEach(function(g) { %>
                                        <option value="<%= g %>"><%= g %></option>
                                    <% }) %>
                                </optgroup>
                            <% } %>
                        </select>
                    </div>

                    <div class="col-md-3 mt-3"><input type="number" name="pulse" class="form-control" placeholder="초기 하트 수" value="0" required></div>
                    <div class="col-md-3 mt-3">
                        <label class="form-label text-muted small mb-0">앨범 커버 이미지</label>
                        <input type="file" name="imageFile" class="form-control" accept="image/*">
                    </div>
                    <div class="col-md-3 mt-3">
                        <label class="form-label text-muted small mb-0">음원 파일 (선택)</label>
                        <input type="file" name="mediaFile" class="form-control" accept="audio/*,video/*">
                    </div>
                    <div class="col-12 mt-4 text-end">
                        <button type="submit" class="btn btn-primary px-5 py-2 fw-bold">🚀 랭킹에 올리기</button>
                    </div>
                </form>
            </div>
        <% } %>

        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            <% if (artists && artists.length > 0) { %>
                <% artists.forEach(function(artist, index) { %>
                    <div class="col">
                        <div class="card h-100">
                            <img src="<%= artist.image %>" class="card-img-top" alt="커버 이미지">
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title d-flex align-items-center mb-3">
                                    <span class="rank-number"><%= index + 1 %></span>
                                    <span class="fw-bold text-truncate"><%= artist.name %></span>
                                </h5>
                                <p class="card-text text-muted mb-1">🎤 <%= artist.type %></p>
                                <span class="badge bg-secondary mb-3 align-self-start"><%= artist.genre %></span>
                                
                                <% if(artist.url && artist.url !== '#') { %>
                                    <audio controls controlsList="nodownload" class="w-100 mb-3" oncontextmenu="return false;">
                                        <source src="<%= artist.url %>" type="audio/mpeg">
                                    </audio>
                                <% } %>

                                <div class="mt-auto d-flex justify-content-between align-items-center">
                                    <% if (user) { %>
                                        <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#editModal<%= artist._id %>">✏️ 수정</button>
                                    <% } else { %>
                                        <div></div>
                                    <% } %>
                                    <span class="pulse-badge">❤️ <%= artist.pulse %></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <% if (user) { %>
                    <div class="modal fade" id="editModal<%= artist._id %>" tabindex="-1">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content">
                                <div class="modal-header"><h5 class="modal-title fw-bold">곡 정보 수정</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                                <form action="/edit/<%= artist._id %>" method="POST">
                                    <div class="modal-body text-start">
                                        <label class="mb-1 fw-bold">음악 제목</label>
                                        <input type="text" name="title" class="form-control mb-3" value="<%= artist.name %>" required>
                                        
                                        <label class="mb-1 fw-bold">아티스트</label>
                                        <input type="text" name="artist" class="form-control mb-3" value="<%= artist.type %>" required>
                                        
                                        <label class="mb-1 fw-bold">장르 선택</label>
                                        <select name="genre" class="form-select mb-3" required>
                                            <% for (let group in melonGenres) { %>
                                                <optgroup label="=== <%= group %> ===">
                                                    <% melonGenres[group].forEach(function(g) { %>
                                                        <option value="<%= g %>" <%= artist.genre === g ? 'selected' : '' %>><%= g %></option>
                                                    <% }) %>
                                                </optgroup>
                                            <% } %>
                                        </select>
                                    </div>
                                    <div class="modal-footer"><button type="submit" class="btn btn-primary w-100">저장하기</button></div>
                                </form>
                            </div>
                        </div>
                    </div>
                    <% } %>

                <% }); %>
            <% } else { %>
                <div class="col-12 text-center py-5">
                    <h2 class="text-muted">🪹 아직 등록된 곡이 없습니다.</h2>
                    <p class="text-muted">로그인하고 첫 번째 1위의 주인공이 되어보세요!</p>
                </div>
            <% } %>
        </div>
    </div>

    <div class="modal fade" id="loginModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header"><h5 class="modal-title fw-bold">로그인</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                <form action="/login" method="POST">
                    <div class="modal-body">
                        <input type="text" name="username" class="form-control mb-3" placeholder="아이디" required>
                        <input type="password" name="password" class="form-control" placeholder="비밀번호" required>
                    </div>
                    <div class="modal-footer"><button type="submit" class="btn btn-primary w-100">로그인 하기</button></div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="signupModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header"><h5 class="modal-title fw-bold">새 계정 만들기</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                <form action="/signup" method="POST">
                    <div class="modal-body">
                        <input type="text" name="username" class="form-control mb-3" placeholder="새로운 아이디" required>
                        <input type="password" name="password" class="form-control" placeholder="새로운 비밀번호" required>
                    </div>
                    <div class="modal-footer"><button type="submit" class="btn btn-success w-100">가입 완료</button></div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>