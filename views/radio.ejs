<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RAM 무드 라디오 📻</title>
    <style>
        /* 🌟 라디오 전용 감성 배경 (PC화면 잘림 방지 스크롤 허용!) */
        body { 
            margin: 0; padding: 0; 
            min-height: 100vh; /* 🚨 height를 min-height로 변경해서 화면이 좁아도 늘어나게 함 */
            background: linear-gradient(135deg, #0b0c0d, #1a1111); 
            color: #fff; font-family: 'Pretendard', sans-serif; 
            display: flex; flex-direction: column; 
            overflow-x: hidden; 
            overflow-y: auto; /* 🚨 PC에서 버튼이 잘리면 스크롤할 수 있도록 허용! */
            transition: background 1s ease; 
        }
        
        /* 상단 뒤로가기 헤더 */
        .radio-header { padding: 20px 30px; display: flex; justify-content: space-between; align-items: center; z-index: 10; }
        .btn-back { color: #aaa; text-decoration: none; font-size: 16px; font-weight: bold; display: flex; align-items: center; gap: 8px; transition: 0.2s; }
        .btn-back:hover { color: #ff5722; }
        .radio-logo { font-size: 20px; font-weight: 900; color: #ff5722; letter-spacing: 1px; }

        /* 메인 중앙 정렬 */
        .radio-container { flex: 1; display: flex; align-items: center; justify-content: center; flex-direction: column; text-align: center; padding: 20px 20px 50px 20px; position: relative; z-index: 5; }
        
        /* 🌟 빙글빙글 블랙 LP판 & 경계선 빛반사 효과 🌟 */
        .vinyl-wrapper { position: relative; margin-bottom: 40px; }
        .vinyl-record { 
            width: 280px; height: 280px; border-radius: 50%; 
            
            /* 🚨 [경계선 해결!] LP판 겉면에 은은한 하얀/회색 빛 테두리를 추가해서 배경과 분리! */
            box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.15), 0 0 0 6px rgba(255, 255, 255, 0.03), 0 20px 50px rgba(0,0,0,0.8); 
            
            background: #111; 
            border: 10px solid #050505; 
            
            object-fit: contain; 
            object-position: center; 
            padding: 80px; 
            box-sizing: border-box; 
            
            animation: spin 6s linear infinite; 
            animation-play-state: paused; 
        }
        .vinyl-record.playing { animation-play-state: running; } 
        
        /* 가운데 구멍 디테일 */
        .vinyl-hole { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 15px; height: 15px; background: #000; border-radius: 50%; border: 2px solid #222; z-index: 2; }
        
        @keyframes spin { 100% { transform: rotate(360deg); } }

        /* 곡 정보 */
        .track-title { font-size: 28px; font-weight: 900; margin: 0 0 10px 0; text-shadow: 0 4px 10px rgba(0,0,0,0.5); }
        .track-artist { font-size: 16px; color: #bbb; margin: 0 0 30px 0; }

        /* 라디오 컨트롤러 */
        .radio-controls { display: flex; align-items: center; gap: 30px; margin-bottom: 40px; }
        .btn-control { background: none; border: none; color: #fff; font-size: 24px; cursor: pointer; transition: 0.2s; }
        .btn-control:hover { color: #ff5722; transform: scale(1.1); }
        .btn-play-huge { width: 70px; height: 70px; background: #ff5722; color: #000; border-radius: 50%; font-size: 28px; display: flex; align-items: center; justify-content: center; padding-left: 4px; box-shadow: 0 10px 20px rgba(255,87,34,0.4); }
        .btn-play-huge:hover { transform: scale(1.05); background: #fff; }

        /* 무드(태그) 선택기 */
        .mood-selector { 
            display: flex; gap: 10px; flex-wrap: wrap; justify-content: center; 
            max-width: 800px; /* 🚨 PC 화면에서 버튼들이 답답하게 안 뭉치도록 넓게 펼쳐줌! */
        }
        .mood-btn { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.15); color: #ccc; padding: 10px 20px; border-radius: 30px; font-size: 14px; font-weight: bold; cursor: pointer; transition: 0.3s; backdrop-filter: blur(5px); }
        .mood-btn:hover { background: rgba(255,255,255,0.15); color: #fff; }
        .mood-btn.active { background: #ff5722; color: #000; border-color: #ff5722; box-shadow: 0 0 15px rgba(255,87,34,0.5); }

        @media (max-width: 600px) {
            .vinyl-record { width: 220px; height: 220px; border-width: 8px; padding: 60px; } 
            .track-title { font-size: 22px; }
            .mood-selector { gap: 8px; max-width: 100%; }
            .mood-btn { padding: 8px 15px; font-size: 13px; }
        }
    </style>
</head>
<body>

    <div class="radio-header">
        <a href="/" class="btn-back">← 메인 차트로 돌아가기</a>
        <div class="radio-logo">RAM RADIO 📻</div>
    </div>

    <div class="radio-container">
        <div class="vinyl-wrapper">
            <img src="/logo.png" class="vinyl-record" id="radio-cover" alt="앨범아트">
            <div class="vinyl-hole"></div>
        </div>

        <h2 class="track-title" id="radio-title">채널을 선택해주세요</h2>
        <p class="track-artist" id="radio-artist">RAM 24/7 Mood Radio</p>

        <div class="radio-controls">
            <button class="btn-control" id="btn-radio-prev" title="이전 곡">⏮</button>
            <button class="btn-control btn-play-huge" id="btn-radio-play" title="재생/일시정지">▶</button>
            <button class="btn-control" id="btn-radio-next" title="다음 곡">⏭</button>
        </div>

       <div class="mood-selector">
            <button class="mood-btn active" onclick="changeMood('all', this)">🌐 전체 랜덤</button>
            <button class="mood-btn" onclick="changeMood('cafe', this)">☕ 카페</button>
            <button class="mood-btn" onclick="changeMood('study', this)">💻 집중/스터디</button>
            <button class="mood-btn" onclick="changeMood('healing', this)">🌿 힐링/명상</button>
            <button class="mood-btn" onclick="changeMood('fitness', this)">🏋️ 헬스/운동</button>
            
            <button class="mood-btn" onclick="changeMood('drive', this)">🚗 신나는 드라이브</button>
            <button class="mood-btn" onclick="changeMood('night', this)">🌃 새벽 감성</button>
            <button class="mood-btn" onclick="changeMood('rain', this)">☔ 비 오는 날</button>
            <button class="mood-btn" onclick="changeMood('work', this)">🎧 노동요/코딩</button>
        </div>
    </div>

    <audio id="radio-audio" style="display:none;"></audio>

    <script>
        const vinyl = document.getElementById('radio-cover');
        const playBtn = document.getElementById('btn-radio-play');
        const titleEl = document.getElementById('radio-title');
        const artistEl = document.getElementById('radio-artist');
        const audio = document.getElementById('radio-audio');

        let radioPlaylist = [];
        let currentIdx = 0;
        let isPlaying = false;
        let currentMood = 'all';

        // 📡 1. 자판기에서 음악 뭉치 뽑아오기
        async function fetchTracks(mood) {
            try {
                const res = await fetch('/api/radio-tracks?mood=' + mood);
                const data = await res.json();
                if(data && data.length > 0) {
                    radioPlaylist = data;
                    currentIdx = 0;
                    loadTrack(0);
                    // 곡을 가져왔으니 바로 재생!
                    if (isPlaying) audio.play().catch(e => console.log(e));
                } else {
                    titleEl.innerText = "이 채널엔 아직 곡이 없어요 😢";
                    vinyl.classList.remove('playing');
                }
            } catch(e) { console.log(e); }
        }

        // 💿 2. 오디오 장전 및 화면(LP판/제목) 업데이트
        function loadTrack(index) {
            if(index >= radioPlaylist.length) {
                // 리스트가 끝났으면 다시 자판기에서 새로운 랜덤 20곡을 뽑아옵니다!
                fetchTracks(currentMood);
                return;
            }
            const track = radioPlaylist[index];
            audio.src = track.audioUrl || track.audio; 
            titleEl.innerText = track.name;
            artistEl.innerText = track.artist;
            vinyl.src = track.imageUrl || '/logo.png';
        }

        // ▶️ 3. 재생/일시정지 버튼
        playBtn.addEventListener('click', () => {
            if(radioPlaylist.length === 0) return alert("채널을 불러오는 중입니다...");
            if(audio.paused) {
                audio.play();
            } else {
                audio.pause();
            }
        });

       // ⏭️ 4. 앞/뒤 곡 넘기기 버튼
        document.getElementById('btn-radio-next').addEventListener('click', () => {
            if(radioPlaylist.length > 0) playNextTrack();
        });
        document.getElementById('btn-radio-prev').addEventListener('click', () => {
            if(currentIdx > 0) {
                currentIdx--;
                loadTrack(currentIdx);
                // 🚨 뒤로가기 누르면 조건 없이 무조건 재생!
                audio.play().catch(e => console.log(e)); 
            }
        });

        // 🎛️ 5. 무드(채널) 변경 버튼 & 배경색 마법
        function changeMood(mood, element) {
            document.querySelectorAll('.mood-btn').forEach(btn => btn.classList.remove('active'));
            element.classList.add('active');
            currentMood = mood;
            
            // 배경색 싹~ 감성적으로 변경
            const body = document.body;
            if(mood === 'cafe') body.style.background = 'linear-gradient(135deg, #1a1412, #2c1e16)';
            else if(mood === 'study') body.style.background = 'linear-gradient(135deg, #0f171e, #1e293b)';
            else if(mood === 'healing') body.style.background = 'linear-gradient(135deg, #141f18, #1c2e22)';
            else if(mood === 'fitness') body.style.background = 'linear-gradient(135deg, #2b1111, #3f1616)';
            else if(mood === 'drive') body.style.background = 'linear-gradient(135deg, #102a43, #0284c7)';
            else if(mood === 'night') body.style.background = 'linear-gradient(135deg, #171010, #2e1065)';
            else if(mood === 'rain') body.style.background = 'linear-gradient(135deg, #1e293b, #334155)';
            else if(mood === 'work') body.style.background = 'linear-gradient(135deg, #141414, #047857)';
            else body.style.background = 'linear-gradient(135deg, #0b0c0d, #1a1111)';

            // 채널이 바뀌면 음악도 싹 새로 가져옵니다!
            titleEl.innerText = "채널 튜닝 중... 📻";
            artistEl.innerText = "잠시만 기다려주세요";
            fetchTracks(mood);
        }

        // 🚀 처음에 접속하면 '전체 랜덤' 채널로 곡을 장전해둠!
        window.onload = () => {
            fetchTracks('all');
        };

        // ==========================================================
        // 🚀 [함정 완벽 제거!] 턴테이블 동기화 & 무한 연속 재생 엔진
        // ==========================================================
        
        audio.addEventListener('play', () => {
            vinyl.classList.add('playing');
            playBtn.innerText = "⏸";
            isPlaying = true;
        });

        audio.addEventListener('pause', () => {
            // 🚨 핵심 방어: 노래가 진짜 끝난게 아니라, 유저가 '일시정지'를 눌렀을 때만 멈춤 처리!
            if (audio.currentTime !== audio.duration && audio.currentTime > 0) {
                vinyl.classList.remove('playing');
                playBtn.innerText = "▶";
                isPlaying = false;
            }
        });

        // 🎵 곡이 끝나면 무조건 다음 곡 쏘기!
        audio.addEventListener('ended', () => {
            playNextTrack(); 
        });

        // 💀 깨진 음원 방어
        audio.addEventListener('error', () => {
            console.log("🚨 깨진 음원 감지! 1초 뒤 강제 스킵합니다.");
            vinyl.classList.remove('playing');
            setTimeout(() => {
                playNextTrack();
            }, 1000);
        });

        // 5. 다음 곡 재생 / 리필 함수
        function playNextTrack() {
            currentIdx++;
            if (currentIdx < radioPlaylist.length) {
                loadTrack(currentIdx);
                
                // 🚨 핵심 해결책: isPlaying 조건 다 빼버리고 무조건 재생 발사!!!
                const playPromise = audio.play();
                if (playPromise !== undefined) {
                    playPromise.then(() => {
                        isPlaying = true;
                    }).catch(e => console.log("자동재생 에러:", e));
                }
            } else {
                console.log("💿 라디오 재생 목록 끝! 새로운 곡을 리필합니다.");
                titleEl.innerText = "채널 곡 리필 중... 📻";
                artistEl.innerText = "잠시만 기다려주세요";
                fetchTracks(currentMood); 
            }
        }
// ==========================================================
        // 🚀 [브라우저 족쇄 풀기 꼼수] 전역 터치 권한 연장기
        // ==========================================================
        // 유저가 화면을 스크롤하거나, 댓글을 보거나, 아무 곳이나 터치할 때마다
        // 브라우저에게 "나 이 사이트 계속 보고 있어!"라고 몰래 신고해서 
        // 오디오 자동재생 권한을 끈질기게 연장시킵니다.
        
        document.addEventListener('touchstart', () => {
            // 브라우저 몰래 무음 오디오 컨텍스트를 계속 깨워줍니다
            if (typeof audioCtx !== 'undefined' && audioCtx.state === 'suspended') {
                audioCtx.resume();
            }
            
            // 만약 브라우저가 막아서 '대기 상태(isPlaying = false)'로 빠졌는데, 
            // 재생 버튼이 번쩍거리고 있는 상황이라면? 
            // 유저가 화면 아무 곳이나 터치하는 순간 바로 낚아채서 재생 시작!
            const mainAudioEl = document.getElementById('main-audio'); // 라디오면 'radio-audio'
            const playBtnEl = document.getElementById('btn-play'); // 라디오면 'btn-radio-play'
            
            if (mainAudioEl && mainAudioEl.paused && playBtnEl && playBtnEl.innerText === "▶" && document.getElementById('main-player-title').innerText.includes("터치해서")) {
                console.log("👀 화면 터치 감지! 막혀있던 재생을 몰래 시작합니다.");
                mainAudioEl.play().then(() => {
                    isPlaying = true;
                    playBtnEl.innerText = "⏸";
                    playBtnEl.style.boxShadow = "none";
                    playBtnEl.style.background = "#fff";
                    playBtnEl.style.color = "#000";
                    
                    const currentTrack = playlist[currentIndex]; // 라디오면 radioPlaylist[currentIdx]
                    if (currentTrack) {
                        document.getElementById('main-player-title').innerText = currentTrack.title || currentTrack.name;
                        document.getElementById('main-player-artist').innerText = currentTrack.artist;
                    }
                }).catch(e => {});
            }
        }, { passive: true });
    </script>
</body>
</html>
