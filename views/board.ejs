<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>커뮤니티 - RANKING AI</title>
    <style>
        /* 🌟 글로벌 기본 설정 (메인 화면과 동일) */
        body { background: #0b0c0d; color: #fff; font-family: 'Pretendard', sans-serif; margin: 0; padding-bottom: 100px; }
        a { text-decoration: none; color: inherit; }
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #0b0c0d; }
        ::-webkit-scrollbar-thumb { background: #333; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #ff5722; }

        /* 🌟 상단바 디자인 (메인 화면과 완벽 일치) */
        .main-header { background: #121314; border-bottom: 1px solid #222; position: sticky; top: 0; z-index: 100; }
        .header-top { display: flex; justify-content: space-between; align-items: center; padding: 15px 40px; border-bottom: 1px solid #1a1b1c; }
        .logo { font-size: 28px; font-weight: 900; letter-spacing: -1px; background: linear-gradient(45deg, #ff5722, #ffb300); -webkit-background-clip: text; -webkit-text-fill-color: transparent; text-shadow: 0 2px 10px rgba(255, 87, 34, 0.2); }
        .top-search-form { display: flex; align-items: center; background: #222; border: 2px solid #ff5722; border-radius: 25px; padding: 5px 15px; width: 400px; transition: all 0.3s ease; }
        .top-search-form:focus-within { box-shadow: 0 0 15px rgba(255, 87, 34, 0.4); border-color: #ffb300; }
        .top-search-input { background: none; border: none; color: white; outline: none; flex: 1; font-size: 15px; padding: 5px; }
        .top-search-btn { background: none; border: none; color: #ff5722; font-weight: bold; cursor: pointer; font-size: 16px; padding: 0 10px; }
        .auth-buttons { display: flex; gap: 20px; align-items: center; }
        .btn-login { color: #bbb; font-size: 14px; }
        .btn-signup { background: #ff5722; color: #000; padding: 8px 20px; border-radius: 20px; font-weight: bold; font-size: 14px; }

        /* 🌟 메뉴바 */
        .header-nav { display: flex; justify-content: center; gap: 40px; padding: 12px 0; background: #0b0c0d; }
        .nav-item { color: #aaa; font-weight: 600; font-size: 16px; transition: 0.2s; position: relative; }
        .nav-item:hover, .nav-item.active { color: #ff5722; }
        .nav-item.active::after { content: ''; position: absolute; bottom: -12px; left: 0; width: 100%; height: 3px; background: #ff5722; }

        /* ========================================= */
        /* 🌟 커뮤니티 전용 프리미엄 디자인 🌟 */
        /* ========================================= */
        .container { max-width: 900px; margin: 0 auto; padding: 40px 20px; }
        
        /* 게시판 헤더 & 글쓰기 버튼 */
        .board-header { display: flex; justify-content: space-between; align-items: flex-end; border-bottom: 2px solid #222; padding-bottom: 15px; margin-bottom: 30px; }
        .board-title { font-size: 28px; font-weight: bold; margin: 0; display: flex; align-items: center; gap: 10px; }
        .btn-write-toggle { background: #ff5722; color: #000; border: none; padding: 10px 20px; border-radius: 8px; font-weight: bold; cursor: pointer; font-size: 14px; transition: 0.2s; }
        .btn-write-toggle:hover { filter: brightness(1.1); transform: translateY(-2px); box-shadow: 0 4px 10px rgba(255, 87, 34, 0.3); }

        /* 글쓰기 입력 상자 (초기엔 숨겨짐) */
        .write-box { background: #161718; padding: 25px; border-radius: 12px; border: 1px solid #333; margin-bottom: 40px; display: none; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        .write-box h3 { margin-top: 0; color: #ff5722; font-size: 18px; margin-bottom: 20px; }
        .write-input { width: 100%; background: #222; border: 1px solid #444; color: #fff; padding: 12px; border-radius: 8px; box-sizing: border-box; margin-bottom: 15px; font-family: inherit; font-size: 15px; transition: 0.2s; }
        .write-input:focus { outline: none; border-color: #ff5722; background: #1a1a1a; }
        .write-textarea { height: 150px; resize: vertical; }
        .btn-submit { width: 100%; background: #ff5722; color: #000; border: none; padding: 14px; border-radius: 8px; font-weight: bold; font-size: 16px; cursor: pointer; transition: 0.2s; }
        .btn-submit:hover { background: #ffb300; }

        /* 프리미엄 카드형 게시글 리스트 */
        .post-list { display: flex; flex-direction: column; gap: 20px; }
        .post-card { background: #161718; border-radius: 12px; padding: 25px; border: 1px solid #222; transition: all 0.3s ease; border-left: 4px solid transparent; }
        .post-card:hover { background: rgba(255, 87, 34, 0.03); border-left: 4px solid #ff5722; transform: translateY(-3px); box-shadow: 0 8px 20px rgba(0,0,0,0.4); }
        
        .post-header-info { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; }
        .post-author { font-weight: bold; color: #ff5722; font-size: 14px; background: rgba(255, 87, 34, 0.1); padding: 4px 10px; border-radius: 12px; }
        .post-date { font-size: 12px; color: #777; }
        
        .post-title { font-size: 20px; font-weight: bold; margin: 0 0 10px 0; color: #fff; }
        .post-content { font-size: 15px; color: #ccc; line-height: 1.6; margin: 0 0 20px 0; word-break: break-all; }
        
        .post-actions { display: flex; gap: 15px; align-items: center; border-top: 1px solid #222; padding-top: 15px; }
        .action-btn { background: none; border: none; color: #aaa; font-size: 13px; cursor: pointer; display: flex; align-items: center; gap: 5px; transition: 0.2s; padding: 0; }
        .action-btn:hover { color: #ff5722; }

        /* 📱 모바일 최적화 */
        @media (max-width: 900px) {
            .header-top { flex-direction: column; align-items: center; padding: 15px; gap: 15px; }
            .top-search-form { width: 100%; box-sizing: border-box; }
            .auth-buttons { width: 100%; justify-content: center; }
            .header-nav { justify-content: flex-start; overflow-x: auto; white-space: nowrap; padding: 12px 15px; gap: 20px; }
            .header-nav::-webkit-scrollbar { display: none; }
            
            .board-header { flex-direction: column; align-items: flex-start; gap: 15px; }
            .btn-write-toggle { width: 100%; }
            .post-card { padding: 15px; }
            .post-title { font-size: 18px; }
        }
    </style>
</head>
<body>
    <header class="main-header">
       <div class="header-top">
            <div class="logo">RANKING AI</div>
            <form action="/" method="GET" class="top-search-form">
                <input type="text" name="search" class="top-search-input" placeholder="아티스트 검색...">
                <button type="submit" class="top-search-btn">🔍</button>
            </form>
            <div class="auth-buttons">
                <% if (user) { %>
                    <span style="color: #aaa; font-size: 14px;"><%= user.id %>님</span>
                    <a href="/logout" class="btn-login">로그아웃</a>
                <% } else { %>
                    <a href="/login" class="btn-login">로그인</a>
                    <a href="/signup" class="btn-signup">회원가입</a>
                <% } %>
            </div>
        </div>
        
        <div class="header-nav">
            <a href="/?sort=views" class="nav-item">RANKING AI 챠트</a>
            <a href="/?sort=latest" class="nav-item">최신음악</a>
            <a href="/?genre=K-POP" class="nav-item">장르별</a>
            <a href="/youtube" class="nav-item">유튜브</a>
            <a href="/shorts" class="nav-item">쇼츠</a>
            <a href="/board" class="nav-item active">커뮤니티</a>
        </div>
    </header>

    <div class="container">
        
        <div class="board-header">
            <h2 class="board-title">💬 커뮤니티 <span style="font-size: 14px; font-weight: normal; color: #777;">자유롭게 이야기를 나눠보세요!</span></h2>
            
            <% if (user) { %>
                <button class="btn-write-toggle" onclick="const box = document.getElementById('writeBox'); box.style.display = (box.style.display === 'block') ? 'none' : 'block'; window.scrollBy({ top: 100, behavior: 'smooth' });">✍️ 글쓰기</button>
            <% } else { %>
                <button class="btn-write-toggle" onclick="location.href='/login'" style="background:#444; color:#fff;">🔒 로그인 후 글쓰기</button>
            <% } %>
        </div>

        <% if (user) { %>
        <div class="write-box" id="writeBox">
            <h3>새로운 글 작성하기</h3>
            <form action="/add-post" method="POST">
                <input type="text" name="title" class="write-input" placeholder="제목을 입력하세요." required>
                <textarea name="content" class="write-input write-textarea" placeholder="내용을 입력하세요. 욕설 및 비방은 제재될 수 있습니다." required></textarea>
                <button type="submit" class="btn-submit">게시글 등록하기</button>
            </form>
        </div>
        <% } %>

        <div class="post-list">
            <% if (typeof posts !== 'undefined' && posts.length > 0) { %>
                <% posts.forEach(post => { %>
                    <div class="post-card">
                        <div class="post-header-info">
                            <span class="post-author">@<%= post.author %></span>
                            <span class="post-date"><%= new Date(post.createdAt).toLocaleDateString() %></span>
                        </div>
                        <h3 class="post-title"><%= post.title %></h3>
                        <p class="post-content"><%= post.content %></p>
                        
                        <div class="post-actions">
                            <button class="action-btn" onclick="this.innerHTML = '❤️ 좋아요 ' + (parseInt(this.innerText.replace(/[^0-9]/g, '')) + 1); this.style.color='#ff4a4a';">🤍 좋아요 <%= Math.floor(Math.random() * 20) %></button>
                            <button class="action-btn">💬 댓글 달기</button>
                            
                            <% if (user && (user.id === post.author || user.role === 'admin')) { %>
                                <form action="/delete-post/<%= post._id %>" method="POST" style="margin-left: auto;" onsubmit="return confirm('정말 삭제하시겠습니까?');">
                                    <button type="submit" class="action-btn" style="color:#ff4a4a;">🗑️ 삭제</button>
                                </form>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div style="text-align:center; padding: 80px 0; color:#555; background:#161718; border-radius:12px; border:1px dashed #333;">
                    <div style="font-size: 40px; margin-bottom:15px;">📝</div>
                    아직 등록된 게시글이 없습니다.<br>첫 번째 글을 남겨보세요!
                </div>
            <% } %>
        </div>

    </div>

</body>
</html>
