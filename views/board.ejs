<!DOCTYPE html>
<html lang="ko">
<head>
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5112383847606285"
         crossorigin="anonymous"></script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>커뮤니티 - RANKING AI</title>
    <style>
        /* 🌟 글로벌 기본 설정 */
        body { background: #0b0c0d; color: #fff; font-family: 'Pretendard', sans-serif; margin: 0; padding-bottom: 100px; }
        a { text-decoration: none; color: inherit; }
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #0b0c0d; }
        ::-webkit-scrollbar-thumb { background: #333; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #ff5722; }

        /* 🌟 상단바 디자인 */
        .main-header { background: #121314; border-bottom: 1px solid #222; position: sticky; top: 0; z-index: 100; }
        .header-top { display: flex; justify-content: space-between; align-items: center; padding: 15px 40px; border-bottom: 1px solid #1a1b1c; }
        .logo { font-size: 28px; font-weight: 900; letter-spacing: -1px; background: linear-gradient(45deg, #ff5722, #ffb300); -webkit-background-clip: text; -webkit-text-fill-color: transparent; text-shadow: 0 2px 10px rgba(255, 87, 34, 0.2); }
        .top-search-form { display: flex; align-items: center; background: #222; border: 2px solid #ff5722; border-radius: 25px; padding: 5px 15px; width: 400px; transition: all 0.3s ease; }
        .top-search-form:focus-within { box-shadow: 0 0 15px rgba(255, 87, 34, 0.4); border-color: #ffb300; }
        .top-search-input { background: none; border: none; color: white; outline: none; flex: 1; font-size: 15px; padding: 5px; }
        .top-search-btn { background: none; border: none; color: #ff5722; font-weight: bold; cursor: pointer; font-size: 16px; padding: 0 10px; }
        .auth-buttons { display: flex; gap: 20px; align-items: center; }
        .btn-login { color: #bbb; font-size: 14px; }
        .btn-signup { background: #ff5722; color: #000; padding: 8px 20px; border-radius: 20px; font-weight: bold; font-size: 14px; }

        /* 🌟 메뉴바 */
        .header-nav { display: flex; justify-content: center; gap: 40px; padding: 12px 0; background: #0b0c0d; }
        .nav-item { color: #aaa; font-weight: 600; font-size: 16px; transition: 0.2s; position: relative; }
        .nav-item:hover, .nav-item.active { color: #ff5722; }
        .nav-item.active::after { content: ''; position: absolute; bottom: -12px; left: 0; width: 100%; height: 3px; background: #ff5722; }

        /* 🌟 커뮤니티 기본 설정 */
        .container { max-width: 900px; margin: 0 auto; padding: 40px 20px; }
        .board-header { display: flex; justify-content: space-between; align-items: flex-end; border-bottom: 2px solid #222; padding-bottom: 15px; margin-bottom: 30px; }
        .board-title { font-size: 28px; font-weight: bold; margin: 0; display: flex; align-items: center; gap: 10px; }
        .btn-write-toggle { background: #ff5722; color: #000; border: none; padding: 10px 20px; border-radius: 8px; font-weight: bold; cursor: pointer; font-size: 14px; transition: 0.2s; }
        .btn-write-toggle:hover { filter: brightness(1.1); transform: translateY(-2px); box-shadow: 0 4px 10px rgba(255, 87, 34, 0.3); }

        /* 🌟 글쓰기 상자 */
        .write-box { background: #161718; padding: 25px; border-radius: 12px; border: 1px solid #333; margin-bottom: 40px; display: none; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        .write-box h3 { margin-top: 0; color: #ff5722; font-size: 18px; margin-bottom: 20px; }
        .write-input { width: 100%; background: #222; border: 1px solid #444; color: #fff; padding: 12px; border-radius: 8px; box-sizing: border-box; margin-bottom: 15px; font-family: inherit; font-size: 15px; transition: 0.2s; }
        .write-input:focus { outline: none; border-color: #ff5722; background: #1a1a1a; }
        .write-textarea { height: 150px; resize: vertical; }
        .btn-submit { width: 100%; background: #ff5722; color: #000; border: none; padding: 14px; border-radius: 8px; font-weight: bold; font-size: 16px; cursor: pointer; transition: 0.2s; }
        .btn-submit:hover { background: #ffb300; }

        /* 🌟 버튼 및 기능 요소 */
        .post-list { display: flex; flex-direction: column; gap: 20px; }
        .post-actions { display: flex; gap: 15px; align-items: center; border-top: 1px solid #222; padding-top: 15px; }
        .action-btn { background: none; border: none; color: #aaa; font-size: 13px; cursor: pointer; display: flex; align-items: center; gap: 5px; transition: 0.2s; padding: 0; }
        .action-btn:hover { color: #ff5722; }

        /* 🌟 보배드림 스타일 테이블 */
        .board-table { width: 100%; border-collapse: collapse; background: #161718; border-radius: 8px; overflow: hidden; margin-top: 15px; }
        .board-table thead { background: #222; color: #888; font-size: 14px; }
        .board-table th { padding: 15px 10px; border-bottom: 1px solid #333; font-weight: 500; }
        .board-table td { padding: 12px 10px; border-bottom: 1px solid #222; text-align: center; font-size: 14px; color: #ccc; }
        .board-row:hover { background: rgba(255, 87, 34, 0.05); cursor: pointer; }
        .td-title { text-align: left !important; padding-left: 20px !important; color: #fff; font-size: 15px; }

        /* 🌟 [NEW] 하단 페이지 번호 (페이징) 디자인 */
        .pagination-container { text-align: center; margin-top: 40px; padding-bottom: 20px; }
        .page-btn { background: #222; color: #aaa; border: 1px solid #333; padding: 8px 14px; margin: 0 4px; border-radius: 6px; cursor: pointer; font-size: 14px; transition: 0.2s; }
        .page-btn:hover { background: #333; color: #fff; }
        .page-btn.active { background: #ff5722; color: #000; font-weight: bold; border-color: #ff5722; pointer-events: none; }

        /* 📱 모바일 최적화 */
        @media (max-width: 900px) {
            .header-top { flex-direction: column; align-items: center; padding: 15px; gap: 15px; }
            .top-search-form { width: 100%; box-sizing: border-box; }
            .auth-buttons { width: 100%; justify-content: center; }
            .header-nav { justify-content: flex-start; overflow-x: auto; white-space: nowrap; padding: 12px 15px; gap: 20px; }
            .header-nav::-webkit-scrollbar { display: none; }
            .board-header { flex-direction: column; align-items: flex-start; gap: 15px; }
            .btn-write-toggle { width: 100%; }
        }
    </style>
</head>
<body>
    <header class="main-header">
       <div class="header-top">
            <img src="/logo.png" alt="RANKING AI 로고" style="height: 45px; cursor: pointer; object-fit: contain;" onclick="window.location.href='/?sort=views'">
            <form action="/" method="GET" class="top-search-form">
                <input type="text" name="search" class="top-search-input" placeholder="아티스트 검색...">
                <button type="submit" class="top-search-btn">🔍</button>
            </form>
            <div class="auth-buttons">
                <% if (user) { %>
                    <span style="color: #aaa; font-size: 14px;"><%= user.id %>님</span>
                    <a href="/logout" class="btn-login">로그아웃</a>
                <% } else { %>
                    <a href="/login" class="btn-login">로그인</a>
                    <a href="/signup" class="btn-signup">회원가입</a>
                <% } %>
            </div>
        </div>
        
        <div class="header-nav">
            <a href="/?sort=views" class="nav-item">RANKING AI 챠트</a>
            <a href="/?sort=latest" class="nav-item">최신음악</a>
            <a href="/?genre=K-POP" class="nav-item">장르별</a>
            <a href="/youtube" class="nav-item">유튜브</a>
            <a href="/shorts" class="nav-item">쇼츠</a>
            <a href="/board" class="nav-item active">커뮤니티</a>
        </div>
    </header>

    <div class="container">
        
        <div class="board-header">
            <h2 class="board-title">💬 커뮤니티 <span style="font-size: 14px; font-weight: normal; color: #777;">자유롭게 이야기를 나눠보세요!</span></h2>
            
            <% if (user) { %>
                <button class="btn-write-toggle" onclick="const box = document.getElementById('writeBox'); box.style.display = (box.style.display === 'block') ? 'none' : 'block'; window.scrollBy({ top: 100, behavior: 'smooth' });">✍️ 글쓰기</button>
            <% } else { %>
                <button class="btn-write-toggle" onclick="location.href='/login'" style="background:#444; color:#fff;">🔒 로그인 후 글쓰기</button>
            <% } %>
        </div>

        <% if (user) { %>
        <div class="write-box" id="writeBox">
            <h3>새로운 글 작성하기</h3>
            <form action="/add-post" method="POST" enctype="multipart/form-data">
                <input type="text" name="title" class="write-input" placeholder="제목을 입력하세요." required>
                <textarea name="content" class="write-input write-textarea" placeholder="내용을 입력하세요. 욕설 및 비방은 제재될 수 있습니다." required></textarea>
                
                <div style="margin-bottom: 20px; background: #222; padding: 12px; border-radius: 8px; border: 1px dashed #555;">
                    <label style="color: #ff5722; font-size: 13px; font-weight: bold; margin-bottom: 8px; display: block;">📷 이미지 첨부 (선택사항)</label>
                    <input type="file" name="image" accept="image/*" style="color: #aaa; font-size: 14px; width: 100%; cursor: pointer;">
                </div>

                <button type="submit" class="btn-submit">게시글 등록하기</button>
            </form>
        </div>
        <% } %>

        <div class="post-list">
            <table class="board-table">
                <thead>
                    <tr>
                        <th width="10%">번호</th>
                        <th width="50%">제목</th>
                        <th width="15%">글쓴이</th>
                        <th width="15%">날짜</th>
                        <th width="10%">좋아요</th>
                    </tr>
                </thead>
                <tbody>
                <% if (typeof posts !== 'undefined' && posts.length > 0) { %>
                    <% posts.forEach((post, index) => { %>
                        <% const pageNum = Math.floor(index / 5) + 1; %>

                        <tr class="board-row page-<%= pageNum %>" 
                            style="<%= pageNum > 1 ? 'display: none;' : '' %>"
                            onclick="const detail = document.getElementById('post-detail-<%= post._id %>'); detail.style.display = (detail.style.display === 'none' || detail.style.display === '') ? 'table-row' : 'none';">
                            
                            <td><%= posts.length - index %></td>
                            <td class="td-title">
                                <%= post.title %>
                                <% if (post.comments && post.comments.length > 0) { %>
                                    <span style="color: #ff5722; font-size: 12px; font-weight: bold; margin-left: 5px;">[<%= post.comments.length %>]</span>
                                <% } %>
                                <% if (post.imageUrl) { %>
                                    <span style="font-size: 12px; margin-left: 5px;">📷</span>
                                <% } %>
                            </td>
                            <td style="color: #aaa;">@<%= post.author %></td>
                            <td style="font-size: 13px;"><%= new Date(post.createdAt).toLocaleDateString() %></td>
                            <td style="color: #ff5722;"><%= post.likes || 0 %></td>
                        </tr>

                        <tr id="post-detail-<%= post._id %>" class="post-detail page-<%= pageNum %>" style="display: none; background: #0e0e0f;">
                            <td colspan="5" style="padding: 25px; text-align: left; border-bottom: 2px solid #ff5722;">
                                
                                <p class="post-content" style="white-space: pre-wrap; line-height: 1.6; word-break: break-word; color: #ccc; margin-top: 0; font-size: 15px;"><%= post.content %></p>
                                
                                <% if (post.imageUrl) { %>
                                    <div style="margin-bottom: 20px; text-align: center;">
                                        <img src="<%= post.imageUrl %>" alt="게시글 이미지" style="max-width: 100%; max-height: 500px; border-radius: 12px; border: 1px solid #333; box-shadow: 0 5px 15px rgba(0,0,0,0.3);">
                                    </div>
                                <% } %>
                                
                                <div class="post-actions">
                                    <% 
                                        let isPostLiked = false;
                                        if (user && post.likedBy && post.likedBy.includes(user.id)) {
                                            isPostLiked = true;
                                        }
                                    %>
                                    <button class="action-btn" id="like-post-btn-<%= post._id %>" onclick="event.stopPropagation(); likePost('<%= post._id %>')" style="<%= isPostLiked ? 'color:#ff4a4a;' : '' %>">
                                        <%= isPostLiked ? '❤️' : '🤍' %> 좋아요 <span id="like-post-count-<%= post._id %>"><%= post.likes || 0 %></span>
                                    </button>
                                    
                                    <button class="action-btn" onclick="event.stopPropagation(); const box = document.getElementById('board-comments-<%= post._id %>'); box.style.display = (box.style.display === 'block') ? 'none' : 'block';">💬 댓글 <%= post.comments ? post.comments.length : 0 %></button>
                                    
                                    <% if (user && (user.id === post.author || user.role === 'admin')) { %>
                                        <div style="display: flex; gap: 10px; margin-left: auto; align-items: center;">
                                            <button onclick="event.stopPropagation(); location.href='/edit-post/<%= post._id %>'" class="action-btn" style="color: #00e5ff; background: none; border: none; cursor: pointer; padding: 0;">✏️ 수정</button>
                                            
                                            <form action="/delete-post/<%= post._id %>" method="POST" style="margin: 0;" onsubmit="return confirm('정말 삭제할까요?');">
                                                <button type="submit" class="action-btn" style="color: #ff4a4a; background: none; border: none; cursor: pointer; padding: 0;">🗑 삭제</button>
                                            </form>
                                        </div>
                                    <% } %>
                                </div>

                                <div id="board-comments-<%= post._id %>" style="display: none; background: #111; padding: 15px; border-radius: 8px; margin-top: 15px; border: 1px solid #222;">
                                    <div style="max-height: 200px; overflow-y: auto; margin-bottom: 15px;">
                                        <% if (post.comments && post.comments.length > 0) { %>
                                            <% post.comments.forEach(function(c) { %>
                                                <div style="border-bottom: 1px solid #333; padding: 10px 0; display: flex; justify-content: space-between; align-items: center;">
                                                    <div>
                                                        <span style="color:#ff5722; font-weight:bold; font-size:13px;">@<%= c.author %></span>
                                                        <span style="font-size:14px; margin-left:8px; color:#ddd;"><%= c.text %></span>
                                                        <div style="font-size:11px; color:#555; margin-top:4px;"><%= new Date(c.createdAt).toLocaleString() %></div>
                                                    </div>
                                                    <% if (user && (user.role === 'admin' || user.id === c.author)) { %>
                                                        <form action="/delete-board-comment/<%= post._id %>/<%= c._id %>" method="POST" style="margin: 0;" onsubmit="return confirm('이 댓글을 삭제할까요?');">
                                                            <button type="submit" style="background: none; border: none; color: #ff4a4a; font-size: 11px; cursor: pointer;">❌삭제</button>
                                                        </form>
                                                    <% } %>
                                                </div>
                                            <% }); %>
                                        <% } else { %>
                                            <p style="font-size:13px; color:#777; text-align:center; padding: 10px 0;">아직 댓글이 없습니다. 첫 번째 댓글을 남겨보세요!</p>
                                        <% } %>
                                    </div>
                                    
                                    <% if (user) { %>
                                        <form action="/add-board-comment/<%= post._id %>" method="POST" style="display:flex; gap:10px;">
                                            <input type="text" name="commentText" placeholder="따뜻한 댓글을 남겨주세요..." style="flex:1; padding:10px; border-radius:6px; border:1px solid #444; background:#222; color:white; font-family:inherit;" required>
                                            <button type="submit" style="background:#ff5722; color:black; border:none; padding:10px 20px; border-radius:6px; font-weight:bold; cursor:pointer;">등록</button>
                                        </form>
                                    <% } else { %>
                                        <div style="text-align:center; font-size:13px; color:#777; padding:10px; background:#222; border-radius:6px;">댓글을 작성하려면 <a href="/login" style="color:#ff5722; text-decoration:underline;">로그인</a>이 필요합니다.</div>
                                    <% } %>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="5" style="padding: 80px 0; color:#555; background:#161718;">
                            <div style="font-size: 40px; margin-bottom:15px;">📝</div>
                            아직 등록된 게시글이 없습니다.<br>첫 번째 글을 남겨보세요!
                        </td>
                    </tr>
                <% } %>
                </tbody>
            </table>
        </div>

        <% if (typeof posts !== 'undefined' && posts.length > 5) { %>
            <div class="pagination-container">
                <% const totalPages = Math.ceil(posts.length / 5); %>
                <% for(let i=1; i<=totalPages; i++) { %>
                    <button class="page-btn <%= i === 1 ? 'active' : '' %>" onclick="changePage(<%= i %>)"><%= i %></button>
                <% } %>
            </div>
        <% } %>

    </div>

    <script>
        function changePage(targetPage) {
            document.querySelectorAll('.board-row').forEach(row => row.style.display = 'none');
            document.querySelectorAll('.post-detail').forEach(row => row.style.display = 'none');

            // 🌟 바로 여기! '' 를 'table-row' 로 수정했습니다! 🌟
            document.querySelectorAll('.board-row.page-' + targetPage).forEach(row => row.style.display = 'table-row');

            document.querySelectorAll('.page-btn').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');

            const boardTop = document.querySelector('.board-header').offsetTop;
            window.scrollTo({ top: boardTop - 80, behavior: 'smooth' });
        }

        async function likePost(postId) {
            try {
                const response = await fetch('/like-post/' + postId, { method: 'POST' });
                const data = await response.json();

                if (data.success) {
                    const countSpan = document.getElementById('like-post-count-' + postId);
                    countSpan.innerText = parseInt(countSpan.innerText) + 1;
                    
                    const btn = document.getElementById('like-post-btn-' + postId);
                    btn.innerHTML = '❤️ 좋아요 <span id="like-post-count-' + postId + '">' + countSpan.innerText + '</span>';
                    btn.style.color = '#ff4a4a';
                } else {
                    alert(data.message);
                }
            } catch (err) {
                console.error("좋아요 에러:", err);
                alert("통신 중 에러가 발생했습니다.");
            }
        }
    </script>
</body>
</html>