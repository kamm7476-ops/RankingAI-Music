<!DOCTYPE html>
<html lang="<%= typeof getLocale !== 'undefined' ? getLocale() : 'ko' %>">
<head>
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5112383847606285" crossorigin="anonymous"></script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= __('menu_community') || '커뮤니티' %> - RANKING AI</title>
    
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
    <meta http-equiv="Pragma" content="no-cache">
    <meta http-equiv="Expires" content="0">
    
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    <link rel="icon" href="/favicon.png" type="image/png">
    
    <style>
        /* 🌟 글로벌 기본 설정 */
        body { background: #0b0c0d; color: #fff; font-family: 'Pretendard', sans-serif; margin: 0; padding-bottom: 100px; }
        a { text-decoration: none; color: inherit; }
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #0b0c0d; }
        ::-webkit-scrollbar-thumb { background: #333; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #ff5722; }

        /* 🌟 상단바 디자인 (메인과 완벽히 동일) */
        .main-header { background: #121314; border-bottom: 1px solid #222; position: sticky; top: 0; z-index: 100; }
        .header-top { display: flex; justify-content: space-between; align-items: center; padding: 10px 15px; border-bottom: 1px solid #1a1b1c; gap: 10px; flex-wrap: nowrap; }
        .logo-img { height: 50px; max-width: 100%; cursor: pointer; object-fit: contain; flex-shrink: 0; }
        
        .top-search-form { display: flex; align-items: center; background: #222 !important; border: 2px solid #ff5722; border-radius: 25px; padding: 5px 12px; flex: 1; max-width: 400px; margin: 0; min-width: 0; }
        .top-search-input { background: transparent !important; border: none !important; color: white !important; outline: none; flex: 1; font-size: 14px; padding: 5px; min-width: 0; }
        .top-search-input::placeholder { color: #aaa; }
        .top-search-btn { background: none; border: none; color: #ff5722; font-weight: bold; cursor: pointer; font-size: 16px; padding: 0 10px; }

        .auth-buttons { display: flex; gap: 15px; align-items: center; flex-shrink: 0; }
        .lang-select { padding: 7px 14px; background: #222; color: #fff; border: 2px solid #ff5722; border-radius: 20px; font-weight: bold; font-size: 13px; outline: none; cursor: pointer; transition: 0.2s; }
        .lang-select:hover { background: #ff5722; color: #000; }
        .btn-admin { color: #ff4a4a; font-weight: bold; font-size: 14px; border: 1px solid #ff4a4a; padding: 5px 12px; border-radius: 15px; }
        .btn-login { color: #bbb; font-size: 14px; }
        .btn-signup { background: #ff5722; color: #000; padding: 8px 20px; border-radius: 20px; font-weight: bold; font-size: 14px; }

        /* 🌟 메뉴바 */
        .header-nav { display: flex; justify-content: center; gap: 40px; padding: 12px 0; background: #0b0c0d; }
        .nav-item { color: #aaa; font-weight: 600; font-size: 16px; transition: 0.2s; position: relative; }
        .nav-item:hover, .nav-item.active { color: #ff5722; }
        .nav-item.active::after { content: ''; position: absolute; bottom: -12px; left: 0; width: 100%; height: 3px; background: #ff5722; }

        /* 🌟 커뮤니티 기본 설정 */
        .container { max-width: 900px; margin: 0 auto; padding: 40px 20px; }
        .board-header { display: flex; justify-content: space-between; align-items: flex-end; border-bottom: 2px solid #222; padding-bottom: 15px; margin-bottom: 30px; }
        .board-title { font-size: 28px; font-weight: bold; margin: 0; display: flex; align-items: center; gap: 10px; }
        .btn-write-toggle { background: #ff5722; color: #000; border: none; padding: 10px 20px; border-radius: 8px; font-weight: bold; cursor: pointer; font-size: 14px; transition: 0.2s; }
        .btn-write-toggle:hover { filter: brightness(1.1); transform: translateY(-2px); box-shadow: 0 4px 10px rgba(255, 87, 34, 0.3); }

        /* 🌟 글쓰기 상자 */
        .write-box { background: #161718; padding: 25px; border-radius: 12px; border: 1px solid #333; margin-bottom: 40px; display: none; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        .write-box h3 { margin-top: 0; color: #ff5722; font-size: 18px; margin-bottom: 20px; }
        .write-input { width: 100%; background: #222; border: 1px solid #444; color: #fff; padding: 12px; border-radius: 8px; box-sizing: border-box; margin-bottom: 15px; font-family: inherit; font-size: 15px; transition: 0.2s; }
        .write-input:focus { outline: none; border-color: #ff5722; background: #1a1a1a; }
        .write-textarea { height: 150px; resize: vertical; }
        .btn-submit { width: 100%; background: #ff5722; color: #000; border: none; padding: 14px; border-radius: 8px; font-weight: bold; font-size: 16px; cursor: pointer; transition: 0.2s; }
        .btn-submit:hover { background: #ffb300; }

        /* 🌟 버튼 및 기능 요소 */
        .post-list { display: flex; flex-direction: column; gap: 20px; }
        .post-actions { display: flex; gap: 15px; align-items: center; border-top: 1px solid #222; padding-top: 15px; }
        .action-btn { background: none; border: none; color: #aaa; font-size: 13px; cursor: pointer; display: flex; align-items: center; gap: 5px; transition: 0.2s; padding: 0; }
        .action-btn:hover { color: #ff5722; }

        /* 🌟 프리미엄 커뮤니티 리스트 (독립된 카드 스타일) */
        .board-table { width: 100%; border-collapse: separate; border-spacing: 0 12px; background: transparent; }
        .board-table thead th { padding: 10px 15px; color: #888; font-size: 14px; border-bottom: 2px solid #333; }
        .board-row { background: #161718; box-shadow: 0 4px 10px rgba(0,0,0,0.2); transition: all 0.2s ease; }
        .board-row td:first-child { border-top-left-radius: 12px; border-bottom-left-radius: 12px; border-left: 1px solid #252628; }
        .board-row td:last-child { border-top-right-radius: 12px; border-bottom-right-radius: 12px; border-right: 1px solid #252628; }
        .board-table td { padding: 22px 15px; border-top: 1px solid #252628; border-bottom: 1px solid #252628; color: #ccc; }
        .board-row:hover { background: #1c1d20; transform: translateY(-3px); box-shadow: 0 8px 20px rgba(255, 87, 34, 0.15); cursor: pointer; }

        .td-title { text-align: left !important; padding-left: 20px !important; font-size: 17px !important; color: #fff !important; font-weight: 500; }
        .post-detail td { background: #111214 !important; border: 1px solid #ff5722 !important; border-radius: 12px !important; box-shadow: 0 10px 30px rgba(0,0,0,0.5) !important; }

        /* 🌟 커뮤니티 본문 가독성 최적화 */
        .post-content { white-space: pre-wrap !important; }
        .post-content p { margin-bottom: 20px !important; margin-top: 0; }
        .post-content img { max-width: 100%; border-radius: 8px; margin: 15px 0; }

        /* 🌟 하단 페이지 번호 (페이징) 디자인 */
        .pagination-container { text-align: center; margin-top: 40px; padding-bottom: 20px; }
        .page-btn { background: #222; color: #aaa; border: 1px solid #333; padding: 8px 14px; margin: 0 4px; border-radius: 6px; cursor: pointer; font-size: 14px; transition: 0.2s; }
        .page-btn:hover { background: #333; color: #fff; }
        .page-btn.active { background: #ff5722; color: #000; font-weight: bold; border-color: #ff5722; pointer-events: none; }

        /* 🚨 모바일 세로 기차 물리적 완전 박멸 (Flexbox 카드 변환) 🚨 */
        @media screen and (max-width: 768px) {
            table.board-table, table.board-table tbody { display: block !important; width: 100% !important; }
            table.board-table thead { display: none !important; }

            tr.board-row { display: flex !important; flex-direction: row !important; align-items: center !important; width: 100% !important; box-sizing: border-box !important; padding: 15px 10px !important; }
            table.board-table td { display: block !important; border: none !important; padding: 0 !important; box-sizing: border-box !important; }
            tr.board-row td:first-child { width: 35px !important; min-width: 35px !important; flex-shrink: 0 !important; text-align: center !important; }
            tr.board-row td.td-title { flex-grow: 1 !important; width: calc(100% - 35px) !important; padding-left: 10px !important; white-space: normal !important; word-break: break-word !important; line-height: 1.5 !important; }

            tr.post-detail { display: none; width: 100% !important; flex-direction: column !important; }
            tr.post-detail[style*="table-row"], tr.post-detail[style*="block"] { display: flex !important; }
            tr.post-detail td { width: 100% !important; padding: 20px 15px !important; }
        }

        /* 🚨 모바일 에디터 터치 및 키보드 미출력 완벽 해결 패치 🚨 */
        .ql-editor {
            -webkit-user-select: text !important; /* 🚀 여기를 text로 변경하여 키보드가 무조건 뜨게 만듭니다 */
            user-select: text !important;
            -webkit-touch-callout: default !important;
            touch-action: manipulation !important;
            cursor: text !important;
            min-height: 250px !important; 
            padding-bottom: 50px !important; 
        }
        
        .write-box { position: relative; z-index: 90; }

    /* ======================================================== */
        /* 🌟 [새로운 디자인] 프리미엄 피드(Feed)형 커뮤니티 카드 🌟 */
        /* ======================================================== */
        .feed-container { max-width: 650px; margin: 0 auto; display: flex; flex-direction: column; gap: 40px; }
        .feed-card { background: #161718; border: 1px solid #2a2b2d; border-radius: 16px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.3); }
        
        .feed-header { padding: 15px 20px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #1f2022; }
        .feed-author { font-weight: bold; color: #ffb300; font-size: 15px; }
        .feed-date { color: #666; font-size: 13px; }
        
        .feed-media { width: 100%; background: #000; display: flex; justify-content: center; align-items: center; }
        .feed-media img { width: 100%; max-height: 500px; object-fit: contain; }
        
        /* 유튜브 영상 비율(16:9) 완벽 유지기 */
        .video-container { position: relative; padding-bottom: 56.25%; height: 0; width: 100%; }
        .video-container iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
        
        .feed-body { padding: 20px; }
        .feed-title { font-size: 20px; margin: 0 0 15px 0; color: #fff; }
        .feed-content { color: #ccc; font-size: 15px; line-height: 1.6; margin-bottom: 20px; white-space: pre-wrap; }
        
        .feed-actions { display: flex; align-items: center; gap: 15px; padding-top: 15px; border-top: 1px solid #222; }
        .feed-btn { background: none; border: 1px solid #444; color: #ccc; padding: 8px 15px; border-radius: 20px; font-size: 14px; cursor: pointer; transition: 0.2s; }
        .feed-btn:hover { background: #222; border-color: #ffb300; color: #ffb300; }
        .admin-actions { margin-left: auto; display: flex; gap: 10px; }
        .text-btn { background: none; border: none; font-size: 13px; cursor: pointer; color: #888; }
        .text-btn:hover { color: #fff; }
        .text-btn.delete { color: #ff4a4a; }

     /* 🚨 모바일 글쓰기 버튼 투명 벽 뚫기 (정확한 이름표 조준 완료!) */
        .btn-write-toggle, #writeBox {
            position: relative !important;
            z-index: 99999 !important;
            pointer-events: auto !important;
        }

        /* 🚨 모바일 글쓰기 박스 내부 "모든 요소(*)" 강제 활성화 (초강력) */
    #writeBox * {
        pointer-events: auto !important; 
        user-select: text !important; /* 글자 선택/입력 무조건 허용 */
        -webkit-user-select: text !important; /* 아이폰 무조건 허용 */
        touch-action: manipulation !important; /* 터치 씹힘 방지 */
    }

    </style>
</head>
<body>
    <header class="main-header">
        <div class="header-top">
            <img src="/logo.png" alt="RANKING AI 로고" class="logo-img" onclick="window.location.href='/?sort=views'">
            
            <form action="/" method="GET" class="top-search-form">
                <div style="display: flex; align-items: center; justify-content: center; cursor: pointer; background: #fff; padding: 2px; border-radius: 4px; margin-right: 10px; box-shadow: 0 0 5px rgba(255,87,34,0.5); flex-shrink: 0;" 
                     title="클릭하면 크게 확대됩니다! 친구들에게 공유해보세요 🚀" 
                     onclick="window.open('https://api.qrserver.com/v1/create-qr-code/?size=500x500&data=https://rankingaimusic.com', '_blank')">
                    <img src="https://api.qrserver.com/v1/create-qr-code/?size=30x30&data=https://rankingaimusic.com" alt="QR Code" style="display: block; width: 24px; height: 24px;">
                </div>
                <input type="text" name="search" class="top-search-input" placeholder="<%= __('search_placeholder') || '아티스트 검색...' %>" value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false">
                <button type="submit" class="top-search-btn">🔍</button>
            </form>

            <div class="auth-buttons">
                <select id="smartLangSelect" onchange="window.location.href='/change-lang/' + this.value" class="lang-select">
                    <option value="ko" <%= typeof getLocale !== 'undefined' && getLocale() === 'ko' ? 'selected' : '' %>>🇰🇷 한국어</option>
                    <option value="en" <%= typeof getLocale !== 'undefined' && getLocale() === 'en' ? 'selected' : '' %>>🇺🇸 English</option>
                    <option value="ja" <%= typeof getLocale !== 'undefined' && getLocale() === 'ja' ? 'selected' : '' %>>🇯🇵 日本語</option>
                    <option value="zh" <%= typeof getLocale !== 'undefined' && getLocale() === 'zh' ? 'selected' : '' %>>🇨🇳 中文</option>
                </select>

                <% if (user && user.role === 'admin') { %>
                    <a href="/admin" class="btn-admin">👑 관리자</a>
                <% } %>
                
                <% if (user) { %>
                    <span style="color: #aaa; font-size: 14px;"><%= user.name || user.id %><%= __('welcome_user') || '님' %></span>
                    <a href="/logout" class="btn-login" style="margin-left: 15px;"><%= __('btn_logout') || '로그아웃' %></a>
                <% } else { %>
                    <a href="/login" class="btn-login"><%= __('btn_login') || '로그인' %></a>
                    <a href="/signup" class="btn-signup"><%= __('btn_signup') || '회원가입' %></a>
                <% } %>
            </div>
        </div>
        
        <div class="header-nav">
            <a href="/?sort=views" class="nav-item"><%= __('menu_chart') || 'RANKING AI 차트' %></a>
            <a href="/?sort=latest" class="nav-item"><%= __('menu_latest') || '최신음악' %></a>
            <a href="/?genre=발라드" class="nav-item"><%= __('menu_genre') || '장르별' %></a>
            <a href="/radio" class="nav-item" style="color: #ffb300; font-weight: 900;"><%= __('menu_bgm') || '🎧상황별BGM' %></a>
            <a href="/youtube" class="nav-item"><%= __('menu_youtube') || '유튜브' %></a>
            <a href="/shorts" class="nav-item"><%= __('menu_shorts') || '쇼츠' %></a>
            <a href="/board" class="nav-item active"><%= __('menu_community') || '커뮤니티' %></a>
        </div>
    </header>

    <div class="container">
        
        <div class="board-header">
            <h2 class="board-title"><%= __('board_title') || '커뮤니티' %> <span style="font-size: 14px; font-weight: normal; color: #777;"><%= __('board_desc') || '자유롭게 이야기를 나눠보세요!' %></span></h2>
            
            <% if (user) { %>
                <button class="btn-write-toggle" onclick="toggleWriteBox();" style="position: relative !important; z-index: 999999 !important; pointer-events: auto !important; touch-action: manipulation !important;">✍️ <%= __('btn_write') || '글쓰기' %></button>
            <% } else { %>
                <button class="btn-write-toggle" onclick="location.href='/login'" style="background:#444; color:#fff;"><%= __('btn_write_login') || '로그인 후 글쓰기' %></button>
            <% } %>
        </div>

       <% if (user) { %>

<div class="write-box" id="writeBox" style="display:none;">
    <form action="/add-post" method="POST" enctype="multipart/form-data">
        
        <input type="text" name="title" class="write-input" placeholder="제목을 입력하세요" required
               style="width: 100%; background: #1c1d20; border: 1px solid #444; color: #fff; padding: 18px 20px; border-radius: 10px; font-size: 18px; margin-bottom: 20px; outline: none;">
        
        <input type="hidden" name="content" id="hidden-content">

        <div id="editor-wrapper" style="background-color: #1c1d20; border-radius: 10px; border: 1px solid #444; overflow: hidden; margin-bottom: 25px;">
            <style>
                .ql-toolbar.ql-snow { border: none !important; border-bottom: 1px solid #444 !important; background: #222; padding: 12px; }
                .ql-snow .ql-stroke { stroke: #ccc !important; }
                .ql-snow .ql-fill { fill: #ccc !important; }
                .ql-snow .ql-picker { color: #ccc !important; }
                .ql-container.ql-snow { border: none !important; min-height: 400px; font-size: 16px; color: #fff; }
                .ql-editor { min-height: 400px; padding: 25px; line-height: 1.8; }
            </style>
            <div id="editor-container" style="min-height: 400px;"></div>
        </div>
        
        <!-- 🌟 [여기에 새로 추가되었습니다!] 유튜브 링크 입력칸 🌟 -->
        <div style="margin-bottom: 25px; background: #222; padding: 15px; border-radius: 8px; border: 1px solid #444;">
            <label style="color: #ff5722; font-size: 14px; font-weight: bold; margin-bottom: 10px; display: block;">🎥 유튜브 링크 첨부 (선택사항)</label>
            <input type="text" name="youtubeUrl" placeholder="예: https://youtu.be/... (공유 링크를 붙여넣으세요)" 
                   style="width: 100%; background: #1c1d20; border: 1px solid #444; color: #fff; padding: 12px; border-radius: 8px; font-size: 15px; outline: none; box-sizing: border-box;">
        </div>

        <div style="margin-bottom: 25px; background: #222; padding: 15px; border-radius: 8px; border: 1px dashed #ff5722;">
            <label style="color: #ff5722; font-size: 14px; font-weight: bold; margin-bottom: 10px; display: block;">📷 커버 이미지 첨부 (선택사항)</label>
            <input type="file" name="image" accept="image/*" style="color: #aaa; font-size: 14px; width: 100%;">
        </div>

        <button type="submit" class="btn-submit" style="width: 100%; background: #ff5722; color: #000; border: none; padding: 16px; border-radius: 10px; font-weight: bold; font-size: 18px; cursor: pointer;">
            ✏️ 커뮤니티에 글 등록하기
        </button>
    </form>
</div>
<% } %>

<!-- 🌟 깔끔한 리스트형 게시판 시작 🌟 -->
<div class="post-list">
    <% 
    // 유튜브 주소를 화면에 띄울 수 있는 Embed 주소로 바꿔주는 마법의 함수
    function getEmbedUrl(url) {
        if(!url) return null;
        const match = url.match(/(?:youtu\.be\/|youtube\.com\/(?:embed\/|v\/|watch\?v=|watch\?.+&v=))([^&?\n]+)/);
        return match ? "https://www.youtube.com/embed/" + match[1] : null;
    }
    %>

    <table class="board-table">
        <thead>
            <tr>
                <th style="width: 60px; text-align: center;">번호</th>
                <th style="width: auto; text-align: left;">제목</th>
            </tr>
        </thead>
        <tbody>
        <% if (typeof posts !== 'undefined' && posts.length > 0) { %>
            <% posts.forEach((post, index) => { %>
                <% const pageNum = Math.floor(index / 20) + 1; %>
                <% const embedUrl = getEmbedUrl(post.youtubeUrl); %>

                <!-- 1. 리스트 줄 (제목) : 클릭하면 아래 내용이 열립니다 -->
                <tr class="board-row page-<%= pageNum %>" 
                    style="<%= pageNum > 1 ? 'display: none;' : '' %>; cursor: pointer;"
                    onclick="const detail = document.getElementById('post-detail-<%= post._id %>'); detail.style.display = (detail.style.display === 'none' || detail.style.display === '') ? 'table-row' : 'none';">
                    
                    <td class="td-num" style="text-align: center; color: #666;"><%= posts.length - index %></td>
                    <td class="td-title" style="font-weight: 500;">
                        <%= post.title %>
                        <% if (post.imageUrl) { %> <span style="font-size: 12px; margin-left: 5px;">📷</span> <% } %>
                        <% if (embedUrl) { %> <span style="font-size: 12px; margin-left: 5px;">🎥</span> <% } %>
                        <span style="color: #ff5722; font-size: 12px; margin-left: 5px;">[<%= post.comments ? post.comments.length : 0 %>]</span>
                    </td>
                </tr>

                <!-- 2. 숨겨진 본문 내용 (클릭 시 등장) -->
                <tr id="post-detail-<%= post._id %>" class="post-detail page-<%= pageNum %>" style="display: none; background: #0e0e0f;">
                    <td colspan="2" style="padding: 30px 20px; text-align: left; border-bottom: 2px solid #ff5722;"> 
                        
                        <div class="post-info-bar" style="margin-bottom: 20px; padding-bottom: 15px; border-bottom: 1px solid #222; font-size: 14px; color: #aaa; display: flex; gap: 15px; flex-wrap: wrap;">
                            <span style="color: #ff5722; font-weight: bold;">@<%= post.author %></span>
                            <span>📅 <%= new Date(post.createdAt).toLocaleDateString() %></span>
                        </div>
                        
