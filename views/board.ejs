<script>
    // 🚀 페이지 로드 즉시 실행되는 기능 초기화
    function initCommunity() {
        console.log("커뮤니티 기능을 강제 활성화합니다.");
        
        // 1. 아코디언 상세 내용 초기 숨김 세팅
        document.querySelectorAll('.post-detail').forEach(detail => {
            detail.style.display = 'none';
        });

        // 2. 모바일에서 클릭이 먹통되는 현상 방지 (포인터 이벤트 강제 활성화)
        const writeBtn = document.querySelector('.btn-write, .btn-submit');
        if (writeBtn) writeBtn.style.pointerEvents = 'auto';
    }

    // 문서가 준비되면 즉시 실행
    document.addEventListener('DOMContentLoaded', initCommunity);

    // 캐시된 화면(뒤로가기 등)으로 올 때도 즉시 실행
    window.addEventListener('pageshow', function(event) {
        initCommunity(); // 디자인 초기화 함수 호출
        
        if (event.persisted || (window.performance && window.performance.navigation.type === 2)) {
            // 캐시가 너무 심할 경우에만 새로고침 수행
            window.location.reload(); 
        }
    });
</script>
    </div> <!-- .container -->
</body>
</html>