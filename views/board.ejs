<script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
    
<script>
  window.quill = null;

function toggleWriteBox() {
    const box = document.getElementById('writeBox');
    const wrapper = document.getElementById('editor-wrapper'); // 👈 아까 위에서 만든 상자를 찾습니다.
    
    if (box.style.display === 'block') {
        box.style.display = 'none';
        return;
    }
    
    // 1. 일단 박스를 눈에 보이게 엽니다.
    box.style.display = 'block'; 

    // 2. 0.2초만 기다렸다가 상자를 새로 짓고 에디터를 넣습니다.
    setTimeout(function() {
        if (typeof Quill === 'undefined') {
            alert("라이브러리 로딩 중입니다. 잠시 후 다시 눌러주세요!");
            return;
        }

        // 🧨 기존 찌꺼기 싹 비우고 도화지 새로 깔기
        if (wrapper) {
            wrapper.innerHTML = '<div id="editor-container" style="min-height: 400px;"></div>';
        }

        quill = new Quill('#editor-container', {
            theme: 'snow',
            placeholder: '내용을 입력하세요...',
            modules: {
                toolbar: [
                    [{ 'size': ['small', false, 'large', 'huge'] }],
                    ['bold', 'italic', 'underline', 'strike'],
                    [{ 'color': [] }, { 'background': [] }],
                    ['image', 'video', 'link'],
                    [{ 'list': 'ordered'}, { 'list': 'bullet' }]
                ]
            }
        });

        const writeForm = document.querySelector('form[action="/add-post"]');
        if (writeForm) {
            writeForm.onsubmit = function() {
                document.getElementById('hidden-content').value = quill.root.innerHTML;
            };
        }

        quill.focus();
        window.scrollBy({ top: 150, behavior: 'smooth' });
    }, 200); 
}

    // 🚀 이미지 자동 압축 엔진
    function compressAndInsertImage(file) {
        if (!file.type.match(/^image\/(jpeg|png|gif|webp)$/)) {
            alert('이미지 파일만 업로드 가능합니다.');
            return;
        }
        const reader = new FileReader();
        reader.onload = function(e) {
            const img = new Image();
            img.onload = function() {
                const canvas = document.createElement('canvas');
                let width = img.width;
                let height = img.height;
                const max_size = 1200;

                if (width > height) {
                    if (width > max_size) {
                        height *= max_size / width;
                        width = max_size;
                    }
                } else {
                    if (height > max_size) {
                        width *= max_size / height;
                        height = max_size;
                    }
                }

                canvas.width = width;
                canvas.height = height;
                const ctx = canvas.getContext('2d');
                ctx.drawImage(img, 0, 0, width, height);

                const compressedDataUrl = canvas.toDataURL('image/jpeg', 0.7);
                
                const range = quill.getSelection(true) || { index: quill.getLength() };
                quill.insertEmbed(range.index, 'image', compressedDataUrl);
                quill.setSelection(range.index + 1);
            };
            img.src = e.target.result;
        };
        reader.readAsDataURL(file);
    }

    function imageHandler() {
        const input = document.createElement('input');
        input.setAttribute('type', 'file');
        input.setAttribute('accept', 'image/*');
        input.click();
        input.onchange = async () => {
            const file = input.files[0];
            if (file) compressAndInsertImage(file);
        };
    }

// ==============================================================
// 🌟 실시간 댓글 달기 함수 (새로고침 방지)
// ==============================================================
async function submitComment(event, postId) {
    // 1. [매우 중요] 브라우저가 페이지를 새로고침하려는 본능을 강제로 막습니다.
    event.preventDefault(); 
    
    // 2. 어느 입력창에 글을 썼는지 찾아서 내용을 가져옵니다.
    const inputField = document.getElementById('comment-input-' + postId);
    const text = inputField.value;
    if (text.trim() === '') return;

    try {
        // 3. 1단계에서 만든 서버 주소로 몰래 데이터를 보냅니다.
        const response = await fetch('/add-board-comment/' + postId, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ commentText: text })
        });
        
        const data = await response.json();

        if (data.success) {
            // 4. 전송 성공 시 입력창을 깨끗이 비웁니다.
            inputField.value = '';

            // 5. 서버에서 받아온 정보를 바탕으로 화면에 즉시 댓글을 끼워 넣습니다.
            // (입력창 바로 위에 새 댓글을 추가하는 방식입니다)
            const newCommentHtml = `
                <div style="margin-bottom: 10px; font-size: 14px; animation: fadeIn 0.5s;">
                    <strong style="color: #ffb300;">@${data.comment.author}</strong>
                    <span style="color: #ccc; margin-left: 5px;">${data.comment.text}</span>
                </div>
            `;
            
            // 전송 버튼이 있는 폼(event.target) 바로 앞에 새 댓글을 추가합니다.
            event.target.insertAdjacentHTML('beforebegin', newCommentHtml);
            
        } else {
            alert(data.message);
        }
    } catch (err) {
        console.error("댓글 통신 에러:", err);
        alert("댓글 등록 중 문제가 발생했습니다.");
    }
}

// ==============================================================
// 🌟 댓글 수정, 삭제, 답글(대댓글) 기능 자바스크립트 모음
// ==============================================================

// ✏️ 댓글 수정 (AJAX)
async function editComment(postId, commentId, oldText) {
    // 1. 사용자에게 수정할 내용을 입력받습니다. (기본값으로 예전 댓글 내용이 뜹니다)
    const newText = prompt("댓글을 수정하세요:", oldText);
    
    // 2. 취소를 누르거나 내용이 그대로면 아무 작업도 하지 않습니다.
    if (!newText || newText.trim() === '' || newText === oldText) return;

    try {
        // 3. 서버 뒷문으로 수정해 달라고 요청을 보냅니다.
        const response = await fetch(`/edit-board-comment/${postId}/${commentId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ newText: newText })
        });
        
        const data = await response.json();
        
        // 4. 성공했다면 새로고침 없이 화면의 글자만 싹 바꿉니다.
        if (data.success) {
            document.getElementById('comment-text-' + commentId).innerText = newText;
        } else {
            alert(data.message || "수정에 실패했습니다.");
        }
    } catch (err) {
        console.error(err);
        alert("통신 에러가 발생했습니다.");
    }
}

// 🗑️ 댓글 삭제 (AJAX)
async function deleteComment(postId, commentId) {
    // 1. 진짜 지울 건지 한 번 더 물어봅니다.
    if (!confirm("정말 이 댓글을 삭제할까요?")) return;

    try {
        // 2. 서버에 삭제 요청을 보냅니다.
        const response = await fetch(`/delete-board-comment/${postId}/${commentId}`, {
            method: 'POST'
        });
        
        const data = await response.json();
        
        // 3. 성공했다면 화면을 깔끔하게 새로고침하여 지워진 상태를 보여줍니다.
        if (data.success) {
            alert("삭제되었습니다.");
            window.location.reload(); 
        } else {
            alert(data.message || "삭제 권한이 없습니다.");
        }
    } catch (err) {
        console.error(err);
        alert("통신 에러가 발생했습니다.");
    }
}

// ↪️ 답글(대댓글) 달기 (AJAX)
async function submitReply(event, postId, commentId) {
    // 1. 폼 전송 시 발생하는 화면 새로고침 깜빡임을 막습니다.
    event.preventDefault(); 
    
    // 2. 입력한 답글 내용을 가져옵니다.
    const inputField = document.getElementById('reply-input-' + commentId);
    const text = inputField.value;
    if (text.trim() === '') return;

    try {
        // 3. 서버에 답글을 저장해 달라고 보냅니다.
        const response = await fetch(`/add-board-reply/${postId}/${commentId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ replyText: text })
        });
        
        const data = await response.json();
        
        // 4. 성공했다면 화면을 새로고침하여 방금 단 답글을 보여줍니다.
        if (data.success) {
            window.location.reload(); 
        } else {
            alert(data.message || "답글 등록에 실패했습니다.");
        }
    } catch (err) {
        console.error(err);
        alert("통신 에러가 발생했습니다.");
    }
}

</script>

    <script>
        function changePage(targetPage) {
            document.querySelectorAll('.board-row').forEach(row => row.style.display = 'none');
            document.querySelectorAll('.post-detail').forEach(row => row.style.display = 'none');

            document.querySelectorAll('.board-row.page-' + targetPage).forEach(row => row.style.display = '');

            document.querySelectorAll('.page-btn').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');

            const boardTop = document.querySelector('.board-header').offsetTop;
            window.scrollTo({ top: boardTop - 80, behavior: 'smooth' });
        }

        async function likePost(postId) {
            try {
                const response = await fetch('/like-post/' + postId, { method: 'POST' });
                const data = await response.json();

                if (data.success) {
                    const countSpan = document.getElementById('like-post-count-' + postId);
                    const currentCount = parseInt(countSpan ? countSpan.innerText : '0');
                    const newCount = currentCount + 1;
                    
                    const btn = document.getElementById('like-post-btn-' + postId) || document.querySelector(`button[onclick*="${postId}"]`);
                    if(btn) {
                        btn.innerHTML = '❤️ <%= __('th_likes') || "좋아요" %> <span id="like-post-count-' + postId + '">' + newCount + '</span>';
                        btn.style.color = '#ff4a4a';
                    }
                } else {
                    alert(data.message);
                }
            } catch (err) {
                console.error("좋아요 에러:", err);
                alert("통신 중 에러가 발생했습니다.");
            }
        }
    </script>

