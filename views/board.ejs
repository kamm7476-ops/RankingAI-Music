<!DOCTYPE html>
<html lang="<%= typeof getLocale !== 'undefined' ? getLocale() : 'ko' %>">
<head>
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5112383847606285" crossorigin="anonymous"></script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= __('menu_community') || '커뮤니티' %> - RANKING AI</title>
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">

    <link rel="icon" href="/favicon.png" type="image/png">
    <style>
        /* 🌟 글로벌 기본 설정 */
        body { background: #0b0c0d; color: #fff; font-family: 'Pretendard', sans-serif; margin: 0; padding-bottom: 100px; }
        a { text-decoration: none; color: inherit; }
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #0b0c0d; }
        ::-webkit-scrollbar-thumb { background: #333; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #ff5722; }

        /* 🌟 상단바 디자인 (메인과 완벽히 동일) */
        .main-header { background: #121314; border-bottom: 1px solid #222; position: sticky; top: 0; z-index: 100; }
        .header-top { display: flex; justify-content: space-between; align-items: center; padding: 10px 15px; border-bottom: 1px solid #1a1b1c; gap: 10px; flex-wrap: nowrap; }
        .logo-img { height: 50px; max-width: 100%; cursor: pointer; object-fit: contain; flex-shrink: 0; }
        
        .top-search-form { display: flex; align-items: center; background: #222 !important; border: 2px solid #ff5722; border-radius: 25px; padding: 5px 12px; flex: 1; max-width: 400px; margin: 0; min-width: 0; }
        .top-search-input { background: transparent !important; border: none !important; color: white !important; outline: none; flex: 1; font-size: 14px; padding: 5px; min-width: 0; }
        .top-search-input::placeholder { color: #aaa; }
        .top-search-btn { background: none; border: none; color: #ff5722; font-weight: bold; cursor: pointer; font-size: 16px; padding: 0 10px; }

        .auth-buttons { display: flex; gap: 15px; align-items: center; flex-shrink: 0; }
        .lang-select { padding: 7px 14px; background: #222; color: #fff; border: 2px solid #ff5722; border-radius: 20px; font-weight: bold; font-size: 13px; outline: none; cursor: pointer; transition: 0.2s; }
        .lang-select:hover { background: #ff5722; color: #000; }
        .btn-admin { color: #ff4a4a; font-weight: bold; font-size: 14px; border: 1px solid #ff4a4a; padding: 5px 12px; border-radius: 15px; }
        .btn-login { color: #bbb; font-size: 14px; }
        .btn-signup { background: #ff5722; color: #000; padding: 8px 20px; border-radius: 20px; font-weight: bold; font-size: 14px; }

        /* 🌟 메뉴바 */
        .header-nav { display: flex; justify-content: center; gap: 40px; padding: 12px 0; background: #0b0c0d; }
        .nav-item { color: #aaa; font-weight: 600; font-size: 16px; transition: 0.2s; position: relative; }
        .nav-item:hover, .nav-item.active { color: #ff5722; }
        .nav-item.active::after { content: ''; position: absolute; bottom: -12px; left: 0; width: 100%; height: 3px; background: #ff5722; }

        /* 🌟 커뮤니티 기본 설정 */
        .container { max-width: 900px; margin: 0 auto; padding: 40px 20px; }
        .board-header { display: flex; justify-content: space-between; align-items: flex-end; border-bottom: 2px solid #222; padding-bottom: 15px; margin-bottom: 30px; }
        .board-title { font-size: 28px; font-weight: bold; margin: 0; display: flex; align-items: center; gap: 10px; }
        .btn-write-toggle { background: #ff5722; color: #000; border: none; padding: 10px 20px; border-radius: 8px; font-weight: bold; cursor: pointer; font-size: 14px; transition: 0.2s; }
        .btn-write-toggle:hover { filter: brightness(1.1); transform: translateY(-2px); box-shadow: 0 4px 10px rgba(255, 87, 34, 0.3); }

        /* 🌟 글쓰기 상자 */
        .write-box { background: #161718; padding: 25px; border-radius: 12px; border: 1px solid #333; margin-bottom: 40px; display: none; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        .write-box h3 { margin-top: 0; color: #ff5722; font-size: 18px; margin-bottom: 20px; }
        .write-input { width: 100%; background: #222; border: 1px solid #444; color: #fff; padding: 12px; border-radius: 8px; box-sizing: border-box; margin-bottom: 15px; font-family: inherit; font-size: 15px; transition: 0.2s; }
        .write-input:focus { outline: none; border-color: #ff5722; background: #1a1a1a; }
        .write-textarea { height: 150px; resize: vertical; }
        .btn-submit { width: 100%; background: #ff5722; color: #000; border: none; padding: 14px; border-radius: 8px; font-weight: bold; font-size: 16px; cursor: pointer; transition: 0.2s; }
        .btn-submit:hover { background: #ffb300; }

        /* 🌟 버튼 및 기능 요소 */
        .post-list { display: flex; flex-direction: column; gap: 20px; }
        .post-actions { display: flex; gap: 15px; align-items: center; border-top: 1px solid #222; padding-top: 15px; }
        .action-btn { background: none; border: none; color: #aaa; font-size: 13px; cursor: pointer; display: flex; align-items: center; gap: 5px; transition: 0.2s; padding: 0; }
        .action-btn:hover { color: #ff5722; }

        /* 🌟 PC 보배드림 스타일 테이블 (table-layout: fixed 추가!) */
        .board-table { width: 100%; table-layout: fixed; border-collapse: collapse; background: #161718; border-radius: 8px; overflow: hidden; margin-top: 15px; }
        .board-table thead { background: #222; color: #888; font-size: 14px; }
        .board-table th { padding: 15px 10px; border-bottom: 1px solid #333; font-weight: 500; }
        .board-table td { padding: 12px 10px; border-bottom: 1px solid #222; text-align: center; font-size: 14px; color: #ccc; }
        .board-row:hover { background: rgba(255, 87, 34, 0.05); cursor: pointer; }
        .td-title { text-align: left !important; padding-left: 20px !important; color: #fff; font-size: 15px; word-break: break-word; white-space: normal; line-height: 1.4; }

        /* 🌟 커뮤니티 본문 가독성 최적화 */
        .post-content { white-space: pre-wrap !important; }
        .post-content p { margin-bottom: 20px !important; margin-top: 0; }
        .post-content img { max-width: 100%; border-radius: 8px; margin: 15px 0; }

        /* 🌟 하단 페이지 번호 (페이징) 디자인 */
        .pagination-container { text-align: center; margin-top: 40px; padding-bottom: 20px; }
        .page-btn { background: #222; color: #aaa; border: 1px solid #333; padding: 8px 14px; margin: 0 4px; border-radius: 6px; cursor: pointer; font-size: 14px; transition: 0.2s; }
        .page-btn:hover { background: #333; color: #fff; }
        .page-btn.active { background: #ff5722; color: #000; font-weight: bold; border-color: #ff5722; pointer-events: none; }

      /* 📱 모바일 커뮤니티 (대표님 아이디어 적용: 제목만 깔끔하게!) */
        @media (max-width: 768px) {
            .board-table, .board-table tbody, .board-row, .board-table td {
                display: block !important; width: 100% !important; box-sizing: border-box !important;
            }
            .board-table thead { display: none !important; }
            
            .board-row { padding: 15px !important; border-bottom: 1px solid #222 !important; text-align: left; }
            
            /* 🔥 핵심: '제목' 빼고 나머지(번호, 글쓴이, 날짜, 댓글, 좋아요) 전부 숨김! */
            .board-row td:not(.td-title) { display: none !important; }
            
            /* 제목은 화면 100%를 독식! (절대 세로로 깨지지 않음) */
            .board-row .td-title {
                display: block !important;
                width: 100% !important;
                padding: 5px 0 !important;
                font-size: 16px !important;
                font-weight: bold !important;
                color: #fff !important;
                white-space: normal !important;
                word-break: break-all !important;
                border: none !important;
            }

            /* 본문 열렸을 때 화면 방어 */
            .post-detail { display: none; width: 100%; box-sizing: border-box; }
            .post-detail[style*="table-row"] { display: block !important; }
            .post-detail td { display: block !important; padding: 20px 15px !important; width: 100%; box-sizing: border-box; }

            /* 본문 안에서 글쓴이/날짜를 보여주는 전용 박스 등장 */
            .mobile-author-info { display: block !important; }
            
            .ql-container { height: 250px !important; }
        }
    </style>
</head>
<body>
    <header class="main-header">
        <div class="header-top">
            <img src="/logo.png" alt="RANKING AI 로고" class="logo-img" onclick="window.location.href='/?sort=views'">
            
            <form action="/" method="GET" class="top-search-form">
                <div style="display: flex; align-items: center; justify-content: center; cursor: pointer; background: #fff; padding: 2px; border-radius: 4px; margin-right: 10px; box-shadow: 0 0 5px rgba(255,87,34,0.5); flex-shrink: 0;" 
                     title="클릭하면 크게 확대됩니다! 친구들에게 공유해보세요 🚀" 
                     onclick="window.open('https://api.qrserver.com/v1/create-qr-code/?size=500x500&data=https://rankingaimusic.com', '_blank')">
                    <img src="https://api.qrserver.com/v1/create-qr-code/?size=30x30&data=https://rankingaimusic.com" alt="QR Code" style="display: block; width: 24px; height: 24px;">
                </div>
                <input type="text" name="search" class="top-search-input" placeholder="<%= __('search_placeholder') || '아티스트 검색...' %>" value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false">
                <button type="submit" class="top-search-btn">🔍</button>
            </form>

            <div class="auth-buttons">
                <select id="smartLangSelect" onchange="window.location.href='/change-lang/' + this.value" class="lang-select">
                    <option value="ko" <%= typeof getLocale !== 'undefined' && getLocale() === 'ko' ? 'selected' : '' %>>🇰🇷 한국어</option>
                    <option value="en" <%= typeof getLocale !== 'undefined' && getLocale() === 'en' ? 'selected' : '' %>>🇺🇸 English</option>
                    <option value="ja" <%= typeof getLocale !== 'undefined' && getLocale() === 'ja' ? 'selected' : '' %>>🇯🇵 日本語</option>
                    <option value="zh" <%= typeof getLocale !== 'undefined' && getLocale() === 'zh' ? 'selected' : '' %>>🇨🇳 中文</option>
                </select>

                <% if (user && user.role === 'admin') { %>
                    <a href="/admin" class="btn-admin">👑 관리자</a>
                <% } %>
                
                <% if (user) { %>
                    <span style="color: #aaa; font-size: 14px;"><%= user.name || user.id %><%= __('welcome_user') || '님' %></span>
                    <a href="/logout" class="btn-login" style="margin-left: 15px;"><%= __('btn_logout') || '로그아웃' %></a>
                <% } else { %>
                    <a href="/login" class="btn-login"><%= __('btn_login') || '로그인' %></a>
                    <a href="/signup" class="btn-signup"><%= __('btn_signup') || '회원가입' %></a>
                <% } %>
            </div>
        </div>
        
        <div class="header-nav">
            <a href="/?sort=views" class="nav-item"><%= __('menu_chart') || 'RANKING AI 차트' %></a>
            <a href="/?sort=latest" class="nav-item"><%= __('menu_latest') || '최신음악' %></a>
            <a href="/?genre=발라드" class="nav-item"><%= __('menu_genre') || '장르별' %></a>
            <a href="/radio" class="nav-item" style="color: #ffb300; font-weight: 900;"><%= __('menu_bgm') || '🎧상황별BGM' %></a>
            <a href="/youtube" class="nav-item"><%= __('menu_youtube') || '유튜브' %></a>
            <a href="/shorts" class="nav-item"><%= __('menu_shorts') || '쇼츠' %></a>
            <a href="/board" class="nav-item active"><%= __('menu_community') || '커뮤니티' %></a>
        </div>
    </header>

    <div class="container">
        
        <div class="board-header">
            <h2 class="board-title"><%= __('board_title') || '커뮤니티' %> <span style="font-size: 14px; font-weight: normal; color: #777;"><%= __('board_desc') || '자유롭게 이야기를 나눠보세요!' %></span></h2>
            
            <% if (user) { %>
                <button class="btn-write-toggle" onclick="const box = document.getElementById('writeBox'); box.style.display = (box.style.display === 'block') ? 'none' : 'block'; window.scrollBy({ top: 100, behavior: 'smooth' });">✍️ <%= __('btn_write') || '글쓰기' %></button>
            <% } else { %>
                <button class="btn-write-toggle" onclick="location.href='/login'" style="background:#444; color:#fff;"><%= __('btn_write_login') || '로그인 후 글쓰기' %></button>
            <% } %>
        </div>

        <% if (user) { %>
        <div class="write-box" id="writeBox">
            <h3><%= __('board_write_new') || '새로운 글 작성하기' %></h3>
            <form action="/add-post" method="POST" enctype="multipart/form-data">
                <input type="text" name="title" class="write-input" placeholder="<%= __('ph_post_title') || '제목을 입력하세요.' %>" required>
                <input type="hidden" name="content" id="hidden-content">

                <div style="background: white; border-radius: 8px; margin-bottom: 15px;">
                    <div id="editor-container" style="height: 600px; color: black; font-family: 'Pretendard', sans-serif; font-size: 15px;"></div>
                </div>
                
                <div style="margin-bottom: 20px; background: #222; padding: 12px; border-radius: 8px; border: 1px dashed #555;">
                    <label style="color: #ff5722; font-size: 13px; font-weight: bold; margin-bottom: 8px; display: block;">📷 <%= __('upload_cover') || '이미지 첨부 (선택사항)' %></label>
                    <input type="file" name="image" accept="image/*" style="color: #aaa; font-size: 14px; width: 100%; cursor: pointer;">
                </div>

                <button type="submit" class="btn-submit"><%= __('btn_submit_chart') || '게시글 등록하기' %></button>
            </form>
        </div>
        <% } %>

        <div class="post-list">
            <table class="board-table">
    <thead>
        <tr>
            <th style="width: 60px; text-align: center;"><%= __('th_num') || '번호' %></th>
            <th style="width: auto; text-align: left;"><%= __('th_title') || '제목' %></th>
            <th style="width: 100px; text-align: center;"><%= __('th_author') || '글쓴이' %></th>
            <th style="width: 100px; text-align: center;"><%= __('th_date') || '날짜' %></th>
            <th style="width: 60px; text-align: center;"><%= __('th_comments') || '댓글' %></th>
            <th style="width: 60px; text-align: center;"><%= __('th_likes') || '좋아요' %></th>
        </tr>
    </thead>
    <tbody>
    <% if (typeof posts !== 'undefined' && posts.length > 0) { %>
        <% posts.forEach((post, index) => { %>
            <% const pageNum = Math.floor(index / 100) + 1; %>

            <tr class="board-row page-<%= pageNum %>" 
                style="<%= pageNum > 1 ? 'display: none;' : '' %>"
                onclick="const detail = document.getElementById('post-detail-<%= post._id %>'); detail.style.display = (detail.style.display === 'none' || detail.style.display === '') ? 'table-row' : 'none';">
                
                <td><%= posts.length - index %></td>
                <td class="td-title">
                    <%= post.title %>
                    <% if (post.imageUrl) { %> <span style="font-size: 12px; margin-left: 5px;">📷</span> <% } %>
                </td>
                <td style="color: #aaa;">@<%= post.author %></td>
                <td style="font-size: 13px;"><%= new Date(post.createdAt).toLocaleDateString() %></td>
                
                <td style="color: #00e5ff; font-weight: bold;"><%= post.comments ? post.comments.length : 0 %></td>
                
                <td style="color: #ff5722;"><%= post.likes || 0 %></td>
            </tr>

           <tr id="post-detail-<%= post._id %>" class="post-detail page-<%= pageNum %>" style="display: none; background: #0e0e0f;">
    <td colspan="6" style="padding: 35px; text-align: left; border-bottom: 2px solid #ff5722;"> 
        
        <div class="mobile-author-info" style="display: none; margin-bottom: 15px; padding-bottom: 15px; border-bottom: 1px solid #333; font-size: 13px; color: #aaa;">
            <span style="color: #ff5722; font-weight: bold; margin-right: 10px;">@<%= post.author %></span>
            <span><%= new Date(post.createdAt).toLocaleDateString() %></span>
        </div>
        
        <div class="post-content" style="white-space: pre-wrap; line-height: 1.9; word-break: keep-all; color: #e5e5e5; margin-top: 0; font-size: 15px; letter-spacing: -0.4px;">
            <%- post.content %>
        </div>
        
        <% if (post.imageUrl) { %>
            <div style="margin-bottom: 20px; text-align: center; margin-top: 20px;">
                <img src="<%= post.imageUrl %>" alt="게시글 이미지" style="max-width: 100%; max-height: 500px; border-radius: 12px; border: 1px solid #333; box-shadow: 0 5px 15px rgba(0,0,0,0.3);">
            </div>
        <% } %>
                    <div class="post-actions" style="display: flex; gap: 15px; align-items: center; border-top: 1px solid #222; padding-top: 15px; margin-top: 15px;">
                        <% let isPostLiked = (user && post.likedBy && post.likedBy.includes(user.id)); %>
                        <button class="action-btn" id="like-post-btn-<%= post._id %>" onclick="event.stopPropagation(); likePost('<%= post._id %>')" style="<%= isPostLiked ? 'color:#ff4a4a;' : '' %> background:none; border:none; cursor:pointer;">
                            <%= isPostLiked ? '❤️' : '🤍' %> <%= __('th_likes') || '좋아요' %> <span id="like-post-count-<%= post._id %>"><%= post.likes || 0 %></span>
                        </button>
                        
                        <button class="action-btn" onclick="event.stopPropagation(); const box = document.getElementById('board-comments-<%= post._id %>'); box.style.display = (box.style.display === 'block') ? 'none' : 'block';" style="background:none; border:none; color:#aaa; cursor:pointer;">
                            💬 <%= __('th_comments') || '댓글' %> <%= post.comments ? post.comments.length : 0 %>
                        </button>
                        
                        <% if (user && (user.id === post.author || user.role === 'admin')) { %>
                            <div style="display: flex; gap: 10px; margin-left: auto;">
                                <button onclick="event.stopPropagation(); location.href='/edit-post/<%= post._id %>'" style="color: #00e5ff; background: none; border: none; cursor: pointer;">✏️ <%= __('action_edit') || '수정' %></button>
                                <form action="/delete-post/<%= post._id %>" method="POST" style="margin: 0;" onsubmit="return confirm('<%= __('yt_confirm_delete') || '정말 삭제할까요?' %>');">
                                    <button type="submit" style="color: #ff4a4a; background: none; border: none; cursor: pointer;">🗑 <%= __('action_delete') || '삭제' %></button>
                                </form>
                            </div>
                        <% } %>
                    </div>

                    <div id="board-comments-<%= post._id %>" style="display: none; background: #111; padding: 15px; border-radius: 8px; margin-top: 15px; border: 1px solid #222;">
                        <p style="font-size:12px; color:#555;"><%= __('board_comment_info') || '댓글 목록 및 작성창은 기존과 동일하게 작동합니다.' %></p>
                    </div>
                </td>
            </tr>
        <% }) %>
    <% } else { %>
        <tr><td colspan="6" style="padding: 80px 0; color:#555; text-align:center;"><%= __('board_no_post') || '등록된 게시글이 없습니다.' %></td></tr>
    <% } %>
    </tbody>
</table>
        </div>

        <% if (typeof posts !== 'undefined' && posts.length > 100) { %>
            <div class="pagination-container">
                <% const totalPages = Math.ceil(posts.length / 100); %>
                <% for(let i=1; i<=totalPages; i++) { %>
                    <button class="page-btn <%= i === 1 ? 'active' : '' %>" onclick="changePage(<%= i %>)"><%= i %></button>
                <% } %>
            </div>
        <% } %>

    </div>

<script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
    <script>
        var quill = new Quill('#editor-container', {
            theme: 'snow',
            placeholder: '<%= __('ph_editor_content') || "여기에 내용을 입력하세요. (사진도 드래그해서 넣을 수 있습니다!)" %>',
            modules: {
                toolbar: [
                    [{ 'size': ['small', false, 'large', 'huge'] }],
                    ['bold', 'italic', 'underline', 'strike'],
                    [{ 'color': [] }, { 'background': [] }],
                    ['image', 'video', 'link'],
                    [{ 'list': 'ordered'}, { 'list': 'bullet' }]
                ]
            }
        });

        const writeForm = document.querySelector('form[action="/add-post"]');
        if(writeForm) {
            writeForm.addEventListener('submit', function(e) {
                document.getElementById('hidden-content').value = quill.root.innerHTML;
            });
        }
    </script>

    <script>
        function changePage(targetPage) {
            document.querySelectorAll('.board-row').forEach(row => row.style.display = 'none');
            document.querySelectorAll('.post-detail').forEach(row => row.style.display = 'none');

            document.querySelectorAll('.board-row.page-' + targetPage).forEach(row => row.style.display = 'table-row');

            document.querySelectorAll('.page-btn').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');

            const boardTop = document.querySelector('.board-header').offsetTop;
            window.scrollTo({ top: boardTop - 80, behavior: 'smooth' });
        }

        async function likePost(postId) {
            try {
                const response = await fetch('/like-post/' + postId, { method: 'POST' });
                const data = await response.json();

                if (data.success) {
                    const countSpan = document.getElementById('like-post-count-' + postId);
                    const currentCount = parseInt(countSpan ? countSpan.innerText : '0');
                    const newCount = currentCount + 1;
                    
                    const btn = document.getElementById('like-post-btn-' + postId);
                    btn.innerHTML = '❤️ <%= __('th_likes') || "좋아요" %> <span id="like-post-count-' + postId + '">' + newCount + '</span>';
                    btn.style.color = '#ff4a4a';
                } else {
                    alert(data.message);
                }
            } catch (err) {
                console.error("좋아요 에러:", err);
                alert("통신 중 에러가 발생했습니다.");
            }
        }
    </script>

