<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>회원가입 - RANKING AI</title>
    <style>
        /* 🌟 모바일 가로 삐져나옴 완벽 방어 마법 🌟 */
        * { box-sizing: border-box; }
        html, body { max-width: 100%; overflow-x: hidden; }

        body { 
            background: #0b0c0d; color: #fff; font-family: 'Pretendard', sans-serif; 
            display: flex; justify-content: center; align-items: center; 
            min-height: 100vh; margin: 0; padding: 40px 20px; 
        }
        .signup-box { 
            background: #161718; padding: 40px 25px; border-radius: 15px; 
            border: 1px solid #333; box-shadow: 0 10px 30px rgba(0,0,0,0.8); 
            width: 100%; max-width: 450px; text-align: center; 
        }
        
        .logo { margin-bottom: 30px; width: 100%; }
        .logo img {
            max-width: 100%; /* 🌟 절대 상자 밖으로 못 나가게 가둠! */
            height: auto;
            max-height: 55px; 
            cursor: pointer;
            object-fit: contain;
            transition: transform 0.2s ease;
        }
        .logo img:hover { transform: scale(1.05); }

        .input-group { margin-bottom: 20px; text-align: left; width: 100%; }
        .input-group label { display: block; margin-bottom: 8px; font-size: 13px; color: #aaa; font-weight: bold; }
        .input-group input[type="text"], .input-group input[type="password"], .input-group input[type="email"] { 
            width: 100%; padding: 14px; background: #222; border: 1px solid #444; 
            border-radius: 8px; color: #fff; 
            font-size: 15px; outline: none; transition: 0.3s; 
        }
        .input-group input:focus { border-color: #ff5722; box-shadow: 0 0 10px rgba(255, 87, 34, 0.2); }
        
        /* 이메일 인증 버튼 스타일 */
        .btn-verify {
            background: #333; color: #fff; border: 1px solid #555; 
            border-radius: 8px; padding: 0 15px; font-size: 13px; font-weight: bold; 
            cursor: pointer; transition: 0.2s; white-space: nowrap;
        }
        .btn-verify:hover { background: #444; border-color: #ff5722; color: #ff5722; }
        .btn-verify-check {
            background: #ff5722; color: #000; border: none; 
            border-radius: 8px; padding: 0 15px; font-size: 13px; font-weight: bold; 
            cursor: pointer; transition: 0.2s; white-space: nowrap;
        }
        .btn-verify-check:hover { background: #ffb300; }

        /* 약관 박스 스타일 (기존 코드 유지) */
        .terms-container { margin-bottom: 25px; text-align: left; width: 100%; }
        .terms-container label.title { display: block; margin-bottom: 8px; font-size: 13px; color: #ff5722; font-weight: bold; }
        .terms-box {
            background: #1a1c1e; border: 1px solid #444; padding: 15px; 
            border-radius: 8px; font-size: 12px; color: #bbb; 
            height: 140px; overflow-y: auto; line-height: 1.6;
            margin-bottom: 12px; width: 100%;
        }
        .checkbox-group { display: flex; align-items: center; gap: 8px; margin-left: 5px; margin-top: 10px; }
        .checkbox-group input { width: 18px; height: 18px; accent-color: #ff5722; cursor: pointer; flex-shrink: 0; }
        .checkbox-group label { font-size: 13px; color: #ddd; cursor: pointer; font-weight: bold;}

        .btn-submit { 
            width: 100%; padding: 14px; background: #ff5722; color: #000; 
            border: none; border-radius: 8px; font-size: 16px; font-weight: bold; 
            cursor: pointer; transition: 0.3s; margin-top: 10px; 
        }
        .btn-submit:hover { background: #ffb300; transform: translateY(-2px); }
        .extra-links { margin-top: 25px; font-size: 13px; color: #777; }
        .extra-links a { color: #aaa; text-decoration: none; transition: 0.2s; font-weight: bold; }
        .extra-links a:hover { color: #ff5722; text-decoration: underline; }
        
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #111; border-radius: 4px; }
        ::-webkit-scrollbar-thumb { background: #444; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #ff5722; }
    </style>
</head>
<body>
    <div class="signup-box">
        <div class="logo">
            <img src="/logo.png" alt="RANKING AI 로고" onclick="window.location.href='/?sort=views'">
        </div>
        
        <form action="/signup" method="POST" id="signupForm" onsubmit="return validateForm()">
            <div class="input-group">
                <label>아이디</label>
                <input type="text" name="username" placeholder="사용할 아이디를 입력하세요" required>
            </div>
            <div class="input-group">
                <label>비밀번호</label>
                <input type="password" name="password" placeholder="비밀번호를 입력하세요" required>
            </div>
            <div class="input-group">
                <label>비밀번호 확인</label>
                <input type="password" name="pw_confirm" placeholder="비밀번호를 다시 입력하세요" required>
            </div>
            <div class="input-group">
                <label>아티스트명 (닉네임)</label>
                <input type="text" name="nickname" placeholder="활동하실 멋진 이름을 입력하세요" required autocomplete="off" maxlength="15">
            </div>

            <div class="input-group">
                <label>이메일 인증</label>
                <div style="display: flex; gap: 10px; width: 100%;">
                    <input type="email" id="emailInput" name="email" placeholder="이메일 주소" required style="flex: 1; min-width: 0;">
                    <button type="button" id="btnSendCode" class="btn-verify" onclick="sendVerificationEmail()">인증번호 발송</button>
                </div>
            </div>
            
            <div class="input-group" id="verifyGroup" style="display: none; width: 100%;">
                <label style="color: #ffb300;">인증번호 입력</label>
                <div style="display: flex; gap: 10px; width: 100%;">
                    <input type="text" id="verifyCodeInput" placeholder="인증번호 6자리" style="flex: 1; min-width: 0;">
                    <button type="button" id="btnVerifyCode" class="btn-verify-check" onclick="checkVerificationCode()">인증 확인</button>
                </div>
            </div>

            <label style="display: flex; align-items: flex-start; gap: 10px; margin: 20px 0; color: #ccc; font-size: 13px; cursor: pointer; background: #222; padding: 15px; border-radius: 8px; border: 1px solid #444;">
                <input type="checkbox" id="agreeTerms" name="agreeTerms" required style="margin-top: 3px; accent-color: #ff5722; width: 18px; height: 18px; cursor: pointer;">
                <span style="line-height: 1.5;">
                    RANKING AI의 <a href="/terms" target="_blank" style="color: #ff5722; font-weight: bold; text-decoration: underline;">이용 및 음원 거래 약관</a>을 모두 읽었으며, 이에 동의합니다. (필수)
                </span>
            </label>

            <button type="submit" class="btn-submit">회원가입 완료</button>
        </form>

        <div style="display: flex; align-items: center; margin-top: 25px; margin-bottom: 20px;">
            <div style="flex-grow: 1; height: 1px; background: #333;"></div>
            <span style="padding: 0 10px; color: #777; font-size: 12px;">또는 1초 만에 시작하기</span>
            <div style="flex-grow: 1; height: 1px; background: #333;"></div>
        </div>

        <button type="button" onclick="window.location.href='/auth/naver'" style="width:100%; background:#03C75A; color:#fff; border:none; padding:14px; border-radius:8px; font-weight:bold; font-size:15px; cursor:pointer; margin-bottom: 10px; display: flex; justify-content: center; align-items: center; gap: 8px;">
            <strong style="font-size: 18px;">N</strong> 네이버로 시작하기
        </button>

        <button type="button" onclick="window.location.href='/auth/google'" style="width:100%; background:#ffffff; color:#000; border:none; padding:14px; border-radius:8px; font-weight:bold; font-size:15px; cursor:pointer; margin-bottom: 10px; display: flex; justify-content: center; align-items: center; gap: 8px;">
            <strong style="font-size: 18px; color: #EA4335;">G</strong> 구글로 시작하기
        </button>

        <div class="extra-links">
            이미 계정이 있으신가요? <a href="/login">로그인하기</a><br><br>
            <a href="/">← 메인 화면으로 돌아가기</a>
        </div>
    </div>

    <script>
        let isEmailVerified = false; 

        async function sendVerificationEmail() {
            const email = document.getElementById('emailInput').value;
            if (!email) return alert("이메일 주소를 먼저 입력해주세요!");
            
            const btn = document.getElementById('btnSendCode');
            btn.innerText = "발송 중...";
            btn.disabled = true;

            try {
                const response = await fetch('/send-verification', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: email })
                });
                const data = await response.json();
                
                if (data.success) {
                    alert("인증번호가 발송되었습니다. 메일함을 확인해주세요!");
                    document.getElementById('verifyGroup').style.display = 'block'; 
                    btn.innerText = "재발송";
                } else {
                    alert(data.message || "발송에 실패했습니다.");
                    btn.innerText = "인증번호 발송";
                }
            } catch (error) {
                alert("서버 오류가 발생했습니다.");
                btn.innerText = "인증번호 발송";
            }
            btn.disabled = false;
        }

        async function checkVerificationCode() {
            const email = document.getElementById('emailInput').value;
            const code = document.getElementById('verifyCodeInput').value;
            if (!code) return alert("인증번호를 입력해주세요!");

            try {
                const response = await fetch('/verify-code', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: email, code: code })
                });
                const data = await response.json();

                if (data.success) {
                    isEmailVerified = true;
                    alert("이메일 인증이 완료되었습니다!");
                    
                    document.getElementById('verifyCodeInput').disabled = true;
                    document.getElementById('emailInput').readOnly = true;
                    document.getElementById('btnSendCode').style.display = 'none';
                    const verifyBtn = document.getElementById('btnVerifyCode');
                    verifyBtn.innerText = "인증 완료 ✅";
                    verifyBtn.style.background = "#03C75A";
                    verifyBtn.style.color = "#fff";
                    verifyBtn.disabled = true;
                } else {
                    alert("인증번호가 틀렸습니다. 다시 확인해주세요.");
                }
            } catch (error) {
                alert("서버 오류가 발생했습니다.");
            }
        }

        function validateForm() {
            if (!isEmailVerified) {
                alert("이메일 인증을 완료하셔야 가입할 수 있습니다.");
                return false; 
            }
            const agreeChecked = document.getElementById('agreeTerms').checked;
            if (!agreeChecked) {
                alert("이용약관에 동의하셔야 회원가입이 가능합니다.");
                return false;
            }
            return true; 
        }
    </script>
</body>
</html>
