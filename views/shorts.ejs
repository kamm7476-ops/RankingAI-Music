<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>쇼츠 모아보기 - RANKING AI</title>
    <style>
        body { background: #000; color: #fff; font-family: 'Pretendard', sans-serif; margin: 0; overflow: hidden; }
        a { text-decoration: none; color: inherit; }

        /* 🌟 상단 네비게이션 (투명하게 띄움) 🌟 */
        .main-header { 
            position: fixed; top: 0; width: 100%; z-index: 1000; 
            background: linear-gradient(to bottom, rgba(0,0,0,0.9), rgba(0,0,0,0)); 
            padding-bottom: 20px;
        }
        .header-top { display: flex; justify-content: space-between; align-items: center; padding: 15px 20px; }
        .logo { font-size: 24px; font-weight: 900; color: #ff5722; letter-spacing: -1px; text-shadow: 2px 2px 4px rgba(0,0,0,0.8); } 
        .auth-buttons { display: flex; gap: 15px; align-items: center; }
        .btn-login { color: #fff; font-size: 14px; text-shadow: 1px 1px 2px #000; }
        .btn-signup { background: #ff5722; color: #000; padding: 6px 15px; border-radius: 20px; font-weight: bold; font-size: 13px; }
        
        .header-nav { display: flex; justify-content: center; gap: 30px; padding-top: 5px; }
        .nav-item { color: #ccc; font-weight: bold; font-size: 15px; text-shadow: 1px 1px 2px #000; transition: 0.2s; }
        .nav-item.active { color: #fff; border-bottom: 2px solid #ff5722; padding-bottom: 3px; }

        /* 🌟 쇼츠 등록창 (토글형) 🌟 */
        .upload-section {
            position: fixed; top: 100px; left: 50%; transform: translateX(-50%);
            background: rgba(20, 20, 20, 0.95); padding: 20px; border-radius: 15px; 
            border: 1px solid #ff5722; z-index: 999; width: 90%; max-width: 400px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.8); display: none; backdrop-filter: blur(10px);
        }
        .upload-section.active { display: block; }
        .input-row { display: flex; flex-direction: column; gap: 10px; margin-bottom: 10px; }
        .input-row input { background: #222; border: 1px solid #444; color: #fff; padding: 12px; border-radius: 8px; font-size: 14px; outline: none; }
        .input-row input:focus { border-color: #ff5722; }
        .btn-upload { background: #ff5722; color: #000; border: none; padding: 12px; border-radius: 8px; font-weight: bold; width: 100%; cursor: pointer; }
        .btn-toggle-upload {
            position: fixed; bottom: 30px; right: 20px; z-index: 1000;
            background: #ff5722; color: #000; width: 50px; height: 50px; border-radius: 50%;
            display: flex; justify-content: center; align-items: center; font-size: 24px;
            box-shadow: 0 5px 15px rgba(255,87,34,0.4); cursor: pointer; border: none;
        }

        /* 🌟 틱톡/쇼츠 핵심: 스냅 스크롤 컨테이너 🌟 */
        .shorts-container {
            height: 100vh;
            width: 100%;
            max-width: 450px; /* PC에서는 폰처럼 보이게 */
            margin: 0 auto;
            overflow-y: scroll;
            scroll-snap-type: y mandatory; /* 위아래 자석 스크롤! */
            background: #111;
            /* 스크롤바 숨기기 */
            -ms-overflow-style: none; scrollbar-width: none;
        }
        .shorts-container::-webkit-scrollbar { display: none; }

        /* 🌟 개별 쇼츠 화면 (100vh 꽉 채움) 🌟 */
        .short-item {
            height: 100vh;
            width: 100%;
            scroll-snap-align: start; /* 화면 끝에 딱 맞춤 */
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
            background: #000;
        }

        .video-wrapper {
            position: relative;
            width: 100%;
            height: 100%; /* 9:16 비율 고정 없이 화면을 꽉 채움 (유튜브가 알아서 레터박스 처리) */
        }
        .video-wrapper iframe {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none;
            pointer-events: auto;
        }

        /* 🌟 정보 오버레이 (제목, 삭제 버튼 등) 🌟 */
        .short-info {
            position: absolute;
            bottom: 40px;
            left: 20px;
            right: 80px;
            z-index: 10;
            pointer-events: none;
        }
        .short-title {
            font-size: 16px; font-weight: bold; color: #fff; margin: 0 0 10px 0;
            text-shadow: 1px 1px 3px rgba(0,0,0,0.8);
            display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
        }
        .uploader-name {
            font-size: 13px; color: #ddd; margin-bottom: 15px; text-shadow: 1px 1px 2px rgba(0,0,0,0.8);
        }
        
        .side-menu {
            position: absolute; bottom: 40px; right: 15px; z-index: 10;
            display: flex; flex-direction: column; gap: 20px; align-items: center;
        }
        .btn-delete { 
            background: rgba(0,0,0,0.6); color: #fff; border: 1px solid #ff4a4a; 
            width: 45px; height: 45px; border-radius: 50%; font-size: 12px; font-weight: bold; 
            cursor: pointer; display: flex; flex-direction: column; justify-content: center; align-items: center;
            pointer-events: auto; backdrop-filter: blur(5px);
        }
        
        .scroll-hint {
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
            color: rgba(255,255,255,0.8); font-size: 40px; pointer-events: none;
            animation: swipeUp 2s infinite; z-index: 5;
        }
        @keyframes swipeUp {
            0% { opacity: 0; transform: translate(-50%, 20px); }
            50% { opacity: 1; transform: translate(-50%, -20px); }
            100% { opacity: 0; transform: translate(-50%, -40px); }
        }

    </style>
</head>
<body>
    <header class="main-header">
        <div class="header-top">
            <div class="logo" style="cursor:pointer;" onclick="window.location.href='/?sort=views'">RANKING AI</div>
            <div class="auth-buttons">
                <% if (user) { %>
                    <span class="btn-login"><%= user.name || user.id %>님</span>
                    <a href="/logout" class="btn-login" style="font-size: 12px; opacity: 0.8;">로그아웃</a>
                <% } else { %>
                    <a href="/login" class="btn-login">로그인</a>
                    <a href="/signup" class="btn-signup">회원가입</a>
                <% } %>
            </div>
        </div>
        <div class="header-nav">
            <a href="/?sort=views" class="nav-item">메인 챠트</a>
            <a href="/youtube" class="nav-item">유튜브</a>
            <a href="/shorts" class="nav-item active">쇼츠</a>
        </div>
    </header>

    <% if (user) { %>
        <button class="btn-toggle-upload" onclick="document.getElementById('uploadBox').classList.toggle('active')">➕</button>
        
        <div class="upload-section" id="uploadBox">
            <div style="display: flex; justify-content: space-between; margin-bottom: 15px;">
                <h3 style="margin:0; color:#ffb300;">📱 쇼츠 영상 등록</h3>
                <span style="cursor:pointer; color:#aaa;" onclick="document.getElementById('uploadBox').classList.remove('active')">❌</span>
            </div>
            <form action="/add-shorts" method="POST">
                <div class="input-row">
                    <input type="text" name="title" placeholder="쇼츠 제목을 입력하세요" required>
                    <input type="text" name="youtubeLink" placeholder="쇼츠 링크 (https://youtube.com/shorts/...)" required>
                </div>
                <button type="submit" class="btn-upload">🚀 업로드하기</button>
            </form>
        </div>
    <% } %>

    <div class="shorts-container" id="shortsFeed">
        <% 
            function getYoutubeId(url) {
                if(!url) return null;
                const match = url.match(/(?:youtu\.be\/|youtube\.com\/(?:embed\/|v\/|watch\?v=|shorts\/|watch\?.+&v=))([^"&?\/\s]{11})/);
                return match ? match[1] : null;
            }
        %>

        <% if (shorts && shorts.length > 0) { %>
            <% shorts.forEach(function(video, index) { 
                const videoId = getYoutubeId(video.url);
                if(videoId) {
            %>
            <div class="short-item" data-vid="<%= videoId %>">
                
                <div class="video-wrapper"></div>

                <% if(index === 0) { %>
                    <div class="scroll-hint">👆</div>
                <% } %>

                <div class="short-info">
                    <div class="uploader-name">@<%= video.uploader %></div>
                    <h3 class="short-title"><%= video.title %></h3>
                </div>

                <div class="side-menu">
                    <% if (user && (user.role === 'admin' || user.id === video.uploader)) { %>
                        <form action="/delete-video/<%= video._id %>" method="POST" onsubmit="return confirm('이 쇼츠를 삭제할까요?');" style="margin:0;">
                            <button type="submit" class="btn-delete">
                                <span style="font-size:16px;">🗑️</span>
                                삭제
                            </button>
                        </form>
                    <% } %>
                    
                    <div style="background:rgba(0,0,0,0.6); padding:10px; border-radius:50%; text-align:center; backdrop-filter:blur(5px);">
                        <svg viewBox="0 0 24 24" width="24" height="24" fill="#ff5722"><path d="M17.77 10.32l-1.2-.5L18 8.06a4.47 4.47 0 0 0-2.48-5.74 4.63 4.63 0 0 0-5.74 2.49L5.94 10.3l1.2.5L5.75 12.5a4.47 4.47 0 0 0 2.48 5.74 4.63 4.63 0 0 0 5.74-2.49L17.77 10.3l-1.2-.5zM10 14.5v-5l4.5 2.5-4.5 2.5z"></path></svg>
                    </div>
                </div>

            </div>
            <% } }); %>
        <% } else { %>
            <div style="display:flex; justify-content:center; align-items:center; height:100vh; color:#777;">
                등록된 쇼츠 영상이 없습니다. 우측 하단 ➕ 버튼을 눌러 추가해주세요!
            </div>
        <% } %>
    </div>

<script>
    // 🌟 핵심 마법: 화면에 보이면 틀고, 안 보이면 끄는 인공지능 눈알 🌟
    document.addEventListener("DOMContentLoaded", function() {
        const observerOptions = {
            root: document.getElementById('shortsFeed'), // 스크롤되는 메인 통
            rootMargin: '0px',
            threshold: 0.6 // 영상이 화면에 60% 이상 들어오면 작동!
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                const wrapper = entry.target.querySelector('.video-wrapper');
                const videoId = entry.target.getAttribute('data-vid');

                if (entry.isIntersecting) {
                    // 화면에 들어왔다! -> 유튜브 플레이어 소환 (자동재생 + 무한반복)
                    // (주의: 브라우저 정책상 첫 클릭 전에는 소리가 안 날 수 있습니다. 화면을 터치/클릭하면 소리가 켜집니다!)
                    wrapper.innerHTML = `
                        <iframe 
                            src="https://www.youtube.com/embed/${videoId}?autoplay=1&controls=1&loop=1&playlist=${videoId}&playsinline=1" 
                            allow="autoplay; encrypted-media" 
                            allowfullscreen>
                        </iframe>
                    `;
                    // 스크롤 힌트 지우기
                    const hint = entry.target.querySelector('.scroll-hint');
                    if(hint) hint.style.display = 'none';

                } else {
                    // 화면 밖으로 나갔다! -> 유튜브 플레이어 파괴 (소리 겹침 방지 & 폰 렉 방지)
                    wrapper.innerHTML = ''; 
                }
            });
        }, observerOptions);

        // 모든 쇼츠 화면에 인공지능 눈알 부착!
        document.querySelectorAll('.short-item').forEach(item => {
            observer.observe(item);
        });
    });
</script>
</body>
</html>