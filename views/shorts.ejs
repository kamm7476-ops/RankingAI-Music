<!DOCTYPE html>
<html lang="ko">
<head>
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
    <meta http-equiv="Pragma" content="no-cache">
    <meta http-equiv="Expires" content="0">
    
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5112383847606285" crossorigin="anonymous"></script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>쇼츠 모아보기 - RANKING AI</title>

    <style>
        body { background: #0b0c0d; color: #fff; font-family: 'Pretendard', sans-serif; margin: 0; padding-bottom: 100px; }
        a { text-decoration: none; color: inherit; }

        .main-header { background: #121314; border-bottom: 1px solid #222; position: sticky; top: 0; z-index: 100; }
        .header-top { display: flex; justify-content: space-between; align-items: center; padding: 15px 40px; border-bottom: 1px solid #1a1b1c; }
        
        .auth-buttons { display: flex; gap: 20px; align-items: center; }
        .btn-login { color: #bbb; font-size: 14px; }
        .btn-signup { background: #ff5722; color: #000; padding: 8px 20px; border-radius: 20px; font-weight: bold; font-size: 14px; }
        .header-nav { display: flex; justify-content: center; gap: 40px; padding: 12px 0; background: #0b0c0d; }
        .nav-item { color: #aaa; font-weight: 600; font-size: 16px; transition: 0.2s; position: relative; }
        .nav-item:hover, .nav-item.active { color: #ff5722; }
        .nav-item.active::after { content: ''; position: absolute; bottom: -12px; left: 0; width: 100%; height: 3px; background: #ff5722; }

        .container { max-width: 1200px; margin: 0 auto; padding: 30px 20px; }
        .upload-section { background: #161718; padding: 30px; border-radius: 15px; margin-bottom: 40px; border: 1px solid #333; }
        .input-row { display: flex; gap: 15px; margin-bottom: 15px; }
        .input-row input { flex: 1; background: #222; border: 1px solid #333; color: #fff; padding: 12px; border-radius: 8px; }
        .btn-upload { background: #ff5722; color: #000; border: none; padding: 12px; border-radius: 8px; cursor: pointer; font-weight: bold; width: 100%; }

        .shorts-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 15px; width: 100%; visibility: visible; }
        .shorts-card { width: 100%; background: #111; border: 1px solid #222; border-radius: 12px; overflow: hidden; position: relative; cursor: pointer; transition: 0.2s; }
        .shorts-card:hover { border-color: #ff5722; transform: translateY(-5px); box-shadow: 0 8px 20px rgba(255,87,34,0.3); }

        .shorts-card-inner { width: 100%; padding-bottom: 177.77%; position: relative; }
        .shorts-card-inner img { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.9; }

        .shorts-logo-box { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 50px; height: 50px; pointer-events: none; z-index: 10; }

        .grid-info { position: absolute; bottom: 0; left: 0; width: 100%; background: linear-gradient(to top, rgba(0,0,0,0.9), transparent); padding: 30px 12px 12px; box-sizing: border-box; pointer-events: none; z-index: 5; }
        .grid-title { font-size: 14px; font-weight: bold; color: #fff; margin: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; text-shadow: 1px 1px 2px #000; }
        .grid-uploader { font-size: 11px; color: #aaa; margin-bottom: 4px; text-shadow: 1px 1px 2px #000;}

        @media (max-width: 1024px) { .shorts-grid { grid-template-columns: repeat(4, 1fr); } }
        @media (max-width: 768px) { 
            .header-top { flex-direction: column; gap: 15px; }
            .header-nav { justify-content: flex-start; overflow-x: auto; white-space: nowrap; padding: 12px 15px; gap: 20px; }
            .header-nav::-webkit-scrollbar { display: none; }
            .input-row { flex-direction: column; }
            .shorts-grid { grid-template-columns: repeat(3, 1fr); gap: 9px; }
            .shorts-card { border-radius: 8px; } 
            .shorts-logo-box { width: 35px; height: 35px; }
            .grid-info { padding: 20px 8px 8px; }
            .grid-title { font-size: 12px; }
            .grid-uploader { font-size: 10px; margin-bottom: 2px; }
        }

        .shorts-modal { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: #000; z-index: 99999; display: none; }
        .btn-close-modal { position: fixed; top: 20px; left: 20px; z-index: 100000; background: rgba(255,255,255,0.2); border: none; color: white; font-size: 20px; width: 45px; height: 45px; border-radius: 50%; cursor: pointer; backdrop-filter: blur(5px); display: flex; align-items: center; justify-content: center; }
        
        .modal-feed { width: 100%; max-width: 450px; height: 100vh; margin: 0 auto; overflow-y: scroll; scroll-snap-type: y mandatory; -ms-overflow-style: none; scrollbar-width: none; background: #000; }
        .modal-feed::-webkit-scrollbar { display: none; }

        .modal-item { width: 100%; height: 100vh; scroll-snap-align: start; position: relative; display: flex; align-items: center; justify-content: center; }
        .modal-iframe-wrap { width: 100%; height: 100%; position: relative; }
        
        .modal-overlay-info { position: absolute; bottom: 30px; left: 15px; right: 70px; z-index: 10; pointer-events: none; }
        .modal-title { font-size: 16px; font-weight: bold; color: #fff; margin: 0 0 10px 0; text-shadow: 1px 1px 3px #000; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
        .modal-uploader { font-size: 13px; color: #ddd; text-shadow: 1px 1px 2px #000; margin-bottom: 5px; }

        .modal-side-menu { position: absolute; bottom: 30px; right: 15px; z-index: 10; display: flex; flex-direction: column; gap: 15px; }
        .btn-delete-modal { background: rgba(0,0,0,0.6); color: #fff; border: 1px solid #ff4a4a; width: 45px; height: 45px; border-radius: 50%; font-size: 12px; font-weight: bold; cursor: pointer; display: flex; justify-content: center; align-items: center; pointer-events: auto; backdrop-filter: blur(5px); }
    </style>
</head>
<body>
    <header class="main-header">
        <div class="header-top">
            <img src="/logo.png" alt="RANKING AI 로고" style="height: 45px; cursor: pointer; object-fit: contain;" onclick="window.location.href='/?sort=views'">
            
            <div class="auth-buttons">
                <% if (user) { %>
                    <span style="color: #aaa; font-size: 14px;"><%= user.name || user.id %>님</span>
                    <a href="/logout" class="btn-login">로그아웃</a>
                <% } else { %>
                    <a href="/login" class="btn-login">로그인</a>
                    <a href="/signup" class="btn-signup">회원가입</a>
                <% } %>
            </div>
        </div>
        <div class="header-nav">
            <a href="/?sort=views" class="nav-item">RANKING AI 챠트</a>
            <a href="/youtube" class="nav-item">유튜브</a>
            <a href="/shorts" class="nav-item active">쇼츠</a>
            <a href="/board" class="nav-item">커뮤니티</a>
        </div>
    </header>

    <div class="container">
        <% if (user) { %>
        <div class="upload-section" style="border-color: #ffb300;">
            <h3 style="margin-top:0; color:#ffb300;">📱 쇼츠 영상 링크 등록</h3>
            <form action="/add-shorts" method="POST">
                <div class="input-row">
                    <input type="text" name="title" placeholder="쇼츠 제목을 입력하세요" required>
                    <input type="text" name="youtubeLink" placeholder="쇼츠 링크 (https://youtube.com/shorts/...)" required>
                </div>
                <button type="submit" class="btn-upload" style="background:#ffb300;">등록하기</button>
            </form>
        </div>
        <% } %>

        <h2 style="border-bottom: 2px solid #333; padding-bottom: 10px;">⚡ 요즘 뜨는 쇼츠</h2>
        
        <div class="shorts-grid">
            <% 
                function getYoutubeId(url) {
                    if(!url) return null;
                    const match = url.match(/(?:youtu\.be\/|youtube\.com\/(?:embed\/|v\/|watch\?v=|shorts\/|watch\?.+&v=))([^"&?\/\s]{11})/);
                    return match ? match[1] : null;
                }
            %>
            <% if (shorts && shorts.length > 0) { %>
                <% shorts.forEach(function(video, index) { 
                    const videoId = getYoutubeId(video.url);
                %>
                <div class="shorts-card" onclick="openModal(<%= index %>)">
                    <% if (videoId) { %>
                        <div class="shorts-card-inner">
                            <img src="https://i.ytimg.com/vi/<%= videoId %>/hqdefault.jpg" alt="썸네일">
                            
                            <div class="shorts-logo-box">
                                <svg viewBox="0 0 32 32" width="100%" height="100%" style="filter: drop-shadow(0px 4px 6px rgba(0,0,0,0.6));">
                                    <path d="M26.2,12.5l-2.6-1.5l2.6-1.5c2.4-1.4,3.2-4.5,1.8-6.9c-1.4-2.4-4.5-3.2-6.9-1.8l-15,8.7 c-2.4,1.4-3.2,4.5-1.8,6.9c0.9,1.5,2.4,2.3,4.1,2.4l2.5,1.5l-2.5,1.5c-2.4,1.4-3.2,4.5-1.8,6.9c1.4,2.4,4.5,3.2,6.9,1.8l15-8.7 C30.9,18.4,31.7,15.3,30.3,12.9C29.4,11.3,27.9,10.5,26.2,12.5z" fill="#ff0000"/>
                                    <polygon points="12.5,9.5 12.5,22.5 21.5,16" fill="#ffffff"/>
                                </svg>
                            </div>

                            <div class="grid-info">
                                <div class="grid-uploader">@<%= video.uploader %></div>
                                <p class="grid-title"><%= video.title %></p>
                            </div>
                        </div>
                    <% } else { %>
                        <div class="shorts-card-inner" style="display:flex; justify-content:center; align-items:center; background:#111; color:#555;">링크 오류</div>
                    <% } %>
                </div>
                <% }); %>
            <% } else { %>
                <p style="color: #777; width:100%; text-align: center; grid-column: 1 / -1;">등록된 쇼츠 영상이 없습니다.</p>
            <% } %>
        </div>
    </div>

    <div id="shortsModal" class="shorts-modal">
        <button class="btn-close-modal" onclick="closeModal()">✕</button>
        
        <div class="modal-feed" id="modalFeed">
            <% if (shorts && shorts.length > 0) { %>
                <% shorts.forEach(function(video, index) { 
                    const videoId = getYoutubeId(video.url);
                %>
                <div class="modal-item" id="modal-item-<%= index %>" data-vid="<%= videoId %>">
                    <div class="modal-iframe-wrap"></div>
                    <div class="modal-overlay-info">
                        <div class="modal-uploader">@<%= video.uploader %></div>
                        <h3 class="modal-title"><%= video.title %></h3>
                    </div>
                    <div class="modal-side-menu">
                        <% if (user && (user.role === 'admin' || user.id === video.uploader)) { %>
                            <form action="/delete-video/<%= video._id %>" method="POST" onsubmit="return confirm('이 쇼츠를 삭제할까요?');" style="margin:0;">
                                <button type="submit" class="btn-delete-modal">🗑️</button>
                            </form>
                        <% } %>
                    </div>
                </div>
                <% }); %>
            <% } %>
        </div>
    </div>

    <script>
        let observer = null;

        // 🚀 핵심 기술 1: 호출되는 즉시 아이프레임을 '생성'해서 꽂아버립니다.
        function getIframeCode(vid) {
            return `
                <iframe 
                    src="https://www.youtube.com/embed/${vid}?autoplay=1&mute=1&loop=1&playlist=${vid}&playsinline=1&rel=0" 
                    title="YouTube Shorts" 
                    frameborder="0" 
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
                    allowfullscreen
                    style="width: 100%; height: 100%; border-radius: 12px; pointer-events: auto; position: absolute; top: 0; left: 0;">
                </iframe>
            `;
        }

        // 🚀 핵심 기술 2: 클릭하는 순간 브라우저 몰래 영상을 틀어버립니다.
        function openModal(index) {
            const modal = document.getElementById('shortsModal');
            modal.style.display = 'block'; 
            document.body.style.overflow = 'hidden'; 
            
            // 모든 기존 영상 싹 다 초기화 (꼬임 방지)
            document.querySelectorAll('.modal-iframe-wrap').forEach(wrap => wrap.innerHTML = '');

            const target = document.getElementById('modal-item-' + index);
            if(target) {
                target.scrollIntoView({ behavior: 'instant' });
                
                // ⚡ [유저 터치 권한 획득] 클릭 즉시 영상을 생성하여 강제 주입!
                const wrap = target.querySelector('.modal-iframe-wrap');
                const vid = target.dataset.vid;
                if (wrap && vid) {
                    wrap.innerHTML = getIframeCode(vid);
                }
            }

            // 스와이프를 위해 0.3초 넉넉히 기다렸다가 센서를 켭니다.
            setTimeout(() => {
                if (observer) observer.disconnect(); 

                observer = new IntersectionObserver((entries) => {
                    entries.forEach(entry => {
                        const wrap = entry.target.querySelector('.modal-iframe-wrap');
                        const vid = entry.target.dataset.vid;

                        if (entry.isIntersecting) {
                            if (vid && wrap.innerHTML === '') {
                                wrap.innerHTML = getIframeCode(vid);
                            }
                        } else {
                            wrap.innerHTML = ''; // 화면에서 사라지면 싹 지워서 메모리 절약
                        }
                    });
                }, { 
                    root: document.getElementById('modalFeed'), 
                    threshold: 0.5 
                });

                document.querySelectorAll('.modal-item').forEach(item => {
                    observer.observe(item);
                });
            }, 300);
        }

        function closeModal() {
            const modal = document.getElementById('shortsModal');
            modal.style.display = 'none'; 
            document.body.style.overflow = ''; 
            
            if (observer) {
                observer.disconnect();
                observer = null;
            }

            // 모달 닫을 때 무조건 영상을 파괴해서 소리를 끕니다.
            document.querySelectorAll('.modal-iframe-wrap').forEach(wrap => {
                wrap.innerHTML = '';
            });
        }

        // 🚀 핵심 기술 3: 아이폰/사파리에서 뒤로 가기로 왔을 때 코드가 멈추는 '유령 캐시' 차단!
        window.onpageshow = function(event) {
            if (event.persisted) {
                window.location.reload();
            }
        };
    </script>
</body>
</html>
