<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>쇼츠 모아보기 - RANKING AI</title>
    <style>
        body { background: #0b0c0d; color: #fff; font-family: 'Pretendard', sans-serif; margin: 0; padding-bottom: 100px; }
        a { text-decoration: none; color: inherit; }

        .main-header { background: #121314; border-bottom: 1px solid #222; position: sticky; top: 0; z-index: 100; }
        .header-top { display: flex; justify-content: space-between; align-items: center; padding: 15px 40px; border-bottom: 1px solid #1a1b1c; }
        .logo { font-size: 28px; font-weight: 900; color: #ff5722; letter-spacing: -1px; } 
        .auth-buttons { display: flex; gap: 20px; align-items: center; }
        .btn-login { color: #bbb; font-size: 14px; }
        .btn-signup { background: #ff5722; color: #000; padding: 8px 20px; border-radius: 20px; font-weight: bold; font-size: 14px; }
        .header-nav { display: flex; justify-content: center; gap: 40px; padding: 12px 0; background: #0b0c0d; }
        .nav-item { color: #aaa; font-weight: 600; font-size: 16px; transition: 0.2s; position: relative; }
        .nav-item:hover, .nav-item.active { color: #ff5722; }
        .nav-item.active::after { content: ''; position: absolute; bottom: -12px; left: 0; width: 100%; height: 3px; background: #ff5722; }

        .container { max-width: 1200px; margin: 0 auto; padding: 30px 20px; }
        .upload-section { background: #161718; padding: 30px; border-radius: 15px; margin-bottom: 40px; border: 1px solid #333; }
        .input-row { display: flex; gap: 15px; margin-bottom: 15px; }
        .input-row input { flex: 1; background: #222; border: 1px solid #333; color: #fff; padding: 12px; border-radius: 8px; }
        .btn-upload { background: #ff5722; color: #000; border: none; padding: 12px; border-radius: 8px; cursor: pointer; font-weight: bold; width: 100%; }

        /* 🌟 가장 잘 작동했던 반응형 그리드 🌟 */
        .shorts-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); 
            gap: 20px;
        }
        .shorts-card {
            background: #161718; border: 1px solid #222; border-radius: 15px; overflow: hidden; transition: 0.2s;
            min-width: 0; /* 🌟 핵심 방어막: 화면 대문짝만해지는 버그 원천 차단 🌟 */
        }
        .shorts-card:hover { border-color: #ffb300; transform: translateY(-5px); box-shadow: 0 5px 15px rgba(255,179,0,0.2); }
        
        /* 🌟 쇼츠 비율 고정 마법 (9:16) 🌟 */
        .shorts-iframe-wrap {
            position: relative;
            width: 100%;
            padding-bottom: 177.77%; 
            height: 0;
            background: #000;
        }
        /* 🌟 177% 팽창 에러 수정 완료 (정상적인 100% 꽉 채우기) 🌟 */
        .shorts-iframe-wrap iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: none;
        }
        
        .shorts-info { padding: 12px; text-align: center; }
        .shorts-title { font-size: 14px; font-weight: bold; margin: 0 0 8px 0; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .btn-delete { background: none; border: none; color: #ff4a4a; cursor: pointer; font-size: 12px; font-weight: bold; padding: 0; }

        @media (max-width: 768px) {
            .header-top { flex-direction: column; gap: 15px; }
            .header-nav { justify-content: flex-start; overflow-x: auto; white-space: nowrap; padding: 12px 15px; gap: 20px; }
            .header-nav::-webkit-scrollbar { display: none; }
            .input-row { flex-direction: column; }
            .shorts-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
        }
    </style>
</head>
<body>
    <header class="main-header">
        <div class="header-top">
            <div class="logo" style="cursor:pointer;" onclick="window.location.href='/?sort=views'">RANKING AI</div>
            <div class="auth-buttons">
                <% if (user) { %>
                    <span style="color: #aaa; font-size: 14px;"><%= user.name || user.id %>님</span>
                    <a href="/logout" class="btn-login">로그아웃</a>
                <% } else { %>
                    <a href="/login" class="btn-login">로그인</a>
                    <a href="/signup" class="btn-signup">회원가입</a>
                <% } %>
            </div>
        </div>
        <div class="header-nav">
            <a href="/?sort=views" class="nav-item">RANKING AI 챠트</a>
            <a href="/youtube" class="nav-item">유튜브</a>
            <a href="/shorts" class="nav-item active">쇼츠</a>
            <a href="/board" class="nav-item">커뮤니티</a>
        </div>
    </header>

    <div class="container">
        <% if (user) { %>
        <div class="upload-section" style="border-color: #ffb300;">
            <h3 style="margin-top:0; color:#ffb300;">📱 쇼츠 영상 등록</h3>
            <form action="/add-shorts" method="POST">
                <div class="input-row">
                    <input type="text" name="title" placeholder="쇼츠 제목을 입력하세요" required>
                    <input type="text" name="youtubeLink" placeholder="쇼츠 링크 (https://youtube.com/shorts/...)" required>
                </div>
                <button type="submit" class="btn-upload" style="background:#ffb300;">등록하기</button>
            </form>
        </div>
        <% } %>

        <h2 style="border-bottom: 2px solid #333; padding-bottom: 10px;">⚡ 요즘 뜨는 쇼츠</h2>
        
        <div class="shorts-grid">
            <% 
                function getYoutubeId(url) {
                    if(!url) return null;
                    const match = url.match(/(?:youtu\.be\/|youtube\.com\/(?:embed\/|v\/|watch\?v=|shorts\/|watch\?.+&v=))([^"&?\/\s]{11})/);
                    return match ? match[1] : null;
                }
            %>
            <% if (shorts && shorts.length > 0) { %>
                <% shorts.forEach(function(video) { 
                    const videoId = getYoutubeId(video.url);
                %>
                <div class="shorts-card">
                    <% if (videoId) { %>
                        <div class="shorts-iframe-wrap" data-id="<%= videoId %>" style="cursor:pointer;">
                            
                            <img src="https://i.ytimg.com/vi/<%= videoId %>/hqdefault.jpg" style="position: absolute; top:0; left:0; width: 100%; height: 100%; object-fit: cover; opacity: 0.8;">
                            
                            <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); pointer-events: none;">
                                <svg viewBox="0 0 24 24" width="70" height="70" fill="#ff0000">
                                    <path d="M17.77 10.32l-1.2-.5L18 8.06a4.47 4.47 0 0 0-2.48-5.74 4.63 4.63 0 0 0-5.74 2.49L5.94 10.3l1.2.5L5.75 12.5a4.47 4.47 0 0 0 2.48 5.74 4.63 4.63 0 0 0 5.74-2.49L17.77 10.3l-1.2-.5zM10 14.5v-5l4.5 2.5-4.5 2.5z"></path>
                                </svg>
                            </div>

                            <div style="position: absolute; top: 12px; right: 12px; background: rgba(0,0,0,0.7); padding: 5px 10px; border-radius: 8px; display: flex; align-items: center; gap: 6px; pointer-events: none; border: 1px solid rgba(255,255,255,0.1);">
                                <svg viewBox="0 0 24 24" width="16" height="16" fill="#ff0000"><path d="M17.77 10.32l-1.2-.5L18 8.06a4.47 4.47 0 0 0-2.48-5.74 4.63 4.63 0 0 0-5.74 2.49L5.94 10.3l1.2.5L5.75 12.5a4.47 4.47 0 0 0 2.48 5.74 4.63 4.63 0 0 0 5.74-2.49L17.77 10.3l-1.2-.5zM10 14.5v-5l4.5 2.5-4.5 2.5z"></path></svg>
                                <span style="font-size: 12px; font-weight: bold; color: #fff;">Shorts</span>
                            </div>
                        </div>
                    <% } else { %>
                        <div class="shorts-iframe-wrap">
                            <div style="display:flex; align-items:center; justify-content:center; height:100%; color:#555; position: absolute; width:100%; top: 0; left: 0;">링크 오류</div>
                        </div>
                    <% } %>

                    <div class="shorts-info">
                        <h4 class="shorts-title"><%= video.title %></h4>
                        <% if (user && (user.role === 'admin' || user.id === video.uploader)) { %>
                            <form action="/delete-video/<%= video._id %>" method="POST" onsubmit="return confirm('삭제할까요?');" style="margin:0;">
                                <button type="submit" class="btn-delete">❌ 삭제</button>
                            </form>
                        <% } %>
                    </div>
                </div>
                <% }); %>
            <% } else { %>
                <p style="color: #777; grid-column: 1 / -1; text-align: center;">등록된 쇼츠 영상이 없습니다.</p>
            <% } %>
        </div>
    </div>

<script>
document.addEventListener("click", function(e) {
  const wrap = e.target.closest(".shorts-iframe-wrap");

  // 쇼츠 영역 아니면 무시
  if (!wrap) return;

  // 이미 실행된 경우 중복 방지
  if (wrap.querySelector("iframe")) return;

  const videoId = wrap.dataset.id;

  wrap.innerHTML = `
    <iframe 
      src="https://www.youtube.com/embed/${videoId}?autoplay=1&playsinline=1"
      allow="autoplay; encrypted-media"
      allowfullscreen
      style="position:absolute; top:0; left:0; width:100%; height:100%; border:none;">
    </iframe>
  `;
});
</script>
</body>
</html>