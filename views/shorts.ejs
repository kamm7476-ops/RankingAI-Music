<!DOCTYPE html>
<html lang="<%= typeof getLocale !== 'undefined' ? getLocale() : 'ko' %>">
<head>
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5112383847606285" crossorigin="anonymous"></script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= __('menu_shorts') || '쇼츠 모아보기' %> - RANKING AI</title>

    <style>
        body { background: #0b0c0d; color: #fff; font-family: 'Pretendard', sans-serif; margin: 0; padding-bottom: 100px; }
        a { text-decoration: none; color: inherit; }

        .main-header { background: #121314; border-bottom: 1px solid #222; position: sticky; top: 0; z-index: 100; }
        .header-top { display: flex; justify-content: space-between; align-items: center; padding: 15px 40px; border-bottom: 1px solid #1a1b1c; }
        
        .logo-img { height: 50px; max-width: 100%; cursor: pointer; object-fit: contain; flex-shrink: 0; }
        
        .top-search-form { display: flex; align-items: center; background: #222 !important; border: 2px solid #ff5722; border-radius: 25px; padding: 5px 12px; flex: 1; max-width: 400px; margin: 0; min-width: 0; }
        .top-search-input { background: transparent !important; border: none !important; color: white !important; outline: none; flex: 1; font-size: 14px; padding: 5px; min-width: 0; }
        .top-search-input::placeholder { color: #aaa; }
        .top-search-btn { background: none; border: none; color: #ff5722; font-weight: bold; cursor: pointer; font-size: 16px; padding: 0 10px; }

        .auth-buttons { display: flex; gap: 15px; align-items: center; flex-shrink: 0; }
        .lang-select { padding: 7px 14px; background: #222; color: #fff; border: 2px solid #ff5722; border-radius: 20px; font-weight: bold; font-size: 13px; outline: none; cursor: pointer; transition: 0.2s; }
        .lang-select:hover { background: #ff5722; color: #000; }
        .btn-admin { color: #ff4a4a; font-weight: bold; font-size: 14px; border: 1px solid #ff4a4a; padding: 5px 12px; border-radius: 15px; }
        .btn-login { color: #bbb; font-size: 14px; }
        .btn-signup { background: #ff5722; color: #000; padding: 8px 20px; border-radius: 20px; font-weight: bold; font-size: 14px; }
        
        .header-nav { display: flex; justify-content: center; gap: 40px; padding: 12px 0; background: #0b0c0d; }
        .nav-item { color: #aaa; font-weight: 600; font-size: 16px; transition: 0.2s; position: relative; }
        .nav-item:hover, .nav-item.active { color: #ff5722; }
        .nav-item.active::after { content: ''; position: absolute; bottom: -12px; left: 0; width: 100%; height: 3px; background: #ff5722; }

        .container { max-width: 1200px; margin: 0 auto; padding: 30px 20px; }
        .upload-section { background: #161718; padding: 30px; border-radius: 15px; margin-bottom: 40px; border: 1px solid #333; }
        .input-row { display: flex; gap: 15px; margin-bottom: 15px; }
        .input-row input { flex: 1; background: #222; border: 1px solid #333; color: #fff; padding: 12px; border-radius: 8px; }
        .btn-upload { background: #ff5722; color: #000; border: none; padding: 12px; border-radius: 8px; cursor: pointer; font-weight: bold; width: 100%; transition: 0.2s; }
        .btn-upload:hover { filter: brightness(1.1); }

        .shorts-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 15px; width: 100%; visibility: visible; }
        .shorts-card { width: 100%; background: #111; border: 1px solid #222; border-radius: 12px; overflow: hidden; position: relative; cursor: pointer; transition: 0.2s; }
        .shorts-card:hover { border-color: #ff5722; transform: translateY(-5px); box-shadow: 0 8px 20px rgba(255,87,34,0.3); }

        .shorts-card-inner { width: 100%; padding-bottom: 177.77%; position: relative; }
        .shorts-card-inner img { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.9; }

        .shorts-logo-box { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 50px; height: 50px; pointer-events: none; z-index: 10; }

        .grid-info { position: absolute; bottom: 0; left: 0; width: 100%; background: linear-gradient(to top, rgba(0,0,0,0.9), transparent); padding: 30px 12px 12px; box-sizing: border-box; pointer-events: none; z-index: 5; }
        .grid-title { font-size: 14px; font-weight: bold; color: #fff; margin: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; text-shadow: 1px 1px 2px #000; }
        .grid-uploader { font-size: 11px; color: #aaa; margin-bottom: 4px; text-shadow: 1px 1px 2px #000;}

        @media (max-width: 1024px) { .shorts-grid { grid-template-columns: repeat(4, 1fr); } }
        @media (max-width: 768px) { 
            .header-top { flex-wrap: wrap !important; padding: 15px 15px !important; gap: 15px !important; }
            .logo-img { height: 60px !important; max-width: 350px !important; flex-shrink: 0 !important; }
            .auth-buttons { flex: 1; justify-content: flex-end; width: auto !important; flex-wrap: nowrap; gap: 10px !important; }
            .lang-select { font-size: 11px !important; padding: 5px 8px !important; margin-bottom: 0 !important; margin-right: auto !important; } 
            .btn-signup, .btn-login { font-size: 12px !important; padding: 6px 10px !important; }
            .top-search-form { width: 100% !important; flex: 1 1 100% !important; margin: 0 !important; padding: 5px 15px !important; order: 3; }
            .top-search-input { font-size: 14px !important; padding: 5px !important; }
            
            .header-nav { justify-content: flex-start; overflow-x: auto; white-space: nowrap; padding: 12px 15px; gap: 20px; }
            .header-nav::-webkit-scrollbar { display: none; }
            .input-row { flex-direction: column; }
            .shorts-grid { grid-template-columns: repeat(3, 1fr); gap: 9px; }
            .shorts-card { border-radius: 8px; } 
            .shorts-logo-box { width: 35px; height: 35px; }
            .grid-info { padding: 20px 8px 8px; }
            .grid-title { font-size: 12px; }
            .grid-uploader { font-size: 10px; margin-bottom: 2px; }
        }

        /* 쇼츠 플레이어 오버레이 */
        #shortsModal {
            display: none;
            position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
            background: #000; z-index: 99999;
            align-items: center; justify-content: center;
            overscroll-behavior: contain;
        }
        #shortsModal.show { display: flex; }
        #sIframeWrap {
            width: 100%; max-width: 450px; height: 100vh;
            position: relative; overflow: hidden;
            touch-action: pan-y;
        }
        #sIframeWrap iframe {
            position: absolute; top: 0; left: 0;
            width: 100%; height: 100%; border: none;
            will-change: transform;
        }
        #sLoadingSpinner {
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
            color: #fff; font-size: 14px; display: flex; flex-direction: column;
            align-items: center; gap: 12px; pointer-events: none; z-index: 2;
        }
        .spinner-ring {
            width: 40px; height: 40px; border: 3px solid #333;
            border-top-color: #ff5722; border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }

        /* 릴스형 슬라이드 전환 애니메이션 */
        .slide-in-up { animation: slideInUp 0.32s cubic-bezier(0.4, 0, 0.2, 1); }
        .slide-in-down { animation: slideInDown 0.32s cubic-bezier(0.4, 0, 0.2, 1); }
        @keyframes slideInUp { from { transform: translateY(100%); opacity: 0.5; } to { transform: translateY(0); opacity: 1; } }
        @keyframes slideInDown { from { transform: translateY(-100%); opacity: 0.5; } to { transform: translateY(0); opacity: 1; } }

        /* 스와이프 힌트 */
        #sSwipeHint {
            position: fixed; bottom: 90px; left: 50%; transform: translateX(-50%);
            z-index: 100001; color: rgba(255,255,255,0.6); font-size: 12px;
            animation: fadeHint 3s ease-out forwards;
            pointer-events: none;
        }
        @keyframes fadeHint { 0% { opacity: 0; } 20% { opacity: 1; } 80% { opacity: 1; } 100% { opacity: 0; } }

        .s-close {
            position: fixed; top: 15px; left: 15px; z-index: 100001;
            background: rgba(0,0,0,0.55); border: none; color: #fff;
            font-size: 22px; width: 44px; height: 44px; border-radius: 50%;
            cursor: pointer; backdrop-filter: blur(4px);
            display: flex; align-items: center; justify-content: center;
        }
        .s-counter {
            position: fixed; top: 15px; left: 50%; transform: translateX(-50%);
            z-index: 100001; color: #ccc; font-size: 13px;
            background: rgba(0,0,0,0.5); padding: 5px 12px; border-radius: 20px;
        }
        .s-info {
            position: fixed; bottom: 30px; left: 15px; right: 75px;
            z-index: 100001; pointer-events: none;
        }
        .s-uploader { font-size: 13px; color: #ddd; text-shadow: 1px 1px 2px #000; margin-bottom: 6px; }
        .s-title   { font-size: 16px; font-weight: bold; color: #fff; text-shadow: 1px 1px 3px #000; }
        .s-nav {
            position: fixed; right: 15px; bottom: 30px; z-index: 100001;
            display: flex; flex-direction: column; gap: 12px;
        }
        .s-btn {
            background: rgba(0,0,0,0.6); color: #fff;
            border: 1px solid #555; width: 44px; height: 44px;
            border-radius: 50%; font-size: 18px; cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            transition: background 0.2s;
        }
        .s-btn:hover { background: rgba(255,87,34,0.5); border-color: #ff5722; }
        .s-btn:disabled { opacity: 0.3; cursor: default; }
        .s-btn-del { border-color: #ff4a4a; font-size: 14px; }
    </style>
</head>
<body>
    <header class="main-header">
        <div class="header-top">
            <img src="/logo.png" alt="RANKING AI 로고" class="logo-img" onclick="window.location.href='/?sort=views'">
            
            <form action="/" method="GET" class="top-search-form">
                <div style="display: flex; align-items: center; justify-content: center; cursor: pointer; background: #fff; padding: 2px; border-radius: 4px; margin-right: 10px; box-shadow: 0 0 5px rgba(255,87,34,0.5); flex-shrink: 0;" 
                     title="클릭하면 크게 확대됩니다! 친구들에게 공유해보세요 🚀" 
                     onclick="window.open('https://api.qrserver.com/v1/create-qr-code/?size=500x500&data=https://rankingaimusic.com', '_blank')">
                    <img src="https://api.qrserver.com/v1/create-qr-code/?size=30x30&data=https://rankingaimusic.com" alt="QR Code" style="display: block; width: 24px; height: 24px;">
                </div>
                <input type="text" name="search" class="top-search-input" placeholder="<%= __('search_placeholder') || '아티스트 검색...' %>" value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false">
                <button type="submit" class="top-search-btn">🔍</button>
            </form>

            <div class="auth-buttons">
                <select id="smartLangSelect" onchange="window.location.href='/change-lang/' + this.value" class="lang-select">
                    <option value="ko" <%= typeof getLocale !== 'undefined' && getLocale() === 'ko' ? 'selected' : '' %>>🇰🇷 한국어</option>
                    <option value="en" <%= typeof getLocale !== 'undefined' && getLocale() === 'en' ? 'selected' : '' %>>🇺🇸 English</option>
                    <option value="ja" <%= typeof getLocale !== 'undefined' && getLocale() === 'ja' ? 'selected' : '' %>>🇯🇵 日本語</option>
                    <option value="zh" <%= typeof getLocale !== 'undefined' && getLocale() === 'zh' ? 'selected' : '' %>>🇨🇳 中文</option>
                </select>

                <% if (user && user.role === 'admin') { %>
                    <a href="/admin" class="btn-admin">👑 관리자</a>
                <% } %>
                
                <% if (user) { %>
                    <span style="color: #aaa; font-size: 14px;"><%= user.name || user.id %><%= __('welcome_user') || '님' %></span>
                    <a href="/logout" class="btn-login" style="margin-left: 15px;"><%= __('btn_logout') || '로그아웃' %></a>
                <% } else { %>
                    <a href="/login" class="btn-login"><%= __('btn_login') || '로그인' %></a>
                    <a href="/signup" class="btn-signup"><%= __('btn_signup') || '회원가입' %></a>
                <% } %>
            </div>
        </div>
        <div class="header-nav">
            <a href="/?sort=views" class="nav-item"><%= __('menu_chart') || 'RANKING AI 차트' %></a>
            <a href="/?sort=latest" class="nav-item"><%= __('menu_latest') || '최신음악' %></a>
            <a href="/?genre=발라드" class="nav-item"><%= __('menu_genre') || '장르별' %></a>
            <a href="/radio" class="nav-item" style="color: #ffb300; font-weight: 900;"><%= __('menu_bgm') || '🎧상황별BGM' %></a>
            <a href="/youtube" class="nav-item"><%= __('menu_youtube') || '유튜브' %></a>
            <a href="/shorts" class="nav-item active"><%= __('menu_shorts') || '쇼츠' %></a>
            <a href="/board" class="nav-item"><%= __('menu_community') || '커뮤니티' %></a>
        </div>
    </header>

    <div class="container">
        <% if (user) { %>
        <div class="upload-section" style="border-color: #ffb300;">
            <h3 style="margin-top:0; color:#ffb300;"><%= __('shorts_upload_title') || '📱 쇼츠 영상 링크 등록' %></h3>
            <form action="/add-shorts" method="POST">
                <div class="input-row">
                    <input type="text" name="title" placeholder="<%= __('shorts_ph_title') || '쇼츠 제목을 입력하세요' %>" required>
                    <input type="text" name="youtubeLink" placeholder="<%= __('shorts_ph_link') || '쇼츠 링크 (https://youtube.com/shorts/...)' %>" required>
                </div>
                <button type="submit" class="btn-upload" style="background:#ffb300;"><%= __('btn_submit_chart') || '등록하기' %></button>
            </form>
        </div>
        <% } %>

        <h2 style="border-bottom: 2px solid #333; padding-bottom: 10px;"><%= __('shorts_title') || '⚡ 요즘 뜨는 쇼츠' %></h2>
        
        <div class="shorts-grid">
            <% 
                function getYoutubeId(url) {
                    if(!url) return null;
                    const match = url.match(/(?:youtube\.com\/shorts\/|youtu\.be\/|youtube\.com\/watch\?v=)([^"&?\/\s]{11})/);
                    return match ? match[1] : null;
                }
            %>
            <% if (shorts && shorts.length > 0) { %>
                <% shorts.forEach(function(video, index) { 
                    const videoId = getYoutubeId(video.url);
                %>
                <div class="shorts-card" onclick="openModal(<%= index %>)" ondblclick="openModal(<%= index %>)">
                    <% if (videoId) { %>
                        <div class="shorts-card-inner">
                            <img src="https://i.ytimg.com/vi/<%= videoId %>/hqdefault.jpg" alt="썸네일">
                            <div class="shorts-logo-box">
                                <svg viewBox="0 0 32 32" width="100%" height="100%" style="filter: drop-shadow(0px 4px 6px rgba(0,0,0,0.6));">
                                    <path d="M26.2,12.5l-2.6-1.5l2.6-1.5c2.4-1.4,3.2-4.5,1.8-6.9c-1.4-2.4-4.5-3.2-6.9-1.8l-15,8.7 c-2.4,1.4-3.2,4.5-1.8,6.9c0.9,1.5,2.4,2.3,4.1,2.4l2.5,1.5l-2.5,1.5c-2.4,1.4-3.2,4.5-1.8,6.9c1.4,2.4,4.5,3.2,6.9,1.8l15-8.7 C30.9,18.4,31.7,15.3,30.3,12.9C29.4,11.3,27.9,10.5,26.2,12.5z" fill="#ff0000"/>
                                    <polygon points="12.5,9.5 12.5,22.5 21.5,16" fill="#ffffff"/>
                                </svg>
                            </div>
                            <div class="grid-info">
                                <div class="grid-uploader">@<%= video.uploader %></div>
                                <p class="grid-title"><%= video.title %></p>
                            </div>
                        </div>
                    <% } else { %>
                        <div class="shorts-card-inner" style="display:flex; justify-content:center; align-items:center; background:#111; color:#555;"><%= __('yt_invalid_link') || '링크 오류' %></div>
                    <% } %>
                </div>
                <% }); %>
            <% } else { %>
                <p style="color: #777; width:100%; text-align: center; grid-column: 1 / -1;"><%= __('shorts_no_video') || '등록된 쇼츠 영상이 없습니다.' %></p>
            <% } %>
        </div>
    </div>

    <div id="shortsModal">
        <button class="s-close" onclick="closeModal()">✕</button>
        <div class="s-counter" id="sCounter"></div>
        <div id="sIframeWrap">
            <!-- 정적 iframe: src만 교체해 autoplay 차단 우회 -->
            <iframe id="sPlayer"
                src=""
                allow="autoplay; fullscreen; encrypted-media; picture-in-picture"
                allowfullscreen
                style="position:absolute;top:0;left:0;width:100%;height:100%;border:none;background:#000;">
            </iframe>
            <div id="sLoadingSpinner"><div class="spinner-ring"></div><span>로딩 중...</span></div>
        </div>
        <div id="sSwipeHint">위로 스와이프 → 다음 쇼츠</div>
        <div class="s-info">
            <div class="s-uploader" id="sUploader"></div>
            <div class="s-title"   id="sTitle"></div>
        </div>
        <div class="s-nav">
            <button class="s-btn" id="sPrevBtn" onclick="navShorts(-1)">↑</button>
            <button class="s-btn" id="sNextBtn" onclick="navShorts(1)">↓</button>
            <button class="s-btn s-btn-del" id="sDeleteBtn" style="display:none;" onclick="deleteCurrentShorts()">🗑️</button>
        </div>
    </div>

<script>
    var shortsData = <%- JSON.stringify((shorts || []).map(function(v) {
        var m = v.url ? v.url.match(/(?:youtube\.com\/shorts\/|youtu\.be\/|youtube\.com\/watch\?v=)([^"&?\/\s]{11})/) : null;
        return { _id: String(v._id), title: v.title || '', uploader: v.uploader || '', vid: m ? m[1] : null };
    })) %>;

    var currentUserRole = '<%= user ? (user.role || "") : "" %>';
    var currentUserId   = '<%= user ? (user.id  || "") : "" %>';
    var currentIdx  = -1;
    var isNavigating = false;

    // ── 유틸: 공통 UI 갱신 ─────────────────────────
    function updateUI(index) {
        var d = shortsData[index];
        document.getElementById('sTitle').textContent    = d.title;
        document.getElementById('sUploader').textContent = '@' + d.uploader;
        document.getElementById('sCounter').textContent  = (index + 1) + ' / ' + shortsData.length;
        document.getElementById('sPrevBtn').disabled     = (index === 0);
        document.getElementById('sNextBtn').disabled     = (index === shortsData.length - 1);
        var del = document.getElementById('sDeleteBtn');
        del.style.display = (currentUserRole === 'admin' || currentUserId === d.uploader) ? 'flex' : 'none';
    }

    // ── 핵심: 정적 iframe src 교체 (autoplay 차단 없음) ─
    function loadVideo(vid, animClass) {
        var player  = document.getElementById('sPlayer');
        var spinner = document.getElementById('sLoadingSpinner');

        if (spinner) { spinner.style.display = 'flex'; }
        player.classList.remove('slide-in-up', 'slide-in-down');

        player.src = 'https://www.youtube.com/embed/' + vid
            + '?autoplay=1&mute=1&loop=1&playlist=' + vid
            + '&playsinline=1&rel=0&controls=1&enablejsapi=1';

        player.onload = function() {
            if (spinner) spinner.style.display = 'none';
            if (animClass) {
                player.classList.add(animClass);
                setTimeout(function() { player.classList.remove(animClass); }, 350);
            }
            isNavigating = false;
        };
    }

    // ── 카드 클릭 → 모달 열기 ──────────────────────
    function openModal(index) {
        var d = shortsData[index];
        if (!d || !d.vid) return;
        currentIdx = index;
        updateUI(index);

        var modal = document.getElementById('shortsModal');
        modal.classList.add('show');
        document.body.style.overflow = 'hidden';

        loadVideo(d.vid, null);
    }

    // ── 이전/다음 탐색 ─────────────────────────────
    function navShorts(dir) {
        if (isNavigating) return;
        var next = currentIdx + dir;
        if (next < 0 || next >= shortsData.length) return;
        isNavigating = true;
        currentIdx = next;
        var d = shortsData[next];
        if (!d || !d.vid) { isNavigating = false; return; }
        updateUI(next);
        loadVideo(d.vid, dir > 0 ? 'slide-in-up' : 'slide-in-down');
    }

    // ── 모달 닫기 ──────────────────────────────────
    function closeModal() {
        var player  = document.getElementById('sPlayer');
        var spinner = document.getElementById('sLoadingSpinner');
        player.src  = '';  // 영상 정지
        if (spinner) spinner.style.display = 'flex';
        document.getElementById('shortsModal').classList.remove('show');
        document.body.style.overflow = '';
        currentIdx   = -1;
        isNavigating = false;
    }

    // ── 쇼츠 삭제 ──────────────────────────────────
    function deleteCurrentShorts() {
        var d = shortsData[currentIdx];
        if (!d) return;
        if (!confirm('<%= __("yt_confirm_delete") || "이 쇼츠를 삭제할까요?" %>')) return;
        var form = document.createElement('form');
        form.method = 'POST';
        form.action = '/delete-video/' + d._id;
        document.body.appendChild(form);
        form.submit();
    }

    // ── 키보드 단축키 ──────────────────────────────
    document.addEventListener('keydown', function(e) {
        if (!document.getElementById('shortsModal').classList.contains('show')) return;
        if (e.key === 'ArrowUp')   navShorts(-1);
        if (e.key === 'ArrowDown') navShorts(1);
        if (e.key === 'Escape')    closeModal();
    });

    // ── 릴스형 터치 스와이프 ───────────────────────
    (function() {
        var startY = 0, startX = 0;
        var dragging = false;
        var THRESHOLD = 70;
        var modal  = document.getElementById('shortsModal');
        var player = document.getElementById('sPlayer');

        modal.addEventListener('touchstart', function(e) {
            if (isNavigating) return;
            startY = e.touches[0].clientY;
            startX = e.touches[0].clientX;
            dragging = true;
        }, { passive: true });

        modal.addEventListener('touchmove', function(e) {
            if (!dragging || isNavigating) return;
            var dy = startY - e.touches[0].clientY;
            var dx = Math.abs(startX - e.touches[0].clientX);
            if (dx > Math.abs(dy)) return;
            // 손가락 드래그 따라 이동 (릴스 느낌)
            var pull = Math.max(-100, Math.min(100, -dy * 0.25));
            player.style.transform = 'translateY(' + pull + 'px)';
        }, { passive: true });

        modal.addEventListener('touchend', function(e) {
            if (!dragging || isNavigating) return;
            dragging = false;
            player.style.transform = '';

            var dy = startY - e.changedTouches[0].clientY;
            var dx = Math.abs(startX - e.changedTouches[0].clientX);
            if (dx > Math.abs(dy) || Math.abs(dy) < THRESHOLD) return;
            if (dy > 0) navShorts(1);
            else        navShorts(-1);
        }, { passive: true });
    })();
</script>
</body>
</html>