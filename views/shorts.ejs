<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>쇼츠 모아보기 - RANKING AI</title>
    <style>
        body { background: #0b0c0d; color: #fff; font-family: 'Pretendard', sans-serif; margin: 0; padding-bottom: 100px; }
        a { text-decoration: none; color: inherit; }

        .main-header { background: #121314; border-bottom: 1px solid #222; position: sticky; top: 0; z-index: 100; }
        .header-top { display: flex; justify-content: space-between; align-items: center; padding: 15px 40px; border-bottom: 1px solid #1a1b1c; }
        .logo { font-size: 28px; font-weight: 900; color: #ff5722; letter-spacing: -1px; } 
        .auth-buttons { display: flex; gap: 20px; align-items: center; }
        .btn-login { color: #bbb; font-size: 14px; }
        .btn-signup { background: #ff5722; color: #000; padding: 8px 20px; border-radius: 20px; font-weight: bold; font-size: 14px; }
        .header-nav { display: flex; justify-content: center; gap: 40px; padding: 12px 0; background: #0b0c0d; }
        .nav-item { color: #aaa; font-weight: 600; font-size: 16px; transition: 0.2s; position: relative; }
        .nav-item:hover, .nav-item.active { color: #ff5722; }
        .nav-item.active::after { content: ''; position: absolute; bottom: -12px; left: 0; width: 100%; height: 3px; background: #ff5722; }

        .container { max-width: 1200px; margin: 0 auto; padding: 30px 20px; }
        .upload-section { background: #161718; padding: 30px; border-radius: 15px; margin-bottom: 40px; border: 1px solid #333; }
        .input-row { display: flex; gap: 15px; margin-bottom: 15px; }
        .input-row input { flex: 1; background: #222; border: 1px solid #333; color: #fff; padding: 12px; border-radius: 8px; }
        .btn-upload { background: #ff5722; color: #000; border: none; padding: 12px; border-radius: 8px; cursor: pointer; font-weight: bold; width: 100%; }

        /* 🌟 가장 안정적인 그리드 (번쩍임 없음) 🌟 */
        .shorts-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); 
            gap: 20px;
        }

        /* 🌟 쇼츠 전용 9:16 비율 카드 🌟 */
        .shorts-card {
            background: #111; 
            border: 1px solid #222; 
            border-radius: 15px; 
            overflow: hidden; 
            position: relative;
            aspect-ratio: 9 / 16; /* 가로세로 비율을 유튜브 쇼츠와 100% 똑같이 강제 고정! */
            transition: 0.2s;
        }
        .shorts-card:hover { border-color: #ff5722; box-shadow: 0 5px 15px rgba(255,87,34,0.3); transform: translateY(-3px); }

        /* 🌟 썸네일 & 영상 컨테이너 🌟 */
        .video-container {
            width: 100%;
            height: 100%;
            background: #000;
        }
        
        .video-container iframe, .video-container img {
            width: 100%; height: 100%; border: none; object-fit: cover;
        }

        /* 🌟 재생 버튼 🌟 */
        .play-overlay {
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
            width: 60px; height: 60px; background: rgba(255, 0, 0, 0.8); border-radius: 50%;
            display: flex; justify-content: center; align-items: center; pointer-events: none;
            box-shadow: 0 4px 10px rgba(0,0,0,0.5);
        }
        .play-overlay::after {
            content: ''; border-top: 10px solid transparent; border-bottom: 10px solid transparent; border-left: 16px solid white;
            margin-left: 4px;
        }

        /* 🌟 정보 오버레이 (제목 등) 🌟 */
        .info-overlay {
            position: absolute; bottom: 0; left: 0; width: 100%;
            background: linear-gradient(to top, rgba(0,0,0,0.9), transparent);
            padding: 30px 15px 15px; box-sizing: border-box; pointer-events: none;
        }
        .short-title { font-size: 15px; font-weight: bold; margin: 0 0 5px 0; color: #fff; text-shadow: 1px 1px 2px #000; }
        .short-uploader { font-size: 12px; color: #ccc; }

        .btn-delete { 
            position: absolute; top: 10px; right: 10px; background: rgba(0,0,0,0.6); 
            border: 1px solid #ff4a4a; color: #fff; padding: 5px 10px; border-radius: 5px; 
            font-size: 12px; cursor: pointer; pointer-events: auto; z-index: 10;
        }

        @media (max-width: 768px) {
            .header-top { flex-direction: column; gap: 15px; }
            .header-nav { justify-content: flex-start; overflow-x: auto; white-space: nowrap; padding: 12px 15px; gap: 20px; }
            .header-nav::-webkit-scrollbar { display: none; }
            .input-row { flex-direction: column; }
            .shorts-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
        }
    </style>
</head>
<body>
    <header class="main-header">
        <div class="header-top">
            <div class="logo" style="cursor:pointer;" onclick="window.location.href='/?sort=views'">RANKING AI</div>
            <div class="auth-buttons">
                <% if (user) { %>
                    <span style="color: #aaa; font-size: 14px;"><%= user.name || user.id %>님</span>
                    <a href="/logout" class="btn-login">로그아웃</a>
                <% } else { %>
                    <a href="/login" class="btn-login">로그인</a>
                    <a href="/signup" class="btn-signup">회원가입</a>
                <% } %>
            </div>
        </div>
        <div class="header-nav">
            <a href="/?sort=views" class="nav-item">RANKING AI 챠트</a>
            <a href="/youtube" class="nav-item">유튜브</a>
            <a href="/shorts" class="nav-item active">쇼츠</a>
            <a href="/board" class="nav-item">커뮤니티</a>
        </div>
    </header>

    <div class="container">
        <% if (user) { %>
        <div class="upload-section" style="border-color: #ffb300;">
            <h3 style="margin-top:0; color:#ffb300;">📱 쇼츠 영상 링크 등록</h3>
            <form action="/add-shorts" method="POST">
                <div class="input-row">
                    <input type="text" name="title" placeholder="쇼츠 제목을 입력하세요" required>
                    <input type="text" name="youtubeLink" placeholder="쇼츠 링크 (https://youtube.com/shorts/...)" required>
                </div>
                <button type="submit" class="btn-upload" style="background:#ffb300;">등록하기</button>
            </form>
        </div>
        <% } %>

        <h2 style="border-bottom: 2px solid #333; padding-bottom: 10px;">⚡ 요즘 뜨는 쇼츠</h2>
        
        <div class="shorts-grid">
            <% 
                function getYoutubeId(url) {
                    if(!url) return null;
                    const match = url.match(/(?:youtu\.be\/|youtube\.com\/(?:embed\/|v\/|watch\?v=|shorts\/|watch\?.+&v=))([^"&?\/\s]{11})/);
                    return match ? match[1] : null;
                }
            %>
            <% if (shorts && shorts.length > 0) { %>
                <% shorts.forEach(function(video) { 
                    const videoId = getYoutubeId(video.url);
                %>
                <div class="shorts-card">
                    <% if (videoId) { %>
                        
                        <div class="video-container" style="cursor: pointer;" onclick="playShorts(this, '<%= videoId %>')">
                            <img src="https://i.ytimg.com/vi/<%= videoId %>/hqdefault.jpg" alt="썸네일">
                            <div class="play-overlay"></div>
                        </div>

                        <% if (user && (user.role === 'admin' || user.id === video.uploader)) { %>
                            <form action="/delete-video/<%= video._id %>" method="POST" onsubmit="return confirm('삭제할까요?');" style="margin:0;">
                                <button type="submit" class="btn-delete">❌ 삭제</button>
                            </form>
                        <% } %>

                        <div class="info-overlay">
                            <h4 class="short-title"><%= video.title %></h4>
                            <div class="short-uploader">@<%= video.uploader %></div>
                        </div>

                    <% } else { %>
                        <div class="video-container" style="display:flex; justify-content:center; align-items:center; color:#555;">링크 오류</div>
                    <% } %>
                </div>
                <% }); %>
            <% } else { %>
                <p style="color: #777; grid-column: 1 / -1; text-align: center;">등록된 쇼츠 영상이 없습니다.</p>
            <% } %>
        </div>
    </div>

    <script>
        function playShorts(element, videoId) {
            // 클릭한 부분의 HTML을 유튜브 영상(iframe)으로 싹 갈아끼웁니다!
            element.innerHTML = `
                <iframe 
                    src="https://www.youtube.com/embed/${videoId}?autoplay=1&playsinline=1&modestbranding=1" 
                    allow="autoplay; encrypted-media" 
                    allowfullscreen>
                </iframe>
            `;
            // 한 번 클릭 후에는 커서 모양 원래대로 (클릭 안 되는 것처럼)
            element.style.cursor = 'default';
            // 클릭 이벤트 중복 실행 방지
            element.onclick = null; 
        }
    </script>
</body>
</html>