<script>
    let currentProposalUploader = "";
    let currentProposalMusicName = "";

    function sendPurchaseMsg(uploaderId, musicName) {
        currentProposalUploader = uploaderId;
        currentProposalMusicName = musicName;
        
        document.getElementById('modalMusicTitle').innerText = "곡 제목: " + musicName;
        document.getElementById('modalProposalText').value = ""; 
        document.getElementById('purchaseModal').style.display = 'flex'; 
    }

    function closePurchaseModal() {
        document.getElementById('purchaseModal').style.display = 'none';
    }

    function submitPurchaseModal() {
        const text = document.getElementById('modalProposalText').value;
        if (!text || text.trim() === "") {
            alert("제안 내용을 입력해주세요!");
            return;
        }

        document.getElementById('msgReceiverId').value = currentProposalUploader;
        document.getElementById('msgUserText').value = `[${currentProposalMusicName} 제안] ` + text;
        document.getElementById('purchaseMsgForm').submit();
        
        alert("제안이 성공적으로 전달되었습니다! 🚀");
        closePurchaseModal();
    }
</script>

<script>
    // 1. 파수꾼(서비스 워커) 등록
    if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
            navigator.serviceWorker.register('/sw.js').then(reg => {
                console.log('RAM 앱 엔진 가동 완료!');
            }).catch(err => console.log('앱 엔진 가동 실패:', err));
        });
    }

    // 2. 인앱 브라우저(네이버, 카카오 등) 감지기
    const ua = navigator.userAgent.toLowerCase();
    const isInAppBrowser = /naver|kakaotalk|line|instagram|facebook/i.test(ua);
    
    let deferredPrompt;
    const installBtn = document.getElementById('pwa-install-btn');

    if (isInAppBrowser) {
        // 🚨 네이버/카톡 앱으로 들어왔을 때: 버튼은 보여주되, 누르면 안내창 띄우기!
        if (installBtn) {
            installBtn.style.display = 'block';
            installBtn.addEventListener('click', (e) => {
                e.preventDefault();
                alert('🚨 네이버/카카오톡 등에서는 앱 설치가 차단되어 있습니다.\n\n화면 하단(또는 우측 상단)의 [점 3개 메뉴 ⋮]를 눌러\n🌐 [다른 브라우저로 열기(크롬/사파리)]를 선택하신 후 다시 눌러주세요!');
            });
        }
    } else {
        // ✅ 크롬, 사파리, 삼성 인터넷 등 정상 브라우저일 때: 진짜 설치 팝업 띄우기
        window.addEventListener('beforeinstallprompt', (e) => {
            e.preventDefault();
            deferredPrompt = e;
            if(installBtn) installBtn.style.display = 'block'; 
        });

        if(installBtn) {
            installBtn.addEventListener('click', async (e) => {
                e.preventDefault();
                if (deferredPrompt) {
                    deferredPrompt.prompt();
                    const { outcome } = await deferredPrompt.userChoice;
                    if (outcome === 'accepted') {
                        installBtn.style.display = 'none'; 
                    }
                    deferredPrompt = null;
                }
            });
        }
    }
    
    // 이미 앱으로 접속한 유저라면 숨김
    window.addEventListener('appinstalled', () => {
        if(installBtn) installBtn.style.display = 'none';
    });
    // PWA 전용 모드(standalone)로 실행 중일 때도 숨김
    if (window.matchMedia('(display-mode: standalone)').matches) {
        if(installBtn) installBtn.style.display = 'none';
    }
</script>

<script>
    if ('mediaSession' in navigator) {
        navigator.mediaSession.setActionHandler('play', () => {
            if (typeof mainAudio !== 'undefined' && mainAudio.paused) togglePlayPause();
        });
        navigator.mediaSession.setActionHandler('pause', () => {
            if (typeof mainAudio !== 'undefined' && !mainAudio.paused) togglePlayPause();
        });
        navigator.mediaSession.setActionHandler('previoustrack', () => {
            if (typeof playPrevTrack === 'function') playPrevTrack();
        });
        navigator.mediaSession.setActionHandler('nexttrack', () => {
            if (typeof playNextTrack === 'function') playNextTrack();
        });
        console.log("🚘 블루투스 리모컨 수신기 장착 완료!");
    }
</script>

<script>
    // 🚀 [실시간 레이더] 10초마다 서버에 생존 신고 & 재생 상태 보고
    setInterval(() => {
        // 현재 음악이 재생 중인지 확인
        const currentlyPlaying = (typeof isPlaying !== 'undefined') ? isPlaying : false;
        
        fetch('/api/heartbeat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ isPlaying: currentlyPlaying })
        }).catch(e => {}); // 에러나도 조용히 무시 (유저 방해 안 함)
    }, 10000);
</script>

