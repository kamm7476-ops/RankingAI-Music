<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <title><%= t.title %></title>
    <style>
        /* 2일 전 우리가 만든 블랙 & 골드 테마 */
        body { background: #121212; color: #ffffff; font-family: 'Pretendard', sans-serif; }
        .header { padding: 30px; border-bottom: 2px solid #ffd700; display: flex; justify-content: space-between; }
        .upload-form { background: #1e1e1e; padding: 25px; border-radius: 15px; margin: 30px auto; max-width: 500px; border: 1px solid #333; }
        .input-style { background: #2a2a2a; border: 1px solid #444; color: white; padding: 12px; margin-bottom: 10px; width: 90%; border-radius: 8px; }
        .gold-btn { background: linear-gradient(45deg, #ffd700, #ffae00); color: black; font-weight: bold; padding: 12px 25px; border: none; border-radius: 8px; cursor: pointer; width: 100%; }
        .gold-btn:hover { filter: brightness(1.1); }
        .artist-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 20px; padding: 40px; }
    </style>
</head>
<body>
    <div class="header">
        <h1>👑 <%= t.title %></h1>
        <div><a href="/change-lang/ko" style="color:#ffd700">KO</a> | <a href="/change-lang/en" style="color:#ffd700">EN</a></div>
    </div>

    <div class="upload-form">
        <h3>✨ <%= t.upload %></h3>
        <form action="/add-artist" method="POST" enctype="multipart/form-data">
            <input type="text" name="name" class="input-style" placeholder="이름" required>
            <input type="text" name="genre" class="input-style" placeholder="장르">
            <input type="file" name="image" class="input-style" accept="image/*" required>
            <button type="submit" class="gold-btn">등록하기</button>
        </form>
    </div>

    <div class="artist-list">
        <% if (artists.length > 0) { %>
            <% artists.forEach(function(artist) { %>
                <div style="background:#222; border-radius:10px; padding:15px; text-align:center;">
                    <img src="<%= artist.imageUrl %>" style="width:100%; border-radius:5px;">
                    <h4><%= artist.name %></h4>
                </div>
            <% }); %>
        <% } else { %>
            <p style="text-align:center; width:100%; color:#888;">아직 등록된 아티스트가 없네요. 사진을 올려보세요!</p>
        <% } %>
    </div>
</body>
</html>
