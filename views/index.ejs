<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RANKING AI</title>
    <style>
        body { background: #0b0c0d; color: #fff; font-family: 'Pretendard', sans-serif; margin: 0; padding-bottom: 100px; }
        a { text-decoration: none; color: inherit; }

        .main-header { background: #121314; border-bottom: 1px solid #222; position: sticky; top: 0; z-index: 100; }
        .header-top { display: flex; justify-content: space-between; align-items: center; padding: 15px 40px; border-bottom: 1px solid #1a1b1c; }
        .logo { font-size: 28px; font-weight: 900; color: #ff5722; letter-spacing: -1px; } 
        .top-search-form { display: flex; align-items: center; background: #222; border: 2px solid #ff5722; border-radius: 25px; padding: 5px 15px; width: 400px; }
        .top-search-input { background: none; border: none; color: white; outline: none; flex: 1; font-size: 15px; padding: 5px; }
        .top-search-btn { background: none; border: none; color: #ff5722; font-weight: bold; cursor: pointer; font-size: 16px; padding: 0 10px; }
        
        .auth-buttons { display: flex; gap: 20px; align-items: center; }
        .btn-admin { color: #ff4a4a; font-weight: bold; font-size: 14px; border: 1px solid #ff4a4a; padding: 5px 12px; border-radius: 15px; }
        .btn-login { color: #bbb; font-size: 14px; }
        .btn-signup { background: #ff5722; color: #000; padding: 8px 20px; border-radius: 20px; font-weight: bold; font-size: 14px; }

        .header-nav { display: flex; justify-content: center; gap: 40px; padding: 12px 0; background: #0b0c0d; }
        .nav-item { color: #aaa; font-weight: 600; font-size: 16px; transition: 0.2s; position: relative; }
        .nav-item:hover, .nav-item.active { color: #ff5722; }
        .nav-item.active::after { content: ''; position: absolute; bottom: -12px; left: 0; width: 100%; height: 3px; background: #ff5722; }

        .container { max-width: 1200px; margin: 0 auto; padding: 30px 20px; }
        .main-layout { display: flex; gap: 30px; align-items: flex-start; }
        .content-left { flex: 1; min-width: 0; }
        
        .sidebar-right { width: 300px; background: #161718; padding: 25px; border-radius: 15px; border: 1px solid #333; position: sticky; top: 150px; }
        .sidebar-title { color: #fff; font-size: 18px; font-weight: bold; margin-top: 0; border-bottom: 2px solid #ff5722; padding-bottom: 12px; margin-bottom: 15px; }
        .artist-list { list-style: none; padding: 0; margin: 0; }
        .artist-item { display: flex; align-items: center; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid #222; }
        .artist-rank { color: #ff5722; font-weight: 900; font-size: 18px; width: 24px; }
        .artist-name { font-size: 15px; font-weight: 500; flex: 1; cursor: pointer; color: #fff; }
        .artist-name:hover { color: #ff5722; }
        .artist-count { font-size: 12px; color: #777; background: #222; padding: 3px 8px; border-radius: 12px; }

        .upload-section { background: #161718; padding: 30px; border-radius: 15px; margin-bottom: 40px; border: 1px solid #333; }
        .input-row { display: flex; gap: 15px; margin-bottom: 15px; align-items: center; }
        input[type="text"] { flex: 1; background: #222; border: 1px solid #333; color: #fff; padding: 12px; border-radius: 8px; }
        textarea { width: 100%; background: #222; border: 1px solid #333; color: #fff; padding: 12px; border-radius: 8px; height: 80px; margin-bottom: 15px; }
        .file-upload { flex: 1; background: #222; padding: 10px; border-radius: 8px; color: #aaa; font-size: 13px; }
        .btn-upload { background: #ff5722; color: #000; border: none; padding: 12px; border-radius: 8px; cursor: pointer; font-weight: bold; width: 100%; margin-top: 10px; transition: 0.2s; }
        .btn-upload:hover { filter: brightness(1.1); }
        
        .genre-selector { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 15px; }
        .genre-btn { background: #222; color: #aaa; border: 1px solid #333; padding: 6px 14px; border-radius: 20px; cursor: pointer; font-size: 13px; transition: 0.2s; }
        .genre-btn:hover { background: #333; color: #fff; }
        .genre-btn.active { background: rgba(255, 87, 34, 0.15); color: #ff5722; border-color: #ff5722; font-weight: bold; }

        .chart-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 20px; border-bottom: 2px solid #222; padding-bottom: 15px; }
        .chart-title { font-size: 28px; font-weight: bold; display: flex; align-items: center; gap: 15px; }
        .tabs { display: flex; gap: 25px; }
        .tab { color: #777; cursor: pointer; font-weight: 600; font-size: 16px; padding-bottom: 10px; }
        .tab.active { color: #ff5722; border-bottom: 3px solid #ff5722; }

        .chart-controls { display: flex; gap: 10px; margin-bottom: 15px; align-items: center; }
        .control-btn { background: #161718; color: #fff; border: 1px solid #444; padding: 8px 15px; border-radius: 20px; font-size: 13px; cursor: pointer; display: flex; align-items: center; gap: 5px; transition: 0.2s; }
        .control-btn:hover { background: #333; border-color: #ff5722; color: #ff5722; }
        .control-my-music { background: #ff5722; color: #000; font-weight: bold; border-color: #ff5722; }

        .music-list { width: 100%; border-collapse: collapse; }
        .music-item { border-bottom: 1px solid #1a1b1c; transition: 0.2s; }
        .music-item:hover { background: rgba(255,255,255,0.02); }
        .music-item td { padding: 15px 10px; vertical-align: top; }
        .check-col { width: 30px; text-align: center; vertical-align: middle !important; }
        .custom-checkbox { width: 18px; height: 18px; accent-color: #ff5722; cursor: pointer; }
        
        .rank { font-size: 22px; font-weight: 900; color: #ff5722; width: 40px; text-align: center; vertical-align: middle !important; }
        .album-art { width: 70px; height: 70px; border-radius: 8px; object-fit: cover; box-shadow: 0 4px 10px rgba(0,0,0,0.5); }
        .song-title { font-size: 16px; font-weight: 600; display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin-bottom: 4px; }
        .singer { font-size: 13px; color: #aaa; }
        .ai-badge { background: rgba(255, 87, 34, 0.1); border: 1px solid #ff5722; color: #ff5722; font-size: 10px; padding: 2px 6px; border-radius: 12px; margin-left: 5px; }
        
        .action-row { display: flex; gap: 8px; align-items: center; margin-top: 10px; }
        .action-btn { display: flex; align-items: center; gap: 4px; background: #222; color: #aaa; padding: 4px 10px; border-radius: 20px; font-size: 12px; cursor: pointer; border: 1px solid #333; }
        .action-btn:hover { background: #333; color: #ff5722; border-color: #ff5722; }

        .hidden-box { display: none; background: #111; padding: 15px; border-radius: 8px; margin-top: 15px; font-size: 14px; color: #ccc; border: 1px solid #222; }
        .lyrics-window { max-height: 200px; overflow-y: auto; }
        .lyrics-line { padding: 5px 0; display: flex; gap: 8px; cursor: pointer; }
        .lyrics-time { color: #ff5722; font-weight: bold; width: 45px; text-align: right; }

        .bottom-player-bar { position: fixed; bottom: 0; left: 0; width: 100%; background: #1a1c1e; border-top: 2px solid #ff5722; padding: 10px 40px; box-sizing: border-box; display: flex; align-items: center; justify-content: space-between; z-index: 1000; box-shadow: 0 -5px 20px rgba(0,0,0,0.8); }
        .player-info { display: flex; align-items: center; gap: 15px; width: 300px; }
        .player-cover { width: 50px; height: 50px; border-radius: 5px; background: #000; object-fit: cover; }
        .player-text { display: flex; flex-direction: column; }
        .player-title { font-size: 15px; font-weight: bold; color: #fff; }
        .player-artist { font-size: 12px; color: #aaa; }
        .main-audio-element { flex: 1; max-width: 600px; outline: none; accent-color: #ff5722; }
        .main-audio-element::-webkit-media-controls-panel { background-color: #1a1c1e; }
        .main-audio-element::-webkit-media-controls-play-button { filter: invert(40%) sepia(80%) saturate(300%) hue-rotate(330deg) brightness(110%); }
        .main-audio-element::-webkit-media-controls-current-time-display, .main-audio-element::-webkit-media-controls-time-remaining-display { color: #fff; }

        @media (max-width: 900px) {
            .header-top { flex-direction: column; gap: 15px; padding: 15px; }
            .top-search-form { width: 100%; box-sizing: border-box; }
            .header-nav { overflow-x: auto; justify-content: flex-start; padding: 12px 20px; gap: 20px; white-space: nowrap; }
            .main-layout { flex-direction: column; }
            .sidebar-right { width: 100%; position: static; }
            
            .music-list, .music-list tbody, .music-list tr, .music-list td { display: block; width: 100%; box-sizing: border-box; }
            .music-item { margin-bottom: 25px; background: #161718; border-radius: 15px; padding: 20px; border: 1px solid #333; position: relative; }
            .music-item td { padding: 0; border: none; }
            .check-col { position: absolute; top: 15px; right: 15px; z-index: 10; border: none !important;}
            .rank { position: absolute; top: -10px; left: 15px; background: #ff5722; color: black; border-radius: 8px; padding: 2px 10px; width: auto; font-size: 16px; z-index: 10; }
            .album-art { width: 100%; height: auto; aspect-ratio: 1; margin: 10px 0; }
            
            .bottom-player-bar { padding: 10px; flex-direction: column; gap: 10px; }
            .player-info { width: 100%; }
            .main-audio-element { width: 100%; max-width: 100%; }
        }
    </style>
</head>
<body>
    <header class="main-header">
        <div class="header-top">
            <div class="logo">RANKING AI</div>
            <div id="google_translate_element" style="margin-left: 15px;"></div>
            <script type="text/javascript">
                function googleTranslateElementInit() {
                    new google.translate.TranslateElement({pageLanguage: 'ko', layout: google.translate.TranslateElement.InlineLayout.SIMPLE}, 'google_translate_element');
                }
            </script>
            <script type="text/javascript" src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
            <form action="/" method="GET" class="top-search-form">
                <input type="text" name="search" class="top-search-input" placeholder="아티스트 검색..." value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
                <button type="submit" class="top-search-btn">🔍</button>
            </form>
            <div class="auth-buttons">
                <% if (user && user.role === 'admin') { %>
                    <a href="/admin" class="btn-admin">👑 관리자</a>
                <% } %>
                
                <% if (user) { %>
                    <span style="color: #aaa; font-size: 14px;"><%= user.id %>님</span>
                    <a href="/logout" class="btn-login">로그아웃</a>
                <% } else { %>
                    <a href="/login" class="btn-login">로그인</a>
                    <a href="/signup" class="btn-signup">회원가입</a>
                <% } %>
            </div>
        </div>
        
        <div class="header-nav">
            <a href="/" class="nav-item active">RANKING AI 챠트</a>
            <a href="/" class="nav-item">최신음악</a>
            <a href="/" class="nav-item">장르별</a>
            <a href="/youtube" class="nav-item">유튜브</a>
            <a href="/shorts" class="nav-item">쇼츠</a>
            <a href="/board" class="nav-item">커뮤니티</a>
        </div>
    </header>

    <div class="container">
        <div class="main-layout">
            <div class="content-left">
                <div class="upload-section">
                    <h3 style="margin-top:0; color:#ff5722;">🎵 회원을 위한 음원 업로드</h3>
                    <form action="/add-music" method="POST" enctype="multipart/form-data" id="musicForm">
                        <div class="input-row">
                            <input type="text" name="name" placeholder="곡 제목" required>
                            <input type="text" name="artist" placeholder="아티스트" required>
                        </div>
                        
                        <div class="genre-selector">
                            <button type="button" class="genre-btn" data-genre="발라드">발라드</button>
                            <button type="button" class="genre-btn" data-genre="댄스">댄스</button>
                            <button type="button" class="genre-btn" data-genre="랩/힙합">랩/힙합</button>
                            <button type="button" class="genre-btn" data-genre="R&B/Soul">R&B/Soul</button>
                            <button type="button" class="genre-btn" data-genre="인디음악">인디음악</button>
                            <button type="button" class="genre-btn" data-genre="록/메탈">록/메탈</button>
                            <button type="button" class="genre-btn" data-genre="트로트">트로트</button>
                            <button type="button" class="genre-btn" data-genre="포크/블루스">포크/블루스</button>
                            <button type="button" class="genre-btn" data-genre="일렉트로니카">일렉트로니카</button>
                            <button type="button" class="genre-btn" data-genre="OST">OST</button>
                            <button type="button" class="genre-btn" data-genre="POP">POP</button>
                            <button type="button" class="genre-btn" data-genre="J-POP">J-POP</button>
                            <button type="button" class="genre-btn" data-genre="클래식">클래식</button>
                            <button type="button" class="genre-btn" data-genre="재즈">재즈</button>
                            <button type="button" class="genre-btn" data-genre="뉴에이지">뉴에이지</button>
                            <button type="button" class="genre-btn" data-genre="국악">국악</button>
                            <button type="button" class="genre-btn" data-genre="CCM/종교">CCM/종교</button>
                            <button type="button" class="genre-btn" data-genre="동요/태교">동요/태교</button>
                            <button type="button" class="genre-btn" data-genre="뮤지컬/연극">뮤지컬/연극</button>
                            <button type="button" class="genre-btn" data-genre="기타장르">기타장르</button>
                        </div>
                        <input type="hidden" name="genre" id="hiddenGenreInput" required>
                        
                        <div class="input-row">
                            <input type="text" name="aiTool" placeholder="사용 프로그램 (예: Suno)" required>
                            <input type="text" name="realName" placeholder="업로더 실명 (비공개)" required>
                        </div>
                        <textarea name="lyrics" placeholder="가사를 시간과 함께 입력하세요. (예: [00:15] 첫 번째 가사)"></textarea>
                        <div class="input-row">
                            <div style="flex:1;"><span style="font-size: 12px; color: #ff5722; display: block; margin-bottom: 5px;">🖼️ 커버 이미지</span><input type="file" name="image" accept="image/*" class="file-upload" required></div>
                            <div style="flex:1;"><span style="font-size: 12px; color: #ff5722; display: block; margin-bottom: 5px;">🎵 MP3 음원</span><input type="file" name="audio" accept="audio/*" class="file-upload" required></div>
                        </div>
                        <button type="submit" class="btn-upload">차트 등록하기</button>
                    </form>
                </div>

                <div class="chart-header">
                    <div class="chart-title">랭킹AI 100 
                        <% if (typeof searchQuery !== 'undefined' && searchQuery) { %>
                            <span style="font-size:16px; color:#ff5722;">(검색결과: <%= searchQuery %>) <a href="/" style="color:#aaa; text-decoration:underline;">초기화</a></span>
                        <% } %>
                    </div>
                    <div class="tabs">
                        <div class="tab active" onclick="switchTab(this)">실시간</div>
                        <div class="tab" onclick="switchTab(this)">일간</div>
                        <div class="tab" onclick="switchTab(this)">주간</div>
                        <div class="tab" onclick="switchTab(this)">월간</div>
                    </div>
                </div>

                <div class="chart-controls">
                    <input type="checkbox" id="checkAll" class="custom-checkbox" onchange="toggleAll(this)">
                    <button class="control-btn" onclick="playAll()">▶ 전체듣기</button>
                    <button class="control-btn" onclick="playSelected()">▶ 선택듣기</button>
                    <button class="control-btn" onclick="addSelectedToMyMusic()">+ 담기</button>
                    <a href="/mymusic" class="control-btn control-my-music">🎵 내 음악 보관함</a>
                </div>

                <table class="music-list">
                    <% if (artists && artists.length > 0) { %>
                        <% artists.forEach(function(music, index) { %>
                        <tr class="music-item" data-id="<%= music._id %>" data-title="<%= music.name %>" data-artist="<%= music.artist %>" data-cover="<%= music.imageUrl %>" data-audio="<%= music.audioUrl %>">
                            <td class="check-col"><input type="checkbox" class="custom-checkbox song-check" value="<%= music._id %>"></td>
                            <td class="rank"><%= index + 1 %></td>
                            <td style="width: 80px;"><img src="<%= music.imageUrl %>" class="album-art"></td>
                            <td class="song-info">
                                <div class="song-title">
                                    <%= music.name %>
                                    
                                    <% if (user && (user.id === music.uploader || user.role === 'admin') && music._id !== "dummy") { %>
                                       <button style="background:none; border:none; color:#00e5ff; cursor:pointer; font-size:12px; padding: 0 5px;" onclick="location.href='/edit/<%= music._id %>'">✏️ 수정</button>
                                        <form action="/delete-music/<%= music._id %>" method="POST" style="display:inline;" onsubmit="return confirm('삭제하시겠습니까?');">
                                            <button type="submit" style="background:none; border:none; color:#ff4a4a; cursor:pointer; font-size:12px; padding: 0;">🗑️ 삭제</button>
                                        </form>
                                    <% } %>
                                </div>
                                <div class="singer"><%= music.artist %> (<%= music.genre %>) <span class="ai-badge">🎵 <%= music.aiTool %></span></div>
                                
                                <div class="action-row">
                                    <div class="action-btn" onclick="playSingleTrack(this)">▶ 듣기</div>
                                    <div class="action-btn" onclick="parseAndShowLyrics('<%= music._id %>', `<%= music.lyrics %>`)">📝 가사</div>
                                    <div class="action-btn" onclick="document.getElementById('comments-<%= music._id %>').style.display = (document.getElementById('comments-<%= music._id %>').style.display === 'block') ? 'none' : 'block';">💬 댓글 <%= music.comments ? music.comments.length : 0 %></div>
                                    <div class="action-btn" onclick="this.innerHTML = '❤️ 좋아요 ' + (parseInt(this.innerText.replace(/[^0-9]/g, '')) + 1); this.style.color='#ff4a4a'; this.style.borderColor='#ff4a4a';">🤍 좋아요 <%= Math.floor(Math.random() * 50) + 1 %></div>
                                </div>

                                <div id="lyrics-<%= music._id %>" class="hidden-box lyrics-window"><div id="lyrics-content-<%= music._id %>"></div></div>
                                
                                <div id="comments-<%= music._id %>" class="hidden-box">
                                    <div style="max-height: 150px; overflow-y: auto; margin-bottom:15px;">
                                        <% if (music.comments && music.comments.length > 0) { %>
                                            <% music.comments.forEach(function(c) { %>
                                                <div style="border-bottom: 1px solid #333; padding: 8px 0;">
                                                    <span style="color:#ff5722; font-weight:bold; font-size:13px;"><%= c.author %></span>
                                                    <span style="font-size:14px; margin-left:8px; color:#ddd;"><%= c.text %></span>
                                                </div>
                                            <% }); %>
                                        <% } else { %>
                                            <p style="font-size:13px; color:#777;">아직 댓글이 없습니다.</p>
                                        <% } %>
                                    </div>
                                    
                                    <% if (music._id !== "dummy") { %>
                                        <form action="/add-comment/<%= music._id %>" method="POST" style="display:flex; gap:10px;">
                                            <input type="text" name="commentText" placeholder="댓글..." style="flex:1; padding:10px; border-radius:6px; border:1px solid #444; background:#222; color:white;" required>
                                            <button type="submit" style="background:#ff5722; color:black; border:none; padding:10px 20px; border-radius:6px; font-weight:bold; cursor:pointer;">등록</button>
                                        </form>
                                    <% } %>
                                </div>
                            </td>
                        </tr>
                        <% }); %>
                    <% } else { %>
                        <tr><td colspan="4" style="text-align:center; padding:100px; color:#555;">검색된 곡이 없습니다.</td></tr>
                    <% } %>
                </table>
            </div>

            <div class="sidebar-right">
                <h3 class="sidebar-title">🏆 인기 아티스트</h3>
                <ul class="artist-list">
                    <% popularArtists.forEach(function(artist, idx) { %>
                        <li class="artist-item">
                            <div style="display: flex; align-items: center; gap: 10px;">
                                <span class="artist-rank"><%= idx + 1 %></span>
                                <a href="/?search=<%= encodeURIComponent(artist._id) %>" class="artist-name"><%= artist._id %></a>
                            </div>
                            <span class="artist-count"><%= artist.count %>곡</span>
                        </li>
                    <% }); %>
                </ul>
            </div>
        </div>
    </div>

    <div class="bottom-player-bar">
        <div class="player-info">
            <img src="https://via.placeholder.com/50/222222/ff5722?text=Play" id="main-player-cover" class="player-cover">
            <div class="player-text">
                <span id="main-player-title" class="player-title">선택된 곡이 없습니다</span>
                <span id="main-player-artist" class="player-artist">목록에서 음악을 선택해주세요</span>
            </div>
        </div>
        
        <div class="player-controls-wrapper">
            <div class="player-buttons">
                <button id="btn-prev" onclick="playPrevTrack()">⏮</button>
                <button id="btn-play" onclick="togglePlayPause()" class="play-btn">▶</button>
                <button id="btn-next" onclick="playNextTrack()">⏭</button>
            </div>
            <div class="progress-area">
                <span id="time-current">00:00</span>
                <input type="range" id="progress-bar" value="0" min="0" max="100" step="1">
                <span id="time-total">00:00</span>
            </div>
        </div>
        
        <audio id="main-audio" style="display:none;"></audio>
    </div>

    <script>
        const genreBtns = document.querySelectorAll('.genre-btn');
        const hiddenInput = document.getElementById('hiddenGenreInput');
        genreBtns.forEach(btn => {
            btn.addEventListener('click', function() { 
                genreBtns.forEach(b => b.classList.remove('active')); 
                this.classList.add('active'); 
                hiddenInput.value = this.getAttribute('data-genre'); 
            });
        });
        
        document.getElementById('musicForm').addEventListener('submit', function(e) { 
            if (!hiddenInput.value) { e.preventDefault(); alert('장르를 선택해주세요!'); } 
        });

        let playlist = [];
        let currentIndex = 0;
        const mainAudio = document.getElementById('main-audio');

        function toggleAll(source) {
            const checkboxes = document.querySelectorAll('.song-check');
            checkboxes.forEach(cb => cb.checked = source.checked);
        }

        function loadTrack(index) {
            if(index >= 0 && index < playlist.length) {
                const track = playlist[index];
                if(!track.audio) { alert("음원 파일이 없는 곡입니다."); return; }
                
                document.getElementById('main-player-title').innerText = track.title;
                document.getElementById('main-player-artist').innerText = track.artist;
                document.getElementById('main-player-cover').src = track.cover;
                
                mainAudio.src = track.audio;
                mainAudio.play();
                currentIndex = index;
            }
        }

        mainAudio.addEventListener('ended', function() {
            if(currentIndex + 1 < playlist.length) loadTrack(currentIndex + 1);
        });

        function playSingleTrack(btnElement) {
            const tr = btnElement.closest('.music-item');
            playlist = [{ id: tr.dataset.id, title: tr.dataset.title, artist: tr.dataset.artist, cover: tr.dataset.cover, audio: tr.dataset.audio }];
            loadTrack(0);
        }

        function playAll() {
            const rows = document.querySelectorAll('.music-item');
            playlist = Array.from(rows).map(tr => ({ id: tr.dataset.id, title: tr.dataset.title, artist: tr.dataset.artist, cover: tr.dataset.cover, audio: tr.dataset.audio })).filter(t => t.audio !== "");
            if(playlist.length > 0) loadTrack(0); else alert("재생할 음원이 없습니다.");
        }

        function playSelected() {
            const checkedBoxes = document.querySelectorAll('.song-check:checked');
            if(checkedBoxes.length === 0) return alert("재생할 곡을 먼저 체크해주세요!");
            
            playlist = Array.from(checkedBoxes).map(cb => {
                const tr = cb.closest('.music-item');
                return { id: tr.dataset.id, title: tr.dataset.title, artist: tr.dataset.artist, cover: tr.dataset.cover, audio: tr.dataset.audio };
            }).filter(t => t.audio !== "");
            
            if(playlist.length > 0) loadTrack(0); else alert("재생 가능한 음원이 없습니다.");
        }

        function addSelectedToMyMusic() {
            const checkedBoxes = document.querySelectorAll('.song-check:checked');
            if(checkedBoxes.length === 0) return alert("담을 곡을 체크해주세요!");

            const musicIds = Array.from(checkedBoxes).map(cb => cb.value);

            fetch('/add-to-mymusic', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ musicIds: musicIds })
            })
            .then(res => res.json())
            .then(data => alert(data.message))
            .catch(err => alert("에러가 발생했습니다. 다시 시도해주세요."));
        }

        function switchTab(clickedTab) { 
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active')); 
            clickedTab.classList.add('active'); 
            alert(`[${clickedTab.innerText} 차트]로 전환합니다.`); 
        }

        function parseAndShowLyrics(musicId, rawLyrics) {
            if(musicId === "dummy") return alert("가짜 데이터입니다.");
            const lyricsWindow = document.getElementById('lyrics-' + musicId);
            const contentDiv = document.getElementById('lyrics-content-' + musicId);
            if(lyricsWindow.style.display === 'block') { lyricsWindow.style.display = 'none'; return; }
            contentDiv.innerHTML = '';
            rawLyrics.split('\n').forEach(line => {
                const match = line.match(/^\[(\d{2}):(\d{2})\](.*)$/);
                const lineDiv = document.createElement('div');
                lineDiv.className = 'lyrics-line';
                if (match) {
                    const totalSecs = parseInt(match[1]) * 60 + parseInt(match[2]);
                    lineDiv.onclick = function() { mainAudio.currentTime = totalSecs; mainAudio.play(); };
                    lineDiv.innerHTML = `<span class="lyrics-time">${match[1]}:${match[2]}</span><span class="lyrics-text">${match[3]}</span>`;
                } else if(line.trim() !== '') {
                    lineDiv.style.cursor = 'default';
                    lineDiv.innerHTML = `<span class="lyrics-time" style="visibility:hidden">00:00</span><span class="lyrics-text">${line}</span>`;
                }
                contentDiv.appendChild(lineDiv);
            });
            lyricsWindow.style.display = 'block';
        }
    </script>
</body>
</html>



