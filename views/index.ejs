        }
        #playlist-modal::-webkit-scrollbar { width: 6px; }
        #playlist-modal::-webkit-scrollbar-track { background: #181818; }
        #playlist-modal::-webkit-scrollbar-thumb { background: #444; border-radius: 3px; }
        .playlist-header { padding: 15px; border-bottom: 1px solid #282828; display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; background: #181818; z-index: 10; }

        .music-item:nth-child(1) .rank { color: #ffd700 !important; text-shadow: 0 0 10px rgba(255, 215, 0, 0.6); font-size: 26px; }
        .music-item:nth-child(2) .rank { color: #c0c0c0 !important; text-shadow: 0 0 10px rgba(192, 192, 192, 0.6); font-size: 24px; }
        .music-item:nth-child(3) .rank { color: #cd7f32 !important; text-shadow: 0 0 10px rgba(205, 127, 50, 0.6); font-size: 24px; }

        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #0b0c0d; }
        ::-webkit-scrollbar-thumb { background: #333; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #ff5722; }
        .music-item { transition: all 0.3s ease; border-left: 4px solid transparent; }
        .music-item:hover { background: rgba(255, 87, 34, 0.08) !important; border-left: 4px solid #ff5722; }
        .album-art { transition: all 0.3s ease; }
        .music-item:hover .album-art { transform: scale(1.08); box-shadow: 0 8px 15px rgba(255, 87, 34, 0.4); }

       /* 🚨 모바일 디자인 핵심 수정 구역 🚨 */
