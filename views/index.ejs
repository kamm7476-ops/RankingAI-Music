        .video-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 25px; }
        .video-card { background: #161718; border: 1px solid #222; border-radius: 12px; overflow: hidden; transition: 0.2s; }
        .video-card:hover { border-color: #ff5722; transform: translateY(-5px); }
