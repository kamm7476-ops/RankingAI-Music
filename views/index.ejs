        .popup-box { background: #161718; border: 2px solid #ff5722; border-radius: 15px; padding: 30px; width: 400px; max-width: 90%; box-shadow: 0 10px 30px rgba(255,87,34,0.3); text-align: center; position: relative; }
        .popup-title { color: #fff; font-size: 22px; font-weight: 900; margin-top: 0; margin-bottom: 15px; border-bottom: 1px solid #333; padding-bottom: 15px; }
        .popup-content { color: #ccc; font-size: 15px; line-height: 1.6; margin-bottom: 25px; white-space: pre-wrap; }
        .popup-close-btn { background: #ff5722; color: #000; font-weight: bold; border: none; padding: 10px 20px; border-radius: 8px; cursor: pointer; width: 100%; font-size: 16px; }
        .popup-close-today { background: none; border: none; color: #888; text-decoration: underline; margin-top: 15px; cursor: pointer; font-size: 13px; }
    </style>
</head>
<body>

    <% if (typeof unreadMessages !== 'undefined' && unreadMessages.length > 0) { %>
        <div class="popup-overlay" style="z-index: 10000;">
            <div class="popup-box" style="border-color: #4caf50;">
                <h2 class="popup-title" style="color: #4caf50;">💌 관리자 쪽지 도착!</h2>
                <div class="popup-content" style="color: #fff; font-size: 16px;"><%= unreadMessages[0].text %></div>
                <form action="/read-message/<%= unreadMessages[0]._id %>" method="POST">
                    <button type="submit" class="popup-close-btn" style="background: #4caf50; color: #fff;">확인했습니다</button>
                </form>
            </div>
        </div>
    <% } %>

    <% if (typeof popup !== 'undefined' && popup && popup.isActive) { %>
        <div class="popup-overlay" id="mainPopup">
            <div class="popup-box">
                <h2 class="popup-title">📢 <%= popup.title %></h2>
                <div class="popup-content"><%= popup.content %></div>
                <button class="popup-close-btn" onclick="document.getElementById('mainPopup').style.display='none'">확인</button>
                <button class="popup-close-today" onclick="closePopupForToday()">오늘 하루 보지 않기</button>
            </div>
        </div>
        <script>
            if (localStorage.getItem('hidePopupToday') === new Date().toDateString()) {
                document.getElementById('mainPopup').style.display = 'none';
            }
            function closePopupForToday() {
                localStorage.setItem('hidePopupToday', new Date().toDateString());
                document.getElementById('mainPopup').style.display = 'none';
            }
        </script>
    <% } %>

    <header class="main-header">
       <div class="header-top">
            <img src="/logo.png" alt="RANKING AI 로고" class="logo-img" onclick="window.location.href='/?sort=views'">
            
            <form action="/" method="GET" class="top-search-form">
                <div style="display: flex; align-items: center; justify-content: center; cursor: pointer; background: #fff; padding: 2px; border-radius: 4px; margin-right: 10px; box-shadow: 0 0 5px rgba(255,87,34,0.5); flex-shrink: 0;" 
                     title="클릭하면 크게 확대됩니다! 친구들에게 공유해보세요 🚀" 
                     onclick="window.open('https://api.qrserver.com/v1/create-qr-code/?size=500x500&data=https://rankingaimusic.com', '_blank')">
                    <img src="https://api.qrserver.com/v1/create-qr-code/?size=30x30&data=https://rankingaimusic.com" alt="QR Code" style="display: block; width: 24px; height: 24px;">
                </div>
                <input type="text" name="search" class="top-search-input" placeholder="아티스트 검색..." value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
                <button type="submit" class="top-search-btn">🔍</button>
            </form>

            <div class="auth-buttons">
                <select id="custom-translate-select" class="lang-select" onchange="changeLanguage(this.value)">
                    <option value="ko">🇰🇷 한국어</option>
                    <option value="en">🇺🇸 English</option>
                    <option value="zh-CN">🇨🇳 中文</option>
                    <option value="zh-TW">🇹🇼 繁體</option>
                    <option value="ja">🇯🇵 日本語</option>
                </select>

                <div id="google_translate_element" style="display:none;"></div>
                <script type="text/javascript">
                    function googleTranslateElementInit() {
                        new google.translate.TranslateElement({
                            pageLanguage: 'ko',
                            includedLanguages: 'en,ko,zh-CN,zh-TW,ja',
                            autoDisplay: false
                        }, 'google_translate_element');
                    }
                    function changeLanguage(langCode) {
                        const googleSelect = document.querySelector('.goog-te-combo');
                        if (googleSelect) {
                            googleSelect.value = langCode;
                            googleSelect.dispatchEvent(new Event('change'));
                        } else setTimeout(() => changeLanguage(langCode), 500);
                    }
                </script>
                <script type="text/javascript" src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>

                <% if (user && user.role === 'admin') { %>
                    <a href="/admin" class="btn-admin">👑 관리자</a>
                <% } %>
                
                <% if (user) { %>
                    <span style="color: #aaa; font-size: 14px;"><%= user.name || user.id %>님</span>
                    <a href="/logout" class="btn-login">로그아웃</a>
                <% } else { %>
                    <a href="/login" class="btn-login">로그인</a>
                    <a href="/signup" class="btn-signup">회원가입</a>
                <% } %>
            </div>
        </div>
        
        <div class="header-nav">
            <a href="/?sort=views" class="nav-item <%= (typeof sortQuery !== 'undefined' && sortQuery === 'views' && !genreQuery) ? 'active' : '' %>">RANKING AI 챠트</a>
            <a href="/?sort=latest" class="nav-item <%= (typeof sortQuery !== 'undefined' && sortQuery === 'latest') ? 'active' : '' %>">최신음악</a>
            <a href="/?genre=발라드" class="nav-item <%= (typeof genreQuery !== 'undefined' && genreQuery) ? 'active' : '' %>">장르별</a>
            <a href="/youtube" class="nav-item">유튜브</a>
            <a href="/shorts" class="nav-item">쇼츠</a>
            <a href="/board" class="nav-item">커뮤니티</a>
        </div>
    </header>

    <div class="container">
        <div class="main-layout">
            <div class="content-left">
                
                <% if (user) { %>
                <div class="upload-section">
                    <h3 style="margin-top:0; color:#ff5722;">🎵 회원을 위한 음원 업로드</h3>
                    <form action="/add-music" method="POST" enctype="multipart/form-data" id="musicForm">
                        <div class="input-row">
                            <input type="text" name="name" placeholder="곡 제목" required>
                            <input type="text" name="artist" placeholder="아티스트" required>
                        </div>
                        
                     <div class="genre-selector">
                            <button type="button" class="genre-btn" data-genre="K-POP">K-POP</button>
                            <button type="button" class="genre-btn" data-genre="POP">POP</button>
                            <button type="button" class="genre-btn" data-genre="J-POP">J-POP</button>
                            <button type="button" class="genre-btn" data-genre="C-POP">C-POP</button>
                            <button type="button" class="genre-btn" data-genre="V-POP">V-POP</button>
                            <button type="button" class="genre-btn" data-genre="T-POP">T-POP</button>
                            <button type="button" class="genre-btn" data-genre="발라드">발라드</button>
                            <button type="button" class="genre-btn" data-genre="댄스">댄스</button>
                            <button type="button" class="genre-btn" data-genre="랩/힙합">랩/힙합</button>
                            <button type="button" class="genre-btn" data-genre="R&B/Soul">R&B/Soul</button>
                            <button type="button" class="genre-btn" data-genre="인디음악">인디음악</button>
                            <button type="button" class="genre-btn" data-genre="록/메탈">록/메탈</button>
                            <button type="button" class="genre-btn" data-genre="트로트">트로트</button>
                            <button type="button" class="genre-btn" data-genre="일렉트로니카">일렉트로니카</button>
                            <button type="button" class="genre-btn" data-genre="클래식/재즈">클래식/재즈</button>
                            <button type="button" class="genre-btn" data-genre="기타장르">기타장르</button>
                        </div>
                        <input type="hidden" name="genre" id="hiddenGenreInput" required>
                        
                        <div class="input-row">
                            <input type="text" name="aiTool" placeholder="사용 프로그램 (예: Suno)" required>
                            <input type="text" name="realName" placeholder="업로더 실명 (비공개)" required>
                        </div>
                        <textarea name="lyrics" placeholder="가사를 시간과 함께 입력하세요. (예: [00:15] 첫 번째 가사)"></textarea>
                        <div class="input-row">
                            <div style="flex:1;"><span style="font-size: 12px; color: #ff5722; display: block; margin-bottom: 5px;">🖼️ 커버 이미지 (선택)</span><input type="file" name="image" accept="image/*" class="file-upload"></div>
                            <div style="flex:1;"><span style="font-size: 12px; color: #ff5722; display: block; margin-bottom: 5px;">🎵 MP3 음원 (필수)</span><input type="file" name="audio" accept="audio/*" class="file-upload" required></div>
                        </div>
                        <button type="submit" class="btn-upload">차트 등록하기</button>
                    </form>
                </div>
                <% } else { %>
                <div class="upload-section" style="text-align: center; padding: 40px 20px;">
                    <div style="font-size: 40px; margin-bottom: 10px;">🔒</div>
                    <h3 style="margin-top:0; color:#aaa;">음원 업로드는 회원 전용입니다</h3>
                    <p style="color: #777; font-size: 14px; margin-bottom: 20px;">나만의 AI 음악을 차트에 올리고 싶다면 로그인해주세요!</p>
                    <button onclick="location.href='/login'" class="btn-upload" style="width: auto; padding: 10px 40px;">로그인하러 가기</button>
                </div>
                <% } %>

                <% if (user && user.role === 'admin') { %>
                <div class="upload-section" style="border-color: #ff4a4a; background: #1a1111;">
                    <h3 style="margin-top:0; color:#ff4a4a;">👑 관리자 팝업 공지 설정</h3>
                    <form action="/admin/popup" method="POST">
                        <input type="text" name="title" placeholder="팝업 제목 (예: 긴급 서버 점검 안내)" required style="width: 100%; box-sizing: border-box; margin-bottom: 10px; border: 1px solid #ff4a4a; padding: 12px; border-radius: 8px; background: #222; color: #fff;">
                        <textarea name="content" placeholder="팝업 내용을 적어주세요!" required style="border: 1px solid #ff4a4a; width: 100%; box-sizing: border-box; padding: 12px; border-radius: 8px; background: #222; color: #fff; height: 80px; margin-bottom: 15px;"></textarea>
                        
                        <div style="display: flex; align-items: center; justify-content: space-between;">
                            <label style="color: #fff; font-weight: bold; cursor: pointer; display: flex; align-items: center; gap: 10px;">
                                <input type="checkbox" name="isActive" checked style="width: 20px; height: 20px; accent-color: #ff4a4a;"> 
                                메인 화면에 팝업 띄우기 (ON/OFF)
                            </label>
                            <button type="submit" class="btn-upload" style="background: #ff4a4a; width: auto; margin-top: 0; padding: 10px 30px;">적용하기</button>
                        </div>
                    </form>
                </div>
                <% } %>

                <div class="chart-header">
                    <div class="chart-title">랭킹AI 100 
                        <% if (typeof searchQuery !== 'undefined' && searchQuery) { %>
                            <span style="font-size:16px; color:#ff5722;">(검색결과: <%= searchQuery %>) <a href="/" style="color:#aaa; text-decoration:underline;">초기화</a></span>
                        <% } %>
                    </div>
                    <div class="tabs">
                        <a href="/?sort=views" class="tab <%= (typeof periodQuery === 'undefined' || !periodQuery) ? 'active' : '' %>">실시간(전체)</a>
                        <a href="/?period=daily" class="tab <%= (typeof periodQuery !== 'undefined' && periodQuery === 'daily') ? 'active' : '' %>">일간</a>
                        <a href="/?period=weekly" class="tab <%= (typeof periodQuery !== 'undefined' && periodQuery === 'weekly') ? 'active' : '' %>">주간</a>
                        <a href="/?period=monthly" class="tab <%= (typeof periodQuery !== 'undefined' && periodQuery === 'monthly') ? 'active' : '' %>">월간</a>
                    </div>
                </div>
<% if (typeof genreQuery !== 'undefined' && genreQuery) { %>
                    <div style="background: #161718; padding: 15px; border-radius: 10px; margin-bottom: 20px; border: 1px solid #333; display: flex; gap: 8px; flex-wrap: wrap;">
                       <% const displayGenres = ['K-POP','POP','J-POP','C-POP','V-POP','T-POP','발라드','댄스','랩/힙합','R&B/Soul','인디음악','록/메탈','트로트','일렉트로니카','클래식/재즈','기타장르']; %>
                        <% displayGenres.forEach(g => { %>
                            <a href="/?genre=<%= g %>" style="padding: 6px 14px; border-radius: 20px; font-size: 13px; font-weight: bold; border: 1px solid <%= genreQuery === g ? '#ff5722' : '#444' %>; background: <%= genreQuery === g ? '#ff5722' : '#222' %>; color: <%= genreQuery === g ? '#000' : '#aaa' %>; transition: 0.2s;"><%= g %></a>
                        <% }) %>
                    </div>
                <% } %>
                <div class="chart-controls">
                    <input type="checkbox" id="checkAll" class="custom-checkbox" onchange="toggleAll(this)">
                    <button class="control-btn" onclick="playAll()">▶ 전체듣기</button>
                    <button class="control-btn" onclick="playSelected()">▶ 선택듣기</button>
                    <button class="control-btn" onclick="addSelectedToMyMusic()">+ 담기</button>
                    <a href="/mymusic" class="control-btn control-my-music">🎵 내 음악 보관함</a>
                </div>

                <table class="music-list">
                    <% if (artists && artists.length > 0) { %>
                        <% artists.forEach(function(music, index) { %>
                        <tr class="music-item" data-id="<%= music._id %>" data-title="<%= music.name %>" data-artist="<%= music.artist %>" data-cover="<%= music.imageUrl || 'https://via.placeholder.com/512/1a1a1a/ff5722?text=RANKING+AI' %>" data-audio="<%= music.audioUrl %>">
                            <td class="check-col"><input type="checkbox" class="custom-checkbox song-check" value="<%= music._id %>"></td>
                            <td class="rank"><%= index + 1 %></td>
                            <td style="width: 80px;"><img src="<%= music.imageUrl || 'https://via.placeholder.com/512/1a1a1a/ff5722?text=RANKING+AI' %>" class="album-art"></td>
                            
                            <td class="song-info">
                                <div class="song-title">
                                    <%= music.name %>
                                    
                                    <% if (user && (user.role === 'admin' || user.id === music.uploader) && music._id !== "dummy") { %>
                                        <div style="margin-left: 10px; display: inline-flex; gap: 8px; align-items: center; background: rgba(0,0,0,0.5); padding: 3px 10px; border-radius: 6px; border: 1px solid #444;">
                                            <% if (user.role === 'admin') { %><span title="관리자 권한" style="font-size: 10px;">👑</span><% } %>
                                            <a href="/edit/<%= music._id %>" style="color: #00e5ff; font-size: 11px; font-weight: bold; text-decoration: none; cursor: pointer;">수정</a>
                                            <span style="color: #555; font-size: 10px;">|</span>
                                            <form action="/delete-music/<%= music._id %>" method="POST" onsubmit="return confirm('이 음원을 차트에서 정말 삭제하시겠습니까?');" style="display: flex; align-items: center; margin: 0;">
                                                <button type="submit" style="background: none; border: none; color: #ff4a4a; font-size: 11px; font-weight: bold; cursor: pointer; padding: 0; font-family: inherit;">삭제</button>
                                            </form>
                                        </div>
                                    <% } %>
                                </div>
                                <div class="singer"><%= music.artist %> (<%= music.genre %>) <span class="ai-badge">🎵 <%= music.aiTool %></span> <span style="margin-left:10px; color:#ff5722; font-size:12px;">🎧 재생 <%= music.views || 0 %>회</span></div>
                                
                                <div class="action-row">
                                    <div class="action-btn" onclick="playSingleTrack(this)">▶ 듣기</div>
                                    <div class="action-btn" onclick="parseAndShowLyrics('<%= music._id %>', `<%= music.lyrics %>`)">📝 가사</div>
                                    <div class="action-btn" onclick="copyMusicLink('<%= music._id %>')">🔗 공유</div>
                                    <div class="action-btn" onclick="document.getElementById('comments-<%= music._id %>').style.display = (document.getElementById('comments-<%= music._id %>').style.display === 'block') ? 'none' : 'block';">💬 댓글 <%= music.comments ? music.comments.length : 0 %></div>
        
                                    <% 
                                        let isLiked = false;
                                        if (user && music.likedBy && music.likedBy.includes(user.id)) {
                                            isLiked = true;
                                        }
                                    %>
                                    <div class="action-btn" id="like-btn-<%= music._id %>" onclick="likeMusic('<%= music._id %>')" style="<%= isLiked ? 'color:#ff4a4a; border-color:#ff4a4a;' : '' %>">
                                        <%= isLiked ? '❤️' : '🤍' %> 좋아요 <span id="like-count-<%= music._id %>"><%= music.views || 0 %></span>
                                    </div>
                                </div>

                                <div id="lyrics-<%= music._id %>" class="hidden-box lyrics-window"><div id="lyrics-content-<%= music._id %>"></div></div>
                                
                                <div id="comments-<%= music._id %>" class="hidden-box">
                                    <div style="max-height: 150px; overflow-y: auto; margin-bottom:15px;">
                                        <% if (music.comments && music.comments.length > 0) { %>
                                            <% music.comments.forEach(function(c) { %>
                                                <div style="border-bottom: 1px solid #333; padding: 8px 0; display: flex; justify-content: space-between; align-items: center;">
                                                    <div>
                                                        <span style="color:#ff5722; font-weight:bold; font-size:13px;"><%= c.author %></span>
                                                        <span style="font-size:14px; margin-left:8px; color:#ddd;"><%= c.text %></span>
                                                    </div>
                                                    <% if (user && (user.role === 'admin' || user.id === c.author)) { %>
                                                        <form action="/delete-music-comment/<%= music._id %>/<%= c._id %>" method="POST" style="margin: 0;" onsubmit="return confirm('이 댓글을 삭제할까요?');">
                                                            <button type="submit" style="background: none; border: none; color: #ff4a4a; font-size: 11px; cursor: pointer;">❌삭제</button>
                                                        </form>
                                                    <% } %>
                                                </div>
                                            <% }); %>
                                        <% } else { %>
                                            <p style="font-size:13px; color:#777;">아직 댓글이 없습니다.</p>
                                        <% } %>
                                    </div>
                                    
                                    <% if (music._id !== "dummy") { %>
                                        <form action="/add-comment/<%= music._id %>" method="POST" style="display:flex; gap:10px;">
                                            <input type="text" name="commentText" placeholder="댓글..." style="flex:1; padding:10px; border-radius:6px; border:1px solid #444; background:#222; color:white;" required>
                                            <button type="submit" style="background:#ff5722; color:black; border:none; padding:10px 20px; border-radius:6px; font-weight:bold; cursor:pointer;">등록</button>
                                        </form>
                                    <% } %>
                                </div>
                            </td>
                        </tr>
                        <% }); %>
                    <% } else { %>
                        <tr><td colspan="4" style="text-align:center; padding:100px; color:#555;">검색된 곡이 없습니다.</td></tr>
                    <% } %>
                </table>
            </div>

            <div class="sidebar-right">
                <h3 class="sidebar-title">🏆 인기 아티스트</h3>
                <ul class="artist-list">
                    <% popularArtists.forEach(function(artist, idx) { %>
                        <li class="artist-item">
                            <div style="display: flex; align-items: center; gap: 10px;">
                                <span class="artist-rank"><%= idx + 1 %></span>
                                <a href="/?search=<%= encodeURIComponent(artist._id) %>" class="artist-name"><%= artist._id %></a>
                            </div>
                            <span class="artist-count"><%= artist.count %>곡</span>
                        </li>
                    <% }); %>
                </ul>
            <div class="ad-section" style="margin-top: 30px; padding: 20px; background: rgba(255,87,34,0.03); border: 1px solid #222; border-radius: 12px; text-align: center;">
        <span style="font-size: 11px; color: #555; display: block; margin-bottom: 15px; letter-spacing: 2px;">SPONSORED / NOTICE</span>
        
        <div style="min-height: 100px; display: flex; flex-direction: column; justify-content: center; align-items: center;">
            <p style="color: #bbb; font-size: 14px; line-height: 1.6; margin: 0;">
                Ranking AI와 함께 성장할<br>파트너를 기다립니다.
            </p>
            
            <a href="/contact" style="margin-top: 15px; font-size: 13px; color: #ff5722; font-weight: bold; text-decoration: underline; text-underline-offset: 4px;">
    💬 제휴 및 홍보 문의하기 (1:1 DM)
</a>
        </div>
    </div>

            </div>
        </div>
    </div>

    <div class="bottom-player-bar" id="bottomPlayerBar">
        <div class="player-toggle-tab" onclick="togglePlayerVisibility()">▼ 숨기기</div>
        
        <div class="player-info">
            <img src="https://via.placeholder.com/50/282828/ff5722?text=Play" id="main-player-cover" class="player-cover">
            <div class="player-text">
                <span id="main-player-title" class="player-title">선택된 곡이 없습니다</span>
                <span id="main-player-artist" class="player-artist">목록에서 음악을 선택해주세요</span>
            </div>
        </div>
        
        <div class="player-controls-wrapper">
           <div class="player-buttons">
               <button id="id-btn-loop" onclick="toggleLoop()" title="한곡 반복">🔁</button>
               <button id="btn-prev" onclick="playPrevTrack()">⏮</button>
               <button id="btn-play" onclick="togglePlayPause()" class="play-btn">▶</button>
               <button id="btn-next" onclick="playNextTrack()">⏭</button>
            </div>
            <div class="progress-area">
                <span id="time-current">00:00</span>
                <input type="range" id="progress-bar" value="0" min="0" max="100" step="1">
                <span id="time-total">00:00</span>
            </div>
        </div>

        <div class="player-right-placeholder">
            <button onclick="togglePlaylist()" style="background:none; border:none; color:#b3b3b3; font-size:22px; cursor:pointer;" title="재생목록 보기">💽</button>
        </div>
        
        <audio id="main-audio" style="display:none;" preload="auto" playsinline webkit-playsinline></audio>
        <audio id="heartbeat-audio" loop playsinline webkit-playsinline style="display:none;" src="data:audio/wav;base64,UklGRigAAABXQVZFZm10IBIAAAABAAEARKwAAIhYAQACABAAAABkYXRhAgAAAAEA"></audio>
    </div>

    <div id="playlist-modal">
        <div class="playlist-header">
            <strong style="color:#fff; font-size:14px;">현재 재생 목록</strong>
            <button onclick="togglePlaylist()" style="background:none; border:none; color:#aaa; font-size:18px; cursor:pointer; padding:0; line-height:1;">✕</button>
        </div>
        <ul id="playlist-ul" style="list-style:none; padding:0; margin:0;">
            <li style="padding:20px; text-align:center; color:#777; font-size:12px;">재생할 곡을 선택해주세요.</li>
        </ul>
    </div>

    <script>
        let isLoop = false; 
        function toggleLoop() {
            const btnLoop = document.getElementById('id-btn-loop');
            isLoop = !isLoop;
            if (isLoop) { btnLoop.style.color = "#ff5722"; btnLoop.innerText = "🔂"; } 
            else { btnLoop.style.color = "#777"; btnLoop.innerText = "🔁"; }
        }
        
        function parseAndShowLyrics(musicId, rawLyrics) {
            const lyricsBox = document.getElementById('lyrics-' + musicId);
            const lyricsContent = document.getElementById('lyrics-content-' + musicId);
            if (!lyricsBox || !lyricsContent) return;
            if (lyricsBox.style.display === 'block') { lyricsBox.style.display = 'none'; return; }
            if (!rawLyrics || rawLyrics.trim() === "" || rawLyrics === "undefined" || rawLyrics === "null") {
                lyricsContent.innerHTML = "<p style='color:#777; text-align:center;'>등록된 가사가 없습니다.</p>";
            } else {
                lyricsContent.innerHTML = `<div style="line-height:1.8; padding:10px;">${rawLyrics.split('\n').join('<br>')}</div>`;
            }
            lyricsBox.style.display = 'block';
        }

        function togglePlayerVisibility() {
            const playerBar = document.getElementById('bottomPlayerBar');
            const toggleTab = document.querySelector('.player-toggle-tab');
            playerBar.classList.toggle('collapsed');
            if (playerBar.classList.contains('collapsed')) toggleTab.innerText = '▲ 열기';
            else toggleTab.innerText = '▼ 숨기기';
        }

        // 🌟 재생목록 토글 & UI 업데이트 함수 🌟
        function togglePlaylist() {
            const modal = document.getElementById('playlist-modal');
            if (modal.style.display === 'block') {
                modal.style.display = 'none';
            } else {
                updatePlaylistUI();
                modal.style.display = 'block';
            }
        }

        function updatePlaylistUI() {
            const ul = document.getElementById('playlist-ul');
            ul.innerHTML = '';
            if (playlist.length === 0) {
                ul.innerHTML = '<li style="padding:20px; text-align:center; color:#777; font-size:12px;">재생할 곡을 선택해주세요.</li>';
                return;
            }
            playlist.forEach((track, i) => {
                const li = document.createElement('li');
                const isCurrent = (i === currentIndex);
                li.style = `padding:10px 15px; border-bottom:1px solid #222; display:flex; align-items:center; gap:12px; cursor:pointer; transition:0.2s; ${isCurrent ? 'background:rgba(255,87,34,0.1);' : ''}`;
                li.onclick = () => { loadTrack(i); };
                li.innerHTML = `
                    <img src="${track.cover || 'https://via.placeholder.com/50/282828/ff5722'}" style="width:36px; height:36px; border-radius:4px; object-fit:cover;">
                    <div style="display:flex; flex-direction:column; overflow:hidden; flex:1;">
                        <span style="font-size:13px; font-weight:${isCurrent ? 'bold' : 'normal'}; color:${isCurrent ? '#ff5722' : '#fff'}; white-space:nowrap; text-overflow:ellipsis; overflow:hidden;">${track.title}</span>
                        <span style="font-size:11px; color:#aaa; white-space:nowrap; text-overflow:ellipsis; overflow:hidden;">${track.artist}</span>
                    </div>
                    ${isCurrent ? '<span style="font-size:10px; color:#ff5722;">🎵</span>' : ''}
                `;
                ul.appendChild(li);
            });
        }

        const genreBtns = document.querySelectorAll('.genre-btn');
        const hiddenInput = document.getElementById('hiddenGenreInput');
        genreBtns.forEach(btn => {
            btn.addEventListener('click', function() { 
                genreBtns.forEach(b => b.classList.remove('active')); 
                this.classList.add('active'); 
                if(hiddenInput) hiddenInput.value = this.getAttribute('data-genre'); 
            });
        });
        
        const musicForm = document.getElementById('musicForm');
        if (musicForm) musicForm.addEventListener('submit', function(e) { if (hiddenInput && !hiddenInput.value) { e.preventDefault(); alert('장르를 선택해주세요!'); } });

        let playlist = []; let currentIndex = 0; let isPlaying = false;
        const mainAudio = document.getElementById('main-audio');
        const heartbeatAudio = document.getElementById('heartbeat-audio'); 
        const btnPlay = document.getElementById('btn-play');
        const progressBar = document.getElementById('progress-bar');
        const timeCurrent = document.getElementById('time-current');
        const timeTotal = document.getElementById('time-total');

        let isAudioUnlocked = false;
        function unlockAudioForMobile() {
            if (isAudioUnlocked) return;
            heartbeatAudio.play().then(() => {
                mainAudio.play().then(() => {
                    mainAudio.pause();
                    isAudioUnlocked = true;
                    console.log("💓 심장박동 가동 완료! 이제 크롬이 잠들지 않습니다.");
                    document.removeEventListener('touchstart', unlockAudioForMobile);
                    document.removeEventListener('click', unlockAudioForMobile);
                }).catch(e => {});
            }).catch(e => {});
        }
        document.addEventListener('touchstart', unlockAudioForMobile, { passive: true });
        document.addEventListener('click', unlockAudioForMobile);

        function toggleAll(source) { document.querySelectorAll('.song-check').forEach(cb => cb.checked = source.checked); }

        function togglePlayPause() {
            if (playlist.length === 0) return alert("재생할 곡을 선택해주세요!");
            if (mainAudio.paused) {
                mainAudio.play(); isPlaying = true;
                if(btnPlay) btnPlay.innerText = "⏸";
                if ('mediaSession' in navigator) navigator.mediaSession.playbackState = "playing";
            } else {
                mainAudio.pause(); isPlaying = false;
                if(btnPlay) btnPlay.innerText = "▶";
                if ('mediaSession' in navigator) navigator.mediaSession.playbackState = "paused";
            }
        }

        function loadTrack(index) {
            if(index >= 0 && index < playlist.length) {
                const track = playlist[index];
                currentIndex = index; 
                
                // 곡이 바뀔 때마다 재생목록 UI 갱신
                updatePlaylistUI();
                
                if(!track.audio || track.audio.trim() === "" || track.audio === "undefined") {
                    setTimeout(() => playNextTrack(), 500); 
                    return; 
                }
                
                document.getElementById('main-player-title').innerText = track.title;
                document.getElementById('main-player-artist').innerText = track.artist;
                document.getElementById('main-player-cover').src = track.cover;
                
                mainAudio.src = track.audio;
                mainAudio.load(); 
                
                const playPromise = mainAudio.play();
                if (playPromise !== undefined) {
                    playPromise.then(() => {
                        isPlaying = true;
                        if(btnPlay) btnPlay.innerText = "⏸";

                        if ('mediaSession' in navigator) {
                            navigator.mediaSession.playbackState = "playing";
                            navigator.mediaSession.metadata = new MediaMetadata({
                                title: track.title, artist: track.artist || 'RANKING AI', album: 'RANKING AI TOP 100',
                                artwork: [{ src: track.cover || 'https://via.placeholder.com/512/1a1a1a/ff5722?text=RANKING+AI', sizes: '512x512', type: 'image/jpeg' }]
                            });
                            navigator.mediaSession.setActionHandler('previoustrack', () => playPrevTrack());
                            navigator.mediaSession.setActionHandler('nexttrack', () => playNextTrack());
                            navigator.mediaSession.setActionHandler('play', () => togglePlayPause());
                            navigator.mediaSession.setActionHandler('pause', () => togglePlayPause());
                        }
                    }).catch(e => {
                        if (e.name === 'NotAllowedError') { isPlaying = false; if(btnPlay) btnPlay.innerText = "▶"; } 
                        else { setTimeout(() => playNextTrack(), 1000); }
                    });
                }
                if (track.id && track.id !== "dummy") fetch('/play-count/' + track.id, { method: 'POST', keepalive: true }).catch(err => {});
            }
        }

        function playPrevTrack() { if (currentIndex > 0) loadTrack(currentIndex - 1); else alert("첫 번째 곡입니다."); }
        function playNextTrack() {
            if (currentIndex < playlist.length - 1) loadTrack(currentIndex + 1);
            else { 
                mainAudio.pause(); isPlaying = false;
                if(btnPlay) btnPlay.innerText = "▶"; 
                if ('mediaSession' in navigator) navigator.mediaSession.playbackState = "paused";
            }
        }

        mainAudio.addEventListener('timeupdate', () => {
            const current = mainAudio.currentTime; const duration = mainAudio.duration;
            if (duration && !isNaN(duration)) {
                progressBar.value = (current / duration) * 100;
                let minC = Math.floor(current / 60); let secC = Math.floor(current % 60);
                if(secC < 10) secC = "0" + secC; timeCurrent.innerText = minC + ":" + secC;
                let minD = Math.floor(duration / 60); let secD = Math.floor(duration % 60);
                if(secD < 10) secD = "0" + secD; timeTotal.innerText = minD + ":" + secD;
            }
        });

        progressBar.addEventListener('input', () => { if (mainAudio.duration) mainAudio.currentTime = (progressBar.value / 100) * mainAudio.duration; });

        mainAudio.addEventListener('ended', () => {
            if (isLoop) {
                mainAudio.currentTime = 0;
                mainAudio.play().catch(e => setTimeout(() => playNextTrack(), 1000));
            } else {
                playNextTrack(); 
            }
        });

        mainAudio.addEventListener('error', (e) => { setTimeout(() => playNextTrack(), 1000); });

        function playSingleTrack(btnElement) {
            const tr = btnElement.closest('.music-item'); const audioUrl = tr.dataset.audio;
            if (!audioUrl || audioUrl === "undefined" || audioUrl.trim() === "") return alert("아직 음원이 제대로 업로드되지 않은 곡입니다!");
            playlist = [{ id: tr.dataset.id, title: tr.dataset.title, artist: tr.dataset.artist, cover: tr.dataset.cover, audio: audioUrl }];
            loadTrack(0);
        }

        function playAll() {
            const rows = document.querySelectorAll('.music-item');
            playlist = Array.from(rows).map(tr => ({ id: tr.dataset.id, title: tr.dataset.title, artist: tr.dataset.artist, cover: tr.dataset.cover, audio: tr.dataset.audio })).filter(t => t.audio && t.audio.trim() !== "" && t.audio !== "undefined");
            if(playlist.length > 0) { currentIndex = 0; loadTrack(0); } else alert("재생 가능한 음원이 없습니다.");
        }

        function playSelected() {
            const checkedBoxes = document.querySelectorAll('.song-check:checked');
            if(checkedBoxes.length === 0) return alert("재생할 곡을 먼저 체크해주세요!");
            playlist = Array.from(checkedBoxes).map(cb => {
                const tr = cb.closest('.music-item');
                return { id: tr.dataset.id, title: tr.dataset.title, artist: tr.dataset.artist, cover: tr.dataset.cover, audio: tr.dataset.audio };
            }).filter(t => t.audio && t.audio.trim() !== "" && t.audio !== "undefined");
            if(playlist.length > 0) { currentIndex = 0; loadTrack(0); } else alert("선택한 곡 중에 재생 가능한 음원이 없습니다.");
        }

        function addSelectedToMyMusic() {
            const checkedBoxes = document.querySelectorAll('.song-check:checked');
            if(checkedBoxes.length === 0) return alert("담을 곡을 체크해주세요!");
            const musicIds = Array.from(checkedBoxes).map(cb => cb.value);
            fetch('/add-to-mymusic', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ musicIds: musicIds }) })
            .then(res => res.json()).then(data => alert(data.message)).catch(err => alert("에러가 발생했습니다. 다시 시도해주세요."));
        }

        document.addEventListener('click', async (e) => {
            const link = e.target.closest('a'); if (!link) return;
            const href = link.getAttribute('href');
            // 🌟 admin을 예외 처리 목록에 추가했습니다!
            if (href && href.startsWith('/') && !href.includes('admin') && !href.includes('delete') && !href.includes('logout') && !href.includes('login') && !href.includes('signup') && !href.includes('edit') && !href.includes('shorts') && !href.includes('youtube')) {
                e.preventDefault(); navigateTo(href);
            }
        });

        document.addEventListener('submit', async (e) => {
            const form = e.target;
            if (form.method.toLowerCase() === 'get') {
                e.preventDefault(); const formData = new FormData(form);
                navigateTo(form.getAttribute('action') + '?' + new URLSearchParams(formData).toString());
            }
        });

        async function navigateTo(href) {
            try {
                const response = await fetch(href); const html = await response.text();
                const newDoc = new DOMParser().parseFromString(html, 'text/html');
                const currentContainer = document.querySelector('.container'); const newContainer = newDoc.querySelector('.container');
                if (currentContainer && newContainer) currentContainer.innerHTML = newContainer.innerHTML;
                const currentNav = document.querySelector('.header-nav'); const newNav = newDoc.querySelector('.header-nav');
                if (currentNav && newNav) currentNav.innerHTML = newNav.innerHTML;
                history.pushState(null, '', href); document.title = newDoc.title;
                
                const playerBar = document.getElementById('bottomPlayerBar');
                if (playerBar) {
                    if (href.includes('/youtube') || href.includes('/shorts') || href.includes('/board')) playerBar.style.display = 'none';
                    else playerBar.style.display = 'flex'; 
                }
                reattachEvents(); window.scrollTo(0, 0); 
            } catch (err) { location.href = href; }
        }

        window.addEventListener('popstate', async () => navigateTo(location.pathname + location.search));

        function reattachEvents() {
            const genreBtns = document.querySelectorAll('.genre-btn'); const hiddenInput = document.getElementById('hiddenGenreInput');
            genreBtns.forEach(btn => {
                btn.addEventListener('click', function() { 
                    genreBtns.forEach(b => b.classList.remove('active')); this.classList.add('active'); 
                    if(hiddenInput) hiddenInput.value = this.getAttribute('data-genre'); 
                });
            });
            const musicForm = document.getElementById('musicForm');
            if(musicForm) musicForm.addEventListener('submit', function(e) { if (hiddenInput && !hiddenInput.value) { e.preventDefault(); alert('장르를 선택해주세요!'); } });
        }

        async function likeMusic(musicId) {
            try {
                const response = await fetch('/like/' + musicId, { method: 'POST' }); const data = await response.json();
                if (data.success) {
                    const countSpan = document.getElementById('like-count-' + musicId); countSpan.innerText = parseInt(countSpan.innerText) + 1;
                    const btn = document.getElementById('like-btn-' + musicId);
                    btn.innerHTML = '❤️ 좋아요 <span id="like-count-' + musicId + '">' + countSpan.innerText + '</span>';
                    btn.style.color = '#ff4a4a'; btn.style.borderColor = '#ff4a4a';
                } else alert(data.message);
            } catch (err) { alert("에러가 발생했습니다."); }
        } 

        function copyMusicLink(musicId) {
            navigator.clipboard.writeText(window.location.origin + '/?play=' + encodeURIComponent(musicId)).then(() => alert("노래 공유 링크가 복사되었습니다! 친구들에게 자랑해보세요. 🔗"));
        }  
    </script>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const imageInput = document.querySelector('input[name="image"]');
            if (imageInput) {
                imageInput.addEventListener('change', function(e) {
                    const file = e.target.files[0];
                    if (!file || !file.type.match(/image.*/)) return;
                    const reader = new FileReader();
                    reader.onload = function(event) {
                        const img = new Image();
                        img.src = event.target.result;
                        img.onload = function() {
                            const MAX_WIDTH = 800;
                            let width = img.width; let height = img.height;
                            if (width > MAX_WIDTH) { height = Math.round((height * MAX_WIDTH) / width); width = MAX_WIDTH; }
                            const canvas = document.createElement('canvas');
                            canvas.width = width; canvas.height = height;
                            const ctx = canvas.getContext('2d');
                            ctx.drawImage(img, 0, 0, width, height);
                            canvas.toBlob(function(blob) {
                                const compressedFile = new File([blob], file.name.replace(/\.[^/.]+$/, "") + ".jpg", { type: 'image/jpeg', lastModified: Date.now() });
                                const dataTransfer = new DataTransfer();
                                dataTransfer.items.add(compressedFile);
                                imageInput.files = dataTransfer.files;
                                const infoSpan = imageInput.parentElement.querySelector('.compress-info');
                                if (!infoSpan) {
                                    const span = document.createElement('span'); span.className = 'compress-info'; span.style = "color: #ffb300; font-size: 11px; margin-left: 10px; font-weight: bold;";
                                    span.innerText = `✅ 초고속 압축 완료! (${(compressedFile.size / 1024).toFixed(1)}KB)`; imageInput.parentElement.appendChild(span);
                                } else infoSpan.innerText = `✅ 초고속 압축 완료! (${(compressedFile.size / 1024).toFixed(1)}KB)`;
                            }, 'image/jpeg', 0.8);
                        }
                    }
                    reader.readAsDataURL(file);
                });
            }
        });
    </script>
</body>
</html>