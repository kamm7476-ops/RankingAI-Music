<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <title><%= t.title %></title>
    <style>
        body { background-color: #000; color: #fff; font-family: 'Noto Sans KR', sans-serif; margin: 0; }
        .header { padding: 20px 40px; border-bottom: 1px solid #222; display: flex; justify-content: space-between; align-items: center; }
        .header h1 { color: #00cd3c; font-size: 24px; }
        .upload-section { background: #111; padding: 30px; border-radius: 15px; margin: 20px auto; max-width: 500px; border: 1px solid #333; }
        .input-field { background: #222; border: 1px solid #444; color: #fff; padding: 10px; width: 90%; margin-bottom: 10px; border-radius: 5px; }
        .submit-btn { background: #00cd3c; color: #000; font-weight: bold; padding: 12px; border: none; width: 100%; border-radius: 5px; cursor: pointer; }
        .ranking-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 25px; padding: 40px; }
        .album-art { position: relative; width: 100%; padding-bottom: 100%; border-radius: 10px; overflow: hidden; background: #222; }
        .album-art img { position: absolute; width: 100%; height: 100%; object-fit: cover; }
    </style>
</head>
<body>
    <div class="header">
        <h1>🍈 <%= t.title %></h1>
        <div><a href="/change-lang/ko" style="color:#00cd3c; text-decoration:none;">KO</a> | <a href="/change-lang/en" style="color:#00cd3c; text-decoration:none;">EN</a></div>
    </div>
    <div class="upload-section">
        <h3>✨ <%= t.upload %></h3>
        <form action="/add-artist" method="POST" enctype="multipart/form-data">
            <input type="text" name="name" class="input-field" placeholder="곡 제목 또는 아티스트 명" required>
            <input type="text" name="genre" class="input-field" placeholder="장르">
            <input type="file" name="image" class="input-field" accept="image/*" required>
            <button type="submit" class="submit-btn">차트 등록하기</button>
        </form>
    </div>
    <div class="ranking-grid">
        <% if (artists && artists.length > 0) { %>
            <% artists.forEach(function(artist, index) { %>
                <div style="text-align:center;">
                    <div class="album-art"><img src="<%= artist.imageUrl %>"></div>
                    <p><%= artist.name %></p>
                </div>
            <% }); %>
        <% } else { %>
            <p style="text-align: center; width:100%; color: #555;">실시간 차트 데이터가 없습니다.</p>
        <% } %>
    </div>
</body>
</html>
