<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ranking AI - AI Music Chart & Community (랭킹 AI / 音楽チャート / 音乐排行榜)</title>
    <meta name="description" content="Global AI music rankings. Discover and share the best AI-generated music. 랭킹 AI - 글로벌 인공지능 음악 차트. AI音楽ランキング. AI音乐排行榜.">
    <meta name="keywords" content="Ranking AI, AI Music, AI Chart, 랭킹AI, AI음악, AI音楽, AI楽曲, AI音乐, AI排行榜, Suno AI, Udio AI">
    <meta property="og:title" content="Ranking AI - World's Best AI Music Chart">
    <meta property="og:description" content="Check out the hottest AI music from around the world!">
    <meta property="og:url" content="https://rankingaimusic.com">
    <meta name="content-language" content="en, ko, ja, zh">  
    <meta name="naver-site-verification" content="34a9f6198c9f271e3250e3d11cabcb17c24a7754" />
    <meta name="google-site-verification" content="hGmKKbn9hQDQ2viDIRcHFRPeIlRIZpkTZfFjgKb_sjA" />
    <style>
        body { background: #0b0c0d; color: #fff; font-family: 'Pretendard', sans-serif; margin: 0; padding-bottom: 100px; }
        a { text-decoration: none; color: inherit; }

        .main-header { background: #121314; border-bottom: 1px solid #222; position: sticky; top: 0; z-index: 100; }
        .header-top { display: flex; justify-content: space-between; align-items: center; padding: 15px 40px; border-bottom: 1px solid #1a1b1c; }
        .logo { font-size: 28px; font-weight: 900; color: #ff5722; letter-spacing: -1px; } 
        .top-search-form { display: flex; align-items: center; background: #222; border: 2px solid #ff5722; border-radius: 25px; padding: 5px 15px; width: 400px; }
        .top-search-input { background: none; border: none; color: white; outline: none; flex: 1; font-size: 15px; padding: 5px; }
        .top-search-btn { background: none; border: none; color: #ff5722; font-weight: bold; cursor: pointer; font-size: 16px; padding: 0 10px; }
        
        .auth-buttons { display: flex; gap: 20px; align-items: center; }
        .btn-admin { color: #ff4a4a; font-weight: bold; font-size: 14px; border: 1px solid #ff4a4a; padding: 5px 12px; border-radius: 15px; }
        .btn-login { color: #bbb; font-size: 14px; }
        .btn-signup { background: #ff5722; color: #000; padding: 8px 20px; border-radius: 20px; font-weight: bold; font-size: 14px; }

        .header-nav { display: flex; justify-content: center; gap: 40px; padding: 12px 0; background: #0b0c0d; }
        .nav-item { color: #aaa; font-weight: 600; font-size: 16px; transition: 0.2s; position: relative; }
        .nav-item:hover, .nav-item.active { color: #ff5722; }
        .nav-item.active::after { content: ''; position: absolute; bottom: -12px; left: 0; width: 100%; height: 3px; background: #ff5722; }

        .container { max-width: 1200px; margin: 0 auto; padding: 30px 20px; }
        .main-layout { display: flex; gap: 30px; align-items: flex-start; }
        .content-left { flex: 1; min-width: 0; }
        
        .sidebar-right { width: 300px; background: #161718; padding: 25px; border-radius: 15px; border: 1px solid #333; position: sticky; top: 150px; }
        .sidebar-title { color: #fff; font-size: 18px; font-weight: bold; margin-top: 0; border-bottom: 2px solid #ff5722; padding-bottom: 12px; margin-bottom: 15px; }
        .artist-list { list-style: none; padding: 0; margin: 0; }
        .artist-item { display: flex; align-items: center; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid #222; }
        .artist-rank { color: #ff5722; font-weight: 900; font-size: 18px; width: 24px; }
        .artist-name { font-size: 15px; font-weight: 500; flex: 1; cursor: pointer; color: #fff; }
        .artist-name:hover { color: #ff5722; }
        .artist-count { font-size: 12px; color: #777; background: #222; padding: 3px 8px; border-radius: 12px; }

        .upload-section { background: #161718; padding: 30px; border-radius: 15px; margin-bottom: 40px; border: 1px solid #333; }
        .input-row { display: flex; gap: 15px; margin-bottom: 15px; align-items: center; }
        .input-row > input[type="text"] { flex: 1; background: #222; border: 1px solid #333; color: #fff; padding: 12px; border-radius: 8px; }
        textarea { width: 100%; background: #222; border: 1px solid #333; color: #fff; padding: 12px; border-radius: 8px; height: 80px; margin-bottom: 15px; box-sizing: border-box; }
        .file-upload { flex: 1; background: #222; padding: 10px; border-radius: 8px; color: #aaa; font-size: 13px; }
        .btn-upload { background: #ff5722; color: #000; border: none; padding: 12px; border-radius: 8px; cursor: pointer; font-weight: bold; width: 100%; margin-top: 10px; transition: 0.2s; }
        .btn-upload:hover { filter: brightness(1.1); }
        
        .genre-selector { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 15px; }
        .genre-btn { background: #222; color: #aaa; border: 1px solid #333; padding: 6px 14px; border-radius: 20px; cursor: pointer; font-size: 13px; transition: 0.2s; }
        .genre-btn:hover { background: #333; color: #fff; }
        .genre-btn.active { background: rgba(255, 87, 34, 0.15); color: #ff5722; border-color: #ff5722; font-weight: bold; }

        .chart-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 20px; border-bottom: 2px solid #222; padding-bottom: 15px; }
        .chart-title { font-size: 28px; font-weight: bold; display: flex; align-items: center; gap: 15px; }
        .tabs { display: flex; gap: 25px; }
        .tab { color: #777; cursor: pointer; font-weight: 600; font-size: 16px; padding-bottom: 10px; }
        .tab.active { color: #ff5722; border-bottom: 3px solid #ff5722; }

        .chart-controls { display: flex; gap: 10px; margin-bottom: 15px; align-items: center; }
        .control-btn { background: #161718; color: #fff; border: 1px solid #444; padding: 8px 15px; border-radius: 20px; font-size: 13px; cursor: pointer; display: flex; align-items: center; gap: 5px; transition: 0.2s; }
        .control-btn:hover { background: #333; border-color: #ff5722; color: #ff5722; }
        .control-my-music { background: #ff5722; color: #000; font-weight: bold; border-color: #ff5722; }

        .music-list { width: 100%; border-collapse: collapse; }
        .music-item { border-bottom: 1px solid #1a1b1c; transition: 0.2s; }
        .music-item:hover { background: rgba(255,255,255,0.02); }
        .music-item td { padding: 15px 10px; vertical-align: top; }
        .check-col { width: 30px; text-align: center; vertical-align: middle !important; }
        .custom-checkbox { width: 18px; height: 18px; accent-color: #ff5722; cursor: pointer; }
        
        .rank { font-size: 22px; font-weight: 900; color: #ff5722; width: 40px; text-align: center; vertical-align: middle !important; }
        .album-art { width: 70px; height: 70px; border-radius: 8px; object-fit: cover; box-shadow: 0 4px 10px rgba(0,0,0,0.5); }
        .song-title { font-size: 16px; font-weight: 600; display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin-bottom: 4px; }
        .singer { font-size: 13px; color: #aaa; }
        .ai-badge { background: rgba(255, 87, 34, 0.1); border: 1px solid #ff5722; color: #ff5722; font-size: 10px; padding: 2px 6px; border-radius: 12px; margin-left: 5px; }
        
        .action-row { display: flex; gap: 8px; align-items: center; margin-top: 10px; }
        .action-btn { display: flex; align-items: center; gap: 4px; background: #222; color: #aaa; padding: 4px 10px; border-radius: 20px; font-size: 12px; cursor: pointer; border: 1px solid #333; }
        .action-btn:hover { background: #333; color: #ff5722; border-color: #ff5722; }

        .hidden-box { display: none; background: #111; padding: 15px; border-radius: 8px; margin-top: 15px; font-size: 14px; color: #ccc; border: 1px solid #222; }
        .lyrics-window { max-height: 200px; overflow-y: auto; }
        .lyrics-line { padding: 5px 0; display: flex; gap: 8px; cursor: pointer; }
        .lyrics-time { color: #ff5722; font-weight: bold; width: 45px; text-align: right; }

        /* 🌟 하단 플레이어 및 애니메이션 CSS 🌟 */
        .bottom-player-bar { 
            position: fixed; bottom: 0; left: 0; width: 100%; 
            background: #1a1c1e; border-top: 2px solid #ff5722; 
            padding: 10px 40px; box-sizing: border-box; 
            display: flex; align-items: center; justify-content: space-between; 
            z-index: 1000; box-shadow: 0 -5px 20px rgba(0,0,0,0.8); 
            transition: transform 0.4s cubic-bezier(0.25, 0.8, 0.25, 1); 
        }
        .bottom-player-bar.collapsed {
            transform: translateY(100%);
        }
        .player-toggle-tab {
            position: absolute; top: -32px; right: 40px;
            background: #1a1c1e; color: #ff5722;
            border: 2px solid #ff5722; border-bottom: none;
            padding: 6px 18px; border-radius: 12px 12px 0 0;
            cursor: pointer; font-size: 13px; font-weight: bold;
            z-index: 1001; box-shadow: 0 -4px 10px rgba(0,0,0,0.4);
            transition: 0.2s;
        }
        .player-toggle-tab:hover { background: #ff5722; color: #000; }

        .player-info { display: flex; align-items: center; gap: 15px; width: 300px; }
        .player-cover { width: 50px; height: 50px; border-radius: 5px; background: #000; object-fit: cover; }
        .player-text { display: flex; flex-direction: column; }
        .player-title { font-size: 15px; font-weight: bold; color: #fff; }
        .player-artist { font-size: 12px; color: #aaa; }
        .player-controls-wrapper { flex: 1; max-width: 600px; display: flex; flex-direction: column; align-items: center; gap: 8px; }
        .player-buttons { display: flex; align-items: center; gap: 20px; }
        .player-buttons button { background: none; border: none; color: #fff; font-size: 20px; cursor: pointer; transition: 0.2s; padding: 0; }
        .player-buttons button:hover { color: #ff5722; }
        .player-buttons .play-btn { font-size: 32px; color: #ff5722; }
        
        .progress-area { width: 100%; display: flex; align-items: center; gap: 10px; font-size: 12px; color: #aaa; }
        #progress-bar { flex: 1; height: 4px; border-radius: 2px; -webkit-appearance: none; background: #444; outline: none; cursor: pointer; accent-color: #ff5722; }
        #progress-bar::-webkit-slider-thumb { -webkit-appearance: none; width: 12px; height: 12px; border-radius: 50%; background: #ff5722; }
        
        .logo-wrap { display: flex; align-items: center; gap: 15px; }
        .lang-select { padding: 6px 12px; background: #222; color: #fff; border: 1px solid #ff5722; border-radius: 20px; font-weight: bold; font-size: 13px; outline: none; cursor: pointer; }

        .logo { background: linear-gradient(45deg, #ff5722, #ffb300); -webkit-background-clip: text; -webkit-text-fill-color: transparent; text-shadow: 0 2px 10px rgba(255, 87, 34, 0.2); }
        .top-search-form { transition: all 0.3s ease; }
        .top-search-form:focus-within { box-shadow: 0 0 15px rgba(255, 87, 34, 0.4); border-color: #ffb300; }

        .music-item:nth-child(1) .rank { color: #ffd700 !important; text-shadow: 0 0 10px rgba(255, 215, 0, 0.6); font-size: 26px; }
        .music-item:nth-child(2) .rank { color: #c0c0c0 !important; text-shadow: 0 0 10px rgba(192, 192, 192, 0.6); font-size: 24px; }
        .music-item:nth-child(3) .rank { color: #cd7f32 !important; text-shadow: 0 0 10px rgba(205, 127, 50, 0.6); font-size: 24px; }

        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #0b0c0d; }
        ::-webkit-scrollbar-thumb { background: #333; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #ff5722; }
        .music-item { transition: all 0.3s ease; border-left: 4px solid transparent; }
        .music-item:hover { background: rgba(255, 87, 34, 0.08) !important; border-left: 4px solid #ff5722; }
        .album-art { transition: all 0.3s ease; }
        .music-item:hover .album-art { transform: scale(1.08); box-shadow: 0 8px 15px rgba(255, 87, 34, 0.4); }

        @media (max-width: 900px) {
            .input-row { flex-direction: column; align-items: stretch; gap: 12px; }
            .input-row > div { width: 100%; box-sizing: border-box; }
            .header-top { flex-direction: column; align-items: center; padding: 15px; gap: 15px; }
            .logo-wrap { width: 100%; justify-content: space-between; }
            .top-search-form { width: 100%; box-sizing: border-box; }
            .auth-buttons { width: 100%; justify-content: center; }

            .header-nav { justify-content: flex-start; overflow-x: auto; white-space: nowrap; padding: 12px 15px; gap: 20px; border-bottom: 1px solid #222; }
            .header-nav::-webkit-scrollbar { display: none; }

            .main-layout { flex-direction: column; gap: 20px; }
            .content-left { width: 100%; max-width: 100%; overflow-x: hidden; }
            .sidebar-right { width: 100%; position: static; box-sizing: border-box; margin-top: 10px; }

            .music-list, .music-list tbody, .music-item, .music-item td { display: block; width: 100%; box-sizing: border-box; }
            .music-item { position: relative; background: #161718; border-radius: 12px; padding: 15px; margin-bottom: 20px; border: 1px solid #222; box-shadow: 0 4px 6px rgba(0,0,0,0.3); }
            .music-item td { padding: 0; border: none; }

            .check-col { position: absolute; top: 15px; right: 15px; z-index: 10; width: auto !important; }
            .rank { position: absolute; top: -12px; left: 15px; background: #ff5722; color: #000; border-radius: 6px; padding: 4px 12px; font-size: 14px; font-weight: 900; width: auto; z-index: 10; box-shadow: 0 2px 5px rgba(255,87,34,0.4); }

            .music-item td:nth-child(3) { float: left; width: 75px; margin-right: 15px; margin-top: 10px; }
            .song-info { margin-top: 12px; overflow: hidden; } 
            
            .action-row { flex-wrap: wrap; gap: 6px; margin-top: 15px; clear: both; }
            .action-btn { padding: 8px 5px; font-size: 12px; flex: 1; text-align: center; justify-content: center; }

            .bottom-player-bar { padding: 12px 15px; flex-direction: column; gap: 12px; bottom: 0; border-top-width: 3px; }
            .player-info { width: 100%; justify-content: flex-start; }
            .player-controls-wrapper { width: 100%; }
            .player-buttons { gap: 40px; }
            
            body { padding-bottom: 160px; } 

            .chart-controls { display: flex !important; width: 100%; overflow-x: auto !important; flex-wrap: nowrap !important; gap: 10px; padding-bottom: 10px; -webkit-overflow-scrolling: touch; }
            .chart-controls::-webkit-scrollbar { display: none; }
            .control-btn { flex: 0 0 auto !important; white-space: nowrap !important; font-size: 13px; padding: 8px 15px; }

            .chart-header { flex-direction: column; align-items: flex-start; gap: 15px; }
            .tabs { display: flex; width: 100%; overflow-x: auto; gap: 20px; padding-bottom: 5px; -webkit-overflow-scrolling: touch; }
            .tabs::-webkit-scrollbar { display: none; }
            .tab { flex: 0 0 auto; white-space: nowrap; font-size: 15px; }
        }

        /* 🌟 팝업창 디자인 🌟 */
        .popup-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 9999; display: flex; align-items: center; justify-content: center; backdrop-filter: blur(5px); }
        .popup-box { background: #161718; border: 2px solid #ff5722; border-radius: 15px; padding: 30px; width: 400px; max-width: 90%; box-shadow: 0 10px 30px rgba(255,87,34,0.3); text-align: center; position: relative; }
        .popup-title { color: #fff; font-size: 22px; font-weight: 900; margin-top: 0; margin-bottom: 15px; border-bottom: 1px solid #333; padding-bottom: 15px; }
        .popup-content { color: #ccc; font-size: 15px; line-height: 1.6; margin-bottom: 25px; white-space: pre-wrap; }
        .popup-close-btn { background: #ff5722; color: #000; font-weight: bold; border: none; padding: 10px 20px; border-radius: 8px; cursor: pointer; width: 100%; font-size: 16px; }
        .popup-close-today { background: none; border: none; color: #888; text-decoration: underline; margin-top: 15px; cursor: pointer; font-size: 13px; }
    </style>
</head>
<body>
    <% if (typeof popup !== 'undefined' && popup && popup.isActive) { %>
        <div class="popup-overlay" id="mainPopup">
            <div class="popup-box">
                <h2 class="popup-title">📢 <%= popup.title %></h2>
                <div class="popup-content"><%= popup.content %></div>
                <button class="popup-close-btn" onclick="document.getElementById('mainPopup').style.display='none'">확인</button>
                <button class="popup-close-today" onclick="closePopupForToday()">오늘 하루 보지 않기</button>
            </div>
        </div>
        <script>
            if (localStorage.getItem('hidePopupToday') === new Date().toDateString()) {
                document.getElementById('mainPopup').style.display = 'none';
            }
            function closePopupForToday() {
                localStorage.setItem('hidePopupToday', new Date().toDateString());
                document.getElementById('mainPopup').style.display = 'none';
            }
        </script>
    <% } %>

    <header class="main-header">
       <div class="header-top">
            <div class="logo-wrap">
                <div class="logo" style="cursor:pointer;" onclick="window.location.href='/?sort=views'">RANKING AI</div>
                <div id="google_translate_element" style="display:none;"></div>
                <select id="custom-translate-select" class="lang-select" onchange="changeLanguage(this.value)">
                    <option value="ko">🇰🇷 한국어</option>
                    <option value="en">🇺🇸 English</option>
                    <option value="zh-CN">🇨🇳 中文 (简体)</option>
                    <option value="zh-TW">🇹🇼 中文 (繁體)</option>
                    <option value="ja">🇯🇵 日本語</option>
                </select>
                <script type="text/javascript">
                    function googleTranslateElementInit() {
                        new google.translate.TranslateElement({
                            pageLanguage: 'ko',
                            includedLanguages: 'en,ko,zh-CN,zh-TW,ja',
                            autoDisplay: false
                        }, 'google_translate_element');
                    }
                    function changeLanguage(langCode) {
                        const googleSelect = document.querySelector('.goog-te-combo');
                        if (googleSelect) {
                            googleSelect.value = langCode;
                            googleSelect.dispatchEvent(new Event('change'));
                        } else setTimeout(() => changeLanguage(langCode), 500);
                    }
                </script>
                <script type="text/javascript" src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
            </div>
            
            <form action="/" method="GET" class="top-search-form">
                <input type="text" name="search" class="top-search-input" placeholder="아티스트 검색..." value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
                <button type="submit" class="top-search-btn">🔍</button>
            </form>
            <div class="auth-buttons">
                <% if (user && user.role === 'admin') { %>
                    <a href="/admin" class="btn-admin">👑 관리자</a>
                <% } %>
                
                <% if (user) { %>
                    <span style="color: #aaa; font-size: 14px;"><%= user.id %>님</span>
                    <a href="/logout" class="btn-login">로그아웃</a>
                <% } else { %>
                    <a href="/login" class="btn-login">로그인</a>
                    <a href="/signup" class="btn-signup">회원가입</a>
                <% } %>
            </div>
        </div>
        
        <div class="header-nav">
            <a href="/?sort=views" class="nav-item <%= (typeof sortQuery !== 'undefined' && sortQuery === 'views' && !genreQuery) ? 'active' : '' %>">RANKING AI 챠트</a>
            <a href="/?sort=latest" class="nav-item <%= (typeof sortQuery !== 'undefined' && sortQuery === 'latest') ? 'active' : '' %>">최신음악</a>
            <a href="/?genre=발라드" class="nav-item <%= (typeof genreQuery !== 'undefined' && genreQuery) ? 'active' : '' %>">장르별</a>
            <a href="/youtube" class="nav-item">유튜브</a>
            <a href="/shorts" class="nav-item">쇼츠</a>
            <a href="/board" class="nav-item">커뮤니티</a>
        </div>
    </header>

    <div class="container">
        <div class="main-layout">
            <div class="content-left">
                
                <% if (user) { %>
                <div class="upload-section">
                    <h3 style="margin-top:0; color:#ff5722;">🎵 회원을 위한 음원 업로드</h3>
                    <form action="/add-music" method="POST" enctype="multipart/form-data" id="musicForm">
                        <div class="input-row">
                            <input type="text" name="name" placeholder="곡 제목" required>
                            <input type="text" name="artist" placeholder="아티스트" required>
                        </div>
                        
                     <div class="genre-selector">
                            <button type="button" class="genre-btn" data-genre="K-POP">K-POP</button>
                            <button type="button" class="genre-btn" data-genre="POP">POP</button>
                            <button type="button" class="genre-btn" data-genre="J-POP">J-POP</button>
                            <button type="button" class="genre-btn" data-genre="C-POP">C-POP</button>
                            <button type="button" class="genre-btn" data-genre="V-POP">V-POP</button>
                            <button type="button" class="genre-btn" data-genre="T-POP">T-POP</button>
                            <button type="button" class="genre-btn" data-genre="발라드">발라드</button>
                            <button type="button" class="genre-btn" data-genre="댄스">댄스</button>
                            <button type="button" class="genre-btn" data-genre="랩/힙합">랩/힙합</button>
                            <button type="button" class="genre-btn" data-genre="R&B/Soul">R&B/Soul</button>
                            <button type="button" class="genre-btn" data-genre="인디음악">인디음악</button>
                            <button type="button" class="genre-btn" data-genre="록/메탈">록/메탈</button>
                            <button type="button" class="genre-btn" data-genre="트로트">트로트</button>
                            <button type="button" class="genre-btn" data-genre="일렉트로니카">일렉트로니카</button>
                            <button type="button" class="genre-btn" data-genre="클래식/재즈">클래식/재즈</button>
                            <button type="button" class="genre-btn" data-genre="기타장르">기타장르</button>
                        </div>
                        <input type="hidden" name="genre" id="hiddenGenreInput" required>
                        
                        <div class="input-row">
                            <input type="text" name="aiTool" placeholder="사용 프로그램 (예: Suno)" required>
                            <input type="text" name="realName" placeholder="업로더 실명 (비공개)" required>
                        </div>
                        <textarea name="lyrics" placeholder="가사를 시간과 함께 입력하세요. (예: [00:15] 첫 번째 가사)"></textarea>
                        <div class="input-row">
                            <div style="flex:1;"><span style="font-size: 12px; color: #ff5722; display: block; margin-bottom: 5px;">🖼️ 커버 이미지</span><input type="file" name="image" accept="image/*" class="file-upload" required></div>
                            <div style="flex:1;"><span style="font-size: 12px; color: #ff5722; display: block; margin-bottom: 5px;">🎵 MP3 음원</span><input type="file" name="audio" accept="audio/*" class="file-upload" required></div>
                        </div>
                        <button type="submit" class="btn-upload">차트 등록하기</button>
                    </form>
                </div>
                <% } else { %>
                <div class="upload-section" style="text-align: center; padding: 40px 20px;">
                    <div style="font-size: 40px; margin-bottom: 10px;">🔒</div>
                    <h3 style="margin-top:0; color:#aaa;">음원 업로드는 회원 전용입니다</h3>
                    <p style="color: #777; font-size: 14px; margin-bottom: 20px;">나만의 AI 음악을 차트에 올리고 싶다면 로그인해주세요!</p>
                    <button onclick="location.href='/login'" class="btn-upload" style="width: auto; padding: 10px 40px;">로그인하러 가기</button>
                </div>
                <% } %>

                <% if (user && user.role === 'admin') { %>
                <div class="upload-section" style="border-color: #ff4a4a; background: #1a1111;">
                    <h3 style="margin-top:0; color:#ff4a4a;">👑 관리자 팝업 공지 설정</h3>
                    <form action="/admin/popup" method="POST">
                        <input type="text" name="title" placeholder="팝업 제목 (예: 긴급 서버 점검 안내)" required style="width: 100%; box-sizing: border-box; margin-bottom: 10px; border: 1px solid #ff4a4a; padding: 12px; border-radius: 8px; background: #222; color: #fff;">
                        <textarea name="content" placeholder="팝업 내용을 적어주세요!" required style="border: 1px solid #ff4a4a; width: 100%; box-sizing: border-box; padding: 12px; border-radius: 8px; background: #222; color: #fff; height: 80px; margin-bottom: 15px;"></textarea>
                        
                        <div style="display: flex; align-items: center; justify-content: space-between;">
                            <label style="color: #fff; font-weight: bold; cursor: pointer; display: flex; align-items: center; gap: 10px;">
                                <input type="checkbox" name="isActive" checked style="width: 20px; height: 20px; accent-color: #ff4a4a;"> 
                                메인 화면에 팝업 띄우기 (ON/OFF)
                            </label>
                            <button type="submit" class="btn-upload" style="background: #ff4a4a; width: auto; margin-top: 0; padding: 10px 30px;">적용하기</button>
                        </div>
                    </form>
                </div>
                <% } %>

                <div class="chart-header">
                    <div class="chart-title">랭킹AI 100 
                        <% if (typeof searchQuery !== 'undefined' && searchQuery) { %>
                            <span style="font-size:16px; color:#ff5722;">(검색결과: <%= searchQuery %>) <a href="/" style="color:#aaa; text-decoration:underline;">초기화</a></span>
                        <% } %>
                    </div>
                    <div class="tabs">
                        <a href="/?sort=views" class="tab <%= (typeof periodQuery === 'undefined' || !periodQuery) ? 'active' : '' %>">실시간(전체)</a>
                        <a href="/?period=daily" class="tab <%= (typeof periodQuery !== 'undefined' && periodQuery === 'daily') ? 'active' : '' %>">일간</a>
                        <a href="/?period=weekly" class="tab <%= (typeof periodQuery !== 'undefined' && periodQuery === 'weekly') ? 'active' : '' %>">주간</a>
                        <a href="/?period=monthly" class="tab <%= (typeof periodQuery !== 'undefined' && periodQuery === 'monthly') ? 'active' : '' %>">월간</a>
                    </div>
                </div>
<% if (typeof genreQuery !== 'undefined' && genreQuery) { %>
                    <div style="background: #161718; padding: 15px; border-radius: 10px; margin-bottom: 20px; border: 1px solid #333; display: flex; gap: 8px; flex-wrap: wrap;">
                       <% const displayGenres = ['K-POP','POP','J-POP','C-POP','V-POP','T-POP','발라드','댄스','랩/힙합','R&B/Soul','인디음악','록/메탈','트로트','일렉트로니카','클래식/재즈','기타장르']; %>
                        <% displayGenres.forEach(g => { %>
                            <a href="/?genre=<%= g %>" style="padding: 6px 14px; border-radius: 20px; font-size: 13px; font-weight: bold; border: 1px solid <%= genreQuery === g ? '#ff5722' : '#444' %>; background: <%= genreQuery === g ? '#ff5722' : '#222' %>; color: <%= genreQuery === g ? '#000' : '#aaa' %>; transition: 0.2s;"><%= g %></a>
                        <% }) %>
                    </div>
                <% } %>
                <div class="chart-controls">
                    <input type="checkbox" id="checkAll" class="custom-checkbox" onchange="toggleAll(this)">
                    <button class="control-btn" onclick="playAll()">▶ 전체듣기</button>
                    <button class="control-btn" onclick="playSelected()">▶ 선택듣기</button>
                    <button class="control-btn" onclick="addSelectedToMyMusic()">+ 담기</button>
                    <a href="/mymusic" class="control-btn control-my-music">🎵 내 음악 보관함</a>
                </div>

                <table class="music-list">
                    <% if (artists && artists.length > 0) { %>
                        <% artists.forEach(function(music, index) { %>
                        <tr class="music-item" data-id="<%= music._id %>" data-title="<%= music.name %>" data-artist="<%= music.artist %>" data-cover="<%= music.imageUrl %>" data-audio="<%= music.audioUrl %>">
                            <td class="check-col"><input type="checkbox" class="custom-checkbox song-check" value="<%= music._id %>"></td>
                            <td class="rank"><%= index + 1 %></td>
                            <td style="width: 80px;"><img src="<%= music.imageUrl %>" class="album-art"></td>
                            
                            <td class="song-info">
                                <div class="song-title">
                                    <%= music.name %>
                                    
                                    <% if (user && (user.role === 'admin' || user.id === music.uploader) && music._id !== "dummy") { %>
                                        <div style="margin-left: 10px; display: inline-flex; gap: 8px; align-items: center; background: rgba(0,0,0,0.5); padding: 3px 10px; border-radius: 6px; border: 1px solid #444;">
                                            <% if (user.role === 'admin') { %><span title="관리자 권한" style="font-size: 10px;">👑</span><% } %>
                                            <a href="/edit/<%= music._id %>" style="color: #00e5ff; font-size: 11px; font-weight: bold; text-decoration: none; cursor: pointer;">수정</a>
                                            <span style="color: #555; font-size: 10px;">|</span>
                                            <form action="/delete-music/<%= music._id %>" method="POST" onsubmit="return confirm('이 음원을 차트에서 정말 삭제하시겠습니까?');" style="display: flex; align-items: center; margin: 0;">
                                                <button type="submit" style="background: none; border: none; color: #ff4a4a; font-size: 11px; font-weight: bold; cursor: pointer; padding: 0; font-family: inherit;">삭제</button>
                                            </form>
                                        </div>
                                    <% } %>
                                </div>
                                <div class="singer"><%= music.artist %> (<%= music.genre %>) <span class="ai-badge">🎵 <%= music.aiTool %></span> <span style="margin-left:10px; color:#ff5722; font-size:12px;">🎧 재생 <%= music.views || 0 %>회</span></div>
                                
                                <div class="action-row">
                                    <div class="action-btn" onclick="playSingleTrack(this)">▶ 듣기</div>
                                    <div class="action-btn" onclick="parseAndShowLyrics('<%= music._id %>', `<%= music.lyrics %>`)">📝 가사</div>
                                    <div class="action-btn" onclick="copyMusicLink('<%= music._id %>')">🔗 공유</div>
                                    <div class="action-btn" onclick="document.getElementById('comments-<%= music._id %>').style.display = (document.getElementById('comments-<%= music._id %>').style.display === 'block') ? 'none' : 'block';">💬 댓글 <%= music.comments ? music.comments.length : 0 %></div>
        
                                    <% 
                                        let isLiked = false;
                                        if (user && music.likedBy && music.likedBy.includes(user.id)) {
                                            isLiked = true;
                                        }
                                    %>
                                    <div class="action-btn" id="like-btn-<%= music._id %>" onclick="likeMusic('<%= music._id %>')" style="<%= isLiked ? 'color:#ff4a4a; border-color:#ff4a4a;' : '' %>">
                                        <%= isLiked ? '❤️' : '🤍' %> 좋아요 <span id="like-count-<%= music._id %>"><%= music.views || 0 %></span>
                                    </div>
                                </div>

                                <div id="lyrics-<%= music._id %>" class="hidden-box lyrics-window"><div id="lyrics-content-<%= music._id %>"></div></div>
                                
                                <div id="comments-<%= music._id %>" class="hidden-box">
                                    <div style="max-height: 150px; overflow-y: auto; margin-bottom:15px;">
                                        <% if (music.comments && music.comments.length > 0) { %>
                                            <% music.comments.forEach(function(c) { %>
                                                <div style="border-bottom: 1px solid #333; padding: 8px 0; display: flex; justify-content: space-between; align-items: center;">
                                                    <div>
                                                        <span style="color:#ff5722; font-weight:bold; font-size:13px;"><%= c.author %></span>
                                                        <span style="font-size:14px; margin-left:8px; color:#ddd;"><%= c.text %></span>
                                                    </div>
                                                    <% if (user && (user.role === 'admin' || user.id === c.author)) { %>
                                                        <form action="/delete-music-comment/<%= music._id %>/<%= c._id %>" method="POST" style="margin: 0;" onsubmit="return confirm('이 댓글을 삭제할까요?');">
                                                            <button type="submit" style="background: none; border: none; color: #ff4a4a; font-size: 11px; cursor: pointer;">❌삭제</button>
                                                        </form>
                                                    <% } %>
                                                </div>
                                            <% }); %>
                                        <% } else { %>
                                            <p style="font-size:13px; color:#777;">아직 댓글이 없습니다.</p>
                                        <% } %>
                                    </div>
                                    
                                    <% if (music._id !== "dummy") { %>
                                        <form action="/add-comment/<%= music._id %>" method="POST" style="display:flex; gap:10px;">
                                            <input type="text" name="commentText" placeholder="댓글..." style="flex:1; padding:10px; border-radius:6px; border:1px solid #444; background:#222; color:white;" required>
                                            <button type="submit" style="background:#ff5722; color:black; border:none; padding:10px 20px; border-radius:6px; font-weight:bold; cursor:pointer;">등록</button>
                                        </form>
                                    <% } %>
                                </div>
                            </td>
                        </tr>
                        <% }); %>
                    <% } else { %>
                        <tr><td colspan="4" style="text-align:center; padding:100px; color:#555;">검색된 곡이 없습니다.</td></tr>
                    <% } %>
                </table>
            </div>

            <div class="sidebar-right">
                <h3 class="sidebar-title">🏆 인기 아티스트</h3>
                <ul class="artist-list">
                    <% popularArtists.forEach(function(artist, idx) { %>
                        <li class="artist-item">
                            <div style="display: flex; align-items: center; gap: 10px;">
                                <span class="artist-rank"><%= idx + 1 %></span>
                                <a href="/?search=<%= encodeURIComponent(artist._id) %>" class="artist-name"><%= artist._id %></a>
                            </div>
                            <span class="artist-count"><%= artist.count %>곡</span>
                        </li>
                    <% }); %>
                </ul>
            <div class="ad-section" style="margin-top: 30px; padding: 20px; background: rgba(255,87,34,0.03); border: 1px solid #222; border-radius: 12px; text-align: center;">
        <span style="font-size: 11px; color: #555; display: block; margin-bottom: 15px; letter-spacing: 2px;">SPONSORED / NOTICE</span>
        
        <div style="min-height: 100px; display: flex; flex-direction: column; justify-content: center; align-items: center;">
            <p style="color: #bbb; font-size: 14px; line-height: 1.6; margin: 0;">
                Ranking AI와 함께 성장할<br>파트너를 기다립니다.
            </p>
            
            <a href="/contact" style="margin-top: 15px; font-size: 13px; color: #ff5722; font-weight: bold; text-decoration: underline; text-underline-offset: 4px;">
    💬 제휴 및 홍보 문의하기 (1:1 DM)
</a>
        </div>
    </div>

            </div>
        </div>
    </div>

    <div class="bottom-player-bar" id="bottomPlayerBar">
        <div class="player-toggle-tab" onclick="togglePlayerVisibility()">▼ 숨기기</div>
        
        <div class="player-info">
            <img src="https://via.placeholder.com/50/222222/ff5722?text=Play" id="main-player-cover" class="player-cover">
            <div class="player-text">
                <span id="main-player-title" class="player-title">선택된 곡이 없습니다</span>
                <span id="main-player-artist" class="player-artist">목록에서 음악을 선택해주세요</span>
            </div>
        </div>
        
        <div class="player-controls-wrapper">
           <div class="player-buttons">
                <button id="id-btn-loop" onclick="toggleLoop()" title="한곡 반복" style="font-size: 16px; margin-right: 10px; color: #777; background:none; border:none; cursor:pointer;">🔁</button>
    
           <button id="btn-prev" onclick="playPrevTrack()">⏮</button>
           <button id="btn-play" onclick="togglePlayPause()" class="play-btn">▶</button>
           <button id="btn-next" onclick="playNextTrack()">⏭</button>
        </div>
            <div class="progress-area">
                <span id="time-current">00:00</span>
                <input type="range" id="progress-bar" value="0" min="0" max="100" step="1">
                <span id="time-total">00:00</span>
            </div>
        </div>
        
        <audio id="main-audio" style="display:none;"></audio>
    </div>

    <script>

        // --- 여기서부터 복사하세요 ---
        let isLoop = false; 

        function toggleLoop() {
            const btnLoop = document.getElementById('id-btn-loop');
            isLoop = !isLoop;
            if (isLoop) {
                btnLoop.style.color = "#ff5722"; // 켜지면 주황색
                btnLoop.innerText = "🔂"; 
            } else {
                btnLoop.style.color = "#777"; // 꺼지면 회색
                btnLoop.innerText = "🔁";
            }
        }
        // --- 여기서부터 아래 내용을 복사해서 붙여넣으세요! ---
        function parseAndShowLyrics(musicId, rawLyrics) {
            const lyricsBox = document.getElementById('lyrics-' + musicId);
            const lyricsContent = document.getElementById('lyrics-content-' + musicId);
            
            if (!lyricsBox || !lyricsContent) return;

            // 이미 열려있으면 닫기
            if (lyricsBox.style.display === 'block') {
                lyricsBox.style.display = 'none';
                return;
            }

            // 가사 내용 넣기
            if (!rawLyrics || rawLyrics.trim() === "" || rawLyrics === "undefined" || rawLyrics === "null") {
                lyricsContent.innerHTML = "<p style='color:#777; text-align:center;'>등록된 가사가 없습니다.</p>";
            } else {
                // 줄바꿈 보존 처리 및 백틱 안전 처리
                const formattedLyrics = rawLyrics.split('\n').join('<br>');
                lyricsContent.innerHTML = `<div style="line-height:1.8; padding:10px;">${formattedLyrics}</div>`;
            }

            lyricsBox.style.display = 'block';
        }
        // --- 여기까지 ---


        // 🌟 플레이어 숨기기/보이기 기능 🌟
        function togglePlayerVisibility() {
            const playerBar = document.getElementById('bottomPlayerBar');
            const toggleTab = document.querySelector('.player-toggle-tab');
            
            playerBar.classList.toggle('collapsed');
            
            if (playerBar.classList.contains('collapsed')) {
                toggleTab.innerText = '▲ 열기';
            } else {
                toggleTab.innerText = '▼ 숨기기';
            }
        }

        const genreBtns = document.querySelectorAll('.genre-btn');
        const hiddenInput = document.getElementById('hiddenGenreInput');
        
        // 🌟 방어막 1: 장르 버튼 기능 (hiddenInput이 있을 때만 작동)
        genreBtns.forEach(btn => {
            btn.addEventListener('click', function() { 
                genreBtns.forEach(b => b.classList.remove('active')); 
                this.classList.add('active'); 
                if(hiddenInput) hiddenInput.value = this.getAttribute('data-genre'); 
            });
        });
        
        // 🌟 방어막 2: 폼이 화면에 존재할 때만(회원일 때만) 감시하기!
        const musicForm = document.getElementById('musicForm');
        if (musicForm) {
            musicForm.addEventListener('submit', function(e) { 
                if (hiddenInput && !hiddenInput.value) { e.preventDefault(); alert('장르를 선택해주세요!'); } 
            });
        }



        // 🌟 연속 재생 강화 엔진 (수정본) 🌟
        let playlist = [];
        let currentIndex = 0;
        let isPlaying = false;
        
        const mainAudio = document.getElementById('main-audio');
        const btnPlay = document.getElementById('btn-play');
        const progressBar = document.getElementById('progress-bar');
        const timeCurrent = document.getElementById('time-current');
        const timeTotal = document.getElementById('time-total');

        function toggleAll(source) {
            document.querySelectorAll('.song-check').forEach(cb => cb.checked = source.checked);
        }

        function togglePlayPause() {
            if (playlist.length === 0) return alert("재생할 곡을 선택해주세요!");
            if (mainAudio.paused) {
                mainAudio.play();
                isPlaying = true;
                if(btnPlay) btnPlay.innerText = "⏸";
            } else {
                mainAudio.pause();
                isPlaying = false;
                if(btnPlay) btnPlay.innerText = "▶";
            }
        }

        // 🌟 핵심: 다음 곡으로 바톤 터치하는 로드 함수
        function loadTrack(index) {
            if(index >= 0 && index < playlist.length) {
                const track = playlist[index];
                currentIndex = index; // 현재 인덱스 업데이트
                
                if(!track.audio || track.audio.trim() === "" || track.audio === "undefined") {
                    console.log("음원 없음, 다음 곡으로:", track.title);
                    playNextTrack(); 
                    return; 
                }
                
                document.getElementById('main-player-title').innerText = track.title;
                document.getElementById('main-player-artist').innerText = track.artist;
                document.getElementById('main-player-cover').src = track.cover;
                
                mainAudio.src = track.audio;
                mainAudio.load(); // 👈 새 음원 장전
                
                const playPromise = mainAudio.play();
                if (playPromise !== undefined) {
                    playPromise.then(() => {
                        isPlaying = true;
                        if(btnPlay) btnPlay.innerText = "⏸";
                    }).catch(e => {
                        console.log("자동 재생 차단됨 (사용자 클릭 필요)");
                        isPlaying = false;
                        if(btnPlay) btnPlay.innerText = "▶";
                    });
                }

                if (track.id && track.id !== "dummy") {
                    fetch('/play-count/' + track.id, { method: 'POST' }).catch(err => {});
                }
            }
        }

        function playPrevTrack() {
            if (currentIndex > 0) loadTrack(currentIndex - 1);
            else alert("첫 번째 곡입니다.");
        }

        function playNextTrack() {
            if (currentIndex < playlist.length - 1) {
                loadTrack(currentIndex + 1);
            } else { 
                mainAudio.pause(); 
                isPlaying = false;
                if(btnPlay) btnPlay.innerText = "▶"; 
                alert("마지막 곡입니다. 🎶"); 
            }
        }

        mainAudio.addEventListener('timeupdate', () => {
            const current = mainAudio.currentTime;
            const duration = mainAudio.duration;
            if (duration && !isNaN(duration)) {
                progressBar.value = (current / duration) * 100;
                let minC = Math.floor(current / 60); let secC = Math.floor(current % 60);
                if(secC < 10) secC = "0" + secC;
                timeCurrent.innerText = minC + ":" + secC;

                let minD = Math.floor(duration / 60); let secD = Math.floor(duration % 60);
                if(secD < 10) secD = "0" + secD;
                timeTotal.innerText = minD + ":" + secD;
            }
        });

        progressBar.addEventListener('input', () => {
            if (mainAudio.duration) {
                mainAudio.currentTime = (progressBar.value / 100) * mainAudio.duration;
            }
        });

        // 🌟 곡이 끝나면 무조건 다음 곡으로 이동!
        mainAudio.addEventListener('ended', () => {
            if (isLoop) {
                mainAudio.currentTime = 0;
                mainAudio.play();
            } else {
                playNextTrack(); // 👈 여기서 끊김 없이 넘겨줍니다.
            }
        });

        function playSingleTrack(btnElement) {
            const tr = btnElement.closest('.music-item');
            const audioUrl = tr.dataset.audio;

            if (!audioUrl || audioUrl === "undefined" || audioUrl.trim() === "") {
                alert("아직 음원이 제대로 업로드되지 않은 곡입니다!");
                return; 
            }

            playlist = [{ id: tr.dataset.id, title: tr.dataset.title, artist: tr.dataset.artist, cover: tr.dataset.cover, audio: audioUrl }];
            loadTrack(0);
        }

        function playAll() {
            const rows = document.querySelectorAll('.music-item');
            playlist = Array.from(rows).map(tr => ({ 
                id: tr.dataset.id, 
                title: tr.dataset.title, 
                artist: tr.dataset.artist, 
                cover: tr.dataset.cover, 
                audio: tr.dataset.audio 
            })).filter(t => t.audio && t.audio.trim() !== "" && t.audio !== "undefined");
            
            if(playlist.length > 0) {
                currentIndex = 0;
                loadTrack(0);
            } else {
                alert("재생 가능한 음원이 없습니다.");
            }
        }

        function playSelected() {
            const checkedBoxes = document.querySelectorAll('.song-check:checked');
            if(checkedBoxes.length === 0) return alert("재생할 곡을 먼저 체크해주세요!");
            
            playlist = Array.from(checkedBoxes).map(cb => {
                const tr = cb.closest('.music-item');
                return { 
                    id: tr.dataset.id, 
                    title: tr.dataset.title, 
                    artist: tr.dataset.artist, 
                    cover: tr.dataset.cover, 
                    audio: tr.dataset.audio 
                };
            }).filter(t => t.audio && t.audio.trim() !== "" && t.audio !== "undefined");
            
            if(playlist.length > 0) {
                currentIndex = 0;
                loadTrack(0);
            } else {
                alert("선택한 곡 중에 재생 가능한 음원이 없습니다.");
            }
        }

        function addSelectedToMyMusic() {
            const checkedBoxes = document.querySelectorAll('.song-check:checked');
            if(checkedBoxes.length === 0) return alert("담을 곡을 체크해주세요!");

            const musicIds = Array.from(checkedBoxes).map(cb => cb.value);

            fetch('/add-to-mymusic', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ musicIds: musicIds })
            })
            .then(res => res.json())
            .then(data => alert(data.message))
            .catch(err => alert("에러가 발생했습니다. 다시 시도해주세요."));
        }

       // 🌟 음악 끊김 방지 마법 엔진 (PJAX) 🌟
        document.addEventListener('click', async (e) => {
            const link = e.target.closest('a');
            if (!link) return;

            const href = link.getAttribute('href');
            if (href && href.startsWith('/') && !href.includes('delete') && !href.includes('logout') && !href.includes('login') && !href.includes('signup') && !href.includes('edit')) {
                e.preventDefault(); 
                navigateTo(href);
            }
        });

        document.addEventListener('submit', async (e) => {
            const form = e.target;
            if (form.method.toLowerCase() === 'get') {
                e.preventDefault(); 
                const formData = new FormData(form);
                const searchParams = new URLSearchParams(formData).toString();
                const href = form.getAttribute('action') + '?' + searchParams;
                navigateTo(href);
            }
        });

        async function navigateTo(href) {
            try {
                const response = await fetch(href);
                const html = await response.text();
                
                const parser = new DOMParser();
                const newDoc = parser.parseFromString(html, 'text/html');
                
                const currentContainer = document.querySelector('.container');
                const newContainer = newDoc.querySelector('.container');
                if (currentContainer && newContainer) {
                    currentContainer.innerHTML = newContainer.innerHTML;
                }
                
                const currentNav = document.querySelector('.header-nav');
                const newNav = newDoc.querySelector('.header-nav');
                if (currentNav && newNav) currentNav.innerHTML = newNav.innerHTML;
                
                history.pushState(null, '', href);
                document.title = newDoc.title;
                
                // 🌟 유튜브, 쇼츠, 커뮤니티 클릭 시 플레이어 자동 숨김!
                const playerBar = document.getElementById('bottomPlayerBar');
                if (playerBar) {
                    if (href.includes('/youtube') || href.includes('/shorts') || href.includes('/board')) {
                        playerBar.style.display = 'none';
                    } else {
                        playerBar.style.display = 'flex';
                    }
                }

                reattachEvents();
                window.scrollTo(0, 0); 
                
            } catch (err) {
                console.log("화면 교체 에러:", err);
                location.href = href; 
            }
        }

        window.addEventListener('popstate', async () => {
            navigateTo(location.pathname + location.search);
        });

        function reattachEvents() {
            const genreBtns = document.querySelectorAll('.genre-btn');
            const hiddenInput = document.getElementById('hiddenGenreInput');
            genreBtns.forEach(btn => {
                btn.addEventListener('click', function() { 
                    genreBtns.forEach(b => b.classList.remove('active')); 
                    this.classList.add('active'); 
                    if(hiddenInput) hiddenInput.value = this.getAttribute('data-genre'); 
                });
            });
            const musicForm = document.getElementById('musicForm');
            if(musicForm) {
                musicForm.addEventListener('submit', function(e) { 
                    if (hiddenInput && !hiddenInput.value) { e.preventDefault(); alert('장르를 선택해주세요!'); } 
                });
            }
        }

        // 🌟 진짜 좋아요 기능 (서버랑 통신함!) 🌟
        async function likeMusic(musicId) {
            try {
                // 서버의 '/like/아이디' 주소로 좋아요 요청을 보냅니다!
                const response = await fetch('/like/' + musicId, { method: 'POST' });
                const data = await response.json();

                if (data.success) {
                    // 서버가 허락했다면? 화면 숫자 +1 올리기
                    const countSpan = document.getElementById('like-count-' + musicId);
                    countSpan.innerText = parseInt(countSpan.innerText) + 1;
                    
                    // 하트 색상 빨간색으로 변경
                    const btn = document.getElementById('like-btn-' + musicId);
                    btn.innerHTML = '❤️ 좋아요 <span id="like-count-' + musicId + '">' + countSpan.innerText + '</span>';
                    btn.style.color = '#ff4a4a';
                    btn.style.borderColor = '#ff4a4a';
                    
                } else {
                    // 서버가 거절했다면? (로그인 안함, 이미 누름 등) 알림창 띄우기
                    alert(data.message);
                }
            } catch (err) {
                console.error("좋아요 통신 에러:", err);
                alert("에러가 발생했습니다.");
            }
        } // 👈 🌟 범인 검거!! 이 괄호가 빠져있어서 모든 기능이 멈췄던 겁니다!! 🌟

        // 🔗 노래 링크 복사 기능 (함수 밖으로 안전하게 독립!)
        function copyMusicLink(musicId) {
            const shareUrl = window.location.origin + '/?play=' + encodeURIComponent(musicId);
            navigator.clipboard.writeText(shareUrl).then(() => {
                alert("노래 공유 링크가 복사되었습니다! 친구들에게 자랑해보세요. 🔗");
            }).catch(err => {
                console.error('복사 실패:', err);
            });
        }  
    </script>
</body>
</html>