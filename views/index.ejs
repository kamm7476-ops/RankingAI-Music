<style>
    /* 멜론/지니 스타일 업그레이드 디자인 */
    body { background-color: #000; color: #fff; font-family: 'Noto Sans KR', sans-serif; }
    
    .ranking-container { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 30px; padding: 40px; }
    
    .music-card { 
        background: none; 
        transition: transform 0.3s ease; 
        cursor: pointer;
    }
    
    .music-card:hover { transform: scale(1.05); }
    
    .album-art-wrapper {
        position: relative;
        width: 100%;
        padding-bottom: 100%; /* 정사각형 유지 */
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 10px 20px rgba(255, 215, 0, 0.1);
    }
    
    .album-art-wrapper img {
        position: absolute; width: 100%; height: 100%; object-fit: cover;
    }
    
    .rank-badge {
        position: absolute; top: 10px; left: 10px;
        background: rgba(0,0,0,0.7); color: #ffd700;
        padding: 5px 12px; border-radius: 8px; font-weight: bold;
    }
    
    .info-box { padding: 12px 5px; text-align: left; }
    .info-box .title { font-size: 1.1rem; font-weight: 600; margin-bottom: 5px; color: #fff; }
    .info-box .artist { font-size: 0.9rem; color: #aaa; }
</style>

<div class="ranking-container">
    <% if (artists && artists.length > 0) { %>
        <% artists.forEach(function(artist, index) { %>
            <div class="music-card">
                <div class="album-art-wrapper">
                    <span class="rank-badge"><%= index + 1 %></span>
                    <img src="<%= artist.imageUrl || '/default-album.jpg' %>" alt="cover">
                </div>
                <div class="info-box">
                    <div class="title"><%= artist.name %></div>
                    <div class="artist"><%= artist.genre %></div>
                </div>
            </div>
        <% }); %>
    <% } %>
</div>
