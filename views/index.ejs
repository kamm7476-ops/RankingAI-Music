                <div class="popup-content" style="color: #fff; font-size: 16px;"><%= unreadMessages[0].text %></div>
                <form action="/read-message/<%= unreadMessages[0]._id %>" method="POST">
                    <button type="submit" class="popup-close-btn" style="background: #4caf50; color: #fff;">확인했습니다</button>
                </form>
            </div>
        </div>
    <% } %>

    <% if (typeof popup !== 'undefined' && popup && popup.isActive) { %>
        <div id="mainPopup" style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 90%; max-width: 400px; max-height: 80vh; z-index: 999999; background: #161718; border: 2px solid #ff5722; border-radius: 12px; box-shadow: 0 15px 50px rgba(0,0,0,0.9); display: flex; flex-direction: column; overflow: hidden;">
            <div style="background: #222; padding: 12px 15px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #333;">
                <span style="color: #ff5722; font-weight: bold; font-size: 15px;">📢 공지사항</span>
            </div>
            <div style="padding: 25px; text-align: center; overflow-y: auto; flex: 1;">
                <h2 style="color: #fff; margin-top: 0; font-size: 20px;"><%= popup.title %></h2>
                <div style="text-align: left; color: #ddd; font-size: 14px; line-height: 1.7; background: #0b0c0d; padding: 15px; border-radius: 8px; margin-bottom: 0; white-space: pre-wrap;"><%= popup.content %></div>
            </div>
            <div style="background: #222; padding: 12px 15px; display: flex; justify-content: space-between; align-items: center; border-top: 1px solid #333;">
                <label style="color: #aaa; font-size: 12px; cursor: pointer; display: flex; align-items: center; gap: 5px;">
                    <input type="checkbox" id="todayCheck" style="accent-color: #ff5722;"> 오늘 하루 이 창을 열지 않음
                </label>
                <button onclick="closePopupWithCheck()" style="background: #444; color: #fff; border: none; padding: 6px 16px; border-radius: 4px; cursor: pointer; font-size: 13px; font-weight: bold;">닫기</button>
            </div>
        </div>

        <script>
            if (localStorage.getItem('hideMainPopup_melon') === new Date().toDateString()) {
                document.getElementById("mainPopup").style.display = 'none';
            }
            function closePopupWithCheck() {
                if (document.getElementById('todayCheck').checked) {
                    localStorage.setItem('hideMainPopup_melon', new Date().toDateString());
                }
                document.getElementById("mainPopup").style.display = 'none';
            }
        </script>
    <% } %>

    <header class="main-header">
       <div class="header-top">
            <img src="/logo.png" alt="RANKING AI 로고" class="logo-img" onclick="window.location.href='/?sort=views'">
            
            <form action="/" method="GET" class="top-search-form">
                <div style="display: flex; align-items: center; justify-content: center; cursor: pointer; background: #fff; padding: 2px; border-radius: 4px; margin-right: 10px; box-shadow: 0 0 5px rgba(255,87,34,0.5); flex-shrink: 0;" 
                     title="클릭하면 크게 확대됩니다! 친구들에게 공유해보세요 🚀" 
                     onclick="window.open('https://api.qrserver.com/v1/create-qr-code/?size=500x500&data=https://rankingaimusic.com', '_blank')">
                    <img src="https://api.qrserver.com/v1/create-qr-code/?size=30x30&data=https://rankingaimusic.com" alt="QR Code" style="display: block; width: 24px; height: 24px;">
                </div>
                <input type="text" name="search" class="top-search-input" placeholder="아티스트 검색..." value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false">
                <button type="submit" class="top-search-btn">🔍</button>
            </form>

            <div class="auth-buttons">
                <select id="custom-translate-select" class="lang-select" onchange="changeLanguage(this.value)">
                    <option value="ko">🇰🇷 한국어</option>
                    <option value="en">🇺🇸 English</option>
                    <option value="zh-CN">🇨🇳 中文</option>
                    <option value="zh-TW">🇹🇼 繁體</option>
                    <option value="ja">🇯🇵 日本語</option>
                </select>

                <div id="google_translate_element" style="display:none;"></div>
                <script type="text/javascript">
                    function googleTranslateElementInit() {
                        new google.translate.TranslateElement({
                            pageLanguage: 'ko', includedLanguages: 'en,ko,zh-CN,zh-TW,ja', autoDisplay: false
                        }, 'google_translate_element');
                    }
                    function changeLanguage(langCode) {
                        const googleSelect = document.querySelector('.goog-te-combo');
                        if (googleSelect) {
                            googleSelect.value = langCode;
                            googleSelect.dispatchEvent(new Event('change'));
                        } else setTimeout(() => changeLanguage(langCode), 500);
                    }
                </script>
                <script type="text/javascript" src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>

                <% if (user && user.role === 'admin') { %>
                    <a href="/admin" class="btn-admin">👑 관리자</a>
