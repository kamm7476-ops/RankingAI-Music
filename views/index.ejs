                    <button onclick="location.href='/login'" class="btn-upload guest-btn">로그인</button>
                </div>
                <% } %>

                <div class="chart-header">
                    <div class="chart-title">랭킹AI 100 
                        <% if (typeof searchQuery !== 'undefined' && searchQuery) { %>
                            <span style="font-size:16px; color:#ff5722;">(검색결과: <%= searchQuery %>) <a href="/" style="color:#aaa; text-decoration:underline;">초기화</a></span>
                        <% } %>
                    </div>
                    <div class="tabs">
                        <a href="/?sort=views" class="tab <%= (typeof periodQuery === 'undefined' || !periodQuery) ? 'active' : '' %>">실시간(전체)</a>
                        <a href="/?period=daily" class="tab <%= (typeof periodQuery !== 'undefined' && periodQuery === 'daily') ? 'active' : '' %>">일간</a>
                        <a href="/?period=weekly" class="tab <%= (typeof periodQuery !== 'undefined' && periodQuery === 'weekly') ? 'active' : '' %>">주간</a>
                        <a href="/?period=monthly" class="tab <%= (typeof periodQuery !== 'undefined' && periodQuery === 'monthly') ? 'active' : '' %>">월간</a>
                    </div>
                </div>
<% if (typeof genreQuery !== 'undefined' && genreQuery) { %>
    <div style="background: #161718; padding: 15px; border-radius: 10px; margin-bottom: 20px; border: 1px solid #333; display: flex; gap: 8px; flex-wrap: wrap;">
       <% const displayGenres = ['K-POP','POP','발라드','댄스','랩/힙합','R&B/Soul','Lo-Fi / 칠아웃','일렉트로니카','록/메탈','애니 / OST','클래식 / 재즈','뉴에이지','트로트','인디음악','밈 / 코미디']; %>
        <% displayGenres.forEach(g => { %>
            <a href="/?genre=<%= encodeURIComponent(g) %>" style="padding: 6px 14px; border-radius: 20px; font-size: 13px; font-weight: bold; border: 1px solid <%= genreQuery === g ? '#ff5722' : '#444' %>; background: <%= genreQuery === g ? '#ff5722' : '#222' %>; color: <%= genreQuery === g ? '#000' : '#aaa' %>; transition: 0.2s;"><%= g %></a>
        <% }) %>
    </div>
<% } %>
                <div class="chart-controls">
                    <input type="checkbox" id="checkAll" class="custom-checkbox" onchange="toggleAll(this)">
                    <button class="control-btn" onclick="playAll()">▶ 전체듣기</button>
                    <button class="control-btn" onclick="playSelected()">▶ 선택듣기</button>
                    <button class="control-btn" onclick="addSelectedToMyMusic()">+ 담기</button>
                    <a href="/mymusic" class="control-btn control-my-music">🎵 내 음악 보관함</a>
                </div>

                <table class="music-list">
                    <% if (artists && artists.length > 0) { %>
                        <% artists.forEach(function(music, index) { %>
                        <tr class="music-item" data-id="<%= music._id %>" data-title="<%= music.name %>" data-artist="<%= music.artist %>" data-cover="<%= music.imageUrl || 'https://via.placeholder.com/512/1a1a1a/ff5722?text=RANKING+AI' %>" data-audio="<%= music.audioUrl %>" data-lyrics="<%= encodeURIComponent(music.lyrics || '') %>">
                            <td class="check-col"><input type="checkbox" class="custom-checkbox song-check" value="<%= music._id %>"></td>
                            <td class="rank"><%= index + 1 %></td>
                            <td style="width: 80px;"><img src="<%= music.imageUrl || 'https://via.placeholder.com/512/1a1a1a/ff5722?text=RANKING+AI' %>" class="album-art"></td>
                            
                            <td class="song-info">
                                <div class="song-title">
                                    <%= music.name %>
                                    
                                    <% if (user && (user.role === 'admin' || user.id === music.uploader) && music._id !== "dummy") { %>
                                        <div style="margin-left: 10px; display: inline-flex; gap: 8px; align-items: center; background: rgba(0,0,0,0.5); padding: 3px 10px; border-radius: 6px; border: 1px solid #444;">
                                            <% if (user.role === 'admin') { %><span title="관리자 권한" style="font-size: 10px;">👑</span><% } %>
                                            <a href="/edit/<%= music._id %>" style="color: #00e5ff; font-size: 11px; font-weight: bold; text-decoration: none; cursor: pointer;">수정</a>
                                            <span style="color: #555; font-size: 10px;">|</span>
                                            <form action="/delete-music/<%= music._id %>" method="POST" onsubmit="return confirm('이 음원을 차트에서 정말 삭제하시겠습니까?');" style="display: flex; align-items: center; margin: 0;">
                                                <button type="submit" style="background: none; border: none; color: #ff4a4a; font-size: 11px; font-weight: bold; cursor: pointer; padding: 0; font-family: inherit;">삭제</button>
                                            </form>
                                        </div>
                                    <% } %>
                                </div>
                                <div class="singer"><%= music.artist %> (<%= music.genre %>) <span class="ai-badge">🎵 <%= music.aiTool %></span> <span style="margin-left:10px; color:#ff5722; font-size:12px;">🎧 재생 <%= music.views || 0 %>회</span></div>
                                
                                <% if (user && user.id !== music.uploader && music._id !== "dummy") { %>
                                    <div style="margin-top: 12px;">
                                        <button type="button" onclick="sendPurchaseMsg('<%= music.uploader %>', '<%= music.name %>')" style="width: 100%; background: rgba(255, 179, 0, 0.1); border: 1px solid #ffb300; color: #ffb300; padding: 8px 0; border-radius: 8px; font-size: 13px; font-weight: bold; cursor: pointer; transition: 0.2s; text-align: center;">
                                            🤝 이 곡의 작곡가에게 구매/사용 제안하기
                                        </button>
                                    </div>
                                <% } %>

                                <div class="action-row">
                                    <div class="action-btn" onclick="playSingleTrack(this)">▶ 듣기</div>
                                    <div class="action-btn" onclick="parseAndShowLyrics('<%= music._id %>', `<%= music.lyrics %>`)">📝 가사</div>
                                    <div class="action-btn" onclick="document.getElementById('comments-<%= music._id %>').style.display = (document.getElementById('comments-<%= music._id %>').style.display === 'block') ? 'none' : 'block';">💬 댓글 <%= music.comments ? music.comments.length : 0 %></div>
        
                                    <% 
                                        let isLiked = false;
                                        if (user && music.likedBy && music.likedBy.includes(user.id)) {
                                            isLiked = true;
                                        }
                                    %>
                                    <div class="action-btn" id="like-btn-<%= music._id %>" onclick="likeMusic('<%= music._id %>')" style="<%= isLiked ? 'color:#ff4a4a; border-color:#ff4a4a;' : '' %>">
                                        <%= isLiked ? '❤️' : '🤍' %> 좋아요 <span id="like-count-<%= music._id %>"><%= music.likes || 0 %></span>
                                    </div>
                                </div>

                                <div id="lyrics-<%= music._id %>" class="hidden-box lyrics-window"><div id="lyrics-content-<%= music._id %>"></div></div>
                                
                                <div id="comments-<%= music._id %>" class="hidden-box">
                                    <div style="max-height: 150px; overflow-y: auto; margin-bottom:15px;">
                                        <% if (music.comments && music.comments.length > 0) { %>
                                            <% music.comments.forEach(function(c) { %>
                                                <div style="border-bottom: 1px solid #333; padding: 8px 0; display: flex; justify-content: space-between; align-items: center;">
                                                    <div>
                                                        <span style="color:#ff5722; font-weight:bold; font-size:13px;"><%= c.author %></span>
                                                        <span style="font-size:14px; margin-left:8px; color:#ddd;"><%= c.text %></span>
                                                    </div>
                                                    <% if (user && (user.role === 'admin' || user.id === c.author)) { %>
                                                        <form action="/delete-music-comment/<%= music._id %>/<%= c._id %>" method="POST" style="margin: 0;" onsubmit="return confirm('이 댓글을 삭제할까요?');">
                                                            <button type="submit" style="background: none; border: none; color: #ff4a4a; font-size: 11px; cursor: pointer;">❌삭제</button>
                                                        </form>
                                                    <% } %>
                                                </div>
                                            <% }); %>
                                        <% } else { %>
                                            <p style="font-size:13px; color:#777;">아직 댓글이 없습니다.</p>
                                        <% } %>
                                    </div>
                                    
                                    <% if (music._id !== "dummy") { %>
                                        <form action="/add-comment/<%= music._id %>" method="POST" style="display:flex; gap:10px;">
                                            <input type="text" name="commentText" placeholder="댓글..." style="flex:1; padding:10px; border-radius:6px; border:1px solid #444; background:#222; color:white;" required>
                                            <button type="submit" style="background:#ff5722; color:black; border:none; padding:10px 20px; border-radius:6px; font-weight:bold; cursor:pointer;">등록</button>
                                        </form>
                                    <% } %>
                                </div>
                            </td>
                        </tr>
                        <% }); %>
                    <% } else { %>
                        <tr><td colspan="4" style="text-align:center; padding:100px; color:#555;">검색된 곡이 없습니다.</td></tr>
                    <% } %>
                </table>
            </div>

            <div class="sidebar-right">
                <h3 class="sidebar-title">🏆 인기 아티스트</h3>
                <ul class="artist-list">
                    <% popularArtists.forEach(function(artist, idx) { %>
                        <li class="artist-item">
                            <div style="display: flex; align-items: center; gap: 10px;">
                                <span class="artist-rank"><%= idx + 1 %></span>
                                <a href="/?search=<%= encodeURIComponent(artist._id) %>" class="artist-name"><%= artist._id %></a>
                            </div>
                            <span class="artist-count"><%= artist.count %>곡</span>
                        </li>
                    <% }); %>
                </ul>
            

            </div>
        </div>
    </div>

    <div class="bottom-player-bar" id="bottomPlayerBar">
        <div class="player-toggle-tab" onclick="togglePlayerVisibility()">▼ 숨기기</div>
        
        <div class="player-info">
            <img src="/logo.png" id="main-player-cover" class="player-cover" style="object-fit: contain; background: #000;">
            <div class="player-text">
                <span id="main-player-title" class="player-title">선택된 곡이 없습니다</span>
                <span id="main-player-artist" class="player-artist">목록에서 음악을 선택해주세요</span>
            </div>
        </div>
        
        <div class="player-controls-wrapper">
           <div class="player-buttons">
               <button id="id-btn-loop" onclick="toggleLoop()" title="한곡 반복">🔁</button>
               <button id="btn-prev" onclick="playPrevTrack()">⏮</button>
               <button id="btn-play" onclick="togglePlayPause()" class="play-btn">▶</button>
               <button id="btn-next" onclick="playNextTrack()">⏭</button>
            </div>
            <div class="progress-area">
                <span id="time-current">00:00</span>
                <input type="range" id="progress-bar" value="0" min="0" max="100" step="1">
                <span id="time-total">00:00</span>
            </div>
        </div>

      <div class="player-right-placeholder">
            <button type="button" onclick="toggleSyncLyrics()" title="실시간 가사 보기">가사</button>
            <button type="button" onclick="togglePlaylist()" title="재생목록 보기">목록</button>
      </div>
        
        <audio id="main-audio" style="display:none;" preload="auto" playsinline webkit-playsinline></audio>
        <audio id="heartbeat-audio" loop playsinline webkit-playsinline style="display:none;" src="data:audio/wav;base64,UklGRigAAABXQVZFZm10IBIAAAABAAEARKwAAIhYAQACABAAAABkYXRhAgAAAAEA"></audio>
    </div>    
    <div id="sync-lyrics-modal" style="display:none; position:fixed; bottom:90px; left:50%; transform:translateX(-50%); width:90%; max-width:400px; height:60vh; background:rgba(15, 16, 17, 0.95); border:1px solid #333; border-radius:15px; z-index:1005; overflow-y:auto; box-shadow:0 10px 40px rgba(0,0,0,0.9); padding:20px 20px 50vh 20px; text-align:center; backdrop-filter:blur(10px); scroll-behavior:smooth;">
        <div style="position:sticky; top:-20px; text-align:right; margin-bottom:20px; z-index:10;">
            <button type="button" onclick="toggleSyncLyrics()" style="background:rgba(0,0,0,0.5); border:1px solid #444; color:#fff; border-radius:50%; width:30px; height:30px; font-size:14px; cursor:pointer;">✕</button>
        </div>
        <div id="sync-lyrics-container" style="display:flex; flex-direction:column; gap:15px; font-size:16px; color:#777; transition:all 0.3s;">
            </div>
    </div>

    <div id="playlist-modal" style="display: none; position: fixed; bottom: 90px; right: 20px; width: 320px; max-height: 400px; background: #181818; border: 1px solid #ff5722; border-radius: 12px; z-index: 999999 !important; overflow-y: auto; box-shadow: 0 10px 30px rgba(0,0,0,0.8);">
        <div class="playlist-header" style="padding: 15px; border-bottom: 1px solid #282828; display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; background: #181818; z-index: 10;">
            <strong style="color:#fff; font-size:14px;">현재 재생 목록</strong>
            <button type="button" onclick="togglePlaylist()" style="background:none; border:none; color:#aaa; font-size:18px; cursor:pointer; padding:0; line-height:1;">✕</button>
        </div>
        <ul id="playlist-ul" style="list-style:none; padding:0; margin:0;">
            <li style="padding:20px; text-align:center; color:#777; font-size:12px;">재생할 곡을 선택해주세요.</li>
        </ul>
    </div>

    <script>
        (function() {
    const ua = navigator.userAgent.toLowerCase();
    const isNaver = /naver/i.test(ua); // 네이버 인앱 브라우저 체크
    const isAndroid = /android/i.test(ua); // 안드로이드 기기 체크

    // 안드로이드이면서 네이버 앱으로 접속했을 때만 실행
    if (isNaver && isAndroid) {
        // 현재 페이지 URL에서 프로토콜(http/https) 제거
        const currentUrl = window.location.href.replace(/https?:\/\//, "");
        
        // 안드로이드용 크롬 강제 실행 인텐트 스키마
        const chromeIntent = `intent://${currentUrl}#Intent;scheme=https;package=com.android.chrome;end`;

        // 💡 수정하신 문구 적용
        if (confirm("보다 안정적인 음악재생을 위해 크롬으로 이동할까요?")) {
            location.href = chromeIntent;
            return; // 👈 [추가] 크롬으로 이동 시 아래 로직(엔진 초기화 등) 실행 중단
        }
    }
})();


        // 🌟 1. 재생 모드 4단계 설정 (기본 -> 전체무한 -> 1곡무한 -> 추천자동)
        let loopMode = 'none'; // 'none', 'all', 'one', 'auto'
        
        function toggleLoop() {
            const btnLoop = document.getElementById('id-btn-loop');
            if (loopMode === 'none') {
                loopMode = 'all';
                btnLoop.style.color = "#ff5722";
                btnLoop.innerText = "🔁";
                btnLoop.title = "전체 무한재생";
            } else if (loopMode === 'all') {
                loopMode = 'one';
                btnLoop.style.color = "#ff5722";
                btnLoop.innerText = "🔂";
                btnLoop.title = "1곡 무한재생";
            } else if (loopMode === 'one') {
                loopMode = 'auto';
                btnLoop.style.color = "#ff5722";
                btnLoop.innerText = "✨"; // 📻 라디오/추천 모드 아이콘
                btnLoop.title = "추천곡 자동재생";
            } else {
                loopMode = 'none';
                btnLoop.style.color = "#777";
                btnLoop.innerText = "🔁";
                btnLoop.title = "전체재생 (반복없음)";
            }
        }
        
        function parseAndShowLyrics(musicId, rawLyrics) {
            const lyricsBox = document.getElementById('lyrics-' + musicId);
            const lyricsContent = document.getElementById('lyrics-content-' + musicId);
            if (!lyricsBox || !lyricsContent) return;
            if (lyricsBox.style.display === 'block') { lyricsBox.style.display = 'none'; return; }
            if (!rawLyrics || rawLyrics.trim() === "" || rawLyrics === "undefined" || rawLyrics === "null") {
                lyricsContent.innerHTML = "<p style='color:#777; text-align:center;'>등록된 가사가 없습니다.</p>";
            } else {
                lyricsContent.innerHTML = `<div style="line-height:1.8; padding:10px;">${decodeURIComponent(rawLyrics).split('\n').join('<br>')}</div>`;
            }
            lyricsBox.style.display = 'block';
        }

        function togglePlayerVisibility() {
            const playerBar = document.getElementById('bottomPlayerBar');
            const toggleTab = document.querySelector('.player-toggle-tab');
            playerBar.classList.toggle('collapsed');
            if (playerBar.classList.contains('collapsed')) toggleTab.innerText = '▲ 열기';
            else toggleTab.innerText = '▼ 숨기기';
        }

        function togglePlaylist() {
            const modal = document.getElementById('playlist-modal');
            if (modal.style.display === 'block') {
                modal.style.display = 'none';
            } else {
                updatePlaylistUI(); // 목록 내용을 새로고침하는 함수
                modal.style.display = 'block';
            }
        }

        function updatePlaylistUI() {
            const ul = document.getElementById('playlist-ul');
            ul.innerHTML = '';
            if (playlist.length === 0) {
                ul.innerHTML = '<li style="padding:20px; text-align:center; color:#777; font-size:12px;">재생할 곡을 선택해주세요.</li>';
                return;
            }
            playlist.forEach((track, i) => {
                const li = document.createElement('li');
                const isCurrent = (i === currentIndex);
                li.style = `padding:10px 15px; border-bottom:1px solid #222; display:flex; align-items:center; gap:12px; cursor:pointer; transition:0.2s; ${isCurrent ? 'background:rgba(255,87,34,0.1);' : ''}`;
                li.onclick = () => { loadTrack(i); };
                li.innerHTML = `
                    <img src="${track.cover || 'https://via.placeholder.com/50/282828/ff5722'}" style="width:36px; height:36px; border-radius:4px; object-fit:cover;">
                    <div style="display:flex; flex-direction:column; overflow:hidden; flex:1;">
                        <span style="font-size:13px; font-weight:${isCurrent ? 'bold' : 'normal'}; color:${isCurrent ? '#ff5722' : '#fff'}; white-space:nowrap; text-overflow:ellipsis; overflow:hidden;">${track.title}</span>
                        <span style="font-size:11px; color:#aaa; white-space:nowrap; text-overflow:ellipsis; overflow:hidden;">${track.artist}</span>
                    </div>
                    ${isCurrent ? '<span style="font-size:10px; color:#ff5722;">🎵</span>' : ''}
                `;
                ul.appendChild(li);
            });
        }

        const genreBtns = document.querySelectorAll('.genre-btn');
        const hiddenInput = document.getElementById('hiddenGenreInput');
        const vibeContainer = document.getElementById('vibe-container'); 
        const hiddenVibeInput = document.getElementById('hiddenVibeInput'); 

        genreBtns.forEach(btn => {
            btn.addEventListener('click', function() { 
                genreBtns.forEach(b => b.classList.remove('active')); 
                this.classList.add('active'); 
                const selectedGenre = this.getAttribute('data-genre');
                if(hiddenInput) hiddenInput.value = selectedGenre;

                // 감성적인 장르 4가지를 선택했을 때만 '매장/상황 무드 태그창'이 짠! 하고 나타납니다
                if (selectedGenre === '뉴에이지' || selectedGenre === 'Lo-Fi / 칠아웃' || selectedGenre === '클래식 / 재즈' || selectedGenre === '인디음악') {
                    if(vibeContainer) vibeContainer.style.display = 'block';
                } else {
                    if(vibeContainer) vibeContainer.style.display = 'none';
                    document.querySelectorAll('.vibe-check').forEach(cb => cb.checked = false);
                    if(hiddenVibeInput) hiddenVibeInput.value = "";
                }
            });
        });

        document.addEventListener('change', function(e) {
            if (e.target.classList.contains('vibe-check')) {
                const checkedValues = Array.from(document.querySelectorAll('.vibe-check:checked')).map(cb => cb.value);
                if(hiddenVibeInput) hiddenVibeInput.value = checkedValues.join(',');
            }
        });
        
        const musicForm = document.getElementById('musicForm');
        if (musicForm) {
            musicForm.addEventListener('submit', function(e) { 
                if (hiddenInput && !hiddenInput.value) { 
                    e.preventDefault(); 
                    alert('장르를 선택해주세요!'); 
                } 
            });
        }

        // 🌟 통합 데이터 및 상태 관리
        let playlist = []; let currentIndex = 0; let isPlaying = false;
        let parsedLyrics = []; 
        let errorCount = 0; // 🌟 3아웃(무한 스킵 방지) 카운터

        const mainAudio = document.getElementById('main-audio');
        const heartbeatAudio = document.getElementById('heartbeat-audio'); 
        const btnPlay = document.getElementById('btn-play');
        const progressBar = document.getElementById('progress-bar');
        const timeCurrent = document.getElementById('time-current');
        const timeTotal = document.getElementById('time-total');

       // 🌟 [완벽 무음 버전] 초미세 백색소음 + 5초 루프 (귀에 절대 안 들림!)
        let audioCtx;
        let isAudioUnlocked = false;
        let keepAliveInterval; 

        function initSuperUltrasonic() {
            if (isAudioUnlocked) {
                if(audioCtx && audioCtx.state === 'suspended') audioCtx.resume();
                return;
            }
            isAudioUnlocked = true;

            try {
                const AudioContext = window.AudioContext || window.webkitAudioContext;
                audioCtx = new AudioContext();
                
                // 1. 삐- 소리 대신 '무음 백색소음'을 만듭니다.
                const bufferSize = audioCtx.sampleRate * 0.5;
                const buffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
                const data = buffer.getChannelData(0);
                for (let i = 0; i < bufferSize; i++) {
                    data[i] = Math.random() * 2 - 1;
                }
                
                const source = audioCtx.createBufferSource();
                source.buffer = buffer;
                source.loop = true; // 무한 반복
                
                // 2. 🚨 볼륨을 0.00001 (0.001%)로 설정! 사람 귀엔 절대 안 들립니다.
                const gainNode = audioCtx.createGain();
                gainNode.gain.value = 0.00001; 
                
                source.connect(gainNode);
                gainNode.connect(audioCtx.destination);
                source.start(); 
                
                if (heartbeatAudio) {
                    heartbeatAudio.volume = 0.1;
                    heartbeatAudio.play().catch(e => {});
                }

                // 3. 5초마다 엔진 강제 기상 (네이버 수면 방지)
                if (!keepAliveInterval) {
                    keepAliveInterval = setInterval(() => {
                        if (audioCtx && audioCtx.state === 'suspended') audioCtx.resume();
                        if (heartbeatAudio && heartbeatAudio.paused) heartbeatAudio.play().catch(e => {});
                    }, 5000);
                }
                
                console.log("💓 완벽 무음 엔진 가동 완료 (귀에 안 들림)");
            } catch (err) { console.log("Web Audio API 미지원"); }
        }
        
        // 화면 터치/클릭 시마다 엔진 깨우기
        document.addEventListener('touchstart', initSuperUltrasonic, { passive: true, once: true });
        document.addEventListener('click', initSuperUltrasonic, { once: true });

        // 🌟 오디오 플레이 시에도 엔진이 죽지 않게 계속 깨움
        mainAudio.addEventListener('play', () => {
            if (audioCtx && audioCtx.state === 'suspended') {
                audioCtx.resume();
            }
            if (heartbeatAudio && heartbeatAudio.paused) {
                heartbeatAudio.play().catch(e => {});
            }
        });

        function toggleAll(source) { document.querySelectorAll('.song-check').forEach(cb => cb.checked = source.checked); }

        function togglePlayPause() {
            if (playlist.length === 0) return alert("재생할 곡을 선택해주세요!");

            if (mainAudio.paused) {
                mainAudio.play().then(() => {
                    isPlaying = true;
                    if(btnPlay) btnPlay.innerText = "⏸";
                    if ('mediaSession' in navigator) navigator.mediaSession.playbackState = "playing";
                    
                    // 🚨 대기 상태에서 눌렀다면 원래 제목으로 복구!
                    const currentTrack = playlist[currentIndex];
                    if (currentTrack && document.getElementById('main-player-title').innerText.includes("터치해서")) {
                        document.getElementById('main-player-title').innerText = currentTrack.title;
                        document.getElementById('main-player-artist').innerText = currentTrack.artist;
                    }
                }).catch(e => console.log(e));
            } else {
                mainAudio.pause(); isPlaying = false;
                if(btnPlay) btnPlay.innerText = "▶";
                if ('mediaSession' in navigator) navigator.mediaSession.playbackState = "paused";
            }
        }

        function toggleSyncLyrics() {
            const modal = document.getElementById('sync-lyrics-modal');
            if(modal) modal.style.display = (modal.style.display === 'block') ? 'none' : 'block';
        }

        function loadSyncLyrics(rawLyrics) {
            parsedLyrics = [];
            const container = document.getElementById('sync-lyrics-container');
            if(!container) return;
            container.innerHTML = "";
            
            if (!rawLyrics || rawLyrics.trim() === "" || rawLyrics === "undefined" || rawLyrics === "null") {
                container.innerHTML = "<p style='color:#555; margin-top:50px;'>등록된 싱크 가사가 없습니다.</p>";
                return;
            }

            const lines = decodeURIComponent(rawLyrics).split('\n');
            const timeRegex = /\[(\d{2}):(\d{2}(?:\.\d{1,3})?)\](.*)/;
            
            lines.forEach(line => {
                const match = line.match(timeRegex);
                if (match) {
                    const time = parseInt(match[1]) * 60 + parseFloat(match[2]);
                    const text = match[3].trim() || "🎵";
                    parsedLyrics.push({ time, text });
                }
            });

            if (parsedLyrics.length > 0) {
                parsedLyrics.forEach((lyric, idx) => {
                    container.innerHTML += `<div id="sync-lyric-${idx}" class="sync-lyric-line" style="transition:0.3s; cursor:pointer; padding:5px 0;" onclick="mainAudio.currentTime=${lyric.time}; mainAudio.play();">${lyric.text}</div>`;
                });
            } else {
                container.innerHTML = `<p style='color:#aaa; line-height:1.8; white-space:pre-wrap;'>${decodeURIComponent(rawLyrics).split('\n').join('<br>')}</p>`;
            }
        }

       function loadTrack(index) {
            if(index >= 0 && index < playlist.length) {
                const track = playlist[index];
                currentIndex = index; 
                
                // 🚨 [필수 수정] 자물쇠 2개를 모두 즉시 해제하여 다음 곡 로딩 준비!
                window.isSwapping = false; 
                window.isPreloading = false; 

                // 👑 [네이버 딥슬립 방지] 초저주파 펄스 엔진 (강화 버전)
                if (!window.naverDeepSleepDefender) {
                    window.naverDeepSleepDefender = true;
                    try {
                        const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                        const oscillator = audioCtx.createOscillator();
                        const gainNode = audioCtx.createGain();
                        oscillator.type = 'sine';
                        oscillator.frequency.setValueAtTime(15, audioCtx.currentTime); // 15Hz: 실제 스피커 물리 진동 유발
                        gainNode.gain.setValueAtTime(0.005, audioCtx.currentTime); 
                        oscillator.connect(gainNode);
                        gainNode.connect(audioCtx.destination);
                        oscillator.start();
                        setInterval(() => {
                            if (audioCtx.state === 'suspended') audioCtx.resume();
                        }, 20000);
                    } catch (e) {}
                }

                if(!track.audio || track.audio.trim() === "" || track.audio === "undefined") {
                    errorCount++;
                    if(errorCount >= 3) { isPlaying = false; if(btnPlay) btnPlay.innerText = "▶"; errorCount = 0; }
                    else { playNextTrack(); } return; 
                }
                
                // 🚀 [우선순위] 오디오 소스부터 즉시 할당
                mainAudio.src = track.audio.trim();
                const playPromise = mainAudio.play();
                
                if (playPromise !== undefined) {
                    playPromise.then(() => {
                        // ✅ 브라우저가 자동재생을 허락함! (정상 재생)
                        errorCount = 0; isPlaying = true;
                        if(btnPlay) btnPlay.innerText = "⏸";
                        if(window.carrierWaveAudio) window.carrierWaveAudio.play().catch(()=>{});

                        // 오디오 안정화 후 UI 업데이트
                        setTimeout(() => {
                            updatePlaylistUI();
                            loadSyncLyrics(track.lyrics);
                            document.getElementById('main-player-title').innerText = track.title;
                            document.getElementById('main-player-artist').innerText = track.artist;
                            document.getElementById('main-player-cover').src = track.cover || '/logo.png';
                            if ('mediaSession' in navigator) {
                                navigator.mediaSession.playbackState = "playing";
                                navigator.mediaSession.metadata = new MediaMetadata({
                                    title: track.title, artist: track.artist || 'RANKING AI',
                                    artwork: [{ src: track.cover || '/logo.png', sizes: '512x512', type: 'image/jpeg' }]
                                });
                            }
                        }, 50);
                    }).catch(e => {
                        // 💀 브라우저가 다음 곡 자동재생을 차단함! (유저 터치 유도 마법 작동!)
                        console.log("🚨 자동재생 차단됨! 유저 터치 대기 중...");
                        isPlaying = false; 
                        if(btnPlay) btnPlay.innerText = "▶";
                        
                        // 제목을 바꿔서 유저가 누르도록 유도
                        
                        // 제목을 바꿔서 유저가 누르도록 유도
                        document.getElementById('main-player-title').innerText = "👆 터치해서 다음 곡 재생";
                        document.getElementById('main-player-artist').innerText = track.title + " (대기중)";
                        updatePlaylistUI();
                    });
                }

                // 👑 [풀옵션 엔진] 15초 전 캐싱 + 0.3초 스왑 + 🚨멈춤 감지 즉시 탈출🚨
                if (!window.proEngineAttached) {
                    window.proEngineAttached = true;
                    window.nextAudioCache = new Audio();

                    mainAudio.addEventListener('timeupdate', () => {
                        const remain = mainAudio.duration - mainAudio.currentTime;
                        
                        // 1. 다음 곡 미리 찌르기 (15초 전)
                        if (remain <= 15.0 && !window.isPreloading && currentIndex < playlist.length - 1) {
                            window.isPreloading = true; // 자물쇠 잠금
                            window.nextAudioCache.src = playlist[currentIndex + 1].audio.trim();
                            window.nextAudioCache.load();
                            console.log("👑 PRO: 다음 곡 프리로딩 시작");
                        }

                        // 2. 0.3초 전 강제 릴레이
                        if (remain <= 0.3 && !window.isSwapping) {
                            window.isSwapping = true;
                            playNextTrack(); 
                        }
                    });

                    // 🚨 가짜 시간 때문에 2초를 남기고 오디오가 멈춰버렸을 때 (waiting/stalled)
                    const forceSkipIfStuck = () => {
                        if (mainAudio.duration && (mainAudio.duration - mainAudio.currentTime <= 5.0)) {
                            if (!window.isSwapping) {
                                window.isSwapping = true;
                                console.log("👑 PRO: 끝부분 허공 멈춤(Stalled) 감지! 즉시 강제 스킵!");
                                playNextTrack();
                            }
                        }
                    };
                    mainAudio.addEventListener('waiting', forceSkipIfStuck);
                    mainAudio.addEventListener('stalled', forceSkipIfStuck);

                    // 3. 정상 종료 시 백업
                    mainAudio.onended = () => {
                        if (!window.isSwapping) {
                            window.isSwapping = true;
                            playNextTrack();
                        }
                    };
                }

                setTimeout(() => {
                    if (track.id && track.id !== "dummy") fetch('/play-count/' + track.id, { method: 'POST', keepalive: true }).catch(()=>{});
                }, 1000);
            }
        }
        
       // 🌟 4. 마법의 똑똑한 다음 곡 넘기기 기능! (4가지 모드 완벽 대응)
        function playNextTrack() {
            if (currentIndex < playlist.length - 1) {
                loadTrack(currentIndex + 1);
            } else { 
                // 플레이리스트의 맨 마지막 곡일 때
                if (loopMode === 'all') {
                    loadTrack(0); // 전체 무한재생: 1번 곡으로 돌아감
                } else if (loopMode === 'auto') {
                    // 추천 자동재생(✨): 현재 화면에서 안 깨진 음원 중 랜덤으로 뽑아서 계속 틀어줌!
                    const rows = document.querySelectorAll('.music-item');
                    const validRows = Array.from(rows).filter(tr => tr.dataset.audio && tr.dataset.audio.trim() !== "" && tr.dataset.audio !== "undefined");
                    
                    if (validRows.length > 0) {
                        const randomRow = validRows[Math.floor(Math.random() * validRows.length)];
                        playlist.push({
                            id: randomRow.dataset.id, title: randomRow.dataset.title, artist: randomRow.dataset.artist, 
                            cover: randomRow.dataset.cover, audio: randomRow.dataset.audio, lyrics: randomRow.dataset.lyrics
                        });
                        loadTrack(playlist.length - 1);
                    } else {
                        mainAudio.pause(); isPlaying = false; if(btnPlay) btnPlay.innerText = "▶";
                    }
                } else {
                    // 기본 모드 -> 얌전히 정지
                    mainAudio.pause(); isPlaying = false;
                    if(btnPlay) btnPlay.innerText = "▶"; 
                    if ('mediaSession' in navigator) navigator.mediaSession.playbackState = "paused";
                }
            }
        }

        mainAudio.addEventListener('timeupdate', () => {
            const current = mainAudio.currentTime; const duration = mainAudio.duration;
            if (duration && !isNaN(duration)) {
                const progressPercent = (current / duration) * 100;
                progressBar.value = progressPercent;
                
                // 🚀 [핵심] 재생되는 퍼센트만큼 실시간으로 주황색 배경 채우기!
                progressBar.style.background = `linear-gradient(to right, #ff5722 ${progressPercent}%, #4d4d4d ${progressPercent}%)`;

                let minC = Math.floor(current / 60); let secC = Math.floor(current % 60);
                if(secC < 10) secC = "0" + secC; timeCurrent.innerText = minC + ":" + secC;
                let minD = Math.floor(duration / 60); let secD = Math.floor(duration % 60);
                if(secD < 10) secD = "0" + secD; timeTotal.innerText = minD + ":" + secD;

                if (parsedLyrics.length > 0) {
                    let activeIdx = -1;
                    for (let i = 0; i < parsedLyrics.length; i++) {
                        if (current >= parsedLyrics[i].time) activeIdx = i; else break;
                    }
                    document.querySelectorAll('.sync-lyric-line').forEach((el, i) => {
                        if (i === activeIdx) {
                            el.style.color = '#ff5722'; el.style.fontWeight = 'bold'; el.style.transform = 'scale(1.1)';
                            const modal = document.getElementById('sync-lyrics-modal');
                            if (modal && modal.style.display === 'block') {
                                modal.scrollTo({ top: el.offsetTop - modal.clientHeight / 2.5, behavior: 'smooth' });
                            }
                        } else {
                            el.style.color = '#777'; el.style.fontWeight = 'normal'; el.style.transform = 'scale(1.0)';
                        }
                    });
                }
            }
        });

        progressBar.addEventListener('input', () => { 
            if (mainAudio.duration) {
                mainAudio.currentTime = (progressBar.value / 100) * mainAudio.duration; 
                // 🚀 사용자가 마우스로 드래그 할 때도 즉시 색깔 채우기
                progressBar.style.background = `linear-gradient(to right, #ff5722 ${progressBar.value}%, #4d4d4d ${progressBar.value}%)`;
            }
        });

       // 🌟 1곡 무한재생 대응
        mainAudio.addEventListener('ended', () => {
            if (loopMode === 'one') {
                mainAudio.currentTime = 0;
                mainAudio.play().catch(e => { 
                    isPlaying = false; 
                    if(btnPlay) btnPlay.innerText = "▶"; 
                    const track = playlist[currentIndex];
                    if(track) {
                        document.getElementById('main-player-title').innerText = "👆 터치해서 재생";
                        document.getElementById('main-player-artist').innerText = track.title + " (대기중)";
                    }
                });
            } else {
                playNextTrack(); // 나머지는 이 녀석이 똑똑하게 처리
            }
        });

        // 🌟 [수정완료] 재생 중 끊김/에러 발생 시 멋대로 다음 곡으로 넘어가지 않음!
        mainAudio.addEventListener('error', (e) => { 
            console.log("오디오 재생 중 에러 또는 네트워크 끊김 발생");
            // 에러가 나면 맘대로 넘어가지 않고, 그냥 얌전히 일시정지 상태로 대기합니다.
            errorCount = 0;
            isPlaying = false; 
            if(btnPlay) btnPlay.innerText = "▶"; 
        });

        function playSingleTrack(btnElement) {
            const tr = btnElement.closest('.music-item'); 
            const audioUrl = tr.dataset.audio;
            if (!audioUrl || audioUrl === "undefined" || audioUrl.trim() === "") return alert("아직 음원이 제대로 업로드되지 않은 곡입니다!");
            
            // 👑 [해결책] 현재 화면에 있는 '모든 곡'을 플레이리스트 큐(Queue)에 먼저 꽉 채워 넣습니다!
            const rows = document.querySelectorAll('.music-item');
            playlist = Array.from(rows).map(row => ({ 
                id: row.dataset.id, title: row.dataset.title, artist: row.dataset.artist, 
                cover: row.dataset.cover, audio: row.dataset.audio, lyrics: row.dataset.lyrics 
            })).filter(t => t.audio && t.audio.trim() !== "" && t.audio !== "undefined");
            
            // 내가 방금 클릭한 곡이 전체 100곡 중 몇 번째(Index)인지 찾아냅니다.
            const clickedId = tr.dataset.id;
            const targetIndex = playlist.findIndex(t => t.id === clickedId);
            
            // 그 번호부터 재생을 시작합니다! (끝나면 자연스럽게 다음 곡으로 무한 주행)
            if (targetIndex !== -1) {
                loadTrack(targetIndex);
            } else {
                loadTrack(0); // 혹시 못 찾으면 1번 곡부터
            }
        }

        function playAll() {
            const rows = document.querySelectorAll('.music-item');
            playlist = Array.from(rows).map(tr => ({ id: tr.dataset.id, title: tr.dataset.title, artist: tr.dataset.artist, cover: tr.dataset.cover, audio: tr.dataset.audio, lyrics: tr.dataset.lyrics })).filter(t => t.audio && t.audio.trim() !== "" && t.audio !== "undefined"); 
            if(playlist.length > 0) { currentIndex = 0; loadTrack(0); } else alert("재생 가능한 음원이 없습니다.");
        }

        function playSelected() {
            const checkedBoxes = document.querySelectorAll('.song-check:checked');
            if(checkedBoxes.length === 0) return alert("재생할 곡을 먼저 체크해주세요!");
            playlist = Array.from(checkedBoxes).map(cb => {
                const tr = cb.closest('.music-item');
                return { id: tr.dataset.id, title: tr.dataset.title, artist: tr.dataset.artist, cover: tr.dataset.cover, audio: tr.dataset.audio, lyrics: tr.dataset.lyrics }; 
            }).filter(t => t.audio && t.audio.trim() !== "" && t.audio !== "undefined");
            if(playlist.length > 0) { currentIndex = 0; loadTrack(0); } else alert("선택한 곡 중에 재생 가능한 음원이 없습니다.");
        }

        function addSelectedToMyMusic() {
            const checkedBoxes = document.querySelectorAll('.song-check:checked');
            if(checkedBoxes.length === 0) return alert("담을 곡을 체크해주세요!");
            const musicIds = Array.from(checkedBoxes).map(cb => cb.value);
            fetch('/add-to-mymusic', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ musicIds: musicIds }) })
            .then(res => res.json()).then(data => alert(data.message)).catch(err => alert("에러가 발생했습니다. 다시 시도해주세요."));
        }

       // 🚀 1. 탭 이동 시 화면 부드럽게 넘기기 (유튜브, 쇼츠 포함)
        document.addEventListener('click', async (e) => {
            const link = e.target.closest('a'); if (!link) return;
            const href = link.getAttribute('href');
            
            // 기존에 있던 shorts와 youtube 예외를 지웠습니다! 이제 끊기지 않습니다.
            // 🚨 [핵심 추가] 단, 'radio' 방은 풀스크린 전용이므로 부드러운 전환 마법에서 제외합니다!
            if (href && href.startsWith('/') && !href.includes('admin') && !href.includes('delete') && !href.includes('logout') && !href.includes('login') && !href.includes('signup') && !href.includes('edit') && !href.includes('radio')) { 
                e.preventDefault(); navigateTo(href); 
            }
        });

        // 📺 2. [스마트 센서] 유튜브/쇼츠 영상(iframe)을 클릭해서 볼 때만 배경 음악을 멈춥니다!
        window.addEventListener('blur', () => {
            if (document.activeElement && document.activeElement.tagName === 'IFRAME') {
                const mainAudio = document.getElementById('main-audio');
                const btnPlay = document.getElementById('btn-play');
                
                if (mainAudio && !mainAudio.paused) {
                    mainAudio.pause(); 
                    if (typeof isPlaying !== 'undefined') isPlaying = false;
                    if (btnPlay) btnPlay.innerText = "▶";
                    console.log("📺 영상 시청 감지! 배경 음악을 정지합니다.");
                }
            }
        });

        document.addEventListener('submit', async (e) => {
            const form = e.target;
            if (form.method.toLowerCase() === 'get') {
                e.preventDefault(); const formData = new FormData(form);
                navigateTo(form.getAttribute('action') + '?' + new URLSearchParams(formData).toString());
            }
        });

        async function navigateTo(href) {
            try {
                const response = await fetch(href); const html = await response.text();
                const newDoc = new DOMParser().parseFromString(html, 'text/html');
                
                // 🚀🚀🚀 [디자인 도둑 마법 추가!] 새 페이지의 CSS 옷을 현재 화면에 강제로 입혀줍니다!
                const newStyles = newDoc.querySelectorAll('style');
                newStyles.forEach(newStyle => {
                    let isExist = false;
                    document.querySelectorAll('style').forEach(existingStyle => {
                        if(existingStyle.innerHTML === newStyle.innerHTML) isExist = true;
                    });
                    if(!isExist) {
                        const s = document.createElement('style');
                        s.innerHTML = newStyle.innerHTML;
                        document.head.appendChild(s);
                    }
                });
                // 🚀🚀🚀 =========================================================

               const currentContainer = document.querySelector('.container'); const newContainer = newDoc.querySelector('.container');
        if (currentContainer && newContainer) {
            currentContainer.innerHTML = newContainer.innerHTML;
            
            // 🚀 [마법의 스크립트 부활 주문] 쇼츠/유튜브 화면의 클릭 기능들을 강제로 깨워줍니다!
            const scripts = currentContainer.querySelectorAll('script');
            scripts.forEach(script => {
                const newScript = document.createElement('script');
                Array.from(script.attributes).forEach(attr => newScript.setAttribute(attr.name, attr.value));
                newScript.innerHTML = script.innerHTML;
                document.body.appendChild(newScript);
                document.body.removeChild(newScript); // 실행만 시키고 흔적 지우기
            });
        }
                const currentNav = document.querySelector('.header-nav'); const newNav = newDoc.querySelector('.header-nav');
                if (currentNav && newNav) currentNav.innerHTML = newNav.innerHTML;
                history.pushState(null, '', href); document.title = newDoc.title;
                
                const playerBar = document.getElementById('bottomPlayerBar');
                if (playerBar) {
                    if (href.includes('/youtube') || href.includes('/shorts') || href.includes('/board')) playerBar.style.display = 'none';
                    else playerBar.style.display = 'flex'; 
                }
                reattachEvents(); window.scrollTo(0, 0); 

                document.body.style.display = 'none';
                document.body.offsetHeight; 
                document.body.style.display = '';
                
            } catch (err) { location.href = href; }
        }

        window.addEventListener('popstate', async () => navigateTo(location.pathname + location.search));

        function reattachEvents() {
            const genreBtns = document.querySelectorAll('.genre-btn'); const hiddenInput = document.getElementById('hiddenGenreInput');
            genreBtns.forEach(btn => {
                btn.addEventListener('click', function() { 
                    genreBtns.forEach(b => b.classList.remove('active')); this.classList.add('active'); 
                    if(hiddenInput) hiddenInput.value = this.getAttribute('data-genre'); 
                });
            });
            const musicForm = document.getElementById('musicForm');
            if(musicForm) musicForm.addEventListener('submit', function(e) { if (hiddenInput && !hiddenInput.value) { e.preventDefault(); alert('장르를 선택해주세요!'); } });
        }

        async function likeMusic(musicId) {
            try {
                const response = await fetch('/like/' + musicId, { method: 'POST' }); const data = await response.json();
                if (data.success) {
                    const countSpan = document.getElementById('like-count-' + musicId); countSpan.innerText = parseInt(countSpan.innerText) + 1;
                    const btn = document.getElementById('like-btn-' + musicId);
                    btn.innerHTML = '❤️ 좋아요 <span id="like-count-' + musicId + '">' + countSpan.innerText + '</span>';
                    btn.style.color = '#ff4a4a'; btn.style.borderColor = '#ff4a4a';
                } else alert(data.message);
            } catch (err) { alert("에러가 발생했습니다."); }
        } 

        function copyMusicLink(musicId) {
            navigator.clipboard.writeText(window.location.origin + '/?play=' + encodeURIComponent(musicId)).then(() => alert("노래 공유 링크가 복사되었습니다! 🔗"));
        }  

// 🚀 [통화 종료 후 화면 복귀 시 자동 재생 엔진] 🚀
        let wasPlayingBeforeInterruption = false;

        mainAudio.addEventListener('pause', () => {
            if (isPlaying) {
                console.log("📞 시스템(전화 등)에 의해 오디오 강제 정지됨!");
                wasPlayingBeforeInterruption = true; 
            }
        });

        document.addEventListener('visibilitychange', () => {
            if (document.visibilityState === 'visible' && wasPlayingBeforeInterruption) {
                console.log("👀 화면 복귀 감지! 중단된 음악을 즉시 자동 재생 시도합니다.");
                
                const playPromise = mainAudio.play();
                if (playPromise !== undefined) {
                    playPromise.then(() => {
                        console.log("✅ 통화 종료 후 자동 재생 성공!");
                        wasPlayingBeforeInterruption = false; 
                        isPlaying = true;
                        if(btnPlay) btnPlay.innerText = "⏸";
                    }).catch(e => {
                        console.log("❌ 브라우저 자동재생 방어막에 막힘 (터치 1회 필요)");
                    });
                }
            }
        });
    </script>

   <script>
        document.addEventListener('DOMContentLoaded', () => {
            const imageInput = document.querySelector('input[name="image"]');
            if (imageInput) {
                imageInput.addEventListener('change', function(e) {
                    const file = e.target.files[0];
                    if (!file || !file.type.match(/image.*/)) return;
                    const reader = new FileReader();
                    reader.onload = function(event) {
                        const img = new Image();
                        img.src = event.target.result;
                        img.onload = function() {
                            const MAX_WIDTH = 800;
                            let width = img.width; let height = img.height;
                            if (width > MAX_WIDTH) { height = Math.round((height * MAX_WIDTH) / width); width = MAX_WIDTH; }
                            const canvas = document.createElement('canvas');
                            canvas.width = width; canvas.height = height;
                            const ctx = canvas.getContext('2d');
                            ctx.drawImage(img, 0, 0, width, height);
                            canvas.toBlob(function(blob) {
                                const compressedFile = new File([blob], file.name.replace(/\.[^/.]+$/, "") + ".jpg", { type: 'image/jpeg', lastModified: Date.now() });
                                const dataTransfer = new DataTransfer();
                                dataTransfer.items.add(compressedFile);
                                imageInput.files = dataTransfer.files;
                                const infoSpan = imageInput.parentElement.querySelector('.compress-info');
                                if (!infoSpan) {
                                    const span = document.createElement('span'); span.className = 'compress-info'; span.style = "color: #ffb300; font-size: 11px; margin-left: 10px; font-weight: bold;";
                                    span.innerText = `✅ 초고속 압축 완료! (${(compressedFile.size / 1024).toFixed(1)}KB)`; imageInput.parentElement.appendChild(span);
                                } else infoSpan.innerText = `✅ 초고속 압축 완료! (${(compressedFile.size / 1024).toFixed(1)}KB)`;
                            }, 'image/jpeg', 0.8);
                        }
                    }
                    reader.readAsDataURL(file);
                });
            }
        });
    </script>

