<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RANKING AI</title>
    <style>
        body { background: #0b0c0d; color: #fff; font-family: 'Pretendard', sans-serif; margin: 0; }
        a { text-decoration: none; color: inherit; }

        .navbar { display: flex; justify-content: space-between; align-items: center; padding: 15px 40px; background: #121314; border-bottom: 1px solid #222; position: sticky; top: 0; z-index: 100; }
        .logo { font-size: 26px; font-weight: 900; color: #00e5ff; letter-spacing: -1px; }
        .auth-buttons { display: flex; gap: 20px; align-items: center; }
        .btn-login { color: #bbb; font-size: 14px; transition: 0.2s; }
        .btn-login:hover { color: #fff; }
        .btn-signup { background: #00e5ff; color: #000; padding: 8px 20px; border-radius: 20px; font-weight: bold; font-size: 14px; }

        .container { max-width: 1000px; margin: 0 auto; padding: 40px 20px; }

        .upload-section { background: #161718; padding: 30px; border-radius: 15px; margin-bottom: 40px; border: 1px solid #222; }
        .input-row { display: flex; gap: 15px; margin-bottom: 15px; }
        input[type="text"] { flex: 1; background: #222; border: 1px solid #333; color: #fff; padding: 12px; border-radius: 8px; box-sizing: border-box; }
        textarea { width: 100%; background: #222; border: 1px solid #333; color: #fff; padding: 12px; border-radius: 8px; height: 80px; margin-bottom: 15px; box-sizing: border-box; }
        .file-upload { flex: 1; background: #222; padding: 10px; border-radius: 8px; color: #aaa; }
        .btn-upload { background: #333; color: #fff; border: none; padding: 12px 30px; border-radius: 8px; cursor: pointer; font-weight: bold; transition: 0.2s; white-space: nowrap; }
        .btn-upload:hover { background: #00e5ff; color: #000; }

        .chart-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 20px; border-bottom: 2px solid #222; padding-bottom: 15px; }
        .chart-title { font-size: 28px; font-weight: bold; }
        .tabs { display: flex; gap: 25px; }
        .tab { color: #777; cursor: pointer; font-weight: 600; font-size: 16px; padding-bottom: 10px; }
        .tab.active { color: #00e5ff; border-bottom: 3px solid #00e5ff; }

        .music-list { width: 100%; border-collapse: collapse; }
        .music-item { border-bottom: 1px solid #1a1b1c; transition: 0.2s; }
        .music-item:hover { background: #1a1c1e; }
        .music-item td { padding: 15px; vertical-align: middle; }
        .rank { font-size: 22px; font-weight: bold; color: #00e5ff; width: 40px; text-align: center; }
        .album-art { width: 60px; height: 60px; border-radius: 8px; object-fit: cover; }
        
        .song-info { display: flex; flex-direction: column; gap: 4px; }
        .song-title { font-size: 16px; font-weight: 600; display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
        .singer { font-size: 14px; color: #888; display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
        
        .ai-badge { background: rgba(0, 229, 255, 0.1); border: 1px solid #00e5ff; color: #00e5ff; font-size: 11px; padding: 2px 8px; border-radius: 12px; font-weight: bold; }
        
        .private-info { font-size: 12px; color: #ff4a4a; margin-top: 4px; }
        .edit-btn { background: #333; color: #fff; font-size: 11px; padding: 4px 8px; border-radius: 4px; cursor: pointer; }
        
        .lyrics-box { display: none; background: #111; padding: 15px; border-radius: 8px; margin-top: 10px; font-size: 14px; color: #ccc; line-height: 1.6; border: 1px solid #222; }
        .actions { display: flex; gap: 15px; font-size: 20px; cursor: pointer; color: #888; }
        .actions span:hover { color: #00e5ff; transform: scale(1.1); transition: 0.2s; }

        /* 🌟 스마트폰 화면용 디자인 (화면이 작아질 때 적용됨) */
        @media (max-width: 768px) {
            .navbar { padding: 15px 20px; }
            .logo { font-size: 20px; }
            .container { padding: 20px 10px; }
            .input-row { flex-direction: column; gap: 10px; } /* 입력칸을 세로로 배치 */
            .chart-header { flex-direction: column; align-items: flex-start; gap: 15px; }
            .music-item td { padding: 10px 5px; }
            .rank { font-size: 18px; width: 25px; }
            .album-art { width: 50px; height: 50px; }
            .song-title { font-size: 14px; }
            .actions { gap: 10px; font-size: 16px; }
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <div class="logo">RANKING AI</div>
        <div class="auth-buttons">
            <a href="/login" class="btn-login">로그인</a>
            <a href="/signup" class="btn-signup">회원가입</a>
        </div>
    </nav>

    <div class="container">
        <div class="upload-section">
            <h3 style="margin-top:0; color:#00e5ff;">🎵 회원을 위한 음원 업로드</h3>
            <form action="/add-music" method="POST" enctype="multipart/form-data">
                <div class="input-row">
                    <input type="text" name="name" placeholder="곡 제목" required>
                    <input type="text" name="artist" placeholder="아티스트" required>
                </div>
                <div class="input-row">
                    <input type="text" name="genre" placeholder="장르 (예: 댄스, 발라드)">
                    <input type="text" name="aiTool" placeholder="사용 프로그램 (예: Suno, Udio)" required>
                </div>
                <textarea name="lyrics" placeholder="가사를 입력하세요. (예: [00:15] 싱크 가사)"></textarea>
                <div class="input-row">
                    <input type="text" name="realName" placeholder="업로더 실명 (비공개 처리됨)" required>
                    <input type="file" name="image" accept="image/*" class="file-upload" required>
                    <button type="submit" class="btn-upload">차트 등록</button>
                </div>
            </form>
        </div>

        <div class="chart-header">
            <div class="chart-title">랭킹AI 100</div>
            <div class="tabs">
                <div class="tab active">실시간</div>
                <div class="tab">일간</div>
                <div class="tab">주간</div>
                <div class="tab">월간</div>
            </div>
        </div>

        <table class="music-list">
            <% if (artists && artists.length > 0) { %>
                <% artists.forEach(function(music, index) { %>
                <tr class="music-item">
                    <td class="rank"><%= index + 1 %></td>
                    <td style="width: 60px;"><img src="<%= music.imageUrl %>" class="album-art"></td>
                    <td class="song-info">
                        <div class="song-title">
                            <%= music.name %>
                            <% if (user && (user.id === music.uploader || user.role === 'admin')) { %>
                                <span class="edit-btn">수정</span>
                            <% } %>
                        </div>
                        <div class="singer">
                            <%= music.artist %> (<%= music.genre %>)
                            <span class="ai-badge">🎵 <%= music.aiTool %></span>
                        </div>
                        
                        <% if (user && (user.id === music.uploader || user.role === 'admin')) { %>
                            <div class="private-info">🔒 등록자 (비공개): <%= music.uploaderRealName %></div>
                        <% } %>

                        <div id="lyrics-<%= index %>" class="lyrics-box"><%= music.lyrics %></div>
                    </td>
                    <td style="text-align: right;">
                        <div class="actions">
                            <span title="음악 듣기">🎧</span>
                            <span title="가사 보기" onclick="document.getElementById('lyrics-<%= index %>').style.display = (document.getElementById('lyrics-<%= index %>').style.display === 'block') ? 'none' : 'block';">📝</span>
                            <span title="좋아요">❤️</span>
                            <span title="댓글 쓰기">💬</span>
                        </div>
                    </td>
                </tr>
                <% }); %>
            <% } else { %>
                <tr>
                    <td colspan="4" style="text-align:center; padding:100px; color:#555;">아직 등록된 곡이 없습니다.</td>
                </tr>
            <% } %>
        </table>
    </div>
</body>
</html>
