                    .guest-btn { width: auto; margin: 0; padding: 8px 25px; font-size: 13px; border-radius: 20px; flex-shrink: 0; height: fit-content; }
                    
                    /* 📱 모바일(좁은 화면): 세로로 안 쌓이고 가로로 얇고 타이트하게 압축! */
