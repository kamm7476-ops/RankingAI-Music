<!DOCTYPE html>
<html lang="<%= typeof getLocale !== 'undefined' ? getLocale() : 'ko' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= __('cp_page_title') || '미발매 음원 저작권 증명' %> - RANKING AI</title>
    <style>
        body { background: #0b0c0d; color: #fff; font-family: 'Pretendard', sans-serif; margin: 0; padding-bottom: 100px; }
        a { text-decoration: none; color: inherit; }

        /* 🌟 네비게이션 & 헤더 (사이트 공통 헤더와 동일) */
        .main-header { background: #121314; border-bottom: 1px solid #222; position: sticky; top: 0; z-index: 100; }
        .header-top { display: flex; justify-content: space-between; align-items: center; padding: 10px 15px; border-bottom: 1px solid #1a1b1c; gap: 10px; flex-wrap: nowrap; }
        .logo-img { height: 50px; max-width: 100%; cursor: pointer; object-fit: contain; flex-shrink: 0; }

        .top-search-form { display: flex; align-items: center; background: #222 !important; border: 2px solid #ff5722; border-radius: 25px; padding: 5px 12px; flex: 1; max-width: 400px; margin: 0; min-width: 0; }
        .top-search-input { background: transparent !important; border: none !important; color: white !important; outline: none; flex: 1; font-size: 14px; padding: 5px; min-width: 0; }
        .top-search-input::placeholder { color: #aaa; }
        .top-search-btn { background: none; border: none; color: #ff5722; font-weight: bold; cursor: pointer; font-size: 16px; padding: 0 10px; }

        .auth-buttons { display: flex; gap: 15px; align-items: center; flex-shrink: 0; }
        .lang-select { padding: 7px 14px; background: #222; color: #fff; border: 2px solid #ff5722; border-radius: 20px; font-weight: bold; font-size: 13px; outline: none; cursor: pointer; transition: 0.2s; }
        .lang-select:hover { background: #ff5722; color: #000; }
        .btn-admin { color: #ff4a4a; font-weight: bold; font-size: 14px; border: 1px solid #ff4a4a; padding: 5px 12px; border-radius: 15px; }
        .btn-login { color: #bbb; font-size: 14px; }
        .btn-signup { background: #ff5722; color: #000; padding: 8px 20px; border-radius: 20px; font-weight: bold; font-size: 14px; }

        .header-nav { display: flex; justify-content: center; gap: 40px; padding: 12px 0; background: #0b0c0d; overflow-x: auto; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
        .header-nav::-webkit-scrollbar { display: none; }
        .nav-item { color: #aaa; font-weight: 600; font-size: 16px; transition: 0.2s; position: relative; white-space: nowrap; flex-shrink: 0; }
        .nav-item:hover, .nav-item.active { color: #ff5722; }
        .nav-item.active::after { content: ''; position: absolute; bottom: -12px; left: 0; width: 100%; height: 3px; background: #ff5722; }

        @media screen and (max-width: 768px) {
            .header-top { flex-wrap: wrap !important; padding: 15px 15px !important; gap: 15px !important; }
            .logo-img { height: 60px !important; max-width: 350px !important; flex-shrink: 0 !important; }
            .auth-buttons { flex: 1; justify-content: flex-end; width: auto !important; flex-wrap: nowrap; gap: 10px !important; }
            .lang-select { font-size: 11px !important; padding: 5px 8px !important; margin-bottom: 0 !important; margin-right: auto !important; }
            .btn-signup, .btn-login { font-size: 12px !important; padding: 6px 10px !important; }
            .top-search-form { width: 100% !important; flex: 1 1 100% !important; margin: 0 !important; padding: 5px 15px !important; order: 3; }
            .top-search-input { font-size: 14px !important; padding: 5px !important; }
            .header-nav { justify-content: flex-start; gap: 20px; padding: 12px 15px; }
        }

        /* 🌟 저작권 증명 페이지 전용 스타일 */
        .container { max-width: 800px; margin: 0 auto; padding: 40px 20px; }
        .page-header { display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #ff5722; padding-bottom: 15px; margin-bottom: 15px; flex-wrap: wrap; gap: 10px; }
        .title { color: #ff5722; margin: 0; font-size: 24px; word-break: keep-all; }
        .btn-home { color: #aaa; text-decoration: none; border: 1px solid #444; padding: 8px 15px; border-radius: 8px; flex-shrink: 0; }
        .desc-box { background: #161718; border: 1px solid #333; border-radius: 12px; padding: 18px 20px; margin-bottom: 30px; color: #bbb; font-size: 13px; line-height: 1.8; word-break: keep-all; overflow-wrap: break-word; }
        .desc-box b { color: #ff5722; }

        .card { background: #161718; border: 1px solid #333; border-radius: 12px; padding: 25px; margin-bottom: 30px; }
        .card h3 { margin-top: 0; color: #fff; font-size: 17px; word-break: keep-all; }

        .drop-zone {
            border: 2px dashed #444; border-radius: 12px; padding: 35px 20px; text-align: center;
            color: #888; cursor: pointer; transition: 0.2s; background: #0f1011;
        }
        .drop-zone p { margin: 0; line-height: 1.6; word-break: keep-all; }
        .drop-zone.dragover { border-color: #ff5722; color: #ff5722; background: rgba(255,87,34,0.05); }
        .drop-zone input[type="file"] { display: none; }

        .input-group { margin-top: 15px; }
        label { display: block; font-size: 13px; color: #aaa; margin-bottom: 5px; word-break: keep-all; }
        input[type="text"] { width: 100%; background: #222; border: 1px solid #444; color: #fff; padding: 12px; border-radius: 8px; box-sizing: border-box; outline: none; font-family: inherit; }
        input[type="text"]:focus { border-color: #ff5722; }

        .hash-box { margin-top: 15px; background: #0f1011; border: 1px solid #333; border-radius: 8px; padding: 12px 15px; font-family: monospace; font-size: 12px; line-height: 1.6; color: #00e5ff; word-break: break-all; display: none; }
        .hash-box.show { display: block; }

        .btn-main { width: 100%; margin-top: 20px; background: #ff5722; color: #000; border: none; padding: 14px; border-radius: 8px; font-weight: bold; font-size: 15px; cursor: pointer; transition: 0.2s; word-break: keep-all; }
        .btn-main:hover { filter: brightness(1.1); }
        .btn-main:disabled { background: #444; color: #888; cursor: not-allowed; }

        .btn-secondary { background: #222; color: #ff5722; border: 1px solid #ff5722; padding: 10px 16px; border-radius: 8px; font-weight: bold; cursor: pointer; font-size: 13px; word-break: keep-all; }

        .cert-result { display: none; margin-top: 25px; background: #0f1011; border: 1px solid #ff5722; border-radius: 12px; padding: 20px; }
        .cert-result.show { display: block; }
        .cert-row { display: flex; flex-direction: column; gap: 5px; padding: 10px 0; border-bottom: 1px dashed #2a2a2a; font-size: 13px; }
        .cert-row:last-child { border-bottom: none; }
        .cert-row .k { color: #888; flex-shrink: 0; word-break: keep-all; }
        .cert-row .v { color: #fff; text-align: left; word-break: break-all; font-family: monospace; line-height: 1.6; }

        .verify-result { margin-top: 15px; padding: 12px 15px; border-radius: 8px; font-size: 13px; line-height: 1.7; word-break: keep-all; overflow-wrap: break-word; display: none; }
        .verify-result.ok { display: block; background: rgba(0,230,64,0.08); border: 1px solid #00e640; color: #6dffa0; }
        .verify-result.bad { display: block; background: rgba(255,74,74,0.08); border: 1px solid #ff4a4a; color: #ffb3b3; }

        table.history { width: 100%; border-collapse: collapse; margin-top: 10px; }
        table.history th, table.history td { text-align: left; padding: 10px 8px; border-bottom: 1px solid #222; font-size: 12px; }
        table.history th { color: #888; font-weight: 600; word-break: keep-all; }
        table.history td { color: #ddd; word-break: break-all; }
        .history-scroll { overflow-x: auto; }
        .mono { font-family: monospace; font-size: 11px; color: #00e5ff; }
        .copy-btn { background: none; border: 1px solid #444; color: #aaa; border-radius: 6px; padding: 3px 8px; font-size: 11px; cursor: pointer; white-space: nowrap; }
        .copy-btn:hover { border-color: #ff5722; color: #ff5722; }

        @media screen and (max-width: 600px) {
            .container { padding: 25px 15px; }
            .title { font-size: 19px; }
            .card { padding: 18px; }
        }
    </style>
</head>
<body>
    <header class="main-header">
        <div class="header-top">
            <img src="/logo.png" alt="RANKING AI 로고" class="logo-img" onclick="window.location.href='/?sort=views'">

            <form action="/" method="GET" class="top-search-form">
                <div style="display: flex; align-items: center; justify-content: center; cursor: pointer; background: #fff; padding: 2px; border-radius: 4px; margin-right: 10px; box-shadow: 0 0 5px rgba(255,87,34,0.5); flex-shrink: 0;"
                     title="클릭하면 크게 확대됩니다! 친구들에게 공유해보세요 🚀"
                     onclick="window.open('https://api.qrserver.com/v1/create-qr-code/?size=500x500&data=https://rankingaimusic.com', '_blank')">
                    <img src="https://api.qrserver.com/v1/create-qr-code/?size=30x30&data=https://rankingaimusic.com" alt="QR Code" style="display: block; width: 24px; height: 24px;">
                </div>
                <input type="text" name="search" class="top-search-input" placeholder="<%= __('search_placeholder') || '아티스트 검색...' %>" value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false">
                <button type="submit" class="top-search-btn">🔍</button>
            </form>

            <div class="auth-buttons">
                <select id="smartLangSelect" onchange="window.location.href='/change-lang/' + this.value" class="lang-select">
                    <option value="ko" <%= typeof getLocale !== 'undefined' && getLocale() === 'ko' ? 'selected' : '' %>>🇰🇷 한국어</option>
                    <option value="en" <%= typeof getLocale !== 'undefined' && getLocale() === 'en' ? 'selected' : '' %>>🇺🇸 English</option>
                    <option value="ja" <%= typeof getLocale !== 'undefined' && getLocale() === 'ja' ? 'selected' : '' %>>🇯🇵 日本語</option>
                    <option value="zh" <%= typeof getLocale !== 'undefined' && getLocale() === 'zh' ? 'selected' : '' %>>🇨🇳 中文</option>
                </select>
                <% if (user && user.role === 'admin') { %>
                    <a href="/admin" class="btn-admin">👑 관리자</a>
                <% } %>
                <% if (user) { %>
                    <span style="color: #aaa; font-size: 13px;"><%= user.name || user.id %><%= __('welcome_user') || '님' %></span>
                    <a href="/logout" class="btn-login"><%= __('btn_logout') || '로그아웃' %></a>
                <% } else { %>
                    <a href="/login" class="btn-login"><%= __('btn_login') || '로그인' %></a>
                    <a href="/signup" class="btn-signup"><%= __('btn_signup') || '회원가입' %></a>
                <% } %>
            </div>
        </div>

        <div class="header-nav">
            <a href="/?sort=views" class="nav-item"><%= __('menu_chart') || 'RANKING AI 차트' %></a>
            <a href="/?sort=latest" class="nav-item"><%= __('menu_latest') || '최신음악' %></a>
            <a href="/?genre=발라드" class="nav-item"><%= __('menu_genre') || '장르별' %></a>
            <a href="/youtube" class="nav-item"><%= __('menu_youtube') || '유튜브' %></a>
            <a href="/board" class="nav-item"><%= __('menu_community') || '커뮤니티' %></a>
            <a href="/copyright-proof" class="nav-item active"><%= __('menu_copyright') || '🔏 저작권 증명' %></a>
        </div>
    </header>

    <div class="container">
        <div class="page-header">
            <h2 class="title"><%= __('cp_title') || '🔏 미발매 음원 저작권 증명' %></h2>
            <a href="/" class="btn-home"><%= __('cp_btn_home') || '돌아가기' %></a>
        </div>

        <div class="desc-box"><%- __('cp_desc') %></div>

        <!-- 1. 새 인증서 발급 -->
        <div class="card">
            <h3><%= __('cp_card1_title') || '1️⃣ 새 저작권 타임스탬프 발급받기' %></h3>

            <% if (!user) { %>
                <div style="text-align:center; padding:35px 15px; background:#0f1011; border:1px dashed #444; border-radius:12px;">
                    <p style="color:#ddd; font-size:14px; line-height:1.8; margin:0 0 18px; word-break:keep-all;">🔒 <%= __('cp_login_required_desc') || '저작권 증명 발급은 회원만 이용할 수 있습니다. 회원가입 후 무료로 발급받아 보세요.' %></p>
                    <div style="display:flex; gap:10px; justify-content:center; flex-wrap:wrap;">
                        <a href="/signup" class="btn-main" style="width:auto; display:inline-block; padding:12px 24px;"><%= __('cp_btn_signup_first') || '회원가입하고 발급받기' %></a>
                    </div>
                </div>
            <% } else { %>
                <div class="drop-zone" id="dropZone">
                    <p id="dropZoneText"><%= __('cp_dropzone_text') %></p>
                    <label for="fileInput" class="btn-secondary" id="browseBtn" style="display:inline-block; margin:14px auto 0;"><%= __('cp_btn_browse') || '📁 파일 찾아보기' %></label>
                    <input type="file" id="fileInput" accept="audio/*">
                </div>
                <div class="hash-box" id="hashBox"></div>

                <div class="input-group">
                    <label><%= __('cp_label_artist') %></label>
                    <input type="text" id="artistName" value="<%= user.name %>" placeholder="<%= __('cp_ph_artist') %>">
                </div>
                <div class="input-group">
                    <label><%= __('cp_label_track') %></label>
                    <input type="text" id="trackTitle" placeholder="<%= __('cp_ph_track') %>">
                </div>

                <button class="btn-main" id="registerBtn" disabled><%= __('cp_btn_select_file') %></button>

                <div class="cert-result" id="certResult"></div>
            <% } %>
        </div>

        <!-- 2. 인증서 검증 -->
        <div class="card">
            <h3><%= __('cp_card2_title') || '2️⃣ 발급된 인증서 검증하기' %></h3>
            <div class="input-group">
                <label><%= __('cp_label_certid') %></label>
                <input type="text" id="verifyCertId" placeholder="<%= __('cp_ph_certid') %>">
            </div>
            <button class="btn-secondary" id="verifyBtn" style="margin-top:12px;"><%= __('cp_btn_verify') %></button>
            <div class="verify-result" id="verifyResult"></div>
        </div>

        <!-- 3. 내 발급 이력 -->
        <% if (user) { %>
        <div class="card">
            <h3><%= __('cp_card3_title') || '3️⃣ 내가 발급받은 인증서 목록' %></h3>
            <% if (myProofs && myProofs.length > 0) { %>
                <div class="history-scroll">
                <table class="history">
                    <thead>
                        <tr><th><%= __('cp_th_issued') %></th><th><%= __('cp_th_artist_track') %></th><th><%= __('cp_th_certid') %></th><th></th></tr>
                    </thead>
                    <tbody>
                        <% myProofs.forEach(function(p) { %>
                            <tr>
                                <td><%= new Date(p.timestamp).toLocaleString(typeof getLocale !== 'undefined' ? getLocale() : 'ko') %></td>
                                <td><%= p.artistName %><% if (p.trackTitle) { %> - <%= p.trackTitle %><% } %></td>
                                <td class="mono"><%= p.certId %></td>
                                <td><button type="button" class="copy-btn" onclick="fillVerify('<%= p.certId %>')"><%= __('cp_btn_fill_verify') %></button></td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
                </div>
            <% } else { %>
                <p style="color:#777; font-size:13px;"><%= __('cp_no_proofs') %></p>
            <% } %>
        </div>
        <% } %>

    <script>
    window.cpI18n = {
        locale: "<%= typeof getLocale !== 'undefined' ? getLocale() : 'ko' %>",
        calculating: "<%= __('cp_js_calculating') %>",
        selectedFile: "<%= __('cp_js_selected_file') %>",
        hashError: "<%= __('cp_js_hash_error') %>",
        btnReady: "<%= __('cp_btn_ready') %>",
        needArtist: "<%= __('cp_js_need_artist') %>",
        registering: "<%= __('cp_js_registering') %>",
        registerFail: "<%= __('cp_js_register_fail') %>",
        registerDone: "<%= __('cp_js_register_done') %>",
        serverError: "<%= __('cp_js_server_error') %>",
        needCertId: "<%= __('cp_js_need_certid') %>",
        verifying: "<%= __('cp_js_verifying') %>",
        certNotFound: "<%= __('cp_js_cert_not_found') %>",
        sigInvalid: "<%= __('cp_js_sig_invalid') %>",
        sigValid: "<%- __('cp_js_sig_valid') %>",
        certId: "<%= __('cp_cert_id') %>",
        certArtist: "<%= __('cp_cert_artist') %>",
        certTrack: "<%= __('cp_cert_track') %>",
        certEmpty: "<%= __('cp_cert_empty') %>",
        certFilename: "<%= __('cp_cert_filename') %>",
        certHash: "<%= __('cp_cert_hash') %>",
        certIssuedAt: "<%= __('cp_cert_issued_at') %>",
        certSignature: "<%= __('cp_cert_signature') %>",
        btnDownloadCert: "<%= __('cp_btn_download_cert') %>",
        btnSelectFile: "<%= __('cp_btn_select_file') %>"
    };
    </script>

    <% if (user) { %>
    <script>
    (function () {
        const dropZone = document.getElementById('dropZone');
        const dropZoneText = document.getElementById('dropZoneText');
        const fileInput = document.getElementById('fileInput');
        const hashBox = document.getElementById('hashBox');
        const registerBtn = document.getElementById('registerBtn');
        const certResult = document.getElementById('certResult');
        const i18n = window.cpI18n;

        function fmt(template, values) {
            return template.replace(/\{(\w+)\}/g, (m, key) => (values[key] !== undefined ? values[key] : m));
        }

        let currentFile = null;
        let currentHash = null;

        // 🌟 파일 -> SHA-256 지문 계산 (100% 브라우저 내장 Web Crypto API, 서버 전송 없음, 비용 0원)
        async function computeSha256(file) {
            const buffer = await file.arrayBuffer();
            const digest = await crypto.subtle.digest('SHA-256', buffer);
            return Array.from(new Uint8Array(digest)).map(b => b.toString(16).padStart(2, '0')).join('');
        }

        async function handleFile(file) {
            if (!file) return;
            currentFile = file;
            dropZoneText.textContent = fmt(i18n.calculating, { file: file.name });
            registerBtn.disabled = true;
            registerBtn.textContent = i18n.registering;

            try {
                currentHash = await computeSha256(file);
                dropZoneText.textContent = fmt(i18n.selectedFile, { file: file.name });
                hashBox.textContent = 'SHA-256: ' + currentHash;
                hashBox.classList.add('show');
                registerBtn.disabled = false;
                registerBtn.textContent = i18n.btnReady;
            } catch (err) {
                dropZoneText.textContent = i18n.hashError;
                registerBtn.disabled = true;
                registerBtn.textContent = i18n.btnSelectFile;
            }
        }

        const browseBtn = document.getElementById('browseBtn');
        // browseBtn is a <label for="fileInput">: clicking it makes the browser forward a native
        // click to fileInput. Since fileInput lives inside dropZone, that forwarded click bubbles
        // back up to dropZone and would call fileInput.click() a second time, reopening/cancelling
        // the OS file dialog before the selection registers. Ignore clicks that originate from the
        // label or the input itself so the picker only ever opens once per user click.
        dropZone.addEventListener('click', (e) => {
            if (e.target === fileInput || e.target === browseBtn) return;
            fileInput.click();
        });
        browseBtn.addEventListener('click', (e) => e.stopPropagation());
        fileInput.addEventListener('change', (e) => handleFile(e.target.files[0]));

        dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('dragover'); });
        dropZone.addEventListener('dragleave', () => dropZone.classList.remove('dragover'));
        dropZone.addEventListener('drop', (e) => {
            e.preventDefault();
            dropZone.classList.remove('dragover');
            if (e.dataTransfer.files.length > 0) handleFile(e.dataTransfer.files[0]);
        });

        registerBtn.addEventListener('click', async () => {
            if (!currentHash) return;
            const artistName = document.getElementById('artistName').value.trim();
            const trackTitle = document.getElementById('trackTitle').value.trim();

            if (!artistName) { alert(i18n.needArtist); return; }

            registerBtn.disabled = true;
            registerBtn.textContent = i18n.registering;

            try {
                const res = await fetch('/api/proof/register', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        fileHash: currentHash,
                        fileName: currentFile ? currentFile.name : '',
                        artistName: artistName,
                        trackTitle: trackTitle
                    })
                });
                const data = await res.json();

                if (!data.success) {
                    alert(data.message || i18n.registerFail);
                    registerBtn.disabled = false;
                    registerBtn.textContent = i18n.btnReady;
                    return;
                }

                renderCertificate(data.record);
                registerBtn.textContent = i18n.registerDone;
            } catch (err) {
                alert(i18n.serverError);
                registerBtn.disabled = false;
                registerBtn.textContent = i18n.btnReady;
            }
        });

        function renderCertificate(record) {
            const dateStr = new Date(record.timestamp).toLocaleString(i18n.locale);
            certResult.innerHTML = `
                <div class="cert-row"><span class="k">${i18n.certId}</span><span class="v">${record.certId}</span></div>
                <div class="cert-row"><span class="k">${i18n.certArtist}</span><span class="v">${record.artistName}</span></div>
                <div class="cert-row"><span class="k">${i18n.certTrack}</span><span class="v">${record.trackTitle || i18n.certEmpty}</span></div>
                <div class="cert-row"><span class="k">${i18n.certFilename}</span><span class="v">${record.fileName || i18n.certEmpty}</span></div>
                <div class="cert-row"><span class="k">${i18n.certHash}</span><span class="v">${record.fileHash}</span></div>
                <div class="cert-row"><span class="k">${i18n.certIssuedAt}</span><span class="v">${dateStr}</span></div>
                <div class="cert-row"><span class="k">${i18n.certSignature}</span><span class="v">${record.signature}</span></div>
                <button class="btn-secondary" style="margin-top:15px; width:100%;" onclick='downloadCertificate(${JSON.stringify(record)})'>${i18n.btnDownloadCert}</button>
            `;
            certResult.classList.add('show');
            document.getElementById('verifyCertId').value = record.certId;
        }

        window.downloadCertificate = function (record) {
            const blob = new Blob([JSON.stringify(record, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'RAM_copyright_certificate_' + record.certId + '.json';
            document.body.appendChild(a);
            a.click();
            a.remove();
            URL.revokeObjectURL(url);
        };

        window.fillVerify = function (certId) {
            document.getElementById('verifyCertId').value = certId;
            window.scrollTo({ top: document.getElementById('verifyCertId').getBoundingClientRect().top + window.scrollY - 100, behavior: 'smooth' });
        };
    })();
    </script>
    <% } %>

    <script>
    (function () {
        // 2. 인증서 검증 (비회원도 이용 가능)
        const i18n = window.cpI18n;

        function fmt(template, values) {
            return template.replace(/\{(\w+)\}/g, (m, key) => (values[key] !== undefined ? values[key] : m));
        }

        const verifyBtn = document.getElementById('verifyBtn');
        const verifyResult = document.getElementById('verifyResult');

        verifyBtn.addEventListener('click', async () => {
            const certId = document.getElementById('verifyCertId').value.trim();
            if (!certId) { alert(i18n.needCertId); return; }

            verifyResult.className = 'verify-result';
            verifyResult.textContent = i18n.verifying;
            verifyResult.style.display = 'block';

            try {
                const res = await fetch('/api/proof/verify/' + encodeURIComponent(certId));
                const data = await res.json();

                if (!data.success) {
                    verifyResult.className = 'verify-result bad';
                    verifyResult.textContent = data.message ? data.message : i18n.certNotFound;
                    return;
                }

                const r = data.record;
                const dateStr = new Date(r.timestamp).toLocaleString(i18n.locale);

                if (data.valid) {
                    verifyResult.className = 'verify-result ok';
                    verifyResult.innerHTML = fmt(i18n.sigValid, { hash: r.fileHash.slice(0, 16) + '...', date: dateStr, artist: r.artistName });
                } else {
                    verifyResult.className = 'verify-result bad';
                    verifyResult.textContent = i18n.sigInvalid;
                }
            } catch (err) {
                verifyResult.className = 'verify-result bad';
                verifyResult.textContent = i18n.serverError;
            }
        });
    })();
    </script>
    </div>
</body>
</html>
