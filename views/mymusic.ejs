<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>내 음악 보관함 - RANKING AI</title>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <style>
        /* 멜론/지니 뮤직 스타일의 미니멀 다크 모드 */
        body { background: #0b0c0d; color: #fff; font-family: 'Pretendard', -apple-system, sans-serif; margin: 0; padding-bottom: 160px; -webkit-font-smoothing: antialiased; }
        a { text-decoration: none; color: inherit; }
        button { border: none; background: none; padding: 0; cursor: pointer; font-family: inherit; color: inherit; outline: none; }

        /* 헤더 스타일 */
        .main-header { background: #121314; border-bottom: 1px solid #1a1b1c; position: sticky; top: 0; z-index: 100; }
        .header-top { display: flex; justify-content: space-between; align-items: center; padding: 15px 30px; }
        .logo { font-size: 26px; font-weight: 900; color: #ff5722; cursor: pointer; background: linear-gradient(45deg, #ff5722, #ffb300); -webkit-background-clip: text; -webkit-text-fill-color: transparent; letter-spacing: -1px; }
        .header-nav { display: flex; justify-content: flex-start; gap: 20px; padding: 12px 20px; background: #0b0c0d; border-bottom: 1px solid #1a1b1c; overflow-x: auto; white-space: nowrap; }
        .nav-item { color: #888; font-weight: 600; font-size: 15px; transition: 0.2s; }
        .nav-item:hover { color: #fff; }

        .container { max-width: 1100px; margin: 0 auto; padding: 30px 20px; }
        .page-title-wrap { display: flex; align-items: center; justify-content: space-between; margin-bottom: 25px; padding-bottom: 15px; border-bottom: 1px solid #222; }
        .page-title { font-size: 26px; font-weight: bold; color: #fff; margin: 0; }
        .song-count { font-size: 14px; color: #666; font-weight: normal; margin-left: 10px; }

        /* 🌟 상단 컨트롤바 (멜론 스타일로 깔끔하게) */
        .chart-controls { display: flex; gap: 8px; margin-bottom: 20px; align-items: center; padding: 5px 0; }
        .control-btn { border: 1px solid #333; color: #aaa; padding: 7px 18px; border-radius: 20px; font-size: 13px; font-weight: 500; transition: 0.2s; display: flex; align-items: center; gap: 6px; }
        .control-btn:hover { border-color: #555; color: #fff; background: rgba(255,255,255,0.03); }
        .control-btn i { font-size: 16px; }
        
        /* 커스텀 체크박스 */
        .custom-checkbox { width: 18px; height: 18px; accent-color: #ff5722; cursor: pointer; border: 1px solid #444; border-radius: 3px; }

        /* 음악 목록 테이블 */
        .music-list { width: 100%; border-collapse: collapse; }
        .music-item { border-bottom: 1px solid #1a1b1c; transition: 0.2s; opacity: 1; }
        .music-item:hover { background: rgba(255,255,255,0.02); }
        .music-item td { padding: 12px 10px; vertical-align: middle; }
        
        .album-art-wrap { position: relative; width: 60px; height: 60px; }
        .album-art { width: 60px; height: 60px; border-radius: 6px; object-fit: cover; border: 1px solid #222; }
        /* 호버 시 아트 위에 재생 아이콘 */
        .art-play-hover { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); border-radius: 6px; display: flex; align-items: center; justify-content: center; opacity: 0; transition: 0.2s; cursor: pointer; }
        .music-item:hover .art-play-hover { opacity: 1; }
        .art-play-hover i { font-size: 28px; color: #fff; }

        .song-title { font-size: 16px; font-weight: 600; color: #fff; margin-bottom: 4px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .singer { font-size: 13px; color: #888; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        
        .song-actions { display: flex; gap: 10px; justify-content: flex-end; }
        .action-icon-btn { font-size: 20px; color: #555; transition: 0.2s; }
        .action-icon-btn:hover { color: #ff4a4a; } /* 삭제 버튼은 빨간색으로 */

        /* 🌟 하단 플레이어 (멜론/지니 스타일 - 촌스러운 주황색 박스 제거) */
        .bottom-player-bar { position: fixed; bottom: 0; left: 0; width: 100%; background: #121314; border-top: 1px solid #222; padding: 12px 40px; box-sizing: border-box; display: flex; align-items: center; justify-content: space-between; z-index: 1000; box-shadow: 0 -5px 25px rgba(0,0,0,0.5); }
        
        .player-info { display: flex; align-items: center; gap: 15px; width: 30%); min-width: 250px; }
        .player-cover { width: 55px; height: 55px; border-radius: 6px; border: 1px solid #222; object-fit: cover; }
        .player-text { display: flex; flex-direction: column; overflow: hidden; }
        .player-title { font-size: 15px; font-weight: 600; color: #fff; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .player-artist { font-size: 12px; color: #888; margin-top: 3px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        
        /* 플레이어 컨트롤 */
        .player-controls-wrapper { flex: 1; max-width: 550px; display: flex; flex-direction: column; align-items: center; gap: 8px; }
        .player-buttons { display: flex; align-items: center; gap: 18px; }
        
        /* 🌟 컨트롤 버튼 스타일 (아이콘 전용, 얇고 세련되게) */
        .btn-ctrl { color: #fff; font-size: 28px; transition: 0.2s; display: flex; align-items: center; justify-content: center; }
        .btn-ctrl:hover { color: #ff5722; }
        .play-btn { font-size: 48px !important; color: #ff5722 !important; }
        
        /* 🔄 🌟 세련된 라인 아이콘 반복 모드 버튼 (이모지 절대 불가) */
        #btn-loop-mode { font-size: 22px; color: #555; margin-left: 15px; position: relative; transition: 0.2s; }
        #btn-loop-mode:hover { color: #999; }
        #btn-loop-mode.active-one { color: #ff5722; } /* 한곡반복: 주황색 */
        #btn-loop-mode.active-all { color: #ffb300; } /* 전체반복: 노란색 */
        
        /* 한곡반복일 때 아이콘 우측 하단에 아주 작은 숫자 '1' 표시 */
        #btn-loop-mode .loop-num { position: absolute; font-size: 9px; font-weight: 800; bottom: -2px; right: -4px; color: #ff5722; display: none; background: #121314; border-radius: 50%; width: 12px; height: 12px; line-height: 12px; text-align: center; }
        #btn-loop-mode.active-one .loop-num { display: block; }

        /* 프로그레스 바 */
        .progress-area { width: 100%; display: flex; align-items: center; gap: 10px; font-size: 11px; color: #666; font-family: monospace; }
        #progress-bar { flex: 1; height: 4px; border-radius: 2px; -webkit-appearance: none; background: #333; outline: none; cursor: pointer; transition: 0.1s; }
        #progress-bar::-webkit-slider-thumb { -webkit-appearance: none; width: 0; height: 0; border-radius: 50%; background: #ff5722; transition: 0.2s; }
        /* 호버 시에만 썸네일 노출 */
        .progress-area:hover #progress-bar::-webkit-slider-thumb { width: 12px; height: 12px; box-shadow: 0 0 10px rgba(255,87,34,0.5); }
        .progress-area:hover #progress-bar { background: #444; }

        /* 모바일 대응 */
        @media (max-width: 900px) {
            .header-top { padding: 15px 20px; }
            .container { padding: 20px 15px; }
            .page-title { font-size: 22px; }
            .chart-controls { padding: 10px; flex-wrap: wrap; gap: 5px; }
            .control-btn { padding: 6px 12px; font-size: 12px; }
            
            .music-item td { padding: 10px 5px; }
            .album-art-wrap, .album-art { width: 50px; height: 50px; }
            .song-title { font-size: 14px; }
            .singer { font-size: 12px; }

            .bottom-player-bar { flex-direction: column; padding: 15px; gap: 12px; }
            .player-info { width: 100%; justify-content: flex-start; min-width: auto; }
            .player-controls-wrapper { width: 100%; max-width: 100%; }
            .player-buttons { gap: 15px; }
            .play-btn { font-size: 40px !important; }
        }
    </style>
</head>
<body>
    <header class="main-header">
        <div class="header-top">
             <div class="logo" onclick="window.location.href='/'">RANKING AI</div>
             <div style="color: #666; font-size: 13px;">🎧 <%= user.id %>님의 보관함</div>
        </div>
        <div class="header-nav">
             <a href="/" class="nav-item">← 메인 차트로 돌아가기</a>
        </div>
    </header>

    <div class="container">
        <div class="page-title-wrap">
            <h1 class="page-title">내 음악 보관함 <span class="song-count">(전체 <%= artists.length %>곡)</span></h1>
        </div>

        <div class="chart-controls">
            <div style="display:flex; align-items:center; gap:10px; margin-right: 10px;">
                <input type="checkbox" id="checkAll" class="custom-checkbox" onchange="toggleAll(this)">
                <label href="#" for="checkAll" style="font-size:13px; color:#888; cursor:pointer;">전체선택</label>
            </div>
            <button class="control-btn" onclick="playAll()"><i class='bx bx-play-circle'></i> 전체듣기</button>
            <button class="control-btn" onclick="playSelected()"><i class='bx bx-list-check' ></i> 선택듣기</button>
        </div>
        
        <% if (!artists || artists.length === 0) { %>
            <div style="text-align: center; padding: 80px 0; background: #121314; border-radius: 12px; border: 1px solid #1a1b1c; margin-top: 20px;">
                <i class='bx bx-disc' style="font-size: 50px; color: #333; margin-bottom: 15px;"></i>
                <h3 style="color: #666; margin: 0 0 10px 0; font-weight: 600;">보관함이 비어있습니다.</h2>
                <p style="color: #555; margin: 0 0 25px 0; font-size: 14px;">메인 차트에서 마음에 드는 곡을 담아보세요!</p>
                <button class="control-btn" style="background: #ff5722; color: #000; border:none; padding: 10px 25px; font-weight:bold;" onclick="location.href='/'">차트 구경가기</button>
            </div>
        <% } else { %>
            <table class="music-list">
                <% artists.forEach(music => { %>
                    <tr class="music-item" id="row-<%= music._id %>" 
                        data-id="<%= music._id %>" 
                        data-title="<%= music.name %>" 
                        data-artist="<%= music.artist %>" 
                        data-cover="<%= music.imageUrl %>" 
                        data-audio="<%= music.audioUrl %>">
                        <td style="width: 30px; text-align: center;">
                            <input type="checkbox" class="song-check custom-checkbox">
                        </td>
                        <td style="width: 60px;">
                            <div class="album-art-wrap">
                                <img src="<%= music.imageUrl %>" class="album-art" alt="<%= music.name %> 커버">
                                <div class="art-play-hover" onclick="playSingleTrackById('<%= music._id %>')">
                                    <i class='bx bx-play'></i>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="song-title"><%= music.name %></div>
                            <div class="singer"><%= music.artist %></div>
                        </td>
                        <td style="width: 60px; text-align: right;">
                            <div class="song-actions">
                                <button class="action-icon-btn" onclick="playSingleTrackById('<%= music._id %>')" title="재생"><i class='bx bx-play-circle'></i></button>
                                <button class="action-icon-btn" onclick="removeFromMyMusic('<%= music._id %>')" title="삭제"><i class='bx bx-trash' ></i></button>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            </table>
        <% } %>
    </div>

    <div class="bottom-player-bar">
        <div class="player-info">
            <img src="https://via.placeholder.com/55/1a1b1c/333333?text=AI" id="main-player-cover" class="player-cover" alt="플레이어 커버">
            <div class="player-text">
                <span id="main-player-title" class="player-title">선택된 곡이 없습니다</span>
                <span id="main-player-artist" class="player-artist">재생 버튼을 눌러주세요</span>
            </div>
        </div>
        <div class="player-controls-wrapper">
            <div class="player-buttons">
                <button class="btn-ctrl" onclick="playPrevTrack()" title="이전 곡"><i class='bx bx-skip-previous'></i></button>
                <button id="btn-play" class="btn-ctrl play-btn" onclick="togglePlayPause()" title="재생/일시정지"><i class='bx bx-play'></i></button>
                <button class="btn-ctrl" onclick="playNextTrack()" title="다음 곡"><i class='bx bx-skip-next'></i></button>
                
                <button id="btn-loop-mode" class="btn-ctrl" onclick="toggleLoopMode()" title="반복 안함">
                    <i class='bx bx-repeat'></i>
                    <span class="loop-num">1</span> </button>
            </div>
            <div class="progress-area">
                <span id="time-current">00:00</span>
                <input type="range" id="progress-bar" value="0" min="0" max="100" step="1">
                <span id="time-total">00:00</span>
            </div>
        </div>
        <div style="width: 30%); min-width: 250px; display: flex; justify-content: flex-end;">
            </div>
        <audio id="main-audio"></audio>
    </div>

    <script>
        let playlist = [];
        let currentIndex = 0;
        let loopMode = 0; // 0: 반복없음, 1: 한곡반복, 2: 전체반복
        let isPlaying = false;
        const mainAudio = document.getElementById('main-audio');
        const btnPlay = document.getElementById('btn-play');
        const btnLoop = document.getElementById('btn-loop-mode');
        const progressBar = document.getElementById('progress-bar');

        // 전체 선택/해제 로직
        function toggleAll(source) {
            document.querySelectorAll('.song-check').forEach(cb => cb.checked = source.checked);
        }

        // 모든 곡을 플레이리스트에 담는 내부 함수
        function loadAllToPlaylist() {
            const rows = document.querySelectorAll('.music-item');
            playlist = Array.from(rows).map(r => ({
                id: r.dataset.id,
                title: r.dataset.title,
                artist: r.dataset.artist,
                cover: r.dataset.cover,
                audio: r.dataset.audio
            })).filter(t => t.audio); // 음원 파일이 있는 것만
        }

        // 🌟 전체듣기 기능
        function playAll() {
            loadAllToPlaylist();
            if(playlist.length > 0) loadTrack(0);
            else alert('재생 가능한 곡이 없습니다.');
        }

        // 🌟 선택듣기 기능
        function playSelected() {
            const checked = document.querySelectorAll('.song-check:checked');
            if(checked.length === 0) return alert('재생할 곡을 먼저 선택해주세요!');
            
            playlist = Array.from(checked).map(cb => {
                const tr = cb.closest('.music-item');
                return { 
                    id: tr.dataset.id,
                    title: tr.dataset.title, 
                    artist: tr.dataset.artist, 
                    cover: tr.dataset.cover, 
                    audio: tr.dataset.audio 
                };
            }).filter(t => t.audio);
            
            if(playlist.length > 0) loadTrack(0);
            else alert('선택한 곡 중에 재생 가능한 음원이 없습니다.');
        }

        // 🌟 개별 곡 재생 (ID 기반으로 플레이리스트 내 위치 찾기)
        function playSingleTrackById(musicId) {
            loadAllToPlaylist(); // 전체 곡을 일단 장전 (연속 재생을 위해)
            const idx = playlist.findIndex(t => t.id === musicId);
            if(idx !== -1) loadTrack(idx);
            else alert('곡을 재생할 수 없습니다.');
        }

        // 보관함 삭제 기능
        async function removeFromMyMusic(musicId) {
            if(!confirm('보관함에서 삭제하시겠습니까?')) return;
            try {
                const res = await fetch('/remove-from-mymusic/' + musicId, { method: 'POST' });
                const data = await res.json();
                if(data.success) {
                    const row = document.getElementById('row-' + musicId);
                    // 삭제 애니메이션
                    row.style.transition = '0.3s';
                    row.style.opacity = '0';
                    row.style.transform = 'translateX(20px)';
                    setTimeout(() => {
                        row.remove();
                        // 곡 수 새로고침 (간단하게 페이지 새로고침 또는 숫자 감소 로직)
                        location.reload(); 
                    }, 300);
                } else {
                    alert(data.message || '삭제에 실패했습니다.');
                }
            } catch(e) { alert('삭제 처리 중 서버 에러가 발생했습니다.'); }
        }

        // 🌟 2. 세련된 아이콘 반복 모드 전환 로직
        function toggleLoopMode() {
            loopMode = (loopMode + 1) % 3;
            
            // 클래스 초기화
            btnLoop.classList.remove('active-one', 'active-all');
            
            if (loopMode === 0) {
                btnLoop.title = "반복 안함";
                // CSS 기본 색상 (#555)
            } else if (loopMode === 1) {
                btnLoop.title = "한곡 반복";
                btnLoop.classList.add('active-one'); // 주황색 + 숫자1 노출 (CSS)
            } else if (loopMode === 2) {
                btnLoop.title = "전체 반복";
                btnLoop.classList.add('active-all'); // 노란색 (CSS)
            }
        }

        // 🌟 3. 재생 핵심 엔진
        function loadTrack(index) {
            if(index >= 0 && index < playlist.length) {
                const track = playlist[index];
                currentIndex = index;
                
                // 플레이어 UI 업데이트
                document.getElementById('main-player-title').innerText = track.title;
                document.getElementById('main-player-artist').innerText = track.artist;
                document.getElementById('main-player-cover').src = track.cover;
                
                // 오디오 소스 설정 및 재생
                mainAudio.src = track.audio;
                mainAudio.load();
                
                const playPromise = mainAudio.play();
                if (playPromise !== undefined) {
                    playPromise.then(() => {
                        isPlaying = true;
                        btnPlay.innerHTML = "<i class='bx bx-pause'></i>"; // 일시정지 아이콘으로 변경
                    }).catch(e => {
                        console.log("자동 재생 차단됨:", e);
                        isPlaying = false;
                        btnPlay.innerHTML = "<i class='bx bx-play'></i>";
                    });
                }
            }
        }

        // ⏭️ 다음 곡 로직 (무한 반복 포함)
        function playNextTrack() {
            if (loopMode === 1) {
                // 한 곡 반복일 때 ➔ 현재 곡 다시 로드
                loadTrack(currentIndex);
            } else if (currentIndex < playlist.length - 1) {
                // 다음 곡 있을 때 ➔ 정상 진행
                loadTrack(currentIndex + 1);
            } else if (loopMode === 2) {
                // 전체 반복 모드이고 마지막 곡일 때 ➔ 첫 곡(0번)으로 점프!
                loadTrack(0);
            } else {
                // 반복 없음 + 마지막 곡일 때 ➔ 정지
                mainAudio.pause();
                mainAudio.currentTime = 0;
                isPlaying = false;
                btnPlay.innerHTML = "<i class='bx bx-play'></i>";
            }
        }

        // ⏮️ 이전 곡 로직
        function playPrevTrack() {
            if (mainAudio.currentTime > 3) {
                // 3초 이상 지났으면 처음으로
                mainAudio.currentTime = 0;
            } else if (currentIndex > 0) {
                // 이전 곡으로
                loadTrack(currentIndex - 1);
            } else if (loopMode === 2) {
                // 전체반복 시 첫 곡에서 이전 누르면 맨 마지막 곡으로
                loadTrack(playlist.length - 1);
            } else {
                mainAudio.currentTime = 0;
            }
        }

        function togglePlayPause() {
            if (!mainAudio.src) return;
            if (mainAudio.paused) {
                mainAudio.play();
                btnPlay.innerHTML = "<i class='bx bx-pause'></i>";
                isPlaying = true;
            } else {
                mainAudio.pause();
                btnPlay.innerHTML = "<i class='bx bx-play'></i>";
                isPlaying = false;
            }
        }

        // 🌟 4. 오디오 이벤트 리스너 (가장 중요)
        
        // 노래 끝나면 playNextTrack 함수 호출 (여기서 루프 모드 체크함)
        mainAudio.addEventListener('ended', playNextTrack);

        // 시간 업데이트 (프로그레스 바 & 숫자)
        mainAudio.addEventListener('timeupdate', () => {
            if (mainAudio.duration) {
                const current = mainAudio.currentTime;
                const duration = mainAudio.duration;
                
                // 프로그레스 바 위치
                progressBar.value = (current / duration) * 100;
                
                // 숫자 시간 계산
                let minC = Math.floor(current / 60);
                let secC = Math.floor(current % 60);
                document.getElementById('time-current').innerText = `${minC}:${secC < 10 ? '0'+secC : secC}`;
                
                let minD = Math.floor(duration / 60);
                let secD = Math.floor(duration % 60);
                document.getElementById('time-total').innerText = `${minD}:${secD < 10 ? '0'+secD : secD}`;
            }
        });

        // 프로그레스 바 직접 조작 (탐색)
        progressBar.addEventListener('input', () => {
            if (mainAudio.duration) {
                mainAudio.currentTime = (progressBar.value / 100) * mainAudio.duration;
            }
        });
    </script>
</body>
</html>