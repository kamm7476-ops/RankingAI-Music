<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>내 음악 보관함 - RANKING AI</title>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <style>
        body { background: #0b0c0d; color: #fff; font-family: 'Pretendard', sans-serif; margin: 0; padding-bottom: 150px; }
        a { text-decoration: none; color: inherit; }
        .main-header { background: #121314; border-bottom: 1px solid #222; position: sticky; top: 0; z-index: 100; }
        .header-top { display: flex; justify-content: space-between; align-items: center; padding: 15px 40px; border-bottom: 1px solid #1a1b1c; }
        .logo { font-size: 28px; font-weight: 900; color: #ff5722; cursor: pointer; background: linear-gradient(45deg, #ff5722, #ffb300); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .header-nav { display: flex; justify-content: flex-start; gap: 25px; padding: 12px 15px; background: #0b0c0d; overflow-x: auto; white-space: nowrap; border-bottom: 1px solid #222; }
        .container { max-width: 1000px; margin: 0 auto; padding: 40px 20px; }
        .page-title { font-size: 28px; font-weight: 900; margin-bottom: 30px; border-bottom: 2px solid #222; padding-bottom: 15px; color: #ff5722; }

        .music-list { width: 100%; border-collapse: collapse; }
        .music-item { border-bottom: 1px solid #222; transition: 0.2s; }
        .music-item:hover { background: rgba(255, 87, 34, 0.05); }
        .music-item td { padding: 15px 10px; vertical-align: middle; }
        .album-art { width: 60px; height: 60px; border-radius: 8px; object-fit: cover; box-shadow: 0 4px 10px rgba(0,0,0,0.5); }
        .song-title { font-size: 16px; font-weight: bold; color: #fff; margin-bottom: 4px; }
        .singer { font-size: 13px; color: #aaa; }
        
        .song-actions { display: flex; gap: 8px; justify-content: flex-end; }
        .song-btn { background: #222; color: #aaa; border: 1px solid #444; padding: 6px 15px; border-radius: 20px; font-size: 13px; font-weight: bold; cursor: pointer; transition: 0.2s; display: flex; align-items: center; gap: 5px; }
        .song-btn:hover { border-color: #ff5722; color: #ff5722; }
        .btn-del { color: #ff4a4a; border-color: #ff4a4a; }
        .btn-del:hover { background: #ff4a4a; color: #000; }

        /* 하단 플레이어 최적화 */
        .bottom-player-bar { position: fixed; bottom: 0; left: 0; width: 100%; background: #1a1c1e; border-top: 2px solid #ff5722; padding: 15px 40px; box-sizing: border-box; display: flex; align-items: center; justify-content: space-between; z-index: 1000; box-shadow: 0 -5px 20px rgba(0,0,0,0.8); }
        .player-info { display: flex; align-items: center; gap: 15px; width: 300px; }
        .player-cover { width: 55px; height: 55px; border-radius: 6px; background: #000; object-fit: cover; }
        .player-text { display: flex; flex-direction: column; }
        .player-title { font-size: 15px; font-weight: bold; color: #fff; }
        .player-artist { font-size: 12px; color: #aaa; margin-top: 2px; }
        
        .player-controls-wrapper { flex: 1; max-width: 600px; display: flex; flex-direction: column; align-items: center; gap: 10px; }
        .player-buttons { display: flex; align-items: center; gap: 20px; }
        
        /* 🌟 컨트롤 버튼 스타일 (아이콘 전용) */
        .btn-ctrl { background: none; border: none; color: #fff; font-size: 26px; cursor: pointer; transition: 0.2s; padding: 0; display: flex; align-items: center; justify-content: center; }
        .btn-ctrl:hover { color: #ff5722; }
        .play-btn { font-size: 45px !important; color: #ff5722 !important; }
        
        /* 🌟 반복모드 버튼 스타일 (세련되게 변경) */
        #btn-loop-mode { font-size: 22px; color: #666; margin-left: 15px; position: relative; }
        #btn-loop-mode.active-one { color: #ff5722; } /* 한곡반복 색상 */
        #btn-loop-mode.active-all { color: #ffb300; } /* 전체반복 색상 */
        
        /* 한곡반복일 때 숫자 '1' 표시 */
        #btn-loop-mode .loop-num { position: absolute; font-size: 9px; font-weight: 800; top: 7px; left: 8px; color: #ff5722; display: none; }
        #btn-loop-mode.active-one .loop-num { display: block; }

        .progress-area { width: 100%; display: flex; align-items: center; gap: 12px; font-size: 12px; color: #aaa; }
        #progress-bar { flex: 1; height: 5px; border-radius: 3px; -webkit-appearance: none; background: #444; outline: none; cursor: pointer; accent-color: #ff5722; }
        #progress-bar::-webkit-slider-thumb { -webkit-appearance: none; width: 12px; height: 12px; border-radius: 50%; background: #ff5722; }

        @media (max-width: 900px) {
            .music-item td:nth-child(1) { float: left; width: 65px; margin-right: 10px; }
            .bottom-player-bar { flex-direction: column; padding: 15px; gap: 15px; }
            .player-info { width: 100%; }
            .player-controls-wrapper { width: 100%; }
        }
    </style>
</head>
<body>
    <header class="main-header">
        <div class="header-top">
             <div class="logo" onclick="window.location.href='/'">RANKING AI</div>
             <div style="color: #aaa; font-size: 14px; font-weight: bold;">🎧 <%= user.id %>님의 보관함</div>
        </div>
        <div class="header-nav">
             <a href="/" class="nav-item">← 메인 차트로 돌아가기</a>
        </div>
    </header>

    <div class="container">
        <div class="page-title">내 음악 보관함</div>
        
        <% if (!artists || artists.length === 0) { %>
            <div style="text-align: center; padding: 100px 0; background: #161718; border-radius: 15px; border: 1px solid #333;">
                <h2 style="color: #777;">보관함이 비어있습니다.</h2>
                <p style="color: #555; margin-bottom: 25px;">메인 차트에서 마음에 드는 곡을 담아보세요!</p>
                <button class="song-btn" style="background: #ff5722; color: #000; padding: 12px 30px;" onclick="location.href='/'">차트 구경가기</button>
            </div>
        <% } else { %>
            <table class="music-list">
                <% artists.forEach(music => { %>
                    <tr class="music-item" id="row-<%= music._id %>" 
                        data-id="<%= music._id %>" 
                        data-title="<%= music.name %>" 
                        data-artist="<%= music.artist %>" 
                        data-cover="<%= music.imageUrl %>" 
                        data-audio="<%= music.audioUrl %>">
                        <td style="width: 70px;"><img src="<%= music.imageUrl %>" class="album-art"></td>
                        <td>
                            <div class="song-title"><%= music.name %></div>
                            <div class="singer"><%= music.artist %></div>
                        </td>
                        <td>
                            <div class="song-actions">
                                <button class="song-btn" onclick="playSingleTrack(this)"><i class='bx bx-play-circle'></i> 듣기</button>
                                <button class="song-btn btn-del" onclick="removeFromMyMusic('<%= music._id %>')"><i class='bx bx-trash' ></i> 삭제</button>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            </table>
        <% } %>
    </div>

    <div class="bottom-player-bar">
        <div class="player-info">
            <img src="https://via.placeholder.com/50/222222/ff5722?text=AI" id="main-player-cover" class="player-cover">
            <div class="player-text">
                <span id="main-player-title" class="player-title">선택된 곡이 없습니다</span>
                <span id="main-player-artist" class="player-artist">재생 버튼을 눌러주세요</span>
            </div>
        </div>
        <div class="player-controls-wrapper">
            <div class="player-buttons">
                <button class="btn-ctrl" onclick="playPrevTrack()"><i class='bx bx-skip-previous'></i></button>
                <button id="btn-play" class="btn-ctrl play-btn" onclick="togglePlayPause()"><i class='bx bx-play'></i></button>
                <button class="btn-ctrl" onclick="playNextTrack()"><i class='bx bx-skip-next'></i></button>
                
                <button id="btn-loop-mode" class="btn-ctrl" onclick="toggleLoopMode()" title="반복 안함">
                    <i class='bx bx-repeat'></i>
                    <span class="loop-num">1</span> </button>
            </div>
            <div class="progress-area">
                <span id="time-current">00:00</span>
                <input type="range" id="progress-bar" value="0" min="0" max="100" step="1">
                <span id="time-total">00:00</span>
            </div>
        </div>
        <audio id="main-audio"></audio>
    </div>

    <script>
        let playlist = [];
        let currentIndex = 0;
        let loopMode = 0; // 0: 반복없음, 1: 한곡반복, 2: 전체반복
        const mainAudio = document.getElementById('main-audio');
        const btnPlay = document.getElementById('btn-play');
        const btnLoop = document.getElementById('btn-loop-mode');
        const progressBar = document.getElementById('progress-bar');

        // 🌟 1. 삭제 기능
        async function removeFromMyMusic(musicId) {
            if(!confirm('보관함에서 삭제하시겠습니까?')) return;
            try {
                const res = await fetch('/remove-from-mymusic/' + musicId, { method: 'POST' });
                const data = await res.json();
                if(data.success) {
                    const row = document.getElementById('row-' + musicId);
                    row.style.opacity = '0';
                    setTimeout(() => row.remove(), 300);
                }
            } catch(e) { alert('삭제 처리에 실패했습니다.'); }
        }

        // 🌟 2. 세련된 아이콘 반복 모드 전환 로직
        function toggleLoopMode() {
            loopMode = (loopMode + 1) % 3;
            
            // 클래스 초기화
            btnLoop.classList.remove('active-one', 'active-all');
            
            if (loopMode === 0) {
                btnLoop.title = "반복 안함";
                // 기본 색상 유지 (CSS)
            } else if (loopMode === 1) {
                btnLoop.title = "한곡 반복";
                btnLoop.classList.add('active-one'); // 주황색 + 숫자1 (CSS)
            } else if (loopMode === 2) {
                btnLoop.title = "전체 반복";
                btnLoop.classList.add('active-all'); // 노란색 (CSS)
            }
        }

        // 🌟 3. 재생 엔진
        function loadTrack(index) {
            if(index >= 0 && index < playlist.length) {
                const track = playlist[index];
                currentIndex = index;
                
                document.getElementById('main-player-title').innerText = track.title;
                document.getElementById('main-player-artist').innerText = track.artist;
                document.getElementById('main-player-cover').src = track.cover;
                
                mainAudio.src = track.audio;
                mainAudio.load();
                mainAudio.play().then(() => {
                    btnPlay.innerHTML = "<i class='bx bx-pause'></i>"; // 일시정지 아이콘
                }).catch(e => console.log("재생 오류:", e));
            }
        }

        function playSingleTrack(btn) {
            const tr = btn.closest('.music-item');
            const rows = document.querySelectorAll('.music-item');
            
            // 현재 리스트 상태를 플레이리스트로 장전
            playlist = Array.from(rows).map(r => ({
                title: r.dataset.title,
                artist: r.dataset.artist,
                cover: r.dataset.cover,
                audio: r.dataset.audio
            }));
            
            const idx = playlist.findIndex(t => t.audio === tr.dataset.audio);
            loadTrack(idx);
        }

        function playNextTrack() {
            if (loopMode === 1) {
                // 한 곡 반복일 때
                loadTrack(currentIndex);
            } else if (currentIndex < playlist.length - 1) {
                // 다음 곡 있을 때
                loadTrack(currentIndex + 1);
            } else if (loopMode === 2) {
                // 전체 반복이고 마지막 곡일 때 첫 곡으로
                loadTrack(0);
            } else {
                // 반복 없음 마지막 곡 ➔ 정지
                btnPlay.innerHTML = "<i class='bx bx-play'></i>";
            }
        }

        function playPrevTrack() {
            if (currentIndex > 0) loadTrack(currentIndex - 1);
            else if (loopMode === 2) loadTrack(playlist.length - 1); // 전체반복 시 맨 마지막 곡으로
        }

        function togglePlayPause() {
            if (!mainAudio.src) return;
            if (mainAudio.paused) {
                mainAudio.play();
                btnPlay.innerHTML = "<i class='bx bx-pause'></i>";
            } else {
                mainAudio.pause();
                btnPlay.innerHTML = "<i class='bx bx-play'></i>";
            }
        }

        // 🌟 4. 이벤트 리스너
        mainAudio.addEventListener('ended', playNextTrack);

        mainAudio.addEventListener('timeupdate', () => {
            if (mainAudio.duration) {
                const current = mainAudio.currentTime;
                const duration = mainAudio.duration;
                progressBar.value = (current / duration) * 100;
                
                let minC = Math.floor(current / 60);
                let secC = Math.floor(current % 60);
                document.getElementById('time-current').innerText = `${minC}:${secC < 10 ? '0'+secC : secC}`;
                
                let minD = Math.floor(duration / 60);
                let secD = Math.floor(duration % 60);
                document.getElementById('time-total').innerText = `${minD}:${secD < 10 ? '0'+secD : secD}`;
            }
        });

        progressBar.addEventListener('input', () => {
            if (mainAudio.duration) {
                mainAudio.currentTime = (progressBar.value / 100) * mainAudio.duration;
            }
        });
    </script>
</body>
</html>