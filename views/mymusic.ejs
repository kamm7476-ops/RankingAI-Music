<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>내 음악 보관함 - RANKING AI</title>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <style>
        body { background: #0b0c0d; color: #fff; font-family: 'Pretendard', -apple-system, sans-serif; margin: 0; padding-bottom: 160px; -webkit-font-smoothing: antialiased; }
        a { text-decoration: none; color: inherit; }
        button { border: none; background: none; padding: 0; cursor: pointer; font-family: inherit; color: inherit; outline: none; }

        /* 헤더 스타일 */
        .main-header { background: #121314; border-bottom: 1px solid #1a1b1c; position: sticky; top: 0; z-index: 100; }
        .header-top { display: flex; justify-content: space-between; align-items: center; padding: 15px 30px; }
        .logo { font-size: 26px; font-weight: 900; color: #ff5722; cursor: pointer; background: linear-gradient(45deg, #ff5722, #ffb300); -webkit-background-clip: text; -webkit-text-fill-color: transparent; letter-spacing: -1px; }
        .header-nav { display: flex; justify-content: flex-start; gap: 20px; padding: 12px 20px; background: #0b0c0d; border-bottom: 1px solid #1a1b1c; overflow-x: auto; white-space: nowrap; }
        .nav-item { color: #888; font-weight: 600; font-size: 15px; transition: 0.2s; }
        .nav-item:hover { color: #fff; }

        .container { max-width: 1100px; margin: 0 auto; padding: 30px 20px; }
        .page-title-wrap { display: flex; align-items: center; justify-content: space-between; margin-bottom: 25px; padding-bottom: 15px; border-bottom: 1px solid #222; }
        .page-title { font-size: 26px; font-weight: bold; color: #fff; margin: 0; }
        .song-count { font-size: 14px; color: #666; font-weight: normal; margin-left: 10px; }

        /* 상단 컨트롤바 */
        .chart-controls { display: flex; gap: 8px; margin-bottom: 20px; align-items: center; padding: 5px 0; }
        .control-btn { border: 1px solid #333; color: #aaa; padding: 7px 18px; border-radius: 20px; font-size: 13px; font-weight: 500; transition: 0.2s; display: flex; align-items: center; gap: 6px; }
        .control-btn:hover { border-color: #ff5722; color: #ff5722; background: rgba(255,87,34,0.05); }
        .control-btn i { font-size: 18px; }
        
        .custom-checkbox { width: 18px; height: 18px; accent-color: #ff5722; cursor: pointer; border: 1px solid #444; border-radius: 3px; }

        /* 음악 목록 */
        .music-list { width: 100%; border-collapse: collapse; }
        .music-item { border-bottom: 1px solid #1a1b1c; transition: 0.2s; }
        .music-item:hover { background: rgba(255,255,255,0.02); }
        .music-item td { padding: 12px 10px; vertical-align: middle; }
        .album-art { width: 60px; height: 60px; border-radius: 6px; object-fit: cover; border: 1px solid #222; }
        .song-title { font-size: 16px; font-weight: 600; color: #fff; margin-bottom: 4px; }
        .singer { font-size: 13px; color: #888; }
        
        .song-actions { display: flex; gap: 10px; justify-content: flex-end; }
        .action-icon-btn { font-size: 22px; color: #555; transition: 0.2s; display: flex; align-items: center; }
        .action-icon-btn:hover { color: #ff5722; }

        /* 🌟 하단 플레이어 (주황색 테마 최적화) */
        .bottom-player-bar { position: fixed; bottom: 0; left: 0; width: 100%; background: #121314; border-top: 1px solid #222; padding: 12px 40px; box-sizing: border-box; display: flex; align-items: center; justify-content: space-between; z-index: 1000; box-shadow: 0 -5px 25px rgba(0,0,0,0.5); }
        
        .player-info { display: flex; align-items: center; gap: 15px; width: 300px; }
        .player-cover { width: 55px; height: 55px; border-radius: 6px; border: 1px solid #222; object-fit: cover; }
        .player-text { display: flex; flex-direction: column; overflow: hidden; }
        .player-title { font-size: 15px; font-weight: 600; color: #fff; white-space: nowrap; text-overflow: ellipsis; overflow: hidden; }
        .player-artist { font-size: 12px; color: #888; margin-top: 3px; }
        
        .player-controls-wrapper { flex: 1; max-width: 550px; display: flex; flex-direction: column; align-items: center; gap: 8px; }
        .player-buttons { display: flex; align-items: center; gap: 20px; }
        
        /* 🌟 컨트롤 버튼 스타일 (크기 확대) */
        .btn-ctrl { color: #fff; font-size: 32px; transition: 0.2s; display: flex; align-items: center; justify-content: center; }
        .btn-ctrl:hover { color: #ff5722; }
        .play-btn { font-size: 52px !important; color: #ff5722 !important; }
        
        /* 🔄 🌟 세련된 주황색 반복 모드 버튼 (이모지 완벽 제거) */
        #btn-loop-mode { font-size: 28px; color: #555; margin-left: 20px; position: relative; transition: 0.2s; }
        #btn-loop-mode.active { color: #ff5722; } /* 활성화 시 주황색 */
        
        /* 한곡반복 시 숫자 '1' 표시 (배경 없이 주황색 숫자로만) */
        #btn-loop-mode .loop-num { position: absolute; font-size: 10px; font-weight: 900; bottom: 0px; right: -3px; color: #ff5722; display: none; background: #121314; border-radius: 50%; width: 14px; height: 14px; line-height: 14px; text-align: center; }
        #btn-loop-mode.active-one .loop-num { display: block; }

        .progress-area { width: 100%; display: flex; align-items: center; gap: 10px; font-size: 11px; color: #666; }
        #progress-bar { flex: 1; height: 4px; border-radius: 2px; -webkit-appearance: none; background: #333; outline: none; cursor: pointer; }
        #progress-bar::-webkit-slider-thumb { -webkit-appearance: none; width: 12px; height: 12px; border-radius: 50%; background: #ff5722; cursor: pointer; }

        @media (max-width: 900px) {
            .bottom-player-bar { flex-direction: column; padding: 15px; gap: 12px; }
            .player-info { width: 100%; min-width: auto; }
            .btn-ctrl { font-size: 28px; }
            .play-btn { font-size: 45px !important; }
            #btn-loop-mode { margin-left: 10px; font-size: 24px; }
        }
    </style>
</head>
<body>
    <header class="main-header">
        <div class="header-top">
             <div class="logo" onclick="window.location.href='/'">RANKING AI</div>
             <div style="color: #666; font-size: 13px;">🎧 <%= user.id %>님의 보관함</div>
        </div>
        <div class="header-nav">
             <a href="/" class="nav-item">← 메인 차트로 돌아가기</a>
        </div>
    </header>

    <div class="container">
        <div class="page-title-wrap">
            <h1 class="page-title">내 음악 보관함 <span class="song-count">(전체 <%= artists.length %>곡)</span></h1>
        </div>

        <div class="chart-controls">
            <div style="display:flex; align-items:center; gap:10px; margin-right: 10px;">
                <input type="checkbox" id="checkAll" class="custom-checkbox" onchange="toggleAll(this)">
                <label for="checkAll" style="font-size:13px; color:#888; cursor:pointer;">전체선택</label>
            </div>
            <button class="control-btn" onclick="playAll()"><i class='bx bx-play-circle'></i> 전체듣기</button>
            <button class="control-btn" onclick="playSelected()"><i class='bx bx-list-check' ></i> 선택듣기</button>
        </div>
        
        <% if (!artists || artists.length === 0) { %>
            <div style="text-align: center; padding: 80px 0; background: #121314; border-radius: 12px; border: 1px solid #1a1b1c;">
                <h3 style="color: #666;">보관함이 비어있습니다.</h3>
                <button class="control-btn" style="background: #ff5722; color: #000; border:none; margin-top:20px; font-weight: bold;" onclick="location.href='/'">곡 담으러 가기</button>
            </div>
        <% } else { %>
            <table class="music-list">
                <% artists.forEach(music => { %>
                    <tr class="music-item" id="row-<%= music._id %>" data-id="<%= music._id %>" data-title="<%= music.name %>" data-artist="<%= music.artist %>" data-cover="<%= music.imageUrl %>" data-audio="<%= music.audioUrl %>">
                        <td style="width: 30px;"><input type="checkbox" class="song-check custom-checkbox"></td>
                        <td style="width: 60px;">
                            <div class="album-art-wrap" style="position:relative;">
                                <img src="<%= music.imageUrl %>" class="album-art">
                                <div class="art-play-hover" onclick="playSingleTrackById('<%= music._id %>')" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.4); display: flex; align-items: center; justify-content: center; opacity: 0; transition: 0.2s; border-radius: 6px; cursor: pointer;">
                                    <i class='bx bx-play' style="font-size: 30px;"></i>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="song-title"><%= music.name %></div>
                            <div class="singer"><%= music.artist %></div>
                        </td>
                        <td style="text-align: right;">
                            <div class="song-actions">
                                <button class="action-icon-btn" onclick="playSingleTrackById('<%= music._id %>')" title="재생"><i class='bx bx-play-circle'></i></button>
                                <button class="action-icon-btn" onclick="removeFromMyMusic('<%= music._id %>')" title="삭제"><i class='bx bx-trash' ></i></button>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            </table>
        <% } %>
    </div>

    <div class="bottom-player-bar">
        <div class="player-info">
            <img src="https://via.placeholder.com/55/1a1b1c/333333?text=AI" id="main-player-cover" class="player-cover">
            <div class="player-text">
                <span id="main-player-title" class="player-title">선택된 곡이 없습니다</span>
                <span id="main-player-artist" class="player-artist">음악을 선택해주세요</span>
            </div>
        </div>
        <div class="player-controls-wrapper">
            <div class="player-buttons">
                <button class="btn-ctrl" onclick="playPrevTrack()" title="이전 곡"><i class='bx bx-skip-previous'></i></button>
                <button id="btn-play" class="btn-ctrl play-btn" onclick="togglePlayPause()" title="재생/일시정지"><i class='bx bx-play'></i></button>
                <button class="btn-ctrl" onclick="playNextTrack()" title="다음 곡"><i class='bx bx-skip-next'></i></button>
                
                <button id="btn-loop-mode" class="btn-ctrl" onclick="toggleLoopMode()" title="반복 안함">
                    <i class='bx bx-repeat'></i>
                    <span class="loop-num">1</span>
                </button>
            </div>
            <div class="progress-area">
                <span id="time-current">00:00</span>
                <input type="range" id="progress-bar" value="0" min="0" max="100" step="1">
                <span id="time-total">00:00</span>
            </div>
        </div>
        <div style="width: 300px;"></div> <audio id="main-audio"></audio>
    </div>

    <script>
        // 기존 모든 기능 스크립트 그대로 유지
        let playlist = [];
        let currentIndex = 0;
        let loopMode = 0; // 0:안함, 1:한곡, 2:전체
        let isPlaying = false;
        const mainAudio = document.getElementById('main-audio');
        const btnPlay = document.getElementById('btn-play');
        const btnLoop = document.getElementById('btn-loop-mode');
        const progressBar = document.getElementById('progress-bar');

        function toggleAll(source) {
            document.querySelectorAll('.song-check').forEach(cb => cb.checked = source.checked);
        }

        function loadAllToPlaylist() {
            const rows = document.querySelectorAll('.music-item');
            playlist = Array.from(rows).map(r => ({
                id: r.dataset.id, title: r.dataset.title, artist: r.dataset.artist, cover: r.dataset.cover, audio: r.dataset.audio
            })).filter(t => t.audio);
        }

        function playAll() {
            loadAllToPlaylist();
            if(playlist.length > 0) loadTrack(0);
        }

        function playSelected() {
            const checked = document.querySelectorAll('.song-check:checked');
            if(checked.length === 0) return alert('곡을 선택해주세요!');
            playlist = Array.from(checked).map(cb => {
                const tr = cb.closest('.music-item');
                return { id: tr.dataset.id, title: tr.dataset.title, artist: tr.dataset.artist, cover: tr.dataset.cover, audio: tr.dataset.audio };
            }).filter(t => t.audio);
            if(playlist.length > 0) loadTrack(0);
        }

        function playSingleTrackById(musicId) {
            loadAllToPlaylist();
            const idx = playlist.findIndex(t => t.id === musicId);
            if(idx !== -1) loadTrack(idx);
        }

        async function removeFromMyMusic(musicId) {
            if(!confirm('보관함에서 삭제하시겠습니까?')) return;
            try {
                const res = await fetch('/remove-from-mymusic/' + musicId, { method: 'POST' });
                const data = await res.json();
                if(data.success) location.reload();
            } catch(e) { alert('에러 발생'); }
        }

        // 🔄 🌟 반복 모드 주황색 활성화 로직
        function toggleLoopMode() {
            loopMode = (loopMode + 1) % 3;
            btnLoop.classList.remove('active', 'active-one');
            
            if (loopMode === 1) { // 한곡 반복
                btnLoop.classList.add('active', 'active-one');
                btnLoop.title = "한곡 반복";
            } else if (loopMode === 2) { // 전체 반복
                btnLoop.classList.add('active');
                btnLoop.title = "전체 반복";
            } else {
                btnLoop.title = "반복 안함";
            }
        }

        function loadTrack(index) {
            if(index >= 0 && index < playlist.length) {
                const track = playlist[index];
                currentIndex = index;
                document.getElementById('main-player-title').innerText = track.title;
                document.getElementById('main-player-artist').innerText = track.artist;
                document.getElementById('main-player-cover').src = track.cover;
                mainAudio.src = track.audio;
                mainAudio.load();
                mainAudio.play().then(() => {
                    isPlaying = true;
                    btnPlay.innerHTML = "<i class='bx bx-pause'></i>";
                });
            }
        }

        function playNextTrack() {
            if (loopMode === 1) loadTrack(currentIndex);
            else if (currentIndex < playlist.length - 1) loadTrack(currentIndex + 1);
            else if (loopMode === 2) loadTrack(0);
            else { isPlaying = false; btnPlay.innerHTML = "<i class='bx bx-play'></i>"; }
        }

        function playPrevTrack() {
            if (currentIndex > 0) loadTrack(currentIndex - 1);
            else if (loopMode === 2) loadTrack(playlist.length - 1);
        }

        function togglePlayPause() {
            if (!mainAudio.src) return;
            if (mainAudio.paused) {
                mainAudio.play();
                btnPlay.innerHTML = "<i class='bx bx-pause'></i>";
            } else {
                mainAudio.pause();
                btnPlay.innerHTML = "<i class='bx bx-play'></i>";
            }
        }

        // 호버 효과를 위한 CSS 동적 추가
        document.querySelectorAll('.music-item').forEach(item => {
            item.addEventListener('mouseenter', () => {
                item.querySelector('.art-play-hover').style.opacity = '1';
            });
            item.addEventListener('mouseleave', () => {
                item.querySelector('.art-play-hover').style.opacity = '0';
            });
        });

        mainAudio.addEventListener('ended', playNextTrack);
        mainAudio.addEventListener('timeupdate', () => {
            if (mainAudio.duration) {
                progressBar.value = (mainAudio.currentTime / mainAudio.duration) * 100;
                let mc = Math.floor(mainAudio.currentTime / 60);
                let sc = Math.floor(mainAudio.currentTime % 60);
                document.getElementById('time-current').innerText = `${mc}:${sc < 10 ? '0'+sc : sc}`;
                let md = Math.floor(mainAudio.duration / 60);
                let sd = Math.floor(mainAudio.duration % 60);
                document.getElementById('time-total').innerText = `${md}:${sd < 10 ? '0'+sd : sd}`;
            }
        });
        progressBar.addEventListener('input', () => {
            if (mainAudio.duration) mainAudio.currentTime = (progressBar.value / 100) * mainAudio.duration;
        });
    </script>
</body>
</html>