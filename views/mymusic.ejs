<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>내 음악 보관함 - RANKING AI</title>
    <style>
        body { background: #0b0c0d; color: #fff; font-family: 'Pretendard', sans-serif; margin: 0; padding-bottom: 120px; }
        a { text-decoration: none; color: inherit; }

        .main-header { background: #121314; border-bottom: 1px solid #222; position: sticky; top: 0; z-index: 100; }
        .header-top { display: flex; justify-content: space-between; align-items: center; padding: 15px 40px; border-bottom: 1px solid #1a1b1c; }
        .logo { font-size: 28px; font-weight: 900; color: #ff5722; cursor: pointer; background: linear-gradient(45deg, #ff5722, #ffb300); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        
        /* 모바일 메뉴 깨짐 방지 적용 완료! */
        .header-nav { display: flex; justify-content: flex-start; gap: 25px; padding: 12px 15px; background: #0b0c0d; overflow-x: auto; white-space: nowrap; -webkit-overflow-scrolling: touch; border-bottom: 1px solid #222; }
        .header-nav::-webkit-scrollbar { display: none; }
        .nav-item { color: #aaa; font-weight: 600; font-size: 16px; transition: 0.2s; position: relative; cursor: pointer; flex-shrink: 0; white-space: nowrap; }
        .nav-item:hover { color: #ff5722; }

        .container { max-width: 1000px; margin: 0 auto; padding: 40px 20px; }
        .page-title { font-size: 28px; font-weight: 900; margin-bottom: 30px; border-bottom: 2px solid #222; padding-bottom: 15px; }

        .music-list { width: 100%; border-collapse: collapse; }
        .music-item { border-bottom: 1px solid #222; transition: 0.2s; }
        .music-item:hover { background: rgba(255,87,34,0.05); }
        .music-item td { padding: 15px 10px; vertical-align: middle; }
        .album-art { width: 60px; height: 60px; border-radius: 8px; object-fit: cover; box-shadow: 0 4px 10px rgba(0,0,0,0.5); }
        .song-title { font-size: 16px; font-weight: bold; margin-bottom: 5px; color: #fff; }
        .singer { font-size: 13px; color: #aaa; }
        
        .song-actions { display: flex; gap: 8px; justify-content: flex-end; }
        .song-btn { background: #222; color: #aaa; border: 1px solid #444; padding: 6px 12px; border-radius: 20px; font-size: 12px; font-weight: bold; cursor: pointer; transition: 0.2s; }
        .song-btn:hover { border-color: #ff5722; background: #ff5722; color: #000; }
        .btn-del { color: #ff4a4a; border-color: #ff4a4a; background: rgba(255, 74, 74, 0.1); }
        .btn-del:hover { background: #ff4a4a; color: #000; }

        .bottom-player-bar { position: fixed; bottom: 0; left: 0; width: 100%; background: #1a1c1e; border-top: 2px solid #ff5722; padding: 10px 40px; box-sizing: border-box; display: flex; align-items: center; justify-content: space-between; z-index: 1000; box-shadow: 0 -5px 20px rgba(0,0,0,0.8); }
        .player-info { display: flex; align-items: center; gap: 15px; width: 300px; }
        .player-cover { width: 50px; height: 50px; border-radius: 5px; background: #000; object-fit: cover; }
        .player-text { display: flex; flex-direction: column; }
        .player-title { font-size: 15px; font-weight: bold; color: #fff; }
        .player-artist { font-size: 12px; color: #aaa; }
        .player-controls-wrapper { flex: 1; max-width: 600px; display: flex; flex-direction: column; align-items: center; gap: 8px; }
        .player-buttons { display: flex; align-items: center; gap: 20px; }
        .player-buttons button { background: none; border: none; color: #fff; font-size: 20px; cursor: pointer; padding: 0; }
        .player-buttons button:hover { color: #ff5722; }
        .player-buttons .play-btn { font-size: 32px; color: #ff5722; }
        .progress-area { width: 100%; display: flex; align-items: center; gap: 10px; font-size: 12px; color: #aaa; }
        #progress-bar { flex: 1; height: 4px; border-radius: 2px; -webkit-appearance: none; background: #444; outline: none; cursor: pointer; accent-color: #ff5722; }
        #progress-bar::-webkit-slider-thumb { -webkit-appearance: none; width: 12px; height: 12px; border-radius: 50%; background: #ff5722; }

        @media (max-width: 900px) {
            .music-item, .music-item td, .music-list, .music-list tbody { display: block; width: 100%; box-sizing: border-box; }
            .music-item { background: #161718; border-radius: 12px; padding: 15px; margin-bottom: 15px; border: 1px solid #333; position: relative; }
            .music-item td { padding: 0; border: none; }
            .music-item td:nth-child(1) { float: left; width: 65px; margin-right: 15px; }
            .song-info-col { margin-top: 5px; }
            .song-actions { justify-content: flex-start; margin-top: 15px; clear: both; }
            .bottom-player-bar { padding: 12px 15px; flex-direction: column; gap: 12px; }
            .player-info { width: 100%; justify-content: flex-start; }
            .player-controls-wrapper { width: 100%; }
            .header-top { flex-direction: column; gap: 15px; }
        }
    </style>
</head>
<body>
    <header class="main-header">
        <div class="header-top">
             <div class="logo" onclick="window.location.href='/?sort=views'">RANKING AI</div>
             <div style="color: #aaa; font-size: 14px; font-weight: bold;">🎧 <%= user.id %>님의 보관함</div>
         </div>
         <div class="header-nav">
             <a href="/?sort=views" class="nav-item">← 메인 차트로 돌아가기</a>
         </div>
     </header>

     <div class="container">
        <div class="page-title">내 음악 보관함</div>
        
        <% if (!artists || artists.length === 0) { %>
            <div style="text-align: center; padding: 100px 0; background: #161718; border-radius: 15px; border: 1px solid #333;">
                <h2 style="color: #777;">보관함이 비어있습니다.</h2>
                <p style="color: #555;">메인 차트에서 마음에 드는 곡을 '+ 담기' 해보세요!</p>
                <button class="song-btn" style="margin-top: 20px; padding: 10px 20px; background: #ff5722; color: #000;" onclick="location.href='/'">차트 구경가기</button>
            </div>
        <% } else { %>
            <table class="music-list">
                <% artists.forEach(music => { %>
                    <tr class="music-item" data-title="<%= music.name %>" data-artist="<%= music.artist %>" data-cover="<%= music.imageUrl %>" data-audio="<%= music.audioUrl %>">
                        <td style="width: 70px;"><img src="<%= music.imageUrl %>" class="album-art"></td>
                        <td class="song-info-col">
                            <div class="song-title"><%= music.name %></div>
                            <div class="singer"><%= music.artist %></div>
                        </td>
                        <td>
                            <div class="song-actions">
                                <button class="song-btn" onclick="playSingleTrack(this)">▶ 듣기</button>
                                <form action="/delete-mymusic/<%= music._id %>" method="POST" style="margin:0;" onsubmit="return confirm('보관함에서 삭제하시겠습니까?');">
                                    <button type="submit" class="song-btn btn-del">🗑️ 삭제</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            </table>
        <% } %>
     </div>

     <div class="bottom-player-bar">
        <div class="player-info">
            <img src="https://via.placeholder.com/50/222222/ff5722?text=Play" id="main-player-cover" class="player-cover">
            <div class="player-text">
                <span id="main-player-title" class="player-title">선택된 곡이 없습니다</span>
                <span id="main-player-artist" class="player-artist">재생 버튼을 눌러주세요</span>
            </div>
        </div>
        <div class="player-controls-wrapper">
            <div class="player-buttons">
                <button id="btn-play" onclick="togglePlayPause()" class="play-btn">▶</button>
            </div>
            <div class="progress-area">
                <span id="time-current">00:00</span>
                <input type="range" id="progress-bar" value="0" min="0" max="100" step="1">
                <span id="time-total">00:00</span>
            </div>
        </div>
        <audio id="main-audio" style="display:none;"></audio>
    </div>

     <script>
         const mainAudio = document.getElementById('main-audio');
         const btnPlay = document.getElementById('btn-play');
         const progressBar = document.getElementById('progress-bar');
         const timeCurrent = document.getElementById('time-current');
         const timeTotal = document.getElementById('time-total');
         let isPlaying = false;

         function playSingleTrack(btn) {
             const tr = btn.closest('.music-item');
             if(!tr.dataset.audio) return alert('음원 파일이 없습니다.');
             
             document.getElementById('main-player-title').innerText = tr.dataset.title;
             document.getElementById('main-player-artist').innerText = tr.dataset.artist;
             document.getElementById('main-player-cover').src = tr.dataset.cover;
             
             mainAudio.src = tr.dataset.audio;
             mainAudio.play();
             isPlaying = true;
             btnPlay.innerText = "⏸";
         }

         function togglePlayPause() {
             if (!mainAudio.src) return alert("곡을 먼저 선택해주세요.");
             if (mainAudio.paused) { mainAudio.play(); isPlaying = true; btnPlay.innerText = "⏸"; } 
             else { mainAudio.pause(); isPlaying = false; btnPlay.innerText = "▶"; }
         }

         mainAudio.addEventListener('timeupdate', () => {
             if (mainAudio.duration) {
                 progressBar.value = (mainAudio.currentTime / mainAudio.duration) * 100;
                 let mc = Math.floor(mainAudio.currentTime / 60); let sc = Math.floor(mainAudio.currentTime % 60);
                 timeCurrent.innerText = mc + ":" + (sc < 10 ? "0"+sc : sc);
                 let md = Math.floor(mainAudio.duration / 60); let sd = Math.floor(mainAudio.duration % 60);
                 timeTotal.innerText = md + ":" + (sd < 10 ? "0"+sd : sd);
             }
         });
         progressBar.addEventListener('input', () => mainAudio.currentTime = (progressBar.value / 100) * mainAudio.duration);
     </script>
</body>
</html>
