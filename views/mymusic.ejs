<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>내 음악 보관함 - RANKING AI</title>
    <style>
        /* 기존 스타일 유지 */
        body { background: #0b0c0d; color: #fff; font-family: 'Pretendard', sans-serif; margin: 0; padding-bottom: 120px; }
        a { text-decoration: none; color: inherit; }
        .main-header { background: #121314; border-bottom: 1px solid #222; position: sticky; top: 0; z-index: 100; }
        .header-top { display: flex; justify-content: space-between; align-items: center; padding: 15px 40px; border-bottom: 1px solid #1a1b1c; }
        .logo { font-size: 28px; font-weight: 900; color: #ff5722; cursor: pointer; background: linear-gradient(45deg, #ff5722, #ffb300); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .header-nav { display: flex; justify-content: flex-start; gap: 25px; padding: 12px 15px; background: #0b0c0d; overflow-x: auto; white-space: nowrap; border-bottom: 1px solid #222; }
        .container { max-width: 1000px; margin: 0 auto; padding: 40px 20px; }
        .page-title { font-size: 28px; font-weight: 900; margin-bottom: 30px; border-bottom: 2px solid #222; padding-bottom: 15px; }
        .music-list { width: 100%; border-collapse: collapse; }
        .music-item { border-bottom: 1px solid #222; transition: 0.2s; }
        .music-item td { padding: 15px 10px; vertical-align: middle; }
        .album-art { width: 60px; height: 60px; border-radius: 8px; object-fit: cover; }
        .song-title { font-size: 16px; font-weight: bold; color: #fff; }
        .singer { font-size: 13px; color: #aaa; }
        .song-actions { display: flex; gap: 8px; justify-content: flex-end; }
        .song-btn { background: #222; color: #aaa; border: 1px solid #444; padding: 6px 15px; border-radius: 20px; font-size: 13px; font-weight: bold; cursor: pointer; }
        .song-btn:hover { border-color: #ff5722; color: #ff5722; }
        .btn-del { color: #ff4a4a; border-color: #ff4a4a; }
        .btn-del:hover { background: #ff4a4a; color: #000; }
        .bottom-player-bar { position: fixed; bottom: 0; left: 0; width: 100%; background: #1a1c1e; border-top: 2px solid #ff5722; padding: 10px 40px; display: flex; align-items: center; justify-content: space-between; z-index: 1000; }
        .player-info { display: flex; align-items: center; gap: 15px; width: 300px; }
        .player-cover { width: 50px; height: 50px; border-radius: 5px; }
        .player-controls-wrapper { flex: 1; max-width: 600px; display: flex; flex-direction: column; align-items: center; gap: 8px; }
        .progress-area { width: 100%; display: flex; align-items: center; gap: 10px; font-size: 12px; color: #aaa; }
        #progress-bar { flex: 1; height: 4px; accent-color: #ff5722; }
        @media (max-width: 900px) {
            .music-item td:nth-child(1) { float: left; width: 65px; }
            .bottom-player-bar { flex-direction: column; padding: 15px; }
        }
    </style>
</head>
<body>
    <header class="main-header">
        <div class="header-top">
             <div class="logo" onclick="window.location.href='/'">RANKING AI</div>
             <div style="color: #aaa; font-size: 14px;">🎧 <%= user.id %>님의 보관함</div>
        </div>
        <div class="header-nav">
             <a href="/" class="nav-item">← 메인 차트로 돌아가기</a>
        </div>
    </header>

    <div class="container">
        <div class="page-title">내 음악 보관함</div>
        
        <% if (!artists || artists.length === 0) { %>
            <div style="text-align: center; padding: 100px 0; background: #161718; border-radius: 15px;">
                <h2 style="color: #777;">보관함이 비어있습니다.</h2>
                <button class="song-btn" onclick="location.href='/'">차트 구경가기</button>
            </div>
        <% } else { %>
            <table class="music-list">
                <% artists.forEach(music => { %>
                    <tr class="music-item" id="row-<%= music._id %>" data-id="<%= music._id %>" data-title="<%= music.name %>" data-artist="<%= music.artist %>" data-cover="<%= music.imageUrl %>" data-audio="<%= music.audioUrl %>">
                        <td style="width: 70px;"><img src="<%= music.imageUrl %>" class="album-art"></td>
                        <td>
                            <div class="song-title"><%= music.name %></div>
                            <div class="singer"><%= music.artist %></div>
                        </td>
                        <td>
                            <div class="song-actions">
                                <button class="song-btn" onclick="playSingleTrack(this)">▶ 듣기</button>
                                <button class="song-btn btn-del" onclick="removeFromMyMusic('<%= music._id %>')">🗑️ 삭제</button>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            </table>
        <% } %>
    </div>

    <div class="bottom-player-bar">
        <div class="player-info">
            <img src="https://via.placeholder.com/50/222222/ff5722?text=Play" id="main-player-cover" class="player-cover">
            <div class="player-text">
                <span id="main-player-title" class="player-title">선택된 곡이 없습니다</span><br>
                <span id="main-player-artist" class="player-artist" style="font-size:12px; color:#777;">재생 버튼을 눌러주세요</span>
            </div>
        </div>
        <div class="player-controls-wrapper">
            <div class="player-buttons">
                <button onclick="playPrevTrack()" style="background:none; border:none; color:white; cursor:pointer;">⏮</button>
                <button id="btn-play" onclick="togglePlayPause()" style="background:none; border:none; color:#ff5722; font-size:30px; cursor:pointer; margin:0 15px;">▶</button>
                <button onclick="playNextTrack()" style="background:none; border:none; color:white; cursor:pointer;">⏭</button>
            </div>
            <div class="progress-area">
                <span id="time-current">00:00</span>
                <input type="range" id="progress-bar" value="0" min="0" max="100">
                <span id="time-total">00:00</span>
            </div>
        </div>
        <audio id="main-audio"></audio>
    </div>

    <script>
        let playlist = [];
        let currentIndex = 0;
        const mainAudio = document.getElementById('main-audio');
        const btnPlay = document.getElementById('btn-play');

        // 🌟 1. 삭제 기능 (서버 연결 완료)
        async function removeFromMyMusic(musicId) {
            if(!confirm('보관함에서 삭제하시겠습니까?')) return;
            try {
                const res = await fetch('/remove-from-mymusic/' + musicId, { method: 'POST' });
                const data = await res.json();
                if(data.success) {
                    document.getElementById('row-' + musicId).style.display = 'none';
                }
            } catch(e) { alert('삭제 실패'); }
        }

        // 🌟 2. 연속 재생 엔진
        function loadTrack(index) {
            if(index >= 0 && index < playlist.length) {
                const track = playlist[index];
                currentIndex = index;
                document.getElementById('main-player-title').innerText = track.title;
                document.getElementById('main-player-artist').innerText = track.artist;
                document.getElementById('main-player-cover').src = track.cover;
                mainAudio.src = track.audio;
                mainAudio.play();
                btnPlay.innerText = "⏸";
            }
        }

        function playSingleTrack(btn) {
            const tr = btn.closest('.music-item');
            // 보관함의 모든 곡을 플레이리스트로 장전
            const rows = document.querySelectorAll('.music-item');
            playlist = Array.from(rows).map(r => ({
                title: r.dataset.title,
                artist: r.dataset.artist,
                cover: r.dataset.cover,
                audio: r.dataset.audio
            }));
            const idx = playlist.findIndex(t => t.audio === tr.dataset.audio);
            loadTrack(idx);
        }

        function playNextTrack() {
            if (currentIndex < playlist.length - 1) loadTrack(currentIndex + 1);
        }
        function playPrevTrack() {
            if (currentIndex > 0) loadTrack(currentIndex - 1);
        }
        function togglePlayPause() {
            if (mainAudio.paused) { mainAudio.play(); btnPlay.innerText = "⏸"; }
            else { mainAudio.pause(); btnPlay.innerText = "▶"; }
        }

        mainAudio.addEventListener('ended', playNextTrack);
        mainAudio.addEventListener('timeupdate', () => {
            const progressBar = document.getElementById('progress-bar');
            if (mainAudio.duration) {
                progressBar.value = (mainAudio.currentTime / mainAudio.duration) * 100;
                // 시간 표시 로직...
            }
        });
    </script>
</body>
</html>