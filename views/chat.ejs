<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <!-- 🚨 핵심 추가 1: 모바일에서 입력창 터치 시 화면이 멋대로 확대되는 것 방지 -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>1:1 거래 대화방</title>
    <style>
        /* 🚨 1. 전체 화면에 대못 박기 (어떤 스마트폰에서도 절대 안 흔들림) */
        html, body { 
            font-family: 'Pretendard', sans-serif; 
            background: #0b0c0d; 
            color: #fff; 
            margin: 0; 
            padding: 0;
            width: 100%; 
            height: 100%; 
            position: fixed; /* 🚨 핵심 1: 화면을 물리적으로 꽉 잠가버림 */
            overflow: hidden; 
        }
        
        /* 🚨 2. 헤더 (천장에 고정) */
        .header { 
            position: absolute; 
            top: 0; left: 0; width: 100%; 
            height: 55px; /* 헤더 높이 고정 */
            box-sizing: border-box;
            background: #161718; padding: 0 20px; border-bottom: 1px solid #222; 
            display: flex; align-items: center; justify-content: space-between; 
            z-index: 100;
        }
        .back-btn { color: #aaa; text-decoration: none; font-size: 15px; font-weight: bold; display: flex; align-items: center; gap: 5px; }
        .back-btn:hover { color: #ffb300; }
        
        /* 🚨 3. 채팅 상자 (천장과 바닥 사이 공간만 씀) */
        .chat-box { 
            position: absolute;
            top: 55px; /* 헤더 바로 아래부터 시작 */
            bottom: 70px; /* 입력창 바로 위에서 끝 (아이폰 안전여백 포함) */
            left: 0; width: 100%;
            box-sizing: border-box;
            padding: 20px; 
            overflow-y: auto; /* 내용이 넘치면 이 안에서만 스크롤 */
            display: flex; flex-direction: column; gap: 12px; 
        }
        .msg { max-width: 75%; padding: 12px 16px; border-radius: 20px; font-size: 14px; line-height: 1.5; word-break: break-all; }
        .msg.my { background: #ffb300; color: #000; font-weight: 500; align-self: flex-end; border-bottom-right-radius: 4px; box-shadow: 0 4px 10px rgba(255,179,0,0.3); }
        .msg.other { background: #222; color: #ddd; align-self: flex-start; border-bottom-left-radius: 4px; border: 1px solid #333; }
        .sender-name { font-size: 11px; color: #777; margin-bottom: 4px; margin-left: 5px; }
        
        /* 🚨 4. 입력창 (바닥에 절대 고정) */
        .input-area { 
            position: absolute; 
            bottom: 0; left: 0; width: 100%;
            height: 70px; /* 입력창 전체 높이 */
            box-sizing: border-box;
            background: #161718; padding: 10px 15px; 
            display: flex; align-items: center; gap: 10px; border-top: 1px solid #222; 
            padding-bottom: max(10px, env(safe-area-inset-bottom)); /* 아이폰 홈 바 안전 보호 */
            z-index: 100;
        }
        .input-area input { flex: 1; height: 45px; box-sizing: border-box; background: #0b0c0d; border: 1px solid #333; color: #fff; padding: 0 20px; border-radius: 25px; outline: none; font-size: 15px; margin: 0; }
        .input-area button { height: 45px; background: #ffb300; color: #000; font-weight: 900; border: none; padding: 0 24px; border-radius: 25px; cursor: pointer; transition: 0.2s; margin: 0; }
        .input-area button:hover { filter: brightness(1.1); transform: scale(1.05); }
    </style>
</head>
<body>
    <div class="header">
        <a href="/chatlist" class="back-btn">⬅ 목록으로</a>
        <strong style="font-size: 16px;">💬 1:1 채팅방</strong>
        <div style="width: 60px;"></div>
    </div>

    <div class="chat-box" id="chatBox">
        <div style="text-align: center; color: #555; font-size: 12px; margin-bottom: 20px; padding: 10px; background: rgba(255,255,255,0.05); border-radius: 10px;">
            대화방이 개설되었습니다.<br>서로 매너있는 대화를 나누어주세요! 🤝
        </div>

        <% if (typeof messages !== 'undefined' && messages && messages.length > 0) { %>
            <% messages.forEach(function(msg) { %>
                <div style="display: flex; flex-direction: column;">
                    <% if (msg.senderId !== user.id) { %>
                        <div class="sender-name"><%= msg.senderName %></div>
                    <% } %>
                    <div class="msg <%= msg.senderId === user.id ? 'my' : 'other' %>">
                        <%= msg.text %>
                    </div>
                </div>
            <% }); %>
        <% } %>
    </div>

    <form class="input-area" id="chatForm">
        <input type="text" id="msgInput" placeholder="메시지를 입력하세요..." autocomplete="off" required>
        <button type="submit">전송</button>
    </form>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io(); 
        const roomId = '<%= room._id %>';
        const myId = '<%= user.id %>';
        const myName = '<%= user.name %>';

        const chatBox = document.getElementById('chatBox');
        const chatForm = document.getElementById('chatForm');
        const msgInput = document.getElementById('msgInput');

        // 들어오자마자 스크롤 맨 밑으로!
        chatBox.scrollTop = chatBox.scrollHeight;

        socket.emit('joinRoom', { roomId: roomId, userId: myId });

        chatForm.addEventListener('submit', (e) => {
            e.preventDefault();
            const text = msgInput.value;
            if (text.trim() === '') return;
            
            socket.emit('chatMessage', { roomId: roomId, senderId: myId, senderName: myName, text: text });
            msgInput.value = ''; 
            msgInput.focus();
        });

        socket.on('message', (msg) => {
            const isMyMsg = (msg.senderId === myId);
            
            const wrapper = document.createElement('div');
            wrapper.style.display = 'flex';
            wrapper.style.flexDirection = 'column';
            
            if (!isMyMsg) {
                const nameDiv = document.createElement('div');
                nameDiv.classList.add('sender-name');
                nameDiv.innerText = msg.senderName;
                wrapper.appendChild(nameDiv);
            }

            const bubble = document.createElement('div');
            bubble.classList.add('msg');
            bubble.classList.add(isMyMsg ? 'my' : 'other');
            bubble.innerText = msg.text;
            
            wrapper.appendChild(bubble);
            chatBox.appendChild(wrapper);
            
            chatBox.scrollTop = chatBox.scrollHeight;
        });
    </script>
</body>
</html>