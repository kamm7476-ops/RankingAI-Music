<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>관리자 대시보드 - RANKING AI</title>
    <style>
        body { background: #0b0c0d; color: #fff; font-family: 'Pretendard', sans-serif; margin: 0; }
        a { text-decoration: none; color: inherit; }

        .navbar { display: flex; justify-content: space-between; align-items: center; padding: 15px 40px; background: #1a0a0a; border-bottom: 2px solid #ff4a4a; position: sticky; top: 0; z-index: 100; }
        .logo { font-size: 24px; font-weight: 900; color: #ff4a4a; letter-spacing: -1px; }
        .btn-home { color: #fff; font-size: 14px; background: #333; padding: 8px 15px; border-radius: 6px; }
        .btn-home:hover { background: #555; }

        .container { max-width: 1100px; margin: 0 auto; padding: 40px 20px; }
        .header-title { font-size: 28px; font-weight: bold; margin-bottom: 30px; display: flex; align-items: center; gap: 10px; }

        /* 통계 카드 디자인 */
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 40px; }
        .stat-card { background: #161718; border: 1px solid #333; padding: 25px; border-radius: 12px; text-align: center; border-top: 4px solid #ff4a4a; }
        .stat-card h3 { color: #aaa; font-size: 14px; margin: 0 0 10px 0; }
        .stat-card .number { font-size: 32px; font-weight: bold; color: #fff; }

        /* 관리자 테이블 */
        .admin-section { background: #161718; padding: 25px; border-radius: 12px; border: 1px solid #333; margin-bottom: 30px; }
        .admin-section h2 { margin-top: 0; font-size: 20px; border-bottom: 1px solid #333; padding-bottom: 15px; }
        
        table { width: 100%; border-collapse: collapse; text-align: left; margin-top: 20px; }
        th { background: #222; padding: 12px; color: #aaa; font-size: 14px; }
        td { padding: 12px; border-bottom: 1px solid #222; font-size: 14px; }
        .btn-delete { background: #ff4a4a; color: #fff; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer; font-size: 12px; font-weight: bold; }
        
        .badge-admin { color: #00e5ff; font-weight: bold; }
        .music-count { color: #ff4a4a; font-weight: bold; }

        @media (max-width: 768px) {
            .navbar { padding: 15px 20px; }
            .container { padding: 20px 10px; }
            .stats-grid { grid-template-columns: 1fr 1fr; }
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <div class="logo">⚙️ RANKING AI 관리자 모드</div>
        <a href="/" class="btn-home">나가기 (메인으로)</a>
    </nav>

    <div class="container">
        <div class="header-title">👑 전체 시스템 실시간 현황</div>

        <div class="stats-grid">
            <div class="stat-card">
                <h3>총 가입 유저</h3>
                <div class="number"><%= stats.totalUsers %>명</div>
            </div>
            <div class="stat-card">
                <h3>등록된 음원</h3>
                <div class="number"><%= stats.totalMusic %>곡</div>
            </div>
            <div class="stat-card">
                <h3>누적 재생수</h3>
                <div class="number" style="color: #00e5ff;"><%= stats.totalViews %>회</div>
            </div>
            <div class="stat-card" style="border-top-color: #ffd700;">
                <h3>오늘 방문자(예상)</h3>
                <div class="number" style="color: #ffd700;"><%= stats.todayVisitor %>명</div>
            </div>
        </div>

        <div class="admin-section">
            <h2>회원 명단 및 등록 음원 현황</h2>
            <table>
                <thead>
                    <tr>
                        <th>아이디</th>
                        <th>실명</th>
                        <th>가입일</th>
                        <th>등록 음원</th>
                        <th>상태</th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach(function(u) { %>
                    <tr>
                        <td><%= u.id %></td>
                        <td style="color: #ff4a4a;"><%= u.name || '미입력' %></td>
                        <td><%= u.createdAt ? u.createdAt.toLocaleDateString() : '-' %></td>
                        <td class="music-count"><%= u.musicCount %>곡</td>
                        <td>
                            <% if(u.role === 'admin') { %>
                                <span class="badge-admin">관리자</span>
                            <% } else { %>
                                <form action="/admin/delete-user/<%= u.id %>" method="POST" onsubmit="return confirm('<%= u.id %> 유저를 정말 강제 탈퇴시키고 모든 음원을 삭제하시겠습니까? (복구 불가)');" style="margin: 0;">
    <button type="submit" class="btn-delete">강제탈퇴</button>
</form>
                            <% } %>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>