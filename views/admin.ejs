<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>관리자 대시보드 - RANKING AI</title>
    <style>
        body { background: #0b0c0d; color: #fff; font-family: 'Pretendard', sans-serif; padding: 20px; }
        .header { display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #333; padding-bottom: 20px; margin-bottom: 30px; }
        .header h1 { margin: 0; color: #ff5722; }
        
        /* 대시보드 현황판 카드 */
        .dashboard { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 40px; }
        .card { background: #161718; padding: 20px; border-radius: 12px; border: 1px solid #333; text-align: center; }
        .card h3 { margin: 0 0 10px 0; color: #aaa; font-size: 14px; }
        .card .number { font-size: 32px; font-weight: bold; color: #fff; margin: 0; }
        .card .number span { font-size: 16px; color: #777; }

        /* 회원 목록 테이블 */
        table { width: 100%; border-collapse: collapse; background: #161718; border-radius: 12px; overflow: hidden; }
        th, td { padding: 15px; text-align: left; border-bottom: 1px solid #333; }
        th { background: #222; color: #ff5722; font-weight: bold; }
        tr:hover { background: #1a1a1a; }
        
        /* 등급 뱃지 & 삭제 버튼 디자인 */
        .badge-admin { background: #ff5722; color: #000; padding: 3px 8px; border-radius: 5px; font-size: 12px; font-weight: bold; }
        .badge-user { background: #444; color: #fff; padding: 3px 8px; border-radius: 5px; font-size: 12px; }
        .btn-delete { background: #e53935; color: #fff; border: none; padding: 6px 12px; border-radius: 5px; cursor: pointer; font-weight: bold; font-size: 12px; transition: 0.2s; }
        .btn-delete:hover { background: #d32f2f; transform: scale(1.05); }
    </style>
</head>
<body>

    <div class="header">
        <h1>👑 RANKING AI 종합 통제실</h1>
        <a href="/" style="color: #fff; text-decoration: none; font-weight: bold;">← 메인 화면으로 돌아가기</a>
    </div>

    <div class="dashboard">
        <div class="card">
            <h3>오늘 방문자 수</h3>
            <p class="number"><%= stats.dailyVisitors %> <span>명</span></p>
        </div>
        <div class="card">
            <h3>누적 방문자 수</h3>
            <p class="number"><%= stats.totalVisitors %> <span>명</span></p>
        </div>
        <div class="card">
            <h3>오늘 재생 수</h3>
            <p class="number"><%= stats.dailyPlays %> <span>회</span></p>
        </div>
        <div class="card">
            <h3>누적 재생 수</h3>
            <p class="number"><%= stats.totalPlays %> <span>회</span></p>
        </div>
    </div>

    <h2 style="margin-bottom: 15px;">👥 회원 가입 목록 (총 <%= users.length %>명)</h2>
    <table>
        <thead>
            <tr>
                <th>가입일</th>
                <th>아이디(닉네임)</th>
                <th>이메일</th>
                <th>등급</th>
                <th>관리(강제탈퇴)</th>
            </tr>
        </thead>
        <tbody>
            <% users.forEach(user => { %>
                <tr>
                    <td><%= user.createdAt ? user.createdAt.toISOString().substring(0, 10) : '날짜 없음' %></td>
                    <td><strong><%= user.username %></strong> <%= user.nickname ? `(${user.nickname})` : '' %></td>
                    <td><%= user.email || '이메일 없음' %></td>
                    <td>
                        <% if(user.role === 'admin') { %>
                            <span class="badge-admin">관리자</span>
                        <% } else { %>
                            <span class="badge-user">일반회원</span>
                        <% } %>
                    </td>
                    <td>
                        <% if(user.role !== 'admin') { %>
                            <form action="/admin/delete-user" method="POST" onsubmit="return confirm('<%= user.username %> 회원을 진짜 탈퇴시키겠습니까? (DB에서 영구 삭제됩니다)');">
                                <input type="hidden" name="userId" value="<%= user._id %>">
                                <button type="submit" class="btn-delete">탈퇴시키기</button>
                            </form>
                        <% } else { %>
                            <span style="color: #777; font-size: 12px; font-weight: bold;">삭제 불가 (대표님)</span>
                        <% } %>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>

</body>
</html>
