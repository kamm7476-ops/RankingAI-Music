<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>유튜브 홍보관 - RANKING AI</title>
    <style>
        body { background: #0b0c0d; color: #fff; font-family: 'Pretendard', sans-serif; margin: 0; padding-bottom: 100px; }
        a { text-decoration: none; color: inherit; }
        .container { max-width: 1200px; margin: 0 auto; padding: 40px 20px; }
        .page-header { border-bottom: 2px solid #222; padding-bottom: 15px; margin-bottom: 30px; display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 15px; }
        .page-title { font-size: 28px; font-weight: bold; margin: 0; color: #fff; }
        .video-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 25px; }
        .video-card-wrap { position: relative; }
        .video-card { background: #161718; border-radius: 12px; overflow: hidden; border: 1px solid #222; transition: all 0.3s ease; display: block; cursor: pointer; }
        .video-card:hover { transform: translateY(-8px); border-color: #ff5722; box-shadow: 0 15px 30px rgba(255, 87, 34, 0.2); }
        .thumb-wrapper { position: relative; width: 100%; padding-top: 56.25%; background: #000; overflow: hidden; }
        .thumb-img { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; }
        .video-info { padding: 15px; }
        .video-title { font-size: 16px; font-weight: bold; margin: 0 0 10px 0; color: #fff; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
        .video-meta { display: flex; justify-content: space-between; font-size: 13px; color: #aaa; }
        .video-author { color: #ff5722; font-weight: bold; }
        /* 팝업 모달 */
        .modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.85); z-index: 9999; justify-content: center; align-items: center; }
        .modal-content { position: relative; width: 90%; max-width: 900px; aspect-ratio: 16/9; }
        .modal-content iframe { width: 100%; height: 100%; border: none; border-radius: 12px; }
        .close-btn { position: absolute; top: -45px; right: 0; color: #fff; font-size: 40px; cursor: pointer; }
    </style>
</head>
<body>
    <div class="container">
        <div class="page-header">
            <h2 class="page-title">📺 유튜브 홍보관</h2>
            <% if (typeof user !== 'undefined' && user) { %>
                <form action="/add-youtube" method="POST" style="display:flex; gap:10px; flex:1; max-width:500px;">
                    <input type="text" name="title" placeholder="영상 제목" required style="flex:0.5; background:#222; border:1px solid #444; color:#fff; padding:10px; border-radius:8px;">
                    <input type="text" name="youtubeLink" placeholder="유튜브 링크" required style="flex:1; background:#222; border:1px solid #444; color:#fff; padding:10px; border-radius:8px;">
                    <button type="submit" style="background:#ff5722; color:#000; border:none; padding:0 20px; border-radius:8px; font-weight:bold; cursor:pointer;">+ 등록</button>
                </form>
            <% } %>
        </div>

        <div class="video-grid">
            <% if (typeof videos !== 'undefined' && videos.length > 0) { %>
                <% videos.forEach(video => { %>
                    <div class="video-card-wrap">
                        <div class="video-card" onclick="playVideo('<%= video.url %>')">
                            <div class="thumb-wrapper">
                                <img src="<%= video.thumbnail ? video.thumbnail : 'https://via.placeholder.com/320x180/222/ff5722?text=No+Image' %>" class="thumb-img" alt="">
                            </div>
                            <div class="video-info">
                                <h3 class="video-title"><%= video.title %></h3>
                                <div class="video-meta">
                                    <span class="video-author">@<%= video.uploader %></span>
                                    <span><%= new Date(video.createdAt).toLocaleDateString() %></span>
                                </div>
                            </div>
                        </div>
                        <% if (typeof user !== 'undefined' && user && (user.role === 'admin' || user.id === video.uploader)) { %>
                            <form action="/delete-video/<%= video._id %>" method="POST" style="position: absolute; top: 10px; right: 10px;">
                                <button type="submit" style="background:rgba(0,0,0,0.6); color:#ff4a4a; border:1px solid #ff4a4a; padding:4px 8px; border-radius:5px; cursor:pointer; font-size:12px;">🗑️ 삭제</button>
                            </form>
                        <% } %>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </div>

    <div id="ytModal" class="modal-overlay" onclick="if(event.target === this) closeVideo()">
        <div class="modal-content">
            <span class="close-btn" onclick="closeVideo()">&times;</span>
            <iframe id="ytIframe" src="" allow="autoplay; encrypted-media" allowfullscreen></iframe>
        </div>
    </div>

    <script>
        function playVideo(url) {
            const id = url.split('v=')[1]?.substring(0,11) || url.split('youtu.be/')[1]?.substring(0,11);
            if(id) {
                document.getElementById('ytIframe').src = 'https://www.youtube.com/embed/' + id + '?autoplay=1';
                document.getElementById('ytModal').style.display = 'flex';
            } else { window.open(url); }
        }
        function closeVideo() {
            document.getElementById('ytIframe').src = '';
            document.getElementById('ytModal').style.display = 'none';
        }
    </script>
</body>
</html>
